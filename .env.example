# BALAGE — LLM Provider Configuration
# Kopiere diese Datei als .env.local und trage deine API-Keys ein.

# OpenAI
BALAGE_OPENAI_API_KEY=sk-...

# Anthropic
BALAGE_ANTHROPIC_API_KEY=sk-ant-...

# LLM Settings
BALAGE_LLM_PROVIDER=openai
BALAGE_LLM_MODEL=gpt-4o-mini
BALAGE_LLM_FALLBACK_MODEL=gpt-4o
BALAGE_MAX_TOKENS_PER_REQUEST=4096
BALAGE_MAX_COST_PER_RUN_USD=1.00

# API Server
BALAGE_API_PORT=3100
BALAGE_API_KEY=

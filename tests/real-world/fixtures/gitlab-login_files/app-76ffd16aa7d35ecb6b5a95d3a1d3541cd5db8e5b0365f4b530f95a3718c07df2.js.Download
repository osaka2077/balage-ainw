"],"DiffblueCover|Diffblue Cover is a generative AI platform that automatically writes comprehensive, human-like Java unit tests. Integrate Diffblue Cover into your CI/CD workflow for fully autonomous operation.":["Diffblue Cover ist eine generative KI-Plattform, die automatisch umfassende Java-Unit-Tests schreibt, die wie durch einen Menschen erstellt wirken. Integriere Diffblue Cover in deinen CI/CD-Workflow f\xfcr einen vollst\xe4ndig autonomen Betrieb."],"DiffblueCover|Diffblue Cover license key.":["Diffblue Cover-Lizenzschl\xfcssel."],"DiffblueCover|Enter your Diffblue Cover license key or go to %{diffblue_link} to obtain a free trial license.":["Gib deinen Diffblue Cover-Lizenzschl\xfcssel ein oder gehe zu %{diffblue_link}, um eine kostenlose Testlizenz zu erhalten."],"DiffblueCover|Integration details":["Integrationsdetails"],"DiffblueCover|Leave blank to use your current license key.":["Leer lassen, um deinen aktuellen Lizenzschl\xfcssel zu verwenden."],"DiffblueCover|Leave blank to use your current secret value.":["Leer lassen, um deinen aktuellen Geheimniswert zu verwenden."],"DiffblueCover|License key":["Lizenzschl\xfcssel"],"DiffblueCover|My token name":["Mein Token-Name"],"DiffblueCover|Name":["Name"],"DiffblueCover|Secret":["Geheimnis"],"DiffblueCover|Try Diffblue Cover":["Diffblue Cover testen"],"Difference between start date and now":["Unterschied zwischen Startdatum und Jetzt"],"Different user's signature":["Unterschiedliche Benutzersignatur"],"DiffsCompareBaseBranch|(HEAD)":["(HEAD)"],"DiffsCompareBaseBranch|(base)":["(basis)"],"Diffs|%d addition":["%d Erg\xe4nzung","%d Erg\xe4nzungen"],"Diffs|%d deletion":["%d L\xf6schung","%d L\xf6schungen"],"Diffs|Hide whitespace changes":["Leerzeichen\xe4nderungen ausblenden"],"Diffs|Inline":["Inline"],"Diffs|Next 20 lines":["N\xe4chste 20 Zeilen"],"Diffs|No file name available":["Kein Dateiname verf\xfcgbar"],"Diffs|Previous 20 lines":["Vorherige 20 Zeilen"],"Diffs|Show %{unfoldCount} lines":["Zeige %{unfoldCo
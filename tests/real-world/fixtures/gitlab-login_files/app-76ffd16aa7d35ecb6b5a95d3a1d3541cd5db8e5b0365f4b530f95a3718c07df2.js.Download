nventory|View project":["Projekt anzeigen"],"SecurityInventory|View security coverage and vulnerabilities for all the projects in this group.":["Zeige die Sicherheitsabdeckung und Sicherheitsl\xfccken f\xfcr alle Projekte in dieser Gruppe an."],"SecurityInventory|View subgroup":["Untergruppe anzeigen"],"SecurityInventory|View vulnerability report":["Sicherheitsl\xfcckenbericht anzeigen"],"SecurityInventory|Vulnerability count":["Zahl der Sicherheitsl\xfccken"],"SecurityInventory|Vulnerability count critical":["Zahl der Sicherheitsl\xfccken: kritisch"],"SecurityInventory|Vulnerability count high":["Zahl der Sicherheitsl\xfccken: hoch"],"SecurityInventory|Vulnerability count info":["Info zur Zahl der Sicherheitsl\xfccken"],"SecurityInventory|Vulnerability count low":["Zahl der Sicherheitsl\xfccken: niedrig"],"SecurityInventory|Vulnerability count medium":["Zahl der Sicherheitsl\xfccken: mittel"],"SecurityInventory|Vulnerability count unknown":["Zahl der Sicherheitsl\xfccken unbekannt"],"SecurityInventory|You are about to disable %{name} for %{count} item. Are you sure you want to proceed?":["Du bist dabei, %{name} f\xfcr %{count}\xa0Element zu deaktivieren. M\xf6chtest du wirklich fortfahren?","Du bist dabei, %{name} f\xfcr %{count}\xa0Elemente zu deaktivieren. M\xf6chtest du wirklich fortfahren?"],"SecurityInventory|You're already viewing this subgroup":["Diese Untergruppe wird bereits angezeigt."],"SecurityOrchestration| and ":["und "],"SecurityOrchestration| and all the following apply:":["und alle folgenden zutreffen:"],"SecurityOrchestration| for any commits":["f\xfcr alle Commits"],"SecurityOrchestration| for unsigned commits":["f\xfcr nicht signierte Commits"],"SecurityOrchestration| or ":["oder "],"SecurityOrchestration| that is %{licenseState} and is":["mit den Eigenschaften %{licenseState} und"],"SecurityOrchestration| triggered by %{sources}":["ausgel\xf6st von %{sources}"],"SecurityOrchestration| with scans distributed over %{humanizedTimeWindowValue}":["mit Scans, die \xfcber %{humanizedTimeWindowValue} verteilt sind"],"SecurityOrchestration|%d project which has compliance framework:":["%d\xa0Projekt mit Konformit\xe4ts-Framework:","%d\xa0Projekte mit Konformit\xe4ts-Framework:"],"SecurityOrchestration|%{agent} for %{namespaces}":["%{agent} f\xfcr %{namespaces}"],"SecurityOrchestration|%{allLabel}%{projectCount} %{projectLabel} in this group":["%{allLabel}%{projectCount} %{projectLabel} in dieser Gruppe"],"SecurityOrchestration|%{boldStart}Add branches%{boldEnd} first before selection.":["F\xfcge vor der Auswahl zuerst %{boldStart}Branches hinzu%{boldEnd}."],"SecurityOrchestration|%{boldStart}Experimental feature:%{boldEnd} Try out auto-dismissed actions for vulnerability policy. This feature is expected to be fully available in %{boldStart}18.8.%{boldEnd}":["%{boldStart}Experimentelle Funktion:%{boldEnd} Probiere die Richtlinie zum automatischen Verwerfen von Sicherheitsl\xfccken aus. Diese Funktion ist voraussichtlich in %{boldStart}18.8%{boldEnd} vollst\xe4ndig verf\xfcgbar."],"SecurityOrchestration|%{boldStart}Send a bot message%{boldEnd} as comment to merge request creator.":["%{boldStart}Sende eine Bot-Nachricht%{boldEnd} als Kommentar an den oder die Ersteller(in) des Merge Requests."],"SecurityOrchestration|%{branchName}":["%{branchName}"],"SecurityOrchestration|%{branchName} (in %{codeStart}%{fullPath}%{codeEnd})":["%{branchName} (in %{codeStart}%{fullPath}%{codeEnd})"],"SecurityOrchestration|%{cadence} on %{branches}%{timeWindowInfo}%{branchExceptionsString}":["%{cadence} auf %{branches}%{timeWindowInfo}%{branchExceptionsString}"],"SecurityOrchestration|%{count} pipelines/hour":[""],"SecurityOrchestration|%{hours}":["%{hours}"],"SecurityOrchestration|%{hours} and %{minutes}":["%{hours} und %{minutes}"],"SecurityOrchestration|%{listType} attempts from %{linkStart}other settings%{linkEnd} to override variables when the policy runs, except the variables defined in the %{list}.":["%{listType} versucht von %{linkStart}anderen Einstellungen%{linkEnd} aus, Variablen zu \xfcberschreiben, wenn die Richtlinie ausgef\xfchrt wird, mit Ausnahme der in %{list} definierten Variablen."],"SecurityOrchestration|%{minutes}":["%{minutes}"],"SecurityOrchestration|%{pageSize}+ projects which have compliance framework:":["Mehr als %{pageSize}\xa0Projekte mit Konformit\xe4ts-Framework:"],"SecurityOrchestration|%{requireStart}Warn users with a bot comment%{requireEnd} and select approvers. The approvers are required unless developers dismiss the warn mode policy. After dismissal, approvers become optional.":["%{requireStart}Warne Benutzer(innen) mit einem Bot-Kommentar%{requireEnd} und lege Genehmigungsberechtigte fest. Die Genehmigungsberechtigten sind erforderlich, es sei denn, die Entwickler(innen) verwerfen die Warnmodus-Richtlinie. In diesem Fall sind Genehmigungsberechtigte optional."],"SecurityOrchestration|%{scanners}":["%{scanners}"],"SecurityOrchestration|%{scanners} of %{severities} severity level":["%{scanners} von %{severities}\xa0Schweregrad","%{scanners} von %{severities}\xa0Schweregraden"],"SecurityOrchestration|%{seconds}":["%{seconds}"],"SecurityOrchestration|%{sources} or %{lastSource}":["%{sources} oder %{lastSource}"],"SecurityOrchestration|%{state} and %{statuses}":["%{state} und %{statuses}"],"SecurityOrchestration|%{strongStart}Run a DAST scan%{strongEnd} with Scan Profile A and Site Profile A %{strongStart}when a pipeline runs against the main branch%{strongEnd}.":["%{strongStart}F\xfchre einen DAST-Scan%{strongEnd} mit Scan-Profil A und Site-Profil A aus, %{strongStart}wenn eine Pipeline gegen den Hauptbranch ausgef\xfchrt wird%{strongEnd}."],"SecurityOrchestration|%{strongStart}Run customized GitLab security templates%{strongEnd} across my projects.":["F%{strongStart}\xfchre benutzerdefinierte Gitlab-Sicherheitsvorlagen%{strongEnd} in meinen Projekten aus."],"SecurityOrchestration|%{type}: %{boldStart}%{value}%{boldEnd}":["%{type}: %{boldStart}%{value}%{boldEnd}"],"SecurityOrchestration|(%{groups})":["(%{groups})"],"SecurityOrchestration|+%{numberOfAdditionalLabels} more":["+\xa0%{numberOfAdditionalLabels}\xa0weitere"],"SecurityOrchestration|, and %{count} more":[", und %{count} mehr"],"SecurityOrchestration|.yaml mode":[".yaml-Modus"],"SecurityOrchestration|.yaml preview":[".yaml-Vorschau"],"SecurityOrchestration|A compliance framework is a label to identify that your project has certain compliance requirements. %{linkStart}Learn more%{linkEnd}.":["Ein Konformit\xe4ts-Framework ist ein Label, mit dem gekennzeichnet wird, dass dein Projekt bestimmte Konformit\xe4tsanforderungen hat. %{linkStart}Mehr erfahren%{linkEnd}."],"SecurityOrchestration|A formal exception record will be created and linked to this merge request":["Es wird ein formaler Ausnahmedatensatz erstellt und mit diesem Merge Request verkn\xfcpft"],"SecurityOrchestration|A new project will be created to be used to store security policies. If a project already exists with security policies, link it via the policy list page.":["Es wird ein neues Projekt zum Speichern von Sicherheitsrichtlinien erstellt. Wenn ein Projekt mit Sicherheitsrichtlinien bereits existiert, verkn\xfcpfe es \xfcber die Seite mit der Liste der Richtlinien."],"SecurityOrchestration|A scan execution policy exceeds the limit of %{maxCount} actions per policy. Remove or separate out actions across multiple policies to reduce the number of actions in one policy.":["Eine Scan-Ausf\xfchrungsrichtlinie \xfcberschreitet das Limit von %{maxCount} Aktionen pro Richtlinie. Entferne oder verteile Aktionen auf mehrere Richtlinien, um die Anzahl der Aktionen in einer Richtlinie zu reduzieren."],"SecurityOrchestration|A scan execution policy exceeds the limit of %{maxScanExecutionPolicySchedules} scheduled rules per policy. Remove or consolidate rules across policies to reduce the total number of rules.":["Eine Scanausf\xfchrungsrichtlinie \xfcberschreitet das Limit von %{maxScanExecutionPolicySchedules} geplanten Regeln pro Richtlinie. Entferne oder konsolidiere Regeln aus verschiedenen Richtlinien, um die Gesamtzahl der Regeln zu reduzieren."],"SecurityOrchestration|A vulnerability management policy can contain only one action.":["Jede Sicherheitsl\xfcckenmanagementrichtlinie kann nur eine Aktion enthalten."],"SecurityOrchestration|A vulnerability management policy can contain only rules of same type.":["Jede Sicherheitsl\xfcckenmanagementrichtlinie kann nur Regeln vom gleichen Typ enthalten."],"SecurityOrchestration|API Fuzzing Scanning Rule":["API Fuzzing-Scan-Regel"],"SecurityOrchestration|API request":["API-Anfrage"],"SecurityOrchestration|Acceptable risk":["Akzeptables Risiko"],"SecurityOrchestration|Access tokens (%{count})":["Zugriffstoken (%{count})"],"SecurityOrchestration|Accounts exceptions (%{count})":["Kontenausnahmen (%{count})"],"SecurityOrchestration|Actions":["Aktionen"],"SecurityOrchestration|Actions and rules must be an array.":["Aktionen und Regeln m\xfcssen als Array vorliegen."],"SecurityOrchestration|Add a numeric suffix to ensure unique job names.":["F\xfcge ein numerisches Suffix hinzu, um eindeutige Jobnamen sicherzustellen."],"SecurityOrchestration|Add another variable":["Weitere Variable hinzuf\xfcgen"],"SecurityOrchestration|Add job name suffix %{suffixEditor} %{suffixIcon}":["Jobnamen-Suffix %{suffixEditor} %{suffixIcon} hinzuf\xfcgen"],"SecurityOrchestration|Add new action":["Neue Aktion hinzuf\xfcgen"],"SecurityOrchestration|Add new approver":["Neue(n) Genehmiger(in) hinzuf\xfcgen"],"SecurityOrchestration|Add new criteria":["Neue Kriterien hinzuf\xfcgen"],"SecurityOrchestration|Add new rule":["Neue Regel hinzuf\xfcgen"],"SecurityOrchestration|Add project full path after @ to following branches: %{branches}":["Vollst\xe4ndigen Projektpfad nach @ zu folgenden Branches hinzuf\xfcgen: %{branches}"],"SecurityOrchestration|Add protected branches":["Gesch\xfctzte Branches hinzuf\xfcgen"],"SecurityOrchestration|Add regular branches":["Normale Branches hinzuf\xfcgen"],"SecurityOrchestration|Add values":[""],"SecurityOrchestration|Additional configuration":["Zus\xe4tzliche Konfiguration"],"SecurityOrchestration|After dismissing the alert, the information will never be shown again.":["Nach dem L\xf6schen des Alarms werden die Informationen nie wieder angezeigt."],"SecurityOrchestration|After this merge request is merged, go to [%{framework}](%{link}) and remove the compliance pipeline so that the new pipeline execution policy can take precedence.":["Nachdem diese Merge-Anfrage zusammengef\xfchrt wurde, gehe zu [%{framework}](%{link}) und entferne die Konformit\xe4ts-Pipeline, damit die neue Pipeline-Ausf\xfchrungsrichtlinie Vorrang haben kann."],"SecurityOrchestration|All policy requirements will be bypassed for this MR and can be merged immediately":["Alle Richtlinienanforderungen werden f\xfcr diese MR umgangen, sodass eine sofortige Zusammenf\xfchrung m\xf6glich ist"],"SecurityOrchestration|All projects in linked groups":["Alle Projekte in verkn\xfcpften Gruppen"],"SecurityOrchestration|All projects in the group.":["Alle Projekte in dieser Gruppe"],"SecurityOrchestration|All projects in this group except:":["Alle Projekte in dieser Gruppe au\xdfer:"],"SecurityOrchestration|All projects in this instance except:":["Alle Projekte in dieser Instanz au\xdfer:"],"SecurityOrchestration|All projects linked to security policy project.":["Alle Projekte, die mit dem Sicherheitsrichtlinienprojekt verkn\xfcpft sind."],"SecurityOrchestration|All projects linked to this project except:":["Alle Projekte, die mit diesem Projekt verkn\xfcpft sind, au\xdfer:"],"SecurityOrchestration|All scanners":["Alle Scanner"],"SecurityOrchestration|All selected policy requirements will be bypassed.":["Alle ausgew\xe4hlten Richtlinienanforderungen werden umgangen."],"SecurityOrchestration|All sources":["Alle Quellen"],"SecurityOrchestration|All types":["Alle Typen"],"SecurityOrchestration|Allowed licenses":["Zugelassene Lizenzen"],"SecurityOrchestration|Allowlist details":["Details der Zulassungsliste"],"SecurityOrchestration|An error occurred assigning your security policy project":["Beim Zuweisen deines Sicherheitsrichtlinienprojekts ist ein Fehler aufgetreten"],"SecurityOrchestration|An error occurred unassigning your security policy project":["Ein Fehler ist beim Aufheben der Zuweisung deines Sicherheitsrichtlinienprojekts aufgetreten"],"SecurityOrchestration|An error occurred while attempting to bypass policies. Please refresh the page and try again.":["Beim Versuch, Richtlinien zu umgehen, ist ein Fehler aufgetreten. Bitte aktualisiere die Seite und versuche es erneut."],"SecurityOrchestration|An error occurred while fetching the scan result policies.":["Beim Abrufen der Scan-Ergebnisrichtlinien ist ein Fehler aufgetreten."],"SecurityOrchestration|And scans to be performed:":["Und durchzuf\xfchrende Scans:"],"SecurityOrchestration|Applies policy evaluations to all projects in this instance.":["Wendet Policy-Auswertungen auf alle Projekte in dieser Instanz an."],"SecurityOrchestration|Apply recommended selections":[""],"SecurityOrchestration|Apply this policy to %{projectScopeType} %{projectSelector}":["Diese Richtlinie anwenden auf %{projectScopeType} %{projectSelector}"],"SecurityOrchestration|Apply this policy to %{projectScopeType}named %{frameworkSelector}":["Anwendung dieser Richtlinie auf %{projectScopeType}benannte %{frameworkSelector}"],"SecurityOrchestration|Apply this policy to current project.":["Diese Richtlinie auf das aktuelle Projekt anwenden."],"SecurityOrchestration|Approval settings might be affected by rules in the following policies if the policies change from warn mode to strictly enforced:":["Genehmigungseinstellungen k\xf6nnen durch Regeln in den folgenden Richtlinien beeinflusst werden, wenn die Richtlinien vom Warnungsmodus zu \u201eStrenge Durchsetzung\u201c ge\xe4ndert werden:"],"SecurityOrchestration|Approval settings might be affected by rules in the following policies:":["Genehmigungseinstellungen k\xf6nnen durch Regeln in den folgenden Richtlinien beeinflusst werden:"],"SecurityOrchestration|Approval settings might be affected by the rules in policy %{policyName} if the policy changes from warn mode to strictly enforced.":["Genehmigungseinstellungen k\xf6nnen durch Regeln in der Richtlinie %{policyName} beeinflusst werden, wenn die Richtlinie vom Warnungsmodus zu \u201eStrenge Durchsetzung\u201c ge\xe4ndert wird:"],"SecurityOrchestration|Approval settings might be affected by the rules in policy %{policyName}.":["Genehmigungseinstellungen k\xf6nnen durch Regeln in der Richtlinie %{policyName} beeinflusst werden."],"SecurityOrchestration|Are you sure you want to change the compliance and security policy group?":["Bist du sicher, dass du die Gruppe f\xfcr Konformit\xe4ts- und Sicherheitsrichtlinien \xe4ndern m\xf6chtest?"],"SecurityOrchestration|Are you sure you want to delete this policy? This action cannot be undone.":["M\xf6chtest du diese Richtlinie wirklich l\xf6schen? Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],"SecurityOrchestration|At least one framework label should be selected":["Es sollte mindestens ein Framework-Label ausgew\xe4hlt werden"],"SecurityOrchestration|Authorized business risk acceptance":["Autorisierte Gesch\xe4ftsrisikoakzeptanz"],"SecurityOrchestration|Auto-Dismiss":["Automatisch verwerfen"],"SecurityOrchestration|Auto-Resolve":["Automatisch aufl\xf6sen"],"SecurityOrchestration|Automate %{strongStart}vulnerability management%{strongEnd} workflows.":["Automatisiere %{strongStart}Sicherheitsl\xfcckenmanagement%{strongEnd}-Workflows."],"SecurityOrchestration|Automatically %{boldStart}dismiss%{boldEnd} these vulnerabilities with the %{reason} reason.":[""],"SecurityOrchestration|Automatically %{boldStart}override severity%{boldEnd} of these vulnerabilities to:":[""],"SecurityOrchestration|Automatically dismiss vulnerabilities when they match all of the following criteria:":["Sicherheitsl\xfccken automatisch verwerfen, wenn sie alle der folgenden Kriterien erf\xfcllen:"],"SecurityOrchestration|Automatically dismiss vulnerabilities with a risk level of %{risk} when they match all of the following criteria:":["Sicherheitsl\xfccken mit Risikostufe %{risk} automatisch verwerfen, wenn sie alle der folgenden Kriterien erf\xfcllen:"],"SecurityOrchestration|Automatically selected runners":["Automatisch ausgew\xe4hlte Runner"],"SecurityOrchestration|Automatically set the status of these vulnerabilities to %{type}.":[""],"SecurityOrchestration|Back to standard editor":["Zur\xfcck zum Standardeditor"],"SecurityOrchestration|Begin test run":[""],"SecurityOrchestration|Branch exceptions (%{count})":["Branch-Ausnahmen (%{count})"],
"SecurityOrchestration|Branch types don't match any existing branches.":["Branchtypen stimmen mit keinen bestehenden Branches \xfcberein."],"SecurityOrchestration|Branch: %{boldStart}%{branchName}%{boldEnd} was not found in project: %{boldStart}%{projectName}%{boldEnd}. Edit or remove this entry.":["Branch: %{boldStart}%{branchName}%{boldEnd} wurde in Projekt: %{boldStart}%{projectName}%{boldEnd} nicht gefunden. Bearbeite oder entferne dieses Element."],"SecurityOrchestration|Bypass Policy Violation":["Richtlinienversto\xdf umgehen"],"SecurityOrchestration|Bypassed as":["Umgangen als"],"SecurityOrchestration|CI/CD template edition to be enforced. The default template is stable, but may not have all the features of the latest template.":["CI/CD-Vorlagenausgabe, die erzwungen werden soll. Die Standardvorlage ist stabil, verf\xfcgt jedoch m\xf6glicherweise nicht \xfcber alle Funktionen der neuesten Vorlage."],"SecurityOrchestration|CI/CD template edition to be enforced. The latest edition may introduce breaking changes.":["CI/CD-Vorlagen-Edition, die erzwungen werden soll. Die\xa0neueste\xa0Edition umfasst unter Umst\xe4nden grundlegende \xc4nderungen."],"SecurityOrchestration|CI/CD template version to be enforced. Specific versions offer stability but may not include the latest features.":["CI/CD-Vorlagen-Edition, die erzwungen werden soll. Bestimmte Versionen bieten Stabilit\xe4t, enthalten aber eventuell nicht die neuesten Funktionen."],"SecurityOrchestration|Cadence is invalid":["Rhythmus ist ung\xfcltig"],"SecurityOrchestration|Can't find project: %{boldStart}%{projectName}%{boldEnd}. Edit or remove this entry.":["Projekt:%{boldStart}%{projectName}%{boldEnd} kann nicht gefunden werden. Bearbeite oder entferne dieses Element."],"SecurityOrchestration|Cannot create an empty policy":["Es ist nicht m\xf6glich, eine leere Richtlinie zu erstellen"],"SecurityOrchestration|Change group":["Gruppe \xe4ndern"],"SecurityOrchestration|ChatOps command":["ChatOps-Befehl"],"SecurityOrchestration|Choose a project":["W\xe4hle ein Projekt"],"SecurityOrchestration|Choose an action":["Aktion ausw\xe4hlen"],"SecurityOrchestration|Choose approver type":["Genehmigertyp w\xe4hlen"],"SecurityOrchestration|Choose from the options below based on how you would like to proceed.":["W\xe4hle basierend darauf, wie du fortfahren m\xf6chtest, aus den unten aufgef\xfchrten Optionen aus."],"SecurityOrchestration|Choose optimization preset %{linkStart}Help me choose%{linkEnd}":["Optimierungsvoreinstellung ausw\xe4hlen %{linkStart}Hilfe bei der Auswahl%{linkEnd}"],"SecurityOrchestration|Choose specific role":["W\xe4hle eine bestimmte Rolle aus"],"SecurityOrchestration|Clear all":["Alle l\xf6schen"],"SecurityOrchestration|Code push":["Code-Push"],"SecurityOrchestration|Comments are required when bypassing policies.":["Beim Umgehen von Richtlinien sind Kommentare erforderlich."],"SecurityOrchestration|Completed: %{time}":[""],"SecurityOrchestration|Compliance and security policy group":["Konformit\xe4ts- und Sicherheitsrichtliniengruppe"],"SecurityOrchestration|Compliance framework has no projects":["Das Konformit\xe4ts-Framework enth\xe4lt keine Projekte"],"SecurityOrchestration|Compliance pipeline migration to pipeline execution policy":["Migration der Konformit\xe4ts-Pipeline zur Pipeline-Ausf\xfchrungsrichtlinie"],"SecurityOrchestration|Configuration":["Konfiguration"],"SecurityOrchestration|Configuration type":["Konfigurationstyp"],"SecurityOrchestration|Configure policies to control whether individual users or service accounts can use %{linkStart}skip_ci%{linkEnd} to skip pipelines.":["Konfiguriere Richtlinien, um zu steuern, ob einzelne Benutzer(innen) oder Dienstkonten %{linkStart}skip_ci%{linkEnd} zum \xdcberspringen von Pipelines verwenden k\xf6nnen."],"SecurityOrchestration|Configure your conditions in the pipeline execution file. %{linkStart}What can pipeline execution do?%{linkEnd}":["Konfiguriere deine Bedingungen in der Pipeline-Ausf\xfchrungsdatei. %{linkStart}Was bietet die Pipeline-Ausf\xfchrung?%{linkEnd}"],"SecurityOrchestration|Container Scanning Rule":["Container-Scan-Regel"],"SecurityOrchestration|Coverage Fuzzing Scanning Rule":["Abdeckungs-Fuzzing-Scan-Regel"],"SecurityOrchestration|Create custom variable":["Benutzerdefinierte Variable erstellen"],"SecurityOrchestration|Create new framework label":["Neues Framework-Label erstellen"],"SecurityOrchestration|Create new project with the new policy":["Neues Projekt mit der neuen Richtlinie erstellen"],"SecurityOrchestration|Create security policies to enforce security and compliance controls that help keep your project secure.":["Erstelle Sicherheitsrichtlinien, um Sicherheits- und Konformit\xe4tskontrollen durchzusetzen, mit denen du dein Projekt sch\xfctzen kannst."],"SecurityOrchestration|Create security policy":["Sicherheitsrichtlinie erstellen"],"SecurityOrchestration|Criteria were not saved in correct format.":["Kriterien wurden nicht im richtigen Format gespeichert."],"SecurityOrchestration|Critical business deadline":["Kritischer Gesch\xe4ftstermin"],"SecurityOrchestration|Custom":["Benutzerdefiniert"],"SecurityOrchestration|Custom roles":["Benutzerdefinierte Rollen"],"SecurityOrchestration|Custom scan experiment has ended in 17.3":["Benutzerdefiniertes Scan-Experiment wurde in 17.3 eingestellt"],"SecurityOrchestration|DAST Scanning Rule":["DAST-Scan-Regel"],"SecurityOrchestration|Days of month":["Tage des Monats"],"SecurityOrchestration|Decrease by one level":["Um eine Stufe verringern"],"SecurityOrchestration|Default approval settings on this merge request have been overridden by policies based on their rules.":["Die standardm\xe4\xdfigen Genehmigungseinstellungen dieser Merge-Anfrage wurden durch Richtlinien gem\xe4\xdf den enthaltenen Regeln \xfcberschrieben."],"SecurityOrchestration|Default approval settings on this merge request have been overridden by policy %{policyName} based on its rules.":["Die standardm\xe4\xdfigen Genehmigungseinstellungen dieser Merge-Anfrage wurden durch die Richtlinie %{policyName} gem\xe4\xdf den enthaltenen Regeln \xfcberschrieben."],"SecurityOrchestration|Default approval settings on this merge request have been overridden by the following policies based on their rules:":["Die standardm\xe4\xdfigen Genehmigungseinstellungen dieser Merge-Anfrage wurden durch die folgenden Richtlinien gem\xe4\xdf den enthaltenen Regeln \xfcberschrieben:"],"SecurityOrchestration|Default mode":["Standardmodus"],"SecurityOrchestration|Define this policy's location, conditions and actions.":["Definiere den Standort, die Bedingungen und Aktionen dieser Richtlinie."],"SecurityOrchestration|Delete policy":["Richtlinie l\xf6schen"],"SecurityOrchestration|Delete policy: %{policy}":["Richtlinie l\xf6schen: %{policy}"],"SecurityOrchestration|Denied licenses":["Gesperrte Lizenzen"],"SecurityOrchestration|Denylist details":["Details der Sperrliste"],"SecurityOrchestration|Dependency Scanning Rule":["Abh\xe4ngigkeitsscanning-Regel"],"SecurityOrchestration|Description":["Beschreibung"],"SecurityOrchestration|Details":["Details"],"SecurityOrchestration|Direct":["Direkt"],"SecurityOrchestration|Don't show the alert anymore":["Alarme nicht erneut anzeigen"],"SecurityOrchestration|Drag with a mouse to adjust editor's width":["Breite des Editors mit Mauszeiger anpassen"],"SecurityOrchestration|Edge case settings":["Edge-Case-Einstellungen"],"SecurityOrchestration|Edit allowlist":["Zulassungsliste bearbeiten"],"SecurityOrchestration|Edit allowlist (%{variablesCount} %{variables})":["Zulassungsliste bearbeiten (%{variablesCount} %{variables})"],"SecurityOrchestration|Edit denylist":["Sperrliste bearbeiten"],"SecurityOrchestration|Edit denylist (%{variablesCount} %{variables})":["Sperrliste bearbeiten (%{variablesCount} %{variables})"],"SecurityOrchestration|Edit merge request approval policy":["Richtlinie zur Genehmigung von Merge Requests bearbeiten"],"SecurityOrchestration|Edit pipeline execution policy":["Pipeline-Ausf\xfchrungsrichtlinie bearbeiten"],"SecurityOrchestration|Edit policy":["Richtlinie bearbeiten"],"SecurityOrchestration|Edit policy project":["Richtlinienprojekt bearbeiten"],"SecurityOrchestration|Edit scan execution policy":["Richtlinie zur Scanausf\xfchrung bearbeiten"],"SecurityOrchestration|Edit vulnerability management policy":["Sicherheitsl\xfcckenmanagementrichtlinie bearbeiten"],"SecurityOrchestration|Emergency hotfix":["Notfall-Hotfix"],"SecurityOrchestration|Emergency production issue":["Notfall-Produktionsproblem"],"SecurityOrchestration|Empty policy name":["Leerer Richtlinienname"],"SecurityOrchestration|Enabled":["Aktiviert"],"SecurityOrchestration|Enforce %{linkStart}security policies%{linkEnd} for all groups within your instance.":["%{linkStart}Sicherheitsrichtlinien%{linkEnd} f\xfcr alle Gruppen innerhalb deiner Instanz durchsetzen."],"SecurityOrchestration|Enforce %{linkStart}security policies%{linkEnd} for all projects in this group.":["%{linkStart}Sicherheitsrichtlinien%{linkEnd} f\xfcr alle Projekte in dieser Gruppe durchsetzen."],"SecurityOrchestration|Enforce %{linkStart}security policies%{linkEnd} for this project.":["%{linkStart}Sicherheitsrichtlinien%{linkEnd} f\xfcr dieses Projekt durchsetzen."],"SecurityOrchestration|Enforce policy on all groups, subgroups, and projects linked to the security policy project. %{linkStart}How does scoping work?%{linkEnd}":["Durchsetzung der Richtlinie f\xfcr alle Gruppen, Untergruppen und Projekte, die mit dem Projekt der Sicherheitsrichtlinie verbunden sind. %{linkStart}Wie funktioniert das Scoping?%{linkEnd}"],"SecurityOrchestration|Enforce the following pipeline execution policy:":["Die folgende Pipeline-Ausf\xfchrungsrichtlinie erzwingen:"],"SecurityOrchestration|Enter up to %{maxBranches} branch names, separated by commas.":[""],"SecurityOrchestration|Every time a pipeline runs for %{branches}%{pipelineSource}%{branchExceptionsString}":["Jedes Mal, wenn eine Pipeline f\xfcr %{branches}%{pipelineSource}%{branchExceptionsString} ausgef\xfchrt wird"],"SecurityOrchestration|Except":["Ausnahme"],"SecurityOrchestration|Except for following users:":["Ausnahme f\xfcr die folgenden Benutzer(innen):"],"SecurityOrchestration|Exception Bypass (pre-approved)":["Ausnahmenumgehung (vorab genehmigt)"],"SecurityOrchestration|Exception branches":["Ausgenommene Branches"],"SecurityOrchestration|Excluded projects":["Ausgeschlossene Projekte"],"SecurityOrchestration|Execution time: %{time}":[""],"SecurityOrchestration|Exploit settings":["Exploit-Einstellungen"],"SecurityOrchestration|External event":["Externes Ereignis"],"SecurityOrchestration|External pull request":["Externer Pull Request"],"SecurityOrchestration|Failed to fetch the scope information. Please refresh the page to try again.":["Fehler beim Abrufen der Bereichsinformationen. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"SecurityOrchestration|Failed to load cluster agents.":["Fehler beim Laden der Cluster-Agenten."],"SecurityOrchestration|Failed to load compliance frameworks":["Fehler beim Laden der Compliance-Frameworks"],"SecurityOrchestration|Failed to load group projects":["Fehler beim Laden der Gruppenprojekte"],"SecurityOrchestration|Failed to load groups":["Fehler beim Laden der Gruppen"],"SecurityOrchestration|Failed to load images.":["Fehler beim Laden der Images."],"SecurityOrchestration|Failed to load projects":["Fehler beim Laden der Projekte"],"SecurityOrchestration|Fallback behavior in case of policy failure":["Fallback-Verhalten im Falle eines Richtlinienfehlers"],"SecurityOrchestration|False positive":["Falsch positiv"],"SecurityOrchestration|Fetching":["Wird abgerufen"],"SecurityOrchestration|Fetching the scope information.":["Abrufen der Bereichsinformationen."],"SecurityOrchestration|Filter and search projects":["Projekte filtern und durchsuchen"],"SecurityOrchestration|Finds %{vulnerabilitiesNumber} vulnerability type that matches all the following criteria:":[""],"SecurityOrchestration|For any merge request on %{branches}%{commitType}%{branchExceptionsString}":["F\xfcr jeden Merge Request zu %{branches}%{commitType}%{branchExceptionsString}"],"SecurityOrchestration|For any merge request that matches this policy's rules, no action is applied. This policy overrides the project approval settings and notifies users with a bot message, which means that no approvals are required.":["F\xfcr Merge Requests, die mit den Regeln dieser Richtlinie \xfcbereinstimmen, wird keine Aktion ausgef\xfchrt. Diese Richtlinie hat Vorrang vor den Projektgenehmigungseinstellungen und benachrichtigt Benutzer(innen) mit einer Bot-Nachricht, d.\xa0h. es sind keine Genehmigungen erforderlich."],"SecurityOrchestration|For any merge request that matches this policy's rules, no action is applied. Users are warned about project approval settings that could have been overridden, if the policy were enforced rather than in warn mode, through a bot message. No additional approvals are required.":["F\xfcr Merge Requests, die mit den Regeln dieser Richtlinie \xfcbereinstimmen, wird keine Aktion ausgef\xfchrt. Die Benutzer(innen) werden in einer Bot-Nachricht auf Projektgenehmigungseinstellungen hingewiesen, die m\xf6glicherweise \xfcberschrieben worden w\xe4ren, wenn die Richtlinie durchgesetzt anstatt im Warnmodus ausgef\xfchrt worden w\xe4re. Es sind keine zus\xe4tzlichen Genehmigungen erforderlich."],"SecurityOrchestration|For large groups, there may be a significant delay in applying policy changes to pre-existing merge requests. Policy changes typically apply almost immediately for newly created merge requests.":["In gro\xdfen Gruppen kann die Anwendung von Richtlinien\xe4nderungen auf bereits vorhandene Merge Requests erheblich verz\xf6gert werden. Bei neu erstellten Merge Requests werden Richtlinien\xe4nderungen in der Regel praktisch sofort \xfcbernommen."],"SecurityOrchestration|Global Settings":["Globale Einstellungen"],"SecurityOrchestration|Group ID: %{id}":["Gruppen-ID: %{id}"],"SecurityOrchestration|Group cannot be deleted because it has projects that are linked as a security policy project":["Die Gruppe kann nicht gel\xf6scht werden, da sie Projekte enth\xe4lt, die als Sicherheitsrichtlinienprojekt verkn\xfcpft sind."],"SecurityOrchestration|Groups":["Gruppen"],"SecurityOrchestration|Hide extra items":["Zus\xe4tzliche Elemente ausblenden"],"SecurityOrchestration|Hide extra projects":["Zus\xe4tzliche Projekte ausblenden"],"SecurityOrchestration|How do I link a group to the policy?":["Wie verkn\xfcpfe ich eine Gruppe mit der Richtlinie?"],"SecurityOrchestration|If %{scanners} of the default branch finds %{severity_level} vulnerabilities are no longer detected.":["Wenn %{scanners} des Standard-Branch Sicherheitsl\xfccken des Schweregrads %{severity_level} findet, werden diese nicht mehr erkannt."],"SecurityOrchestration|If any of the following occur:":["Wenn eines der folgenden Ereignisse eintritt:"],"SecurityOrchestration|If any scanner finds a %{strongStart}newly detected critical vulnerability%{strongEnd} in an open %{strongStart}merge request%{strongEnd} targeting the main branch, then %{strongStart}require two approvals from any two members%{strongEnd} of the application security team.":["Wenn ein Scanner eine %{strongStart}neu entdeckte kritische Sicherheitsl\xfccke%{strongEnd} in einem offenen %{strongStart}Merge Request%{strongEnd} findet, die auf den Hauptbranch abzielt, %{strongStart}m\xfcssen zwei Genehmigungen von zwei beliebigen Mitgliedern%{strongEnd} des Anwendungssicherheitsteams eingeholt werden."],"SecurityOrchestration|If any scanner finds a %{strongStart}vulnerability%{strongEnd} that was %{strongStart}previously detected but no longer found%{strongEnd} in a subsequent scan, then automatically %{strongStart}set the status to Resolved%{strongEnd}.":["Wenn ein Scanner eine %{strongStart}Sicherheitsl\xfccke%{strongEnd} findet, die %{strongStart}zuvor entdeckt wurde, aber bei einem nachfolgenden Scan nicht mehr gefunden wurde%{strongEnd}, %{strongStart}setze den Status automatisch auf \u201eGel\xf6st\u201c%{strongEnd}."],"SecurityOrchestration|If one or more %{securityPoliciesPathStart}security policies%{securityPoliciesPathEnd} become enforced, you can't unprotect this branch. %{linkStart}Learn more%{linkEnd}.":["Wenn eine oder mehrere %{securityPoliciesPathStart}Sicherheitsrichtlinien%{securityPoliciesPathEnd} durchgesetzt werden, kannst du den Schutz dieses Branches nicht aufheben. %{linkStart}Mehr erfahren%{linkEnd}."],"SecurityOrchestration|If vulnerabilities are automatically dismissed when found under following criteria:":["Wenn unter den folgenden Kriterien gefundene Sicherheitsl\xfccken automatisch verworfen werden:"],"SecurityOrchestration|If vulnerabilities have one of the following identifiers:":[""],"SecurityOrchestration|In each pipeline, a %{boldStart}maximum of 1000%{boldEnd} vulnerabilities that are %{italicStart}no longer detected%{italicEnd} will be set to status %{italicStart}Resolved%{italicEnd} until all have been auto-resolved.":["In jeder Pipeline werden maximal %{boldStart}1000 %{boldEnd}\xa0Sicherheitsl\xfccken, die %{italicStart}nicht mehr erkannt werden%{italicEnd}, auf den Status %{italicStart}Gel\xf6st%{italicEnd} gesetzt, bis alle automatisch gel\xf6st wurden."],"SecurityOrchestration|In warn mode, project approval settings are not overridden by policy and violations are reported, but fixes for the violations are not mandatory. %{linkStart}Learn more%{linkEnd}":["Im Warnungsmodus werden Projektgenehmigungseinstellungen nicht von Richtlinien \xfcberschrieben und Verst\xf6\xdfe gemeldet, wobei die Behebung dieser Verst\xf6\xdfe nicht obligatorisch ist. %{linkStart}Mehr erfahren%{linkEnd}"],"SecurityOrchestration|Increase by one level":["Um eine Stufe erh\xf6hen"],"SecurityOrchestration|Individual users":["Individuelle Benutzer(innen)"],"SecurityOrchestration|Inherited":["Vererbt"],"SecurityOrchestration|Inherited from %{namespace}":["Geerbt von %{namespace}"],"SecurityOrchestration|Inherited policy":["Geerbte Richtlinie"],"SecurityOrchestration|Input only one value. Wildcards are supported.":["Gib nur einen Wert ein. Wildcards werden unterst\xfctzt."],"SecurityOrchestration|Invalid Compliance Framework ID(s)":["Ung\xfcltige(s) Konformit\xe4ts-Framework-ID(s)"],"SecurityOrchestration|Invalid branch type detected - rule will not be applied.":["Ung\xfcltiger Branch-Typ erkannt\xa0\u2013 Regel wird nicht angewendet."],"SecurityOrchestration|Invalid criteria format":["Ung\xfcltiges Kriterienformat"],"SecurityOrchestration|Invalid policy":["Ung\xfcltige Richtlinie"],"SecurityOrchestration|Invalid policy type":["Ung\xfcltiger Richtlinientyp"],"SecurityOrchestration|Invalid security report time window":["Ung\xfcltiges Sicherheitsberichts-Zeitfenster"],"SecurityOrchestration|Invalid syntax":["Ung\xfcltige Syntax"],"SecurityOrchestration|Key":["Schl\xfcssel"],"SecurityOrchestration|Latest scan run against %{agent}":["Letzter Scanausf\xfchrung bez\xfcglich %{agent}"],"SecurityOrchestration|Linked groups":["Verkn\xfcpfte Gruppen"],"SecurityOrchestration|List branches in the format %{boldStart}branch-name@group-name/project-name,%{boldEnd} separated by a comma (,).":["Liste Branches im Format %{boldStart}branch-name@group-name/project-name%{boldEnd} auf, getrennt durch ein Komma (,)."],"SecurityOrchestration|Logic error":["Logikfehler"],"SecurityOrchestration|Manual pipeline run":["Manuelle Pipeline-Ausf\xfchrung"],"SecurityOrchestration|Maximum action limit for scan execution policies exceeded":["Maximales Aktionslimit f\xfcr Scanausf\xfchrungsrichtlinien \xfcberschritten"],"SecurityOrchestration|Maximum security policy project schedule rule count exceeded":["Maximale Anzahl der geplanten Regeln f\xfcr das Sicherheitsrichtlinienprojekt \xfcberschritten"],"SecurityOrchestration|May %{linkStart}impact system performance%{linkEnd}.":["Kann %{linkStart}die Systemleistung beeinflussen%{linkEnd}."],"SecurityOrchestration|May take significant time to complete, depending on your instance size, including the number of groups, projects, and merge requests.":["Kann je nach Gr\xf6\xdfe deiner Instanz, einschlie\xdflich der Anzahl von Gruppen, Projekten und Merge Requests, erheblich Zeit in Anspruch nehmen."],"SecurityOrchestration|Merge Request Security":["Merge Request-Sicherheit"],"SecurityOrchestration|Merge request approval":["Merge Request-Genehmigung"],"SecurityOrchestration|Merge request approval policies allow a maximum 1 bot message action.":["Gem\xe4\xdf den Richtlinien zur Genehmigung von Merge-Anfragen ist maximal eine Bot-Nachrichtenaktion zul\xe4ssig."],"SecurityOrchestration|Merge request approval policies allow a maximum of 5 approver actions.":["Gem\xe4\xdf den Richtlinien zur Genehmigung von Merge-Anfragen sind maximal f\xfcnf Aktionen durch Genehmigungsberechtigte zul\xe4ssig."],"SecurityOrchestration|Merge request approval policies can only be created by project owners.":["Genehmigungsrichtlinien f\xfcr Merge Requests k\xf6nnen nur von Projekteigent\xfcmer(inne)n erstellt werden."],"SecurityOrchestration|Merge request approval policy":["Richtlinie zur Genehmigung von Merge Requests"],"SecurityOrchestration|Merge request approval policy syntax changes":["\xc4nderungen der Syntax der Richtlinie zur Genehmigung von Merge Requests"],"SecurityOrchestration|Merge request pipeline":["Merge Request-Pipeline"],"SecurityOrchestration|Mitigating control":["Minderung der Kontrolle"],"SecurityOrchestration|Never":["Nie"],"SecurityOrchestration|New compliance and security policy group":["Neue Konformit\xe4ts- und Sicherheitsrichtliniengruppe"],"SecurityOrchestration|New merge request approval policy":["Neue Richtlinie zur Genehmigung von Merge Requests"],"SecurityOrchestration|New pipeline execution policy":["Neue Pipeline-Ausf\xfchrungsrichtlinie"],"SecurityOrchestration|New policy":["Neue Richtlinie"],"SecurityOrchestration|New scan execution policy":["Neue Richtlinie zur Scanausf\xfchrung"],"SecurityOrchestration|New vulnerability management policy":["Neue Sicherheitsl\xfcckenmanagementrichtlinie"],"SecurityOrchestration|No actions defined - policy will not run.":["Keine Aktionen definiert\xa0\u2013Richtlinie wird nicht ausgef\xfchrt."],"SecurityOrchestration|No compliance frameworks":["Keine Konformit\xe4ts-Frameworks"],"SecurityOrchestration|No description":["Keine Beschreibung"],"SecurityOrchestration|No exceptions":["Keine Ausnahmen"],"SecurityOrchestration|No linked groups":["Keine verkn\xfcpften Gruppen"],"SecurityOrchestration|No other actions are allowed in warn mode":["Im Warnmodus sind keine anderen Aktionen zul\xe4ssig"],"SecurityOrchestration|No policies found":["Keine Richtlinien gefunden"],"SecurityOrchestration|No policies in the security policy project will be enforced until the invalid policies are fixed.":["Es werden keine Richtlinien im Sicherheitsrichtlinienprojekt durchgesetzt, bis die ung\xfcltigen Richtlinien korrigiert sind."],"SecurityOrchestration|No policy.yml file found":[""],"SecurityOrchestration|No rules defined - policy will not run.":["Keine Regeln definiert\xa0\u2013 Richtlinie wird nicht ausgef\xfchrt."],"SecurityOrchestration|No scope":["Kein Geltungsbereich"],"SecurityOrchestration|No tags available":["Keine Tags verf\xfcgbar"],"SecurityOrchestration|Non-existing DAST profiles have been detected in the policy yaml. As a result, rule mode has been disabled. To enable rule mode, remove those non-existing profiles from the policy yaml.":["Nicht vorhandene DAST-Profile wurden in der Richtlinien-Yaml erkannt. Infolgedessen wurde der Regelmodus deaktiviert. Um den Regelmodus zu aktivieren, entferne die nicht vorhandenen Profile aus der Richtlinien-Yaml."],"SecurityOrchestration|Non-existing tags have been detected in the policy yaml. As a result, rule mode has been disabled. To enable rule mode, remove those non-existing tags from the policy yaml.":["Der Regelmodus wurde deaktiviert, weil die Richtlinien-Yaml nicht vorhandene Tags enth\xe4lt. Entferne die nicht vorhandenen Tags aus der Richtlinien-Yaml, um den Regelmodus zu aktivieren."],"SecurityOrchestration|Not Applicable":["Nicht zutreffend"],"SecurityOrchestration|Not enabled":["Nicht aktiviert"],"SecurityOrchestration|On conflict":["Bei Konflikten"],"SecurityOrchestration|On runners with tag:":["Auf Runnern mit dem folgenden Tag:","Auf Runnern mit den folgenden Tags:"],"SecurityOrchestration|Only allowed in warn mode.":["Nur im Warnmodus zul\xe4ssig."],"SecurityOrchestration|Only custom roles with the permission to approve merge requests are shown":["Nur benutzerdefinierte Rollen mit der Berechtigung zur Genehmigung von Merge-Anfragen werden angezeigt"],"SecurityOrchestration|Only overriding settings and bot message will take effect":["Es werden nur die \xdcberschreibungseinstellungen und die Bot-Nachricht angewendet"],"SecurityOrchestration|Only owners can update Security Policy Project":["Nur Eigent\xfcmer k\xf6nnen das Security Policy Project aktualisieren"],"SecurityOrchestration|Only project approval settings will take effect":[""],"SecurityOrchestration|Only projects where you have owner permissions are shown":[""],"SecurityOrchestration|Open policy actions dropdown":["Dropdown f\xfcr Richtlinienaktionen \xf6ffnen"],"SecurityOrchestration|Other":["Sonstige"],"SecurityOrchestration|Override":["\xdcberschreiben"],"SecurityOrchestration|Override the following project settings:":["Die folgenden Projekteinstellungen \xfcberschreiben:"],"SecurityOrchestration|Pipeline execution":["Pipeline-Ausf\xfchrung"],"SecurityOrchestration|Pipeline execution policy":["Pipeline-Ausf\xfchrungsrichtlinie"],"SecurityOrchestration|Please remove duplicated values":["Bitte entferne doppelte Werte"],"SecurityOrchestration|Please remove duplicates.":["Bitte entferne Duplikate."],"SecurityOrchestration|Policies":["Richtlinien"],"SecurityOrchestration|Policies are invalid":["Richtlinien sind ung\xfcltig"],"SecurityOrchestration|Policy Bypass Options":["Optionen zum Umgehen von Richtlinien"],"SecurityOrchestration|Policy Type":["Richtlinientyp"],"SecurityOrchestration|Policy bypass failed":["Fehler bei Richtlinienumgehung"],"SecurityOrchestration|Policy cannot be enabled for non-existing branches (%{branches})":["Richtlinie kann nicht f\xfcr nicht vorhandene Branches aktiviert werden (%{branches})"],"SecurityOrchestration|Policy cannot be enabled without branch information":["Richtlinie kann ohne Branch-Informationen nicht aktiviert werden"],"SecurityOrchestration|Policy changes may take some time to be applied.":["Es kann einige Zeit dauern, bis Richtlinien\xe4nderungen \xfcbernommen werden."],"SecurityOrchestration|Policy contains %{linkStart}deprecated syntax%{linkEnd} (%{deprecatedProperties}).":["Die Richtlinie enth\xe4lt %{linkStart}veraltete Syntax%{linkEnd} (%{deprecatedProperties})."],"SecurityOrchestration|Policy definition":["Richtliniendefinition"],"SecurityOrchestration|Policy editor":["Richtlinieneditor"],"SecurityOrchestration|Policy enforcement":["Richtliniendurchsetzung"],"SecurityOrchestration|Policy exceeds the maximum of %{limit} actions":["Richtlinie \xfcberschreitet das Maximum an %{limit}\xa0Aktionen"],"SecurityOrchestration|Policy exceeds the maximum of %{limit} approver actions":["Richtlinie \xfcberschreitet das Maximum an %{limit}\xa0Aktionen durch Genehmigungsberechtigte"],"SecurityOrchestration|Policy exceeds the maximum of %{limit} pipeline execution schedules":["Richtlinie \xfcberschreitet das Maximum an %{limit}\xa0Zeitpl\xe4nen zur Pipelineausf\xfchrung"],"SecurityOrchestration|Policy exceeds the maximum of %{limit} rule schedules":["Richtlinie \xfcberschreitet das Maximum an %{limit}\xa0Regelzeitpl\xe4nen"],"SecurityOrchestration|Policy false positive":["Richtlinie \u2013falsch positiv"],"SecurityOrchestration|Policy has reached the maximum of %{actionsCount} %{actions}":["Richtlinie hat das Maximum an %{actionsCount}\xa0%{actions} erreicht"],"SecurityOrchestration|Policy is invalid":["Richtlinie ist ung\xfcltig"],"SecurityOrchestration|Policy override":["Richtlinien\xfcberschreibung"],"SecurityOrchestration|Policy scope":["Geltungsbereich der Richtlinie"],"SecurityOrchestration|Policy status":["Richtlinienstatus"],"SecurityOrchestration|Policy type":["Richtlinientyp"],"SecurityOrchestration|Policy will have no effect":[""],"SecurityOrchestration|Prevent users from skipping pipelines":["Benutzer(innen) daran hindern, Pipelines zu \xfcberspringen"],"SecurityOrchestration|Project cannot be deleted because it is linked as a security policy project":["Das Projekt kann nicht gel\xf6scht werden, da es als Sicherheitsrichtlinienprojekt verkn\xfcpft ist."],"SecurityOrchestration|Provide a detailed justification for policy bypass.":["Gib eine detaillierte Erkl\xe4rung f\xfcr die Richtlinienumgehung an."],"SecurityOrchestration|Reason for policy bypass":["Grund f\xfcr Richtlinienumgehung"],"SecurityOrchestration|Reason for snoozing policy (optional)":["Grund zum Aussetzen der Richtlinie (optional)"],"SecurityOrchestration|Recommended":[""],"SecurityOrchestration|Recommended (%{count} scanner)":["",""],"SecurityOrchestration|Recommended selection":[""],"SecurityOrchestration|Release Security":["Release-Sicherheit"],"SecurityOrchestration|Require %{approvals} %{plural} from %{approvers}":["%{approvals} %{plural} von %{approvers} erfordern"],"SecurityOrchestration|Require Approvers":["Genehmiger(innen) anfordern"],"SecurityOrchestration|Required approvals exceed eligible approvers.":["Erforderliche Genehmigungen \xfcbersteigen die Anzahl der berechtigten Genehmiger(innen)."],"SecurityOrchestration|Requires no approvals if any of the following occur:":["Erfordert keine Genehmigungen, wenn einer der folgenden F\xe4lle eintritt:"],"SecurityOrchestration|Resolve the following vulnerabilities that are no longer detected on the default branch:":["Behebe die folgenden Sicherheitsl\xfccken, die nicht mehr im Standard-Branch erkannt werden:"],"SecurityOrchestration|Resolved":["Gel\xf6st"],"SecurityOrchestration|Results of most recent test":[""],"SecurityOrchestration|Roles":["Rollen"],"SecurityOrchestration|Roles (%{count})":["Rollen (%{count})"],"SecurityOrchestration|Rule %{number}":["Regel %{number}"],"SecurityOrchestration|Rule mode":["Regelmodus"],"SecurityOrchestration|Rule mode is unavailable for this policy. In some cases, we cannot parse the YAML file back into the rules editor.":["Der Regelmodus ist f\xfcr diese Richtlinie nicht verf\xfcgbar. In manchen F\xe4llen kann die YAML-Datei nicht zur\xfcck in den Regeleditor geparst werden."],"SecurityOrchestration|Rules":["Regeln"],"SecurityOrchestration|Run %{scannerStart}%{scanner}%{scannerEnd} with the following options:":["F\xfchre %{scannerStart}%{scanner}%{scannerEnd} mit den folgenden Optionen aus:"],"SecurityOrchestration|Run a %{scannerStart}%{scanner}%{scannerEnd} scan with the following options:":["F\xfchre einen %{scannerStart}%{scanner}%{scannerEnd}-Scan mit den folgenden Optionen aus:"],"SecurityOrchestration|Run a test to understand how this policy will impact your infrastructure before enabling it across all projects. The test executes real pipelines to provide accurate timing and resource estimates.":[""],"SecurityOrchestration|Run a test to understand how this policy will impact your infrastructure before enabling it on this project. The test executes real pipelines to provide accurate timing and resource estimates.":[""],"SecurityOrchestration|Run scans for merge request pipelines targeting default branches and on default branches. Optimized for MR approval policy compatibility":["Scans f\xfcr Merge-Request-Pipelines ausf\xfchren, die auf Standardbranches und auf Standardbranches abzielen. Optimiert f\xfcr die Kompatibilit\xe4t mit MR-Genehmigungsrichtlinien."],"SecurityOrchestration|Runs against %{branches} %{branchExceptions} and finds %{vulnerabilitiesNumber} vulnerability type that matches all the following criteria:":["L\xe4uft gegen %{branches} %{branchExceptions} und findet Sicherheitsl\xfcckentyp %{vulnerabilitiesNumber}, der alle der folgenden Kriterien erf\xfcllt:"],"SecurityOrchestration|Runs comprehensive scans for `release/*` branches and when merging to main/production branches":["F\xfchrt umfassende Scans f\xfcr `release/*`-Branches und beim Mergen in Haupt-/Produktionsbranches aus"],"SecurityOrchestration|Runs scans on a schedule for maintenance and continuous monitoring of protected branches":["F\xfchrt zu Wartungszwecken und zur fortlaufenden \xdcberwachung gesch\xfctzter Branches Scans nach einem Zeitplan aus"],"SecurityOrchestration|SAST Scanning Rule":["SAST-Scan-Regel"],"SecurityOrchestration|Save allowlist":["Zulassungsliste speichern"],
"SecurityOrchestration|Save changes":["\xc4nderungen speichern"],"SecurityOrchestration|Save denylist":["Sperrliste speichern"],"SecurityOrchestration|Scan actions exceed the limit of %{maxScanExecutionPolicyActions} actions per policy.":["Scan-Aktionen \xfcberschreiten das Limit von %{maxScanExecutionPolicyActions}\xa0Aktionen pro Richtlinie."],"SecurityOrchestration|Scan execution":["Scan-Ausf\xfchrung"],"SecurityOrchestration|Scan execution configuration":["Scan-Ausf\xfchrungskonfiguration"],"SecurityOrchestration|Scan execution policies can only be created by project owners.":["Scan-Ausf\xfchrungsrichtlinien k\xf6nnen nur von Projekteigent\xfcmern erstellt werden."],"SecurityOrchestration|Scan execution policies using `custom` scan action have been detected. Policies using this action will not work after GitLab 18.0 (May 10, 2025). You must edit these policies to remove the deprecated action. Learn more about the %{linkStart}pipeline execution policy%{linkEnd}.":["Scan-Ausf\xfchrungsrichtlinien mit der Scan-Aktion `custom` wurden erkannt. Richtlinien mit dieser Aktion werden nach GitLab 18.0 (10.\xa0Mai\xa02025) nicht mehr funktionieren. Du musst diese Richtlinien bearbeiten, um die veraltete Aktion zu entfernen. Erfahre mehr \xfcber die %{linkStart}Pipeline-Ausf\xfchrungsrichtlinie%{linkEnd}."],"SecurityOrchestration|Scan execution policy":["Richtlinie zur Scanausf\xfchrung"],"SecurityOrchestration|Scan execution strategy":["Scan-Ausf\xfchrungsstrategie"],"SecurityOrchestration|Scan will automatically choose a runner to run on because there are no tags exist on runners. You can %{linkStart}create a new tag in settings%{linkEnd}.":["Der Scan w\xe4hlt automatisch einen Runner zur Ausf\xfchrung aus, da keine Tags zu Runnern vorhanden sind. Du kannst %{linkStart}ein neues Tag in den Einstellungen erstellen%{linkEnd}."],"SecurityOrchestration|Scanner false positive":["Scanner \u2013 falsch positiv"],"SecurityOrchestration|Schedule a new":["neu planen"],"SecurityOrchestration|Schedule the following pipeline execution policy to run %{branchInfo} %{scheduleTypeInfo} %{timeInfo} %{timeWindowInfo} %{timezoneInfo}.":["Plane die Ausf\xfchrung der folgenden Pipeline-Ausf\xfchrungsrichtlinie: %{branchInfo} %{scheduleTypeInfo} %{timeInfo} %{timeWindowInfo} %{timezoneInfo}."],"SecurityOrchestration|Schedule to run for %{branchSelector}":["Ausf\xfchrungsplanung f\xfcr %{branchSelector}"],"SecurityOrchestration|Scheduled Scanning":["Geplantes Scannen"],"SecurityOrchestration|Scheduled pipeline":["Geplante Pipeline"],"SecurityOrchestration|Scheduled pipeline execution":["Geplante Pipeline-Ausf\xfchrung"],"SecurityOrchestration|Scope":["Geltungsbereich"],"SecurityOrchestration|Secret Detection Scanning Rule":["Geheimniserkennungs-Scan-Regel"],"SecurityOrchestration|Security Approvals":["Sicherheitsgenehmigungen"],"SecurityOrchestration|Security job template":["Sicherheitesjobvorlage"],"SecurityOrchestration|Security policies cannot be enforced due to invalid YAML syntax in the linked security policy project's %{linkStart}policy.yml%{linkEnd}.":["Sicherheitsrichtlinien k\xf6nnen aufgrund einer ung\xfcltigen YAML-Syntax in der Datei %{linkStart}policy.yml%{linkEnd}, die mit der Sicherheitsrichtlinie des Projekts verkn\xfcpft ist, nicht erzwungen werden."],"SecurityOrchestration|Security policy overwrites this setting":["Sicherheitsrichtlinie \xfcberschreibt diese Einstellung"],"SecurityOrchestration|Security policy project was linked successfully":["Sicherheitsrichtlinienprojekt wurde erfolgreich verkn\xfcpft"],"SecurityOrchestration|Security policy project will be unlinked soon":["Verkn\xfcpfung des Sicherheitsrichtlinienprojekts wird bald aufgehoben"],"SecurityOrchestration|Security policy projects store your organization's security policies. They are identified when policies are created, or when a project is linked as a security policy project. %{linkStart}Learn more%{linkEnd}.":["In Sicherheitsrichtlinienprojekten werden die Sicherheitsrichtlinien deiner Organisation gespeichert. Sie werden identifiziert, wenn Richtlinien erstellt werden oder wenn ein Projekt als Sicherheitsrichtlinienprojekt verkn\xfcpft wird. %{linkStart}Erfahre mehr%{linkEnd}."],"SecurityOrchestration|Security policy violated":["Sicherheitsrichtlinie wurde verletzt"],"SecurityOrchestration|Security scans to execute":["Auszuf\xfchrende Sicherheits-Scans"],"SecurityOrchestration|Security teams will be notified of this exception":["Sicherheitsteams werden von dieser Ausnahme in Kenntnis gesetzt"],"SecurityOrchestration|Select a cadence":["Rhythmus ausw\xe4hlen"],"SecurityOrchestration|Select a group":["Gruppe ausw\xe4hlen"],"SecurityOrchestration|Select a project to store your security policies in. %{linkStart}More information.%{linkEnd}":["W\xe4hle ein Projekt aus, in dem deine Sicherheitsrichtlinien gespeichert werden sollen. %{linkStart}Weitere Informationen.%{linkEnd}"],"SecurityOrchestration|Select a variable":["Variable ausw\xe4hlen"],"SecurityOrchestration|Select bypass reasons":["Gr\xfcnde f\xfcr Umgehung ausw\xe4hlen"],"SecurityOrchestration|Select criteria":["Kriterien ausw\xe4hlen"],"SecurityOrchestration|Select customize type":["Anpassungstyp ausw\xe4hlen"],"SecurityOrchestration|Select date":["Datum ausw\xe4hlen"],"SecurityOrchestration|Select days":["Tage ausw\xe4hlen"],"SecurityOrchestration|Select dismiss reason":["Verwerfungsgrund ausw\xe4hlen"],"SecurityOrchestration|Select frameworks":["Frameworks ausw\xe4hlen"],"SecurityOrchestration|Select identifier type":[""],"SecurityOrchestration|Select list type":["Listentyp ausw\xe4hlen"],"SecurityOrchestration|Select one of the criteria":["Eines der Kriterien ausw\xe4hlen"],"SecurityOrchestration|Select policies":["Richtlinien ausw\xe4hlen"],"SecurityOrchestration|Select policies to bypass":["Zu umgehende Richtlinien ausw\xe4hlen"],"SecurityOrchestration|Select policy":["Richtlinie ausw\xe4hlen"],"SecurityOrchestration|Select security policy project":["Sicherheitsrichtlinienprojekt ausw\xe4hlen"],"SecurityOrchestration|Select severity level":["Schweregrad ausw\xe4hlen"],"SecurityOrchestration|Select source, currently selected: %{selected}":["Quelle ausw\xe4hlen. Aktuell ausgew\xe4hlt: %{selected}"],"SecurityOrchestration|Select suffix":["Suffix ausw\xe4hlen"],"SecurityOrchestration|Select target project":[""],"SecurityOrchestration|Select type, currently selected: %{selected}":["Typ ausw\xe4hlen. Aktuell ausgew\xe4hlt: %{selected}"],"SecurityOrchestration|Send a bot message when the conditions match.":["Sende eine Bot-Nachricht, wenn die Bedingungen erf\xfcllt sind."],"SecurityOrchestration|Send bot message":["Bot-Nachricht senden"],"SecurityOrchestration|Set to":["Setzen auf"],"SecurityOrchestration|Settings from outside of the policy can override variables when the policy runs, except the variables defined in the denylist.":["Einstellungen von au\xdferhalb der Richtlinie k\xf6nnen Variablen \xfcberschreiben, wenn die Richtlinie ausgef\xfchrt wird, mit Ausnahme der in der Sperrliste definierten Variablen."],"SecurityOrchestration|Settings from outside of the policy can override variables when the policy runs.":["Einstellungen au\xdferhalb der Richtlinie k\xf6nnen beim Ausf\xfchren der Richtlinie Variablen \xfcberschreiben."],"SecurityOrchestration|Settings from outside of the policy cannot override variables when the policy runs, except for the variables defined in the allowlist.":["Einstellungen von au\xdferhalb der Richtlinie k\xf6nnen Variablen nicht \xfcberschreiben, wenn die Richtlinie ausgef\xfchrt wird, mit Ausnahme der in der Zulassungsliste definierten Variablen."],"SecurityOrchestration|Settings from outside of the policy cannot override variables when the policy runs.":["Einstellungen au\xdferhalb der Richtlinie k\xf6nnen beim Ausf\xfchren der Richtlinie keine Variablen \xfcberschreiben."],"SecurityOrchestration|Several merge request approval policy criteria have been deprecated. Policies using these criteria will not work after GitLab 18.0 (May 10, 2025). You must edit these policies to replace or remove the deprecated criteria.":["Mehrere Kriterien f\xfcr die Genehmigung von Merge Requests sind veraltet. Richtlinien, die diese Kriterien verwenden, werden nach GitLab\xa018.0 (10.\xa0Mai\xa02025) nicht mehr funktionieren. Du musst diese Richtlinien bearbeiten, um die veralteten Kriterien zu ersetzen oder zu entfernen."],"SecurityOrchestration|Severity and status settings will apply to all scan rules":["Schweregrad und Statuseinstellungen gelten f\xfcr alle Scan-Regeln"],"SecurityOrchestration|Severity is %{severity}.":["Schweregrad ist %{severity}."],"SecurityOrchestration|Show all included projects":["Alle enthaltenen Projekte anzeigen"],"SecurityOrchestration|Show more projects":["Mehr Projekte anzeigen"],"SecurityOrchestration|Show only linked security policy projects":["Nur verlinkte Sicherheitsrichtlinienprojekte anzeigen"],"SecurityOrchestration|Snooze policy":["Richtlinie aussetzen"],"SecurityOrchestration|Snooze the policy until %{until} because %{reason}":["Richtlinie aussetzen bis %{until} \u2013 Grund: %{reason}"],"SecurityOrchestration|Some settings may be affected by policy %{policyName} based on its rules.":["Die Richtlinie %{policyName} und ihre Regeln haben Auswirkungen auf einige Einstellungen."],"SecurityOrchestration|Some settings may be affected by the following policies based on their rules:":["Die folgenden Richtlinien und ihre Regeln haben Auswirkungen auf einige Einstellungen:"],"SecurityOrchestration|Something went wrong, unable to fetch groups":["Etwas ist schiefgelaufen. Gruppen k\xf6nnen nicht abgerufen werden."],"SecurityOrchestration|Something went wrong, unable to fetch policies":["Etwas ist schiefgelaufen. Richtlinien k\xf6nnen nicht abgerufen werden"],"SecurityOrchestration|Sorry, your filter produced no results.":["Dein Filter hat leider keine Ergebnisse geliefert."],"SecurityOrchestration|Source":["Quelle"],"SecurityOrchestration|Standard roles":["Standardrollen"],"SecurityOrchestration|Status":["Status"],"SecurityOrchestration|Strictly enforced":["Strenge Durchsetzung"],"SecurityOrchestration|Summary":["Zusammenfassung"],"SecurityOrchestration|Summary of syntax changes:":["Zusammenfassung der Syntax\xe4nderungen:"],"SecurityOrchestration|Technical limitation":["Technische Einschr\xe4nkung"],"SecurityOrchestration|Template":["Vorlage"],"SecurityOrchestration|Test runs":[""],"SecurityOrchestration|The action will be logged in the audit log with your justification":["Die Aktion wird ohne Erkl\xe4rung im Auditprotokoll protokolliert"],"SecurityOrchestration|The action will be logged in the audit log.":["Die Aktion wird im Auditprotokoll protokolliert."],"SecurityOrchestration|The compliance pipeline will continue to override the new pipeline execution policy until it is removed from the compliance framework configuration.":["Die Konformit\xe4ts-Pipeline wird die neue Pipeline-Ausf\xfchrungsrichtlinie weiterhin \xfcberschreiben, bis sie aus der Konfiguration des Konformit\xe4ts-Frameworks entfernt wird."],"SecurityOrchestration|The current YAML syntax is invalid so you cannot edit the actions in rule mode. To resolve the issue, switch to YAML mode and fix the syntax.":["Die aktuelle YAML-Syntax ist ung\xfcltig. Daher kannst du die Aktionen im Regelmodus nicht bearbeiten. Wechsle in den YAML-Modus und korrigiere die Syntax, um das Problem zu beheben."],"SecurityOrchestration|The current YAML syntax is invalid so you cannot edit the conditions in rule mode. To resolve the issue, switch to YAML mode and fix the syntax.":["Die aktuelle YAML-Syntax ist ung\xfcltig. Daher kannst du die Bedingungen im Regelmodus nicht bearbeiten. Wechsle in den YAML-Modus und korrigiere die Syntax, um das Problem zu beheben."],"SecurityOrchestration|The current YAML syntax is invalid so you cannot edit the rules in rule mode. To resolve the issue, switch to YAML mode and fix the syntax.":["Die aktuelle YAML-Syntax ist ung\xfcltig. Daher kannst du die Regeln im Regelmodus nicht bearbeiten. Wechsle in den YAML-Modus und korrigiere die Syntax, um das Problem zu beheben."],"SecurityOrchestration|The current YAML syntax is invalid so you cannot edit the settings in rule mode. To resolve the issue, switch to YAML mode and fix the syntax.":["Die aktuelle YAML-Syntax ist ung\xfcltig. Daher kannst du die Einstellungen im Regelmodus nicht bearbeiten. Wechsle in den YAML-Modus und korrigiere die Syntax, um das Problem zu beheben."],"SecurityOrchestration|The following branches do not exist on this development project: %{branches}. Please review all protected branches to ensure the values are accurate before updating this policy.":["Die folgenden Branches in diesem Entwicklungsprojekt existieren nicht: %{branches}. \xdcberpr\xfcfe alle gesch\xfctzten Branches, um sicherzustellen, dass die Werte korrekt sind, bevor du diese Richtlinie aktualisierst."],"SecurityOrchestration|The linked security policy project does not contain a %{linkStart}policy.yml%{linkEnd} file. Merge the policy changes to create the file, or add it manually.":[""],"SecurityOrchestration|The schedule is snoozed until %{until} for reason: %{reason}.":["Der Zeitplan wird bis %{until} ausgesetzt, Grund: %{reason}."],"SecurityOrchestration|The schedule is snoozed until %{until}.":["Der Zeitplan wird bis %{until} ausgesetzt."],"SecurityOrchestration|The security findings remain in their current status and are still visible, but will no longer block the merge request.":["Die Sicherheitsfunde behalten ihren aktuellen Status bei und sind weiterhin sichtbar, blockieren die Merge Request jedoch nicht mehr."],"SecurityOrchestration|There are no exception branches yet.":["Es gibt noch keine Ausnahme-Branches."],"SecurityOrchestration|There was a problem creating the new security policy":["Es gab ein Problem beim Erstellen der neuen Sicherheitsrichtlinie"],"SecurityOrchestration|These policies are configured in warn mode. This allows you to bypass violations with proper justification.":["Diese Richtlinien sind im Warnungsmodus konfiguriert. Dadurch kannst du Verst\xf6\xdfe mit einer ordnungsgem\xe4\xdfen Erkl\xe4rung umgehen."],"SecurityOrchestration|This %{namespaceType} does not contain any security policies.":["Dieser %{namespaceType} enth\xe4lt keine Sicherheitsrichtlinien."],"SecurityOrchestration|This %{namespaceType} is not linked to a security policy project. Create a policy, which also creates and links a security policy project. Alternatively, %{linkStart}link this %{namespaceType} to an existing security policy project%{linkEnd}.":["Dieser %{namespaceType} ist nicht mit einem Sicherheitsrichtlinienprojekt verkn\xfcpft. Erstelle eine Richtlinie, wodurch auch ein Sicherheitsrichtlinienprojekt erstellt und verkn\xfcpft wird. Alternativ kannst du %{linkStart}diesen %{namespaceType} mit einem vorhandenen Sicherheitsrichtlinienprojekt verkn\xfcpfen%{linkEnd}."],"SecurityOrchestration|This applies to following compliance frameworks:":["Dies gilt f\xfcr folgende Konformit\xe4ts-Frameworks:"],"SecurityOrchestration|This change starts a synchronization process that:":["Diese \xc4nderung startet einen Synchronisierungsprozess, der Folgendes durchf\xfchrt:"],"SecurityOrchestration|This group":["Diese Gruppe"],"SecurityOrchestration|This instance policy is inherited from %{namespace}":["Diese Instanzrichtlinie wird geerbt von %{namespace}."],"SecurityOrchestration|This is a group-level policy":["Dies ist eine Richtlinie auf Gruppenebene."],"SecurityOrchestration|This is a project-level policy":["Dies ist eine Richtlinie auf Projektebene."],"SecurityOrchestration|This is an instance policy":["Dies ist eine Instanzrichtlinie"],"SecurityOrchestration|This merge request approval policy targets the default branch, but the default branch is not protected in this project. To set up this policy, the default branch must be protected.":["Diese Genehmigungsrichtlinie f\xfcr Merge Requests zielt auf den Standard-Branch ab, aber der Standard-Branch ist in diesem Projekt nicht gesch\xfctzt. Um diese Richtlinie einzurichten, muss der Standard-Branch gesch\xfctzt werden."],"SecurityOrchestration|This merge request migrates compliance pipeline `%{path}` to a pipeline execution policy scoped to framework [%{framework}](%{link}).":["Diese Merge-Anfrage migriert die Konformit\xe4ts-Pipeline `%{path}` zu einer Pipeline-Ausf\xfchrungsrichtlinie, die auf das Framework [%{framework}](%{link}) beschr\xe4nkt ist."],"SecurityOrchestration|This policy doesn't contain any actions or override project approval settings. You cannot create an empty policy.":["Diese Richtlinie enth\xe4lt keine Aktionen oder Einstellungen f\xfcr das \xdcberschreiben von Projektgenehmigungen. Du kannst keine leere Richtlinie erstellen."],"SecurityOrchestration|This policy has no rules to match merge requests against. Add rules for this policy to take effect.":[""],"SecurityOrchestration|This policy has no rules, so branch-level settings will not be applied. Only project approval settings will take effect.":[""],"SecurityOrchestration|This policy is applied to current project.":["Diese Richtlinie wird auf das aktuelle Projekt angewendet."],"SecurityOrchestration|This policy is inherited":["Diese Richtlinie wurde geerbt"],"SecurityOrchestration|This policy is inherited from %{linkStart}namespace%{linkEnd} and must be edited there":["Diese Richtlinie wird vom %{linkStart}Namensraum%{linkEnd} geerbt und muss dort bearbeitet werden"],"SecurityOrchestration|This policy is inherited from %{namespace}":["Diese Richtlinie wird geerbt von %{namespace}."],"SecurityOrchestration|This policy was previously in warn mode, which was an experimental feature. Due to changes in the feature, warn mode is now disabled. To enable the new warn mode setting, update this property.":["Diese Richtlinie befand sich zuvor im Warnungsmodus, was eine experimentelle Funktion war. Aufgrund von \xc4nderungen an der Funktion wurde der Warnungsmodus jetzt deaktiviert. Aktualisiere diese Eigenschaft, um die Einstellung f\xfcr den neuen Warnungsmodus zu aktivieren."],"SecurityOrchestration|This project":["Dieses Projekt"],"SecurityOrchestration|This setting will be locked for 10 minutes after making changes to prevent further performance issues.":["Diese Einstellung wird nach dem Vornehmen von \xc4nderungen f\xfcr 10\xa0Minuten gesperrt, um weitere Leistungsprobleme zu verhindern."],"SecurityOrchestration|This view only shows scan results for the agent %{agent}. You can view scan results for all agents in the %{linkStart}Operational Vulnerabilities tab of the vulnerability report%{linkEnd}.":["In dieser Ansicht werden nur Scan-Ergebnisse f\xfcr den Agenten %{agent} angezeigt. Du kannst die Scanergebnisse f\xfcr alle Agenten auf der Registerkarte %{linkStart}Operationale Sicherheitsl\xfccken des Sicherheitsanf\xe4lligkeitsberichts%{linkEnd} anzeigen."],"SecurityOrchestration|This will disconnect your top-level compliance and security policy group, and all the frameworks it shares, from all other top-level groups.":["Dies trennt deine oberste Konformit\xe4ts- und Sicherheitsrichtliniengruppe und alle von ihr geteilten Frameworks von allen anderen obersten Gruppen."],"SecurityOrchestration|Timezone is invalid":["Die Zeitzone ist ung\xfcltig."],"SecurityOrchestration|To widen your search, change filters above or select a different security policy project.":["Um deine Suche zu erweitern, \xe4ndere die Filter oben oder w\xe4hle ein anderes Sicherheitsrichtlinienprojekt aus."],"SecurityOrchestration|Trigger":["Trigger"],"SecurityOrchestration|Try advanced editor":["Erweiterten Editor ausprobieren"],"SecurityOrchestration|Turn off default mode to edit scope.":["Deaktiviere den Standardmodus, um den Bereich zu bearbeiten."],"SecurityOrchestration|Type in custom variable":["Benutzerdefinierte Variable eingeben"],"SecurityOrchestration|Unknown source":["Unbekannte Quelle"],"SecurityOrchestration|Unlink project":["Projektverkn\xfcpfung aufheben"],"SecurityOrchestration|Unlink the following projects from the following containers:":["Hebe die Verkn\xfcpfung der folgenden Projekte mit den folgenden Containern auf:"],"SecurityOrchestration|Unlink the project from the following containers:":["Hebe die Verkn\xfcpfung des Projekts mit den folgenden Containern auf:"],"SecurityOrchestration|Unlinking a security project removes all policies stored in the linked security project. Save to confirm this action.":["Durch das Aufheben der Verkn\xfcpfung eines Sicherheitsprojekts werden alle im verkn\xfcpften Sicherheitsprojekt gespeicherten Richtlinien entfernt. Speichern, um diese Aktion zu best\xe4tigen."],"SecurityOrchestration|Update security policies":["Sicherheitsrichtlinien aktualisieren"],"SecurityOrchestration|Update via merge request":["Aktualisierung \xfcber Merge Request"],"SecurityOrchestration|Use a merge request approval policy to create rules that %{strongStart}check%{strongEnd} for %{strongStart}security vulnerabilities%{strongEnd} and %{strongStart}license compliance%{strongEnd} before %{strongStart}merging a merge request%{strongEnd}.":["Verwende eine Richtlinie zur Genehmigung von Merge Requests, um Regeln zu erstellen, die vor dem %{strongStart}Zusammenf\xfchren von Merge Requests%{strongEnd} nach %{strongStart}Sicherheitsl\xfccken%{strongEnd} suchen und die %{strongStart}Lizenzkonformit\xe4t%{strongEnd} %{strongStart}\xfcberpr\xfcfen%{strongEnd}."],"SecurityOrchestration|Use a pipeline execution policy to %{strongStart}enforce a custom CI/CD configuration%{strongEnd} to run in project pipelines.":["Verwende eine Pipeline-Ausf\xfchrungsrichtlinie, um %{strongStart}eine benutzerdefinierte CI/CD-Konfiguration durchzusetzen%{strongEnd}, die in Projekt-Pipelines ausgef\xfchrt wird."],"SecurityOrchestration|Use a scan execution policy to create rules which %{strongStart}enforce security scans%{strongEnd} for %{strongStart}particular branches%{strongEnd} at %{strongStart}certain times%{strongEnd}. Supported types are SAST, SAST IaC, DAST, Secret detection, Container scanning, and Dependency scanning.":["Verwende eine Scan-Ausf\xfchrungsrichtlinie, um Regeln zu erstellen, die %{strongStart}Sicherheits-Scans%{strongEnd} f\xfcr %{strongStart}bestimmte Branches%{strongEnd} %{strongStart}zu einem bestimmten Zeitpunkt erzwingen%{strongEnd}. Unterst\xfctzte Typen sind SAST, SAST IaC, DAST, Erkennung von Geheimnissen, Container-Scans und Abh\xe4ngigkeitssuche."],"SecurityOrchestration|Use default mode for scoping":["Standardmodus f\xfcr Scoping verwenden"],"SecurityOrchestration|Use the format %{schemaStart}path-to-package@package-version%{schemaEnd}. For multiple packages, separate paths with commas. For example: npm/lodash@4.17.21, maven/org.apache.commons/commons-lang3@3.12.0, pypi/requests":["Verwende das Format %{schemaStart}paketpfad@paketversion%{schemaEnd}. Trenne bei mehreren Paketen die Pfade durch Kommas. Beispiel: npm/lodash@4.17.21, maven/org.apache.commons/commons-lang3@3.12.0, pypi/requests"],"SecurityOrchestration|Use this compliance and security policy group to create security policies. Do not create new projects in this group.":["Verwende diese Konformit\xe4ts- und Sicherheitsrichtliniengruppe, um Sicherheitsrichtlinien zu erstellen. Erstelle keine neuen Projekte in dieser Gruppe."],"SecurityOrchestration|Used in tests":["In Tests verwendet"],"SecurityOrchestration|Users and Groups (%{count})":["Benutzer(innen) und Gruppen (%{count})"],"SecurityOrchestration|Users can skip pipelines":["Benutzer(innen) k\xf6nnen Pipelines \xfcberspringen"],"SecurityOrchestration|Users can't skip pipelines":["Benutzer(innen) k\xf6nnen Pipelines nicht \xfcberspringen"],"SecurityOrchestration|Validating branch names, which might take a while.":["Branch-Namen werden validiert. Dies kann eine Weile dauern."],"SecurityOrchestration|Variable option":["Variablenoption"],"SecurityOrchestration|Variable precedence":["Variablenvorrang"],"SecurityOrchestration|Variables override configuration has invalid structure.":["Die Konfiguration zur Variablen\xfcberschreibung weist eine ung\xfcltige Struktur auf."],"SecurityOrchestration|Variables that can be overridden:":["\xdcberschreibbare Variablen:"],"SecurityOrchestration|Variables that cannot be overriden:":["Nicht \xfcberschreibbare Variablen:"],"SecurityOrchestration|View policy project":["Richtlinienprojekt anzeigen"],"SecurityOrchestration|Vulnerabilities %{vulnerabilityStates}.":["Sicherheitsl\xfccken %{vulnerabilityStates}."],"SecurityOrchestration|Vulnerabilities are %{vulnerabilityStates}.":["Sicherheitsl\xfccken sind %{vulnerabilityStates}."],"SecurityOrchestration|Vulnerability age is greater than %{vulnerabilityAge}.":["Das Alter der Sicherheitsl\xfccke ist gr\xf6\xdfer als %{vulnerabilityAge}."],"SecurityOrchestration|Vulnerability age is less than %{vulnerabilityAge}.":["Das Alter der Sicherheitsl\xfccke ist kleiner als %{vulnerabilityAge}."],"SecurityOrchestration|Vulnerability age requires previously existing vulnerability states (detected, confirmed, resolved, or dismissed)":["Das Alter der Sicherheitsl\xfccke erfordert einen bereits bestehenden Status der Sicherheitsl\xfccke (erkannt, best\xe4tigt, behoben oder verworfen)"],"SecurityOrchestration|Vulnerability management":["Sicherheitsl\xfcckenmanagement"],"SecurityOrchestration|Vulnerability management policy":["Sicherheitsl\xfcckenmanagementrichtlinie"],"SecurityOrchestration|Warn in merge request":["In Merge Request warnen"],"SecurityOrchestration|Warn mode":["Warnungsmodus"],"SecurityOrchestration|Warn mode (bypass eligible)":["Warnungsmodus (umgehungsberechtigt)"],"SecurityOrchestration|Warn users with a bot comment and require users to either dismiss the policy or obtain %{approvals} %{plural} from %{approvers}":["Benutzer(innen) mit einem Bot-Kommentar warnen und von Benutzer(innen) verlangen, dass entweder die Richtlinie verworfen wird oder %{approvals} %{plural} von %{approvers} eingeholt werden"],"SecurityOrchestration|Web UI":["Web-UI"],"SecurityOrchestration|What does an example message look like?":["Wie sieht eine Beispielnachricht aus?"],"SecurityOrchestration|What is linked group?":["Was ist eine verkn\xfcpfte Gruppe?"],"SecurityOrchestration|When %{scanners} %{vulnerabilitiesAllowed} %{vulnerability} in an open merge request %{targeting}%{branches}%{branchExceptionsString}%{criteriaApply}":["Wenn %{scanners} %{vulnerabilitiesAllowed} %{vulnerability} in einem offenen Merge Request findet, die %{targeting}%{branches}%{branchExceptionsString}%{criteriaApply}"],"SecurityOrchestration|When a %{scanType} with %{scanners} runs against %{branches} %{branchExceptions} and finds %{vulnerabilitiesNumber} vulnerability type that matches all the following criteria:":["Wenn ein %{scanType} mit %{scanners} f\xfcr %{branches} %{branchExceptions} ausgef\xfchrt wird und den Sicherheitsl\xfcckentyp %{vulnerabilitiesNumber} findet, der alle der folgenden Kriterien erf\xfcllt:"],"SecurityOrchestration|When license scanner finds any license except %{licenses}%{detection} in an open merge request %{targeting}%{branches}%{branchExceptionsString}":["Wenn der Lizenzscanner in einem offenen Merge Request eine Lizenz au\xdfer %{licenses}%{detection} findet, die %{targeting}%{branches}%{branchExceptionsString}"],"SecurityOrchestration|When license scanner finds any license matching %{licenses}%{detection} in an open merge request %{targeting}%{branches}%{branchExceptionsString}":["Wenn der Lizenzscanner in einem offenen Merge Request eine Lizenz findet, die mit %{licenses}%{detection} \xfcbereinstimmt, und %{targeting}%{branches}%{branchExceptionsString}"],"SecurityOrchestration|With the %{template} security job template":["Mit der Sicherheitsauftragsvorlage %{template}"],"SecurityOrchestration|With the following customized CI variables:":["Mit den folgenden benutzerdefinierten CI-Variablen:"],"SecurityOrchestration|YAML":["YAML"],"SecurityOrchestration|Yaml":["YAML"],"SecurityOrchestration|You already have the maximum %{maximumAllowed} %{policyType} %{instance}.":["Du verf\xfcgst bereits \xfcber die maximale Anzahl von %{maximumAllowed}\xa0%{policyType} %{instance}."],"SecurityOrchestration|You can add a maximum of %{rulesCount} %{rules}.":["Du kannst maximal %{rulesCount}\xa0%{rules} hinzuf\xfcgen."],"SecurityOrchestration|You can add a maximum of 3 criteria.":["Du kannst maximal 3\xa0Kriterien hinzuf\xfcgen."],"SecurityOrchestration|You can select this option only once.":["Du kannst diese Option nur einmal ausw\xe4hlen."],"SecurityOrchestration|You can use auto-dismiss actions only with detected rules.":["Aktionen zum automatischen Verwerfen k\xf6nnen nur mit erkannten Regeln verwendet werden."],"SecurityOrchestration|You can use auto-resolve actions only with no longer detected rules.":["Aktionen zum automatischen Aufl\xf6sen k\xf6nnen nur mit erkannten Regeln verwendet werden."],"SecurityOrchestration|You can use override actions only with detected rules.":[""],"SecurityOrchestration|You can't change the default branch because its protection is enforced by one or more %{security_policies_link_start}security policies%{security_policies_link_end}. %{learn_more_link_start}Learn more%{learn_more_link_end}.":["Du kannst den Standard-Branch nicht \xe4ndern, da der Schutz durch mindestens eine %{security_policies_link_start}Sicherheitsrichtlinie%{security_policies_link_end} erzwungen wird. %{learn_more_link_start}Mehr erfahren%{learn_more_link_end}."],"SecurityOrchestration|You can't unprotect this branch because its protection is enforced by one or more %{securityPoliciesPathStart}security policies%{securityPoliciesPathEnd}. %{linkStart}Learn more%{linkEnd}.":["Du kannst den Schutz dieses Zweigs nicht aufheben, da der Schutz durch mindestens eine %{securityPoliciesPathStart}Sicherheitsrichtlinie%{securityPoliciesPathEnd} erzwungen wird. %{linkStart}Mehr erfahren%{linkEnd}."],"SecurityOrchestration|You can't unprotect this branch because its protection is enforced by one or more %{security_policies_link_start}security policies%{security_policies_link_end}. %{learn_more_link_start}Learn more%{learn_more_link_end}.":["Du kannst den Schutz dieses Branchs nicht aufheben, da der Schutz durch mindestens eine %{security_policies_link_start}Sicherheitsrichtlinie%{security_policies_link_end} erzwungen wird. %{learn_more_link_start}Mehr erfahren%{learn_more_link_end}."],"SecurityOrchestration|You cannot use auto-dismiss rules with override rules.":[""],"SecurityOrchestration|You do not have the permission required to edit policies":["Du hast nicht die zum Bearbeiten von Richtlinien erforderliche Berechtigung."],"SecurityOrchestration|You don't have any security policies yet":["Du hast noch keine Sicherheitsrichtlinien"],"SecurityOrchestration|You have been granted bypass permissions for these policies based on organizational role or custom role assignments.":["Dir wurden aufgrund deiner Organisationsrolle oder von benutzerdefinierten Rollenzuweisungen Berechtigungen zum Umgehen dieser Richtlinien gew\xe4hrt."],"SecurityOrchestration|You have permissions to bypass all checks in this merge request or selectively only bypass Warn Mode policies.":["Du hast Berechtigungen zum Umgehen aller Pr\xfcfungen in diesem Merge Request oder selektiv nur zum Umgehen der Warnungsmodus-Richtlinien."],"SecurityOrchestration|You must edit the policy and replace the deprecated syntax (%{deprecatedProperties}). For details on its replacement, see the %{linkStart}policy documentation%{linkEnd}.":["Du musst die Richtlinie bearbeiten und die veraltete Syntax (%{deprecatedProperties}) ersetzen. N\xe4here Informationen zu deren Ersetzung findest du in der %{linkStart}Richtliniendokumentation%{linkEnd}."],"SecurityOrchestration|You must select one or more compliance frameworks to which this policy should apply.":["Du musst ein oder mehrere Konformit\xe4ts-Frameworks ausw\xe4hlen, f\xfcr die diese Richtlinie gelten soll."],"SecurityOrchestration|You must select one or more groups from this policy.":["Du musst eine oder mehrere Gruppen von dieser Richtlinie ausw\xe4hlen."],"SecurityOrchestration|You must select one or more projects to be excluded from this policy.":["Du musst ein oder mehrere Projekte ausw\xe4hlen, die von dieser Richtlinie ausgeschlossen werden sollen."],"SecurityOrchestration|You must select one or more projects to which this policy should apply.":["Du musst ein oder mehrere Projekte ausw\xe4hlen, f\xfcr die diese Richtlinie gelten soll."],
"SecurityOrchestration|You need the Developer, Maintainer, or Owner role in the project or group. You also need one one of these roles in the security policy project.":["Du ben\xf6tigst die Rolle \u201eEntwickler(in)\u201c, \u201eBetreuer(in) oder \u201eEigent\xfcmer(in)\u201c f\xfcr das Projekt oder die Gruppe. Au\xdferdem ben\xf6tigst du eine dieser Rollen f\xfcr das Sicherheitsrichtlinienprojekt."],"SecurityOrchestration|You've reached the maximum limit of %{max} %{type} policies allowed. Policies are disabled when added.":["Du hast die maximal zul\xe4ssige Anzahl %{max} f\xfcr %{type}-Richtlinien erreicht. Wenn Richtlinien hinzugef\xfcgt werden, sind sie deaktiviert."],"SecurityOrchestration|Your policy is using GitLab's recommended settings for this scanner and optimized for industry best practices.":[""],"SecurityOrchestration|a license scanner found license violations":["ein Lizenzscanner hat Lizenzverletzungen festgestellt"],"SecurityOrchestration|a merge request has been opened against a protected branch":["ein Merge Request wurde f\xfcr einen gesch\xfctzten Branch ge\xf6ffnet"],"SecurityOrchestration|a security policy has been violated":["eine Sicherheitsrichtlinie wurde verletzt"],"SecurityOrchestration|a security scanner found vulnerabilities matching the criteria":["ein Sicherheitsscanner hat Sicherheitsl\xfccken gefunden, die den Kriterien entsprechen"],"SecurityOrchestration|all namespaces":["Alle Namensr\xe4ume"],"SecurityOrchestration|all projects in the groups":["Alle Projekte in dieser Gruppe"],"SecurityOrchestration|all projects in the linked groups":["alle Projekte in den verkn\xfcpften Gruppen"],"SecurityOrchestration|all projects in this group":["alle Projekte in dieser Gruppe"],"SecurityOrchestration|all projects in this instance":["Alle Projekte in dieser Instanz"],"SecurityOrchestration|allowlist":["Zulassungsliste"],"SecurityOrchestration|and run for %{timeWindowInfo}":["und f\xfcr %{timeWindowInfo} ausf\xfchren"],"SecurityOrchestration|any":["beliebig"],"SecurityOrchestration|any branch":["jeder Branch"],"SecurityOrchestration|any branch that targets a protected branch":["jeder Branch, der auf einen gesch\xfctzten Branch abzielt"],"SecurityOrchestration|any branch that targets the default branch":["jeder Branch, der auf den Standard-Branch abzielt"],"SecurityOrchestration|any default branch":["beliebiger Standardbranch"],"SecurityOrchestration|any merge request":["alle Merge Requests"],"SecurityOrchestration|any protected branch":["beliebiger gesch\xfctzter Branch"],"SecurityOrchestration|any security scanner finds":["ein Sicherheitsscanner findet"],"SecurityOrchestration|are false positives":["sind falsch positiv"],"SecurityOrchestration|are not false positives":["sind nicht falsch positiv"],"SecurityOrchestration|at %{time}":["um %{time}"],"SecurityOrchestration|at the following times: %{cadenceSelector}, start at %{start}, run for: %{duration}, and timezone is %{timezoneSelector}":["zu den folgenden Zeiten: %{cadenceSelector}, Start um %{start}, Ausf\xfchrung f\xfcr %{duration} in Zeitzone %{timezoneSelector}"],"SecurityOrchestration|branch":["Branch"],"SecurityOrchestration|branches":["Branches"],"SecurityOrchestration|branches input":[""],"SecurityOrchestration|by the agent named %{agents} %{cadence}%{timeWindowInfo}%{branchExceptionsString}":["durch den Agenten namens %{agents} %{cadence}%{timeWindowInfo}%{branchExceptionsString}"],"SecurityOrchestration|choose exception branches":["ausgenommene Branches ausw\xe4hlen"],"SecurityOrchestration|compliance frameworks":["Konformit\xe4ts-Frameworks"],"SecurityOrchestration|default":["Standard"],"SecurityOrchestration|denylist":["Sperrliste"],"SecurityOrchestration|directory":["Verzeichnis"],"SecurityOrchestration|e.g. main, develop, release":[""],"SecurityOrchestration|except for:":["Ausnahme:"],"SecurityOrchestration|except groups":["au\xdfer Gruppen"],"SecurityOrchestration|except personal projects":["mit Ausnahme pers\xf6nlicher Projekte"],"SecurityOrchestration|except projects":["mit Ausnahme der Projekte"],"SecurityOrchestration|exceptions":["Ausnahmen"],"SecurityOrchestration|exceptions: %{exceptions}":["Ausnahmen: %{exceptions}"],"SecurityOrchestration|file path":["Dateipfad"],"SecurityOrchestration|for %{branchType}":["f\xfcr %{branchType}"],"SecurityOrchestration|group level branch input":["Branch-Input auf Gruppenebene"],"SecurityOrchestration|group level branch selector":["Branch-Selector auf Gruppenebene"],"SecurityOrchestration|have a fix available":["haben einen verf\xfcgbaren Fix"],"SecurityOrchestration|have no fix available":["haben keinen verf\xfcgbaren Fix"],"SecurityOrchestration|identifier":["Bezeichner"],"SecurityOrchestration|in timezone %{timezone}":["in Zeitzone %{timezone}"],"SecurityOrchestration|instance policy":["Instanzrichtlinie"],"SecurityOrchestration|latest":["neueste"],"SecurityOrchestration|license scan":["Lizenz-Scan"],"SecurityOrchestration|more than %{allowed}":["mehr als %{allowed}"],"SecurityOrchestration|no exceptions":["keine Ausnahmen"],"SecurityOrchestration|on %{dayText} %{days} of each month":["am %{days}. %{dayText} jedes Monats"],"SecurityOrchestration|on every":["an jedem"],"SecurityOrchestration|personal projects":["Pers\xf6nliche Projekte"],"SecurityOrchestration|pipeline sources":["Pipeline-Quellen"],"SecurityOrchestration|policy.yml file has syntax errors":["Datei \u201epolicy.yml\u201c weist Syntaxfehler auf"],"SecurityOrchestration|projects with compliance frameworks":["Projekte mit Konformit\xe4ts-Frameworks"],"SecurityOrchestration|scanner finds":["Scanner findet"],"SecurityOrchestration|scanners":["Scanner"],"SecurityOrchestration|scanners find":["Scanner finden"],"SecurityOrchestration|security scan":["Sicherheits-Scan"],"SecurityOrchestration|select scan type":["Scan-Typ ausw\xe4hlen"],"SecurityOrchestration|specific projects":["bestimmte Projekte"],"SecurityOrchestration|starting every %{days}":["an jedem %{days}"],"SecurityOrchestration|targeting %{branchTypeText}":["zielt auf %{branchTypeText}"],"SecurityOrchestration|the %{branches}":["die %{branches}"],"SecurityOrchestration|the %{branches} and %{lastBranch} branches":["die %{branches} und %{lastBranch}-Branches"],"SecurityOrchestration|the %{branches} branch":["der %{branches}-Branch"],"SecurityOrchestration|the %{namespaces} and %{lastNamespace} namespaces":["Die %{namespaces} und %{lastNamespace} Namensr\xe4ume"],"SecurityOrchestration|the %{namespaces} namespace":["Der %{namespaces} Namensraum"],"SecurityOrchestration|the default branch":["der Standard-Branch"],"SecurityOrchestration|type: scan_result_policy is replaced with %{linkStart}type: approval_policy%{linkEnd}":["type: scan_result_policy wird durch %{linkStart}type: approval_policy%{linkEnd} ersetzt"],"SecurityOrchestration|v2":["v2"],"SecurityOrchestration|vulnerabilities allowed":["zul\xe4ssige Sicherheitsl\xfccken"],"SecurityOrchestration|with %{exceptionType}":["mit %{exceptionType}"],"SecurityOrchestration|with %{exceptionType} on %{branchSelector}":["mit %{exceptionType} auf %{branchSelector}"],"SecurityOrchestration|without exceptions":["ohne Ausnahmen"],"SecurityOrchestration|without group exceptions":[""],"SecurityOrchestration|without project exceptions":[""],"SecurityPolicies|Invalid or empty policy":["Ung\xfcltige oder leere Richtlinie"],"SecurityProfiles|Action unavailable":["Aktion nicht verf\xfcgbar"],"SecurityProfiles|Active":["Aktiv"],"SecurityProfiles|Apply default profile":["Standardprofil anwenden"],"SecurityProfiles|Apply profile to enable":["Profil anwenden zum Aktivieren"],"SecurityProfiles|Block secrets such as keys and API tokens from being pushed to your repositories. Secret push protection is triggered when commits are pushed to a repository. If any secrets are detected, the push is blocked. %{linkStart}Learn more%{linkEnd}.":["Verhindere, dass Geheimnisse wie Schl\xfcssel und API-Token in deine Repositorys gepusht werden. Der Geheimnis-Push-Schutz wird ausgel\xf6st, wenn Commits in ein Repository gepusht werden. Falls irgendwelche Geheimnisse entdeckt werden, wird der Push blockiert. %{linkStart}Mehr erfahren%{linkEnd}."],"SecurityProfiles|Configuration profiles are reusable settings templates for security tools. Create and manage profiles once, then apply them to multiple projects to ensure consistent security coverage. %{linkStart}Learn more%{linkEnd}.":["Konfigurationsprofile sind wiederverwendbare Einstellungsvorlagen f\xfcr Sicherheitstools. Du kannst Profile einmal erstellen und verwalten und anschlie\xdfend auf mehrere Projekte anwenden, um eine einheitliche Sicherheitsabdeckung sicherzustellen. %{linkStart}Mehr erfahren%{linkEnd}."],"SecurityProfiles|Configure once. Apply everywhere. Profiles make it easier to configure and manage your security tools at scale. Secret push protection is the first type of scan supported by this new feature.":["Einmal konfigurieren. \xdcberall anwenden. Profile erleichtern die Konfiguration und Verwaltung deiner Sicherheits-Tools im gro\xdfen Ma\xdfstab. Geheimnis-Push-Schutz ist die erste Scan-Art, die von dieser neuen Funktion unterst\xfctzt wird."],"SecurityProfiles|Disable":["Deaktivieren"],"SecurityProfiles|Disable %{scannerName}":["%{scannerName} deaktivieren"],"SecurityProfiles|Error applying profile. Please try again.":["Fehler beim Anwenden des Profils. Bitte erneut versuchen."],"SecurityProfiles|Error detaching profile. Please try again.":["Fehler beim Trennen des Profils. Bitte erneut versuchen."],"SecurityProfiles|Error loading profiles. Please try again.":["Fehler beim Laden der Profile. Bitte erneut versuchen."],"SecurityProfiles|Got it!":["Verstanden!"],"SecurityProfiles|Introducing Security Configuration Profiles":["Einf\xfchrung von Sicherheitskonfigurationsprofilen"],"SecurityProfiles|Learn more":["Mehr erfahren"],"SecurityProfiles|New feature":["Neue Funktion"],"SecurityProfiles|No profile applied":["Kein Profil angewendet"],"SecurityProfiles|Not configured":["Nicht konfiguriert"],"SecurityProfiles|Only a project maintainer or owner can apply or disable profiles.":["Nur ein(e) Projekt-Verwalter(in) oder -Eigent\xfcmer(in) kann Profile anwenden oder deaktivieren."],"SecurityProfiles|Preview default profile":["Standardprofil als Vorschau ansehen"],"SecurityProfiles|Profile applied successfully.":["Profil erfolgreich angewendet."],"SecurityProfiles|Profile disabled successfully.":["Profil erfolgreich deaktiviert."],"SecurityProfiles|Secret Detection":["Geheimnis-Erkennung"],"SecurityProfiles|Security configuration illustration":["Illustration der Sicherheitskonfiguration"],"SecurityProfiles|What are configuration profiles?":["Was sind Konfigurationsprofile?"],"SecurityProfiles|What is secret push protection?":["Was ist Geheimnis-Push-Schutz?"],"SecurityProfiles|You are about to disable %{scannerName} for this project. Are you sure you want to proceed?":["Du bist dabei, %{scannerName} f\xfcr dieses Projekt zu deaktivieren. M\xf6chtest du wirklich fortfahren?"],"SecurityReports|%{count} Selected":["%{count} ausgew\xe4hlt"],"SecurityReports|%{count} project not shown":["%{count} Projekt nicht angezeigt","%{count} Projekte nicht angezeigt"],"SecurityReports|%{count}+":["%{count}+"],"SecurityReports|%{count}+ projects":["\xfcber %{count} Projekte"],"SecurityReports|%{firstProject} and %{secondProject}":["%{firstProject} und %{secondProject}"],"SecurityReports|%{firstProject}, %{secondProject}, and %{rest}":["%{firstProject}, %{secondProject} und %{rest}"],"SecurityReports|%{nrVulnerabilities} vulnerabilities attached to %{nrIssues} issues":["%{nrVulnerabilities} Sicherheitsl\xfccken verkn\xfcpft mit %{nrIssues} Tickets"],"SecurityReports|%{nrVulnerabilities} vulnerabilities attached to 1 issue":["%{nrVulnerabilities} Sicherheitsl\xfccken verkn\xfcpft mit 1 Ticket"],"SecurityReports|%{rating} risk score":["Risikobewertung %{rating}"],"SecurityReports|%{supStart}*%{supEnd}Base score (associated with severity level) + EPSS modifier + KEV modifier":["%{supStart}*%{supEnd}Basispunkte (abh\xe4ngig vom Schweregrad) + EPSS-Modifikator + KEV-Modifikator"],"SecurityReports|%{supStart}\xa7%{supEnd}Diversity factor = 0.4":["%{supStart}\xa7%{supEnd}Diversit\xe4tsfaktor = 0,4"],"SecurityReports|%{supStart}\u2020%{supEnd}Sum of vulnerability ages in months * 0.005":["%{supStart}\u2020%{supEnd}Gesamtalter der Sicherheitsl\xfccke in Monaten * 0,005"],"SecurityReports|%{supStart}\u2021%{supEnd}Diminishing factor = 1.0 / \u221a(vulnerability count)":["%{supStart}\u2021%{supEnd}D\xe4mpfungsfaktor = 1,0 / \u221a(Zahl der Sicherheitsl\xfccken)"],"SecurityReports|(Sum of open vulnerability scores%{supStart}*%{supEnd} + Age penalty%{supStart}\u2020%{supEnd}) * Diminishing factor%{supStart}\u2021%{supEnd} * Diversity factor%{supStart}\xa7%{supEnd}":["(Summe der Punkte von offenen Sicherheitsl\xfccken%{supStart}*%{supEnd} + Altersfaktor%{supStart}\u2020%{supEnd}) * D\xe4mpfungsfaktor%{supStart}\u2021%{supEnd} * Diversit\xe4tsfaktor%{supStart}\xa7%{supEnd}"],"SecurityReports|1 vulnerability attached to %{nrIssues} issues":["1 Sicherheitsl\xfccke verkn\xfcpft mit %{nrIssues} Tickets"],"SecurityReports|1 vulnerability attached to 1 issue":["1 Sicherheitsl\xfccke verkn\xfcpft mit 1 Ticket"],"SecurityReports|30 days":["30 Tage"],"SecurityReports|60 days":["60 Tage"],"SecurityReports|90 days":["90 Tage"],"SecurityReports|A comment is required when changing the severity.":["F\xfcr die \xc4nderung des Schweregrads ist ein Kommentar erforderlich."],"SecurityReports|A comment is required when dismissing.":["F\xfcr das Verwerfen ist ein Kommentar erforderlich."],"SecurityReports|A dismissal reason is required.":["Ein Ablehnungsgrund ist erforderlich."],"SecurityReports|Active secret":["Aktives Geheimnis"],"SecurityReports|Activity":["Aktivit\xe4t"],"SecurityReports|Add a comment":["Einen Kommentar hinzuf\xfcgen"],"SecurityReports|Add a comment (required)":["Einen Kommentar hinzuf\xfcgen (erforderlich)"],"SecurityReports|Add a comment or reason for dismissal":["Kommentar oder Grund f\xfcr die Ablehnung angeben"],"SecurityReports|Add or remove projects to monitor in the security area. Projects included in this list will have their results displayed in the security dashboard and vulnerability report.":["Hier kannst du Projekte, die im Sicherheitsbereich \xfcberwacht werden sollen, hinzuf\xfcgen oder entfernen. Die \xdcberpr\xfcfungsergebnisse der Projekte in dieser Liste werden im Sicherheits-Dashboard und im Sicherheitsl\xfcckenbericht angezeigt."],"SecurityReports|Add projects":["Projekte hinzuf\xfcgen"],"SecurityReports|Add reason for the severity change (required)":["Grund f\xfcr die \xc4nderung des Schweregrads hinzuf\xfcgen (erforderlich)"],"SecurityReports|All activity":["Alle Aktivit\xe4ten"],"SecurityReports|All clusters":["Alle Cluster"],"SecurityReports|All dismissal reasons":["Alle Ablehnungsgr\xfcnde"],"SecurityReports|All images":["Alle Bilder"],"SecurityReports|All projects":["Alle Projekte"],"SecurityReports|All report types":["Alle Berichtstypen"],"SecurityReports|All scanners":["Alle Scanner"],"SecurityReports|All severities":["Alle Schweregrade"],"SecurityReports|All statuses":["Alle Status"],"SecurityReports|All tools":["Alle Tools"],"SecurityReports|All tracked refs":["Alle nachverfolgten Refs"],"SecurityReports|Attach to existing issue":["An vorhandenes Ticket anh\xe4ngen"],"SecurityReports|Attach to new issue":["An neues Ticket anh\xe4ngen"],"SecurityReports|Branches":["Branches"],"SecurityReports|CVSS v%{version}:":["CVSS v%{version}:"],"SecurityReports|Change severity":["Schweregrad \xe4ndern"],"SecurityReports|Change status":["Status \xe4ndern"],"SecurityReports|Chart failed to initialize. Please refresh the page and try again.":["Diagramm konnte nicht initialisiert werden. Bitte aktualisiere die Seite und versuche es erneut."],"SecurityReports|Chart is still loading. Please try again after all data has loaded.":["Diagramm wird noch geladen. Bitte versuche es erneut, nachdem alle Daten geladen wurden."],"SecurityReports|Check the messages generated while parsing the following security reports, as they may prevent the results from being ingested by GitLab. Ensure the security report conforms to a supported %{helpPageLinkStart}JSON schema%{helpPageLinkEnd}.":["\xdcberpr\xfcfe die Nachrichten, die beim Parsen der folgenden Sicherheitsberichte generiert werden, da sie verhindern k\xf6nnen, dass die Ergebnisse von GitLab aufgenommen werden. Stelle sicher, dass der Sicherheitsbericht einem unterst\xfctzten %{helpPageLinkStart}JSON-Schema%{helpPageLinkEnd} entspricht."],"SecurityReports|Cluster":["Cluster"],"SecurityReports|Collapse security scanning details":[""],"SecurityReports|Coming soon: time-based data retention limits":["Bald verf\xfcgbar: Zeitbasierte Limits f\xfcr die Aufbewahrung von Daten"],"SecurityReports|Comment (required)":["Kommentar (erforderlich)"],"SecurityReports|Configure security testing":["Sicherheitstests konfigurieren"],"SecurityReports|Confirm dismissal":["Verwerfen best\xe4tigen"],"SecurityReports|Container Scanning for Registry scans the latest tag of each image for vulnerabilities. %{linkStart}How do I enable Container Scanning for Registry?%{linkEnd}":["\u201eContainer-Scanning f\xfcr die Registry\u201c scannt das neueste Tag jedes Images nach Sicherheitsl\xfccken. %{linkStart}Wie aktiviere ich Container-Scanning f\xfcr die Registry?%{linkEnd}"],"SecurityReports|Container Scanning for Registry scans the latest tag of each image. It scans for vulnerabilities in the container %{linkStart}registry%{linkEnd} when an image or database is updated.":["\u201eContainer-Scanning f\xfcr die Registry\u201c scannt das neueste Tag jedes Images. Es sucht nach Sicherheitsl\xfccken in der Container-%{linkStart}Registry%{linkEnd}, wenn ein Image oder eine Datenbank aktualisiert wird."],"SecurityReports|Container Scanning for registry is active":["Container-Scanning f\xfcr die Registry ist aktiv"],"SecurityReports|Container registry vulnerabilities":["Container-Registry-Sicherheitsl\xfccken"],"SecurityReports|Container scanning for registry is not enabled":["Container-Scanning f\xfcr die Registry ist nicht aktiviert"],"SecurityReports|Container scanning for registry scans the latest tag of each image. It scans for vulnerabilities in the container registry when an image or database is updated.":["\u201eContainer-Scanning f\xfcr die Registry\u201c scannt das neueste Tag jedes Images. Es sucht nach Sicherheitsl\xfccken in der Container-Registry, wenn ein Image oder eine Datenbank aktualisiert wird."],"SecurityReports|Create Jira issue":["Jira-Ticket erstellen"],"SecurityReports|Create issue":["Ticket erstellen"],"SecurityReports|Critical":["Kritisch"],"SecurityReports|Critical risk":["Kritisches Risiko"],"SecurityReports|Detected in external sources such as running containers and URLs. These vulnerabilities are not necessarily associated with your GitLab project.":["Wird in externen Quellen wie laufenden Containern und URLs erkannt. Diese Sicherheitsl\xfccken sind nicht unbedingt mit deinem GitLab-Projekt verbunden."],"SecurityReports|Detection":["Erkennung"],"SecurityReports|Development vulnerabilities":["Entwicklungssicherheitsl\xfccken"],"SecurityReports|Dismiss vulnerability":["Sicherheitsl\xfccke verwerfen"],"SecurityReports|Dismissal reason (required)":["Ablehnungsgrund (erforderlich)"],"SecurityReports|Dismissed (all reasons)":["Abgelehnt (alle Gr\xfcnde)"],"SecurityReports|Dismissed as\u2026":["Abgelehnt als\xa0\u2026"],"SecurityReports|Dismissed by vulnerability policy":["Von Sicherheitsl\xfcckenrichtlinie verworfen"],"SecurityReports|Dismissed in MR":["In MR verworfen"],"SecurityReports|Does not have a solution":["Hat keine L\xf6sung"],"SecurityReports|Does not have issue":["Hat keine Tickets"],"SecurityReports|Does not have merge request":["Hat keine Merge Requests"],"SecurityReports|Download %{artifactName}":["%{artifactName} herunterladen"],"SecurityReports|Download %{artifactName} (%{fileType})":["%{artifactName} herunterladen (%{fileType})"],"SecurityReports|Download results":["Ergebnisse herunterladen"],"SecurityReports|Download scanned URLs":["Gescannte URLs herunterladen"],"SecurityReports|EPSS:":["EPSS:"],"SecurityReports|Edit dismissal":["Verwerfen bearbeiten"],"SecurityReports|Edit vulnerability":["Sicherheitsl\xfccke bearbeiten"],"SecurityReports|Either you don't have permission to view this dashboard or the dashboard has not been setup. Please check your permission settings with your administrator or check your dashboard configurations to proceed.":["Du hast keine Berechtigung, dieses Dashboard anzuzeigen, oder das Dashboard wurde nicht eingerichtet. \xdcberpr\xfcfe deine Berechtigungseinstellungen mit deinem/deiner Administrator(in) oder \xfcberpr\xfcfe deine Dashboard-Konfigurationen, um fortzufahren."],"SecurityReports|Ensure that %{trackingStart}issue tracking%{trackingEnd} is enabled for this project and you have %{permissionsStart}permission to create new issues%{permissionsEnd}.":["Stelle sicher, dass die %{trackingStart}Ticketverfolgung%{trackingEnd} f\xfcr dieses Projekt aktiviert ist und du %{permissionsStart}zur Erstellung neuer Tickets berechtigt%{permissionsEnd} bist."],"SecurityReports|Enter at least 3 characters to view available identifiers.":["Gib mindestens drei Zeichen ein, um die verf\xfcgbaren Kennungen anzuzeigen."],"SecurityReports|Error fetching the vulnerability counts. Please check your network connection and try again.":["Fehler beim Abrufen der Sicherheitsl\xfcckenanzahl. \xdcberpr\xfcfe deine Netzwerkverbindung und versuche es erneut."],"SecurityReports|Error fetching the vulnerability list. Please check your network connection and try again.":["Fehler beim Abrufen der Sicherheitsl\xfcckenliste. \xdcberpr\xfcfe deine Netzwerkverbindung und versuche es erneut."],"SecurityReports|Error parsing security reports":["Fehler beim Parsen von Sicherheitsberichten"],"SecurityReports|Expand security scanning details":[""],"SecurityReports|Export":["Export"],"SecurityReports|Export as PDF":["Als PDF exportieren"],"SecurityReports|Failed to get security report information. Please reload the page or try again later.":["Informationen zum Sicherheitsbericht konnten nicht abgerufen werden. Bitte lade die Seite neu oder versuche es sp\xe4ter erneut."],"SecurityReports|Failed to load Security attributes.":[""],"SecurityReports|Failed to load tracked refs.":["Fehler beim Laden der nachverfolgten Refs."],"SecurityReports|Failed to retrieve the vulnerability data. Please refresh the page.":["Fehler beim Abrufen der Sicherheitsl\xfcckendaten. Bitte aktualisiere die Seite."],"SecurityReports|Failed updating vulnerabilities with the following IDs: %{ids}":["Die Aktualisierung von Sicherheitsl\xfccken mit den folgenden IDs ist fehlgeschlagen: %{ids}"],"SecurityReports|False positive":["Falsch positiv"],"SecurityReports|Filter results...":["Ergebnisse filtern..."],"SecurityReports|GitLab Duo FP detection":["GitLab Duo FP-Erkennung"],"SecurityReports|GitLab Duo resolution":["GitLab Duo-Aufl\xf6sung"],"SecurityReports|Group your vulnerabilities by one of the provided categories. Leave feedback or suggestions in %{feedbackIssueStart}this issue%{feedbackIssueEnd}.":["Gruppiere deine Sicherheitsl\xfccken nach einer der angegebenen Kategorien. Hinterlasse Feedback oder Vorschl\xe4ge in %{feedbackIssueStart}diesem Ticket%{feedbackIssueEnd}."],"SecurityReports|Has a solution":["Hat eine L\xf6sung"],"SecurityReports|Has issue":["Hat ein Ticket"],"SecurityReports|Has merge request":["Hat Merge Request"],"SecurityReports|High":["Hoch"],"SecurityReports|High risk":["Hohes Risiko"],"SecurityReports|Historical view of open vulnerabilities in the default branch. Excludes vulnerabilities that were resolved or dismissed. %{linkStart}Learn more.%{linkEnd}":["Historische Ansicht offener Sicherheitsl\xfccken im Standard-Branch. Schlie\xdft Sicherheitsl\xfccken aus, die behoben oder verworfen wurden. %{linkStart}Mehr erfahren.%{linkEnd}"],"SecurityReports|Identifier":["Kennung"],"SecurityReports|If you were expecting vulnerabilities to be shown here, check that you've completed the %{linkStart}security scanning prerequisites%{linkEnd}.":["Wenn du erwartet hast, dass hier Sicherheitsl\xfccken angezeigt werden, \xfcberpr\xfcfe, ob du die %{linkStart}Voraussetzungen f\xfcr die Sicherheits\xfcberpr\xfcfung%{linkEnd} erf\xfcllt hast."],"SecurityReports|Image":["Image"],"SecurityReports|Inactive secret":["Inaktives Geheimnis"],"SecurityReports|Investigate this vulnerability by creating an issue":["Untersuche diese Sicherheitsl\xfccke, indem du ein Ticket erstellst"],"SecurityReports|Issue":["Ticket"],"SecurityReports|Issues created from a vulnerability cannot be removed.":["Tickets, die anhand einer Sicherheitsl\xfccke erstellt wurden, k\xf6nnen nicht entfernt werden."],"SecurityReports|KEV:":["KEV:"],"SecurityReports|Learn more about security configuration":["Erfahre mehr \xfcber die Sicherheitskonfiguration"],"SecurityReports|Learn more about setting up your dashboard":["Weitere Informationen zum Einrichten deines Dashboards"],"SecurityReports|Limited experience available":["Eingeschr\xe4nktes Erlebnis verf\xfcgbar"],"SecurityReports|Low":["Niedrig"],"SecurityReports|Low risk":["Niedriges Risiko"],"SecurityReports|Manage and track vulnerabilities identified in projects within your group. Vulnerabilities in projects are shown here when security testing is configured and a pipeline has been run on the default branch.":["Verwalte und verfolge Sicherheitsl\xfccken, die in Projekten innerhalb deiner Gruppe identifiziert wurden. Hier werden Sicherheitsl\xfccken in Projekten angezeigt, wenn Sicherheitstests konfiguriert sind und eine Pipeline im Standard-Branch ausgef\xfchrt wurde."],"SecurityReports|Manage and track vulnerabilities identified in your project. Vulnerabilities are shown here when security testing is configured and a pipeline has been run on the default branch.":["Verwalte und verfolge Sicherheitsl\xfccken, die in deinem Projekt identifiziert wurden. Hier werden Sicherheitsl\xfccken angezeigt, wenn Sicherheitstests konfiguriert sind und eine Pipeline im Standard-Branch ausgef\xfchrt wurde."],"SecurityReports|Manage and track vulnerabilities identified in your selected projects. Vulnerabilities for selected projects are shown here when security testing is configured and a pipeline has been run on the default branch.":["Verwalte und verfolge Sicherheitsl\xfccken, die in deinen ausgew\xe4hlten Projekten identifiziert wurden. Hier werden Sicherheitsl\xfccken f\xfcr ausgew\xe4hlte Projekte angezeigt, wenn Sicherheitstests konfiguriert sind und eine Pipeline im Standard-Branch ausgef\xfchrt wurde."],"SecurityReports|Maximum selected projects limit reached":["Maximales Limit f\xfcr ausgew\xe4hlte Projekte erreicht"],"SecurityReports|Median: %{days} day":["Median: %{days} Tag","Median: %{days} Tage"],"SecurityReports|Medium":["Mittel"],"SecurityReports|Medium risk":["Mittleres Risiko"],"SecurityReports|Merge Request":["Merge Request"],"SecurityReports|Monitor vulnerabilities in all of your projects":["\xdcberwache Sicherheitsl\xfccken in all deinen Projekten"],"SecurityReports|Monitor vulnerabilities in your group":["\xdcberwache Sicherheitsl\xfccken in deiner Gruppe"],"SecurityReports|Monitor vulnerabilities in your project":["\xdcberwache Sicherheitsl\xfccken in deinem Projekt"],"SecurityReports|Monitored projects":["\xdcberwachte Projekte"],"SecurityReports|New feature: Grouping":["Neues Feature: Gruppierung"],"SecurityReports|New status must be different than current status.":["Der neue Status darf nicht mit dem aktuellen Status \xfcbereinstimmen."],"SecurityReports|No grouping":["Keine Gruppierung"],"SecurityReports|No identifiers found.":["Keine Kennungen gefunden."],"SecurityReports|No longer detected":["Nicht mehr erkannt"],"SecurityReports|No vulnerabilities to report":["Keine zu meldenden Sicherheitsl\xfccken"],"SecurityReports|None":["Keine"],"SecurityReports|Not available":["Nicht verf\xfcgbar"],"SecurityReports|Not dismissed by vulnerability policy":["Nicht von Sicherheitsl\xfcckenrichtlinie verworfen"],"SecurityReports|Not found":["Nicht gefunden"],"SecurityReports|Not identified as false positive":["Nicht als falsch positiv identifiziert"],"SecurityReports|OWASP Top 10 2017":["OWASP Top 10 2017"],"SecurityReports|OWASP Top 10 2021":["OWASP Top 10 2021"],"SecurityReports|Only the top %{count} projects with the highest risk scores are shown. Use the filter at the top of the dashboard to narrow down your results.":["Es werden nur die ersten %{count} Projekte mit der h\xf6chsten Risikobewertung angezeigt. Anhand der Filter oben im Dashboard kannst du die Ergebnisse weiter eingrenzen."],"SecurityReports|Oops, something doesn't seem right.":["Irgendetwas scheint nicht zu stimmen."],"SecurityReports|Open vulnerabilities by the amount of time since they were opened.":["Offene Sicherheitsl\xfccken nach der Zeit, seitdem sie er\xf6ffnet wurden."],"SecurityReports|Open vulnerability trends over time. To interact with a link in a chart popover, click to pin the popover first.":["\xd6ffne die Sicherheitsl\xfccken-Trends im Laufe der Zeit. Um mit einem Link in einem Diagramm-Popover zu interagieren, klicke zun\xe4chst, um das Popover anzuheften."],"SecurityReports|Operational vulnerabilities":["Betriebliche Sicherheitsl\xfccken"],"SecurityReports|Panels that categorize vulnerabilities as open include those with Needs triage or Confirmed status. Hover over the info icon (%{infoIcon}) to view more information about the data shown in each panel. To interact with a link in a chart popover, click to pin the popover first. To unstick it, click outside the popover. %{learnMoreStart}Learn more%{learnMoreEnd}":["Panels, die Sicherheitsl\xfccken als offen kategorisieren, enthalten auch solche mit dem Status \u201eTriage erforderlich\u201c oder \u201eBest\xe4tigt\u201c. Zeige mit der Maus auf das Infosymbol (%{infoIcon}), um weitere Informationen zu den Daten in den einzelnen Bereichen anzusehen. Um mit einem Link in einem Diagramm-Popover zu interagieren, klicke zun\xe4chst, um das Popover anzuheften. Klicke au\xdferhalb des Popovers, um das Anheften aufzuheben. %{learnMoreStart}Mehr erfahren%{learnMoreEnd}"],"SecurityReports|Parsing errors and warnings in pipeline":["Parsen von Fehlern und Warnungen in der Pipeline"],"SecurityReports|Parsing errors in pipeline":["Parsen von Fehlern in der Pipeline"],"SecurityReports|Parsing warnings in pipeline":["Parsen von Warnungen in der Pipeline"],"SecurityReports|Policy actions":["Richtlinienaktionen"],"SecurityReports|Policy violations":["Richtlinienverst\xf6\xdfe"],"SecurityReports|Possibly active secret":["M\xf6glicherweise aktives Geheimnis"],"SecurityReports|Project":["Projekt"],"SecurityReports|Project %{project}, risk score: %{riskScore}":["Projekt %{project}, Risikobewertung: %{riskScore}"],"SecurityReports|Project was not found or you do not have permission to add this project to Security Dashboards.":["Projekt wurde nicht gefunden oder du hast keine Berechtigung, dieses Projekt zu den Sicherheits-Dashboards hinzuzuf\xfcgen."],"SecurityReports|Projects added":["Hinzugef\xfcgte Projekte"],"SecurityReports|Reachability":["Erreichbarkeit"],"SecurityReports|Reachable:":["Erreichbar:"],"SecurityReports|Remove project from dashboard":["Projekt aus dem Dashboard entfernen"],"SecurityReports|Report Type":["Berichtstyp"],"SecurityReports|Report export in progress. After the report is generated, an email will be sent with the download link.":["Der Export des Berichts l\xe4uft. Nachdem der Bericht erstellt wurde, wird eine E-Mail mit dem Download-Link gesendet."],"SecurityReports|Report has expired":["Bericht ist abgelaufen"],"SecurityReports|Report type":["Berichtstyp"],"SecurityReports|Results show vulnerability findings from the latest successful %{helpPageLinkStart}pipeline%{helpPageLinkEnd}.":["Die Ergebnisse zeigen Sicherheitsl\xfccken aus der neuesten erfolgreichen %{helpPageLinkStart}Pipeline%{helpPageLinkEnd}."],"SecurityReports|Risk score":["Risikobewertung"],"SecurityReports|Risk score formula":["Formel f\xfcr Risikobewertung"],"SecurityReports|Scan details":["Scan-Details"],"SecurityReports|Scanner":["Scanner"],"SecurityReports|Security dashboard":["Sicherheits-Dashboard"],"SecurityReports|Security scans have run":["Sicherheitsscans wurden ausgef\xfchrt"],"SecurityReports|Select a project to add by using the project search field above.":["W\xe4hle oben im Suchfeld ein Projekt aus, das du hinzuf\xfcgen m\xf6chtest."],"SecurityReports|Select a ref":["Ref ausw\xe4hlen"],"SecurityReports|Select action":["Aktion ausw\xe4hlen"],
"SecurityReports|Select dismissal reason":["Ablehnungsgrund ausw\xe4hlen"],"SecurityReports|Select project":["Projekt ausw\xe4hlen"],"SecurityReports|Select severity":["Schweregrad ausw\xe4hlen"],"SecurityReports|Select status":["Status ausw\xe4hlen"],"SecurityReports|Send as CSV to email":["Als CSV an E-Mail-Adresse senden"],"SecurityReports|Severity":["Schweregrad"],"SecurityReports|Show %d item":["%d\xa0Element anzeigen","%d\xa0Elemente anzeigen"],"SecurityReports|Solution available":["L\xf6sung verf\xfcgbar"],"SecurityReports|Sometimes a scanner can't determine a finding's severity. Those findings may still be a potential source of risk though. Please review these manually.":["Manchmal kann ein Scanner den Schweregrad eines Fundes nicht bestimmen. Diese Funde k\xf6nnen dennoch eine potenzielle Risikoquelle darstellen. Bitte \xfcberpr\xfcfe diese manuell."],"SecurityReports|Sorry, your filter produced no results":["Leider hat dein Filter keine Ergebnisse geliefert"],"SecurityReports|Starting 2025-05-15, we will gradually migrate vulnerabilities that have not been updated in the last 12 months to the vulnerability archive. Archived vulnerabilities are stored for 3 years before deletion. To access the archive, on the left sidebar, select Secure &gt; Security Configuration &gt; Vulnerability Management.":["Ab dem 15.05.2025 migrieren wir schrittweise Sicherheitsl\xfccken, die in den letzten 12\xa0Monaten nicht aktualisiert wurden, in das Sicherheitsl\xfcckenarchiv. Archivierte Sicherheitsl\xfccken werden drei Jahre lang gespeichert und anschlie\xdfend gel\xf6scht. Um auf das Archiv zuzugreifen, w\xe4hle in der linken Seitenleiste \u201eSch\xfctzen &gt; Sicherheitskonfiguration &gt; Sicherheitsl\xfcckenmanagement\u201c."],"SecurityReports|Starting in GitLab 18.8 (available January 2026) on GitLab.com and in GitLab 18.9 (available February 2026) on GitLab Self-Managed and GitLab Dedicated, the Vulnerabilities over time chart excludes no longer detected vulnerabilities. This change might result in a drop in the total number of vulnerabilities shown in the chart. %{linkStart}Learn more%{linkEnd}":["Ab GitLab\xa018.8 (verf\xfcgbar ab Januar\xa02026) auf GitLab.com bzw. ab GitLab\xa018.9 (verf\xfcgbar ab Februar\xa02026) in GitLab Self-Managed oder GitLab Dedicated werden nicht mehr erkannte Sicherheitsl\xfccken aus dem Diagramm \u201eSicherheitsl\xfccken im Laufe der Zeit\u201c ausgeschlossen. Diese \xc4nderung kann dazu f\xfchren, dass im Diagramm insgesamt weniger Sicherheitsl\xfccken angezeigt werden. %{linkStart}Mehr erfahren%{linkEnd}"],"SecurityReports|Status":["Status"],"SecurityReports|Still detected":["Immer noch erkannt"],"SecurityReports|Submit vulnerability":["Sicherheitsl\xfccke absenden"],"SecurityReports|Tags":["Tags"],'SecurityReports|The Activity filter now defaults to showing only vulnerabilities that are "still detected". To see vulnerabilities regardless of their detection status, remove this filter.':["Der Aktivit\xe4tsfilter zeigt jetzt standardm\xe4\xdfig nur noch Sicherheitsl\xfccken an, die \u201enoch erkannt\u201c werden. Entferne diesen Filter, um Sicherheitsl\xfccken unabh\xe4ngig von ihrem Erkennungsstatus anzuzeigen."],"SecurityReports|The Vulnerability Report shows results of successful scans on your project's default branch, manually added vulnerability records, and vulnerabilities found from scanning operational environments. %{linkStart}Learn more%{linkEnd}.":["Der Sicherheitsl\xfcckenbericht zeigt die Ergebnisse erfolgreicher Scans im Standardbranch deines Projekts, manuell hinzugef\xfcgte Sicherheitsl\xfcckendatens\xe4tze und Sicherheitsl\xfccken, die beim Scannen von Betriebsumgebungen gefunden wurden. %{linkStart}Mehr erfahren%{linkEnd}."],"SecurityReports|The following SBOM reports could not be parsed. Therefore the list of reported vulnerabilities may be incomplete.":["Die folgenden SBOM-Berichte konnten nicht geparst werden. Daher ist die Liste der gemeldeten Sicherheitsl\xfccken m\xf6glicherweise unvollst\xe4ndig."],"SecurityReports|The following security reports contain one or more vulnerability findings that could not be parsed and were not recorded. To investigate a report, download the artifacts in the job output. Ensure the security report conforms to the relevant %{helpPageLinkStart}JSON schema%{helpPageLinkEnd}.":["Die folgenden Sicherheitsberichte enthalten eine oder mehrere Sicherheitsl\xfccken, die nicht geparst werden konnten und nicht aufgezeichnet wurden. Lade die Artefakte in der Jobausgabe herunter, um einen Bericht zu untersuchen. Stelle sicher, dass der Sicherheitsbericht dem entsprechenden %{helpPageLinkStart}JSON-Schema%{helpPageLinkEnd} entspricht."],"SecurityReports|The security report for this pipeline has %{helpPageLinkStart}expired%{helpPageLinkEnd}. Re-run the pipeline to generate a new security report.":["Der Sicherheitsbericht f\xfcr diese Pipeline ist %{helpPageLinkStart}abgelaufen%{helpPageLinkEnd}. F\xfchre die Pipeline erneut aus, um einen neuen Sicherheitsbericht zu erstellen."],"SecurityReports|There was an error creating a Jira issue for the finding. Please try again.":["Beim Erstellen eines Jira-Tickets f\xfcr dieses Ergebnis ist ein Fehler aufgetreten. Bitte versuche es erneut."],"SecurityReports|There was an error creating the issue. Please try again.":["Beim Erzeugen des Tickets ist ein Fehler aufgetreten. Bitte versuche es erneut."],"SecurityReports|There was an error creating the merge request. Please try again.":["Beim Erstellen des Merge Request ist ein Fehler aufgetreten. Bitte versuche es erneut."],"SecurityReports|There was an error dismissing the finding. Please try again.":["Fehler beim Verwerfen des Funds. Versuche es erneut."],"SecurityReports|There was an error fetching the finding. Please try again.":["Fehler beim Abrufen des Funds. Versuche es erneut."],"SecurityReports|There was an error fetching the finding. The security report for this pipeline may have expired. To generate a new security report, go the %{boldStart}Pipelines%{boldEnd} tab and run a pipeline.":["Beim Abrufen des Ergebnisses ist ein Fehler aufgetreten. Der Sicherheitsbericht f\xfcr diese Pipeline ist m\xf6glicherweise abgelaufen. Um einen neuen Sicherheitsbericht zu erstellen, gehe auf die Registerkarte %{boldStart}Pipelines%{boldEnd} und f\xfchre eine Pipeline aus."],"SecurityReports|There was an error fetching the identifiers for this project. Please try again later.":["Beim Abrufen der Kennungen f\xfcr dieses Projekt ist ein Fehler aufgetreten. Bitte versuche es sp\xe4ter erneut."],"SecurityReports|There was an error reverting the dismissal.":["Verwerfungsvorgang konnte nicht r\xfcckg\xe4ngig gemacht werden."],"SecurityReports|There was an error while generating the report.":["Fehler beim Erstellen des Berichts"],"SecurityReports|This project has reached the maximum number of vulnerabilities it can contain and some of the vulnerabilities couldn't be ingested.":["Dieses Projekt hat die maximale Anzahl an Sicherheitsl\xfccken erreicht, die es enthalten kann. Einige der Sicherheitsl\xfccken konnten nicht aufgenommen werden."],"SecurityReports|This project has reached the maximum number of vulnerabilities it can contain. New vulnerabilities will not be created.":["Dieses Projekt hat die maximale Anzahl an Sicherheitsl\xfccken erreicht, die es enthalten kann. Es werden keine neuen Sicherheitsl\xfccken erstellt."],"SecurityReports|This project is reaching the maximum number of vulnerabilities it can contain.":["Dieses Projekt erreicht die maximale Zahl an Sicherheitsl\xfccken, die es enthalten kann."],"SecurityReports|This selection is required.":["Diese Auswahl ist erforderlich."],"SecurityReports|Time period":["Zeitraum"],"SecurityReports|To widen your search, change or remove filters above":["Um deine Suche zu erweitern, \xe4nder oder entferne die obigen Filter."],"SecurityReports|Tool":["Tool"],"SecurityReports|Total number of %{boldStart}open%{boldEnd} %{severity} vulnerabilities and their median amount of time open. Select the number to see the open vulnerabilities in the vulnerability report.":["Gesamtzahl der Sicherheitsl\xfccken mit %{boldStart}offenem%{boldEnd} %{severity} und der Median-Wert der Zeit, die sie offen waren. W\xe4hlen die Nummer aus, um die offenen Sicherheitsl\xfccken im Sicherheitsl\xfcckenbericht anzuzeigen."],"SecurityReports|Total number of %{boldStart}open%{boldEnd} %{severity} vulnerabilities. Select the number to see the open vulnerabilities in the vulnerability report.":["Gesamtzahl der Sicherheitsl\xfccken mit %{boldStart}offenem%{boldEnd} %{severity}. W\xe4hle die Nummer aus, um die offenen Sicherheitsl\xfccken im Sicherheitsl\xfcckenbericht anzuzeigen."],"SecurityReports|Tracked ref":["Nachverfolgte Ref"],"SecurityReports|Unable to add %{invalidProjectsMessage}: %{errorMessage}":["Konnte nicht hinzugef\xfcgt werden %{invalidProjectsMessage}: %{errorMessage}"],"SecurityReports|Undo dismiss":["Verwerfen r\xfcckg\xe4ngig machen"],"SecurityReports|Validity check":["G\xfcltigkeitspr\xfcfung"],"SecurityReports|Validity check couldn't confirm whether the secret is active or inactive.":["Die G\xfcltigkeitspr\xfcfung konnte nicht best\xe4tigen, ob das Geheimnis aktiv oder inaktiv ist."],"SecurityReports|Vulnerabilities by age":["Sicherheitsl\xfccken nach Alter"],"SecurityReports|Vulnerabilities over time":["Sicherheitsl\xfccken im Laufe der Zeit"],"SecurityReports|Vulnerability Resolution available":["Vulnerability Resolution verf\xfcgbar"],"SecurityReports|Vulnerability Resolution unavailable":["Vulnerability Resolution nicht verf\xfcgbar"],"SecurityReports|Vulnerability report":["Sicherheitsl\xfcckenbericht"],"SecurityReports|Vulnerability will be archived on %{date}":["Sicherheitsl\xfccke wird am %{date} archiviert"],"SecurityReports|Warning parsing security reports":["Warnung beim Parsen von Sicherheitsberichten"],"SecurityReports|Yes":["Ja"],"SecurityReports|Your environment does not have advanced vulnerability management enabled which limits some functionality. %{linkStart}How do I enable advanced vulnerability management?%{linkEnd}":["Das erweiterte Sicherheitsl\xfcckenmanagement ist in deiner Umgebung nicht aktiviert, daher ist nicht der komplette Funktionsumfang verf\xfcgbar. %{linkStart}Wie aktiviere ich das erweiterte Sicherheitsl\xfcckenmanagement?%{linkEnd}"],"SecurityReports|scanned resources":["gescannte Ressourcen"],"SecurityReports|security scanning prerequisites":["Voraussetzungen f\xfcr Sicherheitsscans"],"SecurityTrackedRefs|%{selectedRefsCount} refs selected of %{availableSpots} spots available":["%{selectedRefsCount}\xa0Refs ausgew\xe4hlt von %{availableSpots}\xa0verf\xfcgbaren Spots"],"SecurityTrackedRefs|Archive associated vulnerabilities":["Zugeh\xf6rige Schwachstellen archivieren"],"SecurityTrackedRefs|Are you sure you want to remove tracking from this %{refType}?":["M\xf6chtest du die Nachverfolgung wirklich von diesem %{refType} entfernen?"],"SecurityTrackedRefs|Could not fetch available refs. Please try again later.":["Verf\xfcgbare Refs konnten nicht abgerufen werden. Versuche es sp\xe4ter erneut."],"SecurityTrackedRefs|Could not remove tracked ref. Please refresh the page, or try again later.":["Verfolgte Ref konnten nicht abgerufen werden. Aktualisiere die Seite oder versuche es sp\xe4ter erneut."],"SecurityTrackedRefs|Could not search refs. Please try again later.":["Refs konnten nicht gesucht werden. Versuche es sp\xe4ter erneut."],"SecurityTrackedRefs|Could not track refs. Please refresh the page, or try again later.":["Refs konnten nicht verfolgt werden. Aktualisiere die Seite oder versuche es sp\xe4ter erneut."],"SecurityTrackedRefs|Currently tracked refs":["Derzeit nachverfolgte Refs"],"SecurityTrackedRefs|If you do not archive associated vulnerabilities, the data for %{count} vulnerability will be permanently deleted.":["Wenn du zugeh\xf6rige Schwachstellen nicht archivierst, werden die Daten f\xfcr %{count} Schwachstelle dauerhaft gel\xf6scht.","Wenn du zugeh\xf6rige Schwachstellen nicht archivierst, werden die Daten f\xfcr %{count} Schwachstellen dauerhaft gel\xf6scht."],"SecurityTrackedRefs|Loading tracked refs. Please wait.":["Verfolgte Refs werden geladen. Bitte warten."],"SecurityTrackedRefs|Maximum number of tracked refs reached. Remove a ref to track a new one.":["Obergrenze f\xfcr verfolgte Refs erreicht. Entferne eine Ref, um eine neue zu verfolgen."],"SecurityTrackedRefs|Most recently updated":["Zuletzt aktualisiert"],"SecurityTrackedRefs|No refs available":["Keine Refs verf\xfcgbar"],"SecurityTrackedRefs|Remove %{refName}":["%{refName} entfernen"],"SecurityTrackedRefs|Remove ref tracking":["Nachverfolgung von Refs entfernen"],"SecurityTrackedRefs|Remove tracking":["Nachverfolgung entfernen"],"SecurityTrackedRefs|Remove tracking for %{refType}":["Nachverfolgung f\xfcr %{refType} entfernen"],"SecurityTrackedRefs|Search branches and tags (enter at least 3 characters)":["Branches und Tags durchsuchen (mindestens 3 Zeichen eingeben)"],'SecurityTrackedRefs|Search results for "%{searchTerm}"':["Suchergebnisse f\xfcr \u201e%{searchTerm}\u201c"],"SecurityTrackedRefs|The default ref cannot be removed from being tracked":["Die Nachverfolgung f\xfcr die Standard-Ref kann nicht entfernt werden."],"SecurityTrackedRefs|There are no refs available to track.":["Es sind keine zu verfolgenden Refs vorhanden."],"SecurityTrackedRefs|Track new ref(s)":["Neue Ref(s) nachverfolgen"],"SecurityTrackedRefs|Track ref(s)":["Ref(s) nachverfolgen"],"SecurityTrackedRefs|Tracking refs in progress. Please wait.":["Refs werden verfolgt. Bitte warten."],"SecurityTrackedRefs|You can remove tracked refs in the Configuration page.":["Du kannst verfolgte Refs auf der Konfigurationsseite entfernen."],"SecurityTrackedRefs|branch":["Branch"],"SecurityTrackedRefs|default":["Standard"],"SecurityTrackedRefs|open vulnerability":["offene Schwachstelle","offene Schwachstellen"],"SecurityTrackedRefs|tag":["Tag"],"SecurityTraining|Primary Training":["Basisschulung"],"SecurityTraining|Training from this partner takes precedence when more than one training partner is enabled.":["Die Schulung von diesem Partner hat Vorrang, wenn mehr als ein Schulungspartner aktiviert ist."],"SecurityTxt|Add security contact information":["Sicherheitskontaktdaten hinzuf\xfcgen"],"SecurityTxt|Configure a %{codeOpen}security.txt%{codeClose} file.":["Datei %{codeOpen}security.txt%{codeClose} konfigurieren."],"SecurityTxt|Content for security.txt":["Inhalt f\xfcr security.txt"],"SecurityTxt|When present, this will be publicly available at %{codeOpen}https://gitlab.example.com/.well-known/security.txt%{codeClose}. Maximum 2048 characters.":["Falls vorhanden, wird diese \xf6ffentlich unter %{codeOpen}https://gitlab.example.com/.well-known/security.txt%{codeClose} verf\xfcgbar sein. Maximal 2048\xa0Zeichen."],"See example DevOps Score page in our documentation.":["Siehe Beispiel DevOps Score-Seite in unserer Dokumentation."],"See examples.":["Siehe Beispiele."],"See our website for help":["Hilfe findest du auf unserer Website"],"See the Geo troubleshooting documentation to learn more: %{docs_url}":["Sieh dir die Dokumentation zur Geo-Fehlerbehebung an, um mehr zu erfahren: %{docs_url}"],"See the affected projects in the GitLab admin panel":["Betroffene Projekte im GitLab-Adminbereich anzeigen"],"See usage statistics":["Nutzungsstatistiken anzeigen"],"See vulnerability %{vulnerability_link} for any Remediation details.":["Weitere Informationen zur Behebung findest du unter Sicherheitsl\xfccken %{vulnerability_link}."],"See vulnerability %{vulnerability_link} for any Solution details.":["Weitere Informationen zur L\xf6sung findest du unter Sicherheitsl\xfccken %{vulnerability_link}."],Select:["Ausw\xe4hlen"],"Select %{strongStart}Delete%{strongEnd}.":["W\xe4hle %{strongStart}L\xf6schen%{strongEnd} aus."],"Select Delete.":["W\xe4hle \u201eL\xf6schen\u201c aus."],"Select Git revision":["W\xe4hle eine Git-Revision"],"Select Profile":["W\xe4hle ein Profil"],"Select a LDAP group":["LDAP-Gruppe w\xe4hlen"],"Select a branch":["Branch ausw\xe4hlen"],"Select a branch to compare":["W\xe4hle einen branch zum vergleichen aus"],"Select a cluster management project":["Clustermanagement-Projekt ausw\xe4hlen"],"Select a color":["W\xe4hle eine Farbe aus"],"Select a color from the color picker or from the presets below.":["W\xe4hle eine Farbe aus der Farbauswahl oder aus den Voreinstellungen unten aus."],"Select a comment template":["W\xe4hle eine Kommentarvorlage aus"],"Select a country or region":["Land oder Region ausw\xe4hlen"],"Select a day":["Tag ausw\xe4hlen"],"Select a default search scope. For the system default, a scope is selected automatically based on context and availability.":["W\xe4hle einen standardm\xe4\xdfigen Suchbereich aus. F\xfcr den Systemstandard wird ein Bereich automatisch auf Basis von Kontext und Verf\xfcgbarkeit ausgew\xe4hlt."],"Select a group":["W\xe4hle eine Gruppe"],"Select a group to create, distribute, and manage compliance frameworks and security polices for this GitLab instance. You should select a group without existing compliance frameworks.":["W\xe4hle eine Gruppe zum Erstellen, Verteilen und Verwalten von Konformit\xe4tsframeworks und Sicherheitsrichtlinien f\xfcr diese GitLab-Instanz aus. W\xe4hle eine Gruppe ohne bestehende Konformit\xe4tsframeworks aus."],"Select a label":["Ein Label ausw\xe4hlen"],"Select a merge moment":["Zusammenf\xfchrungszeitpunkt ausw\xe4hlen"],"Select a milestone":["Einen Meilenstein ausw\xe4hlen"],"Select a new namespace":["Neuen Namensraum ausw\xe4hlen"],"Select a project":["W\xe4hle ein Projekt aus"],"Select a reason":["Grund ausw\xe4hlen"],"Select a repository containing templates for common files.":["W\xe4hle ein Repository aus, das Vorlagen f\xfcr g\xe4ngige Dateien enth\xe4lt."],"Select a status to use for each current status. Items using these statuses will automatically be updated to the new status.":["W\xe4hle einen Status aus, der f\xfcr jeden aktuellen Status angezeigt werden soll. Elemente, die diese Status verwenden, werden automatisch auf den neuen Status aktualisiert."],"Select a template repository":["W\xe4hle ein Vorlagen-Repository aus"],"Select a valid target branch.":["W\xe4hle einen g\xfcltigen Ziel-Branch aus."],"Select action":["Aktion ausw\xe4hlen"],"Select all":["Alles ausw\xe4hlen"],"Select all items":["Alle Elemente ausw\xe4hlen"],"Select all vulnerabilities on current page":["Alle Sicherheitsl\xfccken auf der aktuellen Seite ausw\xe4hlen"],"Select an assignee":["Beauftragte(n) ausw\xe4hlen"],"Select an iteration":["W\xe4hle eine Iteration aus"],"Select an option":["W\xe4hle eine Option aus"],"Select artifacts":["Artefakt ausw\xe4hlen"],"Select assignee":["Beauftragte(n) ausw\xe4hlen"],"Select assignees":["Beauftragte ausw\xe4hlen"],"Select branch":["Branch ausw\xe4hlen"],"Select branch or create wildcard":["Branch ausw\xe4hlen oder Wildcard erstellen"],"Select branches":["Branches ausw\xe4hlen"],"Select color":["W\xe4hle eine Farbe aus"],"Select confidentiality":["Vertraulichkeit ausw\xe4hlen"],"Select default branch":["Standard-Branch ausw\xe4hlen"],"Select due date":["F\xe4lligkeitsdatum festlegen"],"Select environment or create wildcard":["Umgebung ausw\xe4hlen oder Wildcard erstellen"],"Select group":["Gruppe ausw\xe4hlen"],"Select group or project":["Gruppe oder Projekt ausw\xe4hlen"],"Select groups":["Gruppen ausw\xe4hlen"],"Select health status":["Integrit\xe4tsstatus ausw\xe4hlen"],"Select item":["Element ausw\xe4hlen"],"Select iteration":["Iteration ausw\xe4hlen"],"Select label":["Etikett ausw\xe4hlen"],"Select labels":["Etiketts ausw\xe4hlen"],"Select labels (optional)":["Label ausw\xe4hlen (optional)"],"Select language":["Sprache ausw\xe4hlen"],"Select merge moment":["Zusammenf\xfchrungszeitpunkt ausw\xe4hlen"],"Select milestone":["Meilenstein ausw\xe4hlen"],"Select organizations":["Organisationen ausw\xe4hlen"],"Select private project":["Privates Projekt ausw\xe4hlen"],"Select project":["Projekt ausw\xe4hlen"],"Select project to create %{type}":["Projekt ausw\xe4hlen und %{type} erstellen"],"Select projects":["Projekte ausw\xe4hlen"],"Select protected branch":["Gesch\xfctzten Branch ausw\xe4hlen"],"Select protected branches":["Gesch\xfctzte Branches ausw\xe4hlen"],"Select report":["Bericht ausw\xe4hlen"],"Select reviewer":["Pr\xfcfer(in) ausw\xe4hlen"],"Select reviewers":["Pr\xfcfer ausw\xe4hlen"],"Select severity (optional)":["Schweregrad ausw\xe4hlen (optional)"],"Select source":["Quelle ausw\xe4hlen"],"Select source branch":["Quellbranch ausw\xe4hlen"],"Select source project":["W\xe4hle ein Quellprojekt aus"],"Select start date":["Startdatum ausw\xe4hlen:"],"Select state":["Status w\xe4hlen"],"Select status":["Status ausw\xe4hlen"],"Select strategy activation method":["Aktivierungsmethode f\xfcr die Strategie ausw\xe4hlen"],"Select subgroup":["Untergruppe ausw\xe4hlen"],"Select subscription":["Abonnement ausw\xe4hlen"],"Select tags":["Tags ausw\xe4hlen"],"Select target branch":["Zielbranch ausw\xe4hlen"],"Select target branch or tag":["Zielbranch oder -Tag ausw\xe4hlen"],"Select target project":["W\xe4hle ein Zielprojekt aus"],"Select the focused file or directory":["Fokussierte Datei oder Verzeichnis ausw\xe4hlen"],"Select timezone":["Zeitzone w\xe4hlen"],"Select type":["Typ ausw\xe4hlen"],"Select vulnerability":["Sicherheitsl\xfccke ausw\xe4hlen"],Selected:["Ausgew\xe4hlt"],"Selected commits":["Ausgew\xe4hlte Commits"],"Selected database":["Ausgew\xe4hlte Datenbank"],"Selected for all items.":["F\xfcr alle Elemente ausgew\xe4hlt."],"Selected for some items.":["F\xfcr einige Elemente ausgew\xe4hlt."],"Selected tag is already in use. Choose another option.":["Das ausgew\xe4hlte Tag wird bereits verwendet. W\xe4hle eine andere Option aus."],'Selecting a GitLab user will add a link to the GitLab user in the descriptions of issues and comments (e.g. "By %{link_open}@johnsmith%{link_close}"). It will also associate and/or assign these issues and comments with the selected user.':["W\xe4hle eine(n) GitLab-Benutzer(in) aus, um einen Link zum GitLab-Benutzer/zur GitLab-Benutzerin in den Beschreibungen von Tickets und Kommentaren einzuf\xfcgen (z.\xa0B. \u201eVon %{link_open}@beispielname%{link_close}\u201c). Au\xdferdem werden die entsprechenden Tickets und Kommentare mit dem ausgew\xe4hlten Benutzer/der ausgew\xe4hlten Benutzerin verkn\xfcpft bzw. der Person zugewiesen."],"Self hosted AI Gateway URL is not set. It can be changed in the Gitlab Duo configuration.":["Die URL des selbst gehosteten KI-Gateways ist nicht festgelegt. Sie kann in der GitLab Duo-Konfiguration ge\xe4ndert werden."],"Self hosted AI Gateway URL is set to %{url}. It can be changed in the Gitlab Duo configuration.":["Die URL des selbst gehosteten KI-Gateways festgelegt auf %{url}. Sie kann in der GitLab Duo-Konfiguration ge\xe4ndert werden."],"Semantic search":["Semantische Suche"],"Semantic search will be disabled soon.":["Die semantische Suche wird demn\xe4chst deaktiviert."],"SemanticSearch|Connect a vector store to index and store embeddings.":[""],"SemanticSearch|Current status of the semantic code search.":[""],"SemanticSearch|Disabled":[""],"SemanticSearch|Enabled":[""],"SemanticSearch|Status":[""],"SemanticSearch|Vector storage":[""],Send:["Senden"],"Send a single email notification to Owners and Maintainers for new alerts.":["Eine einzelne E-Mail-Benachrichtigung an Eigent\xfcmer(innen) und Betreuer(innen) f\xfcr neue Benachrichtigungen senden."],"Send email in multipart format (HTML and plain text). Uncheck to send email messages in plain text only.":["Sende E-Mails im mehrteiligen Format (HTML und Klartext). Deaktiviere diese Option, um E-Mail-Nachrichten nur im Klartext zu senden."],"Send email notification":["E-Mail-Benachrichtigung senden"],"Send emails to users upon account deactivation.":["Sende E-Mails an Benutzer(innen) nach der Deaktivierung des Kontos."],"Send message":["Nachricht senden"],"Send notifications about project events to Mattermost channels.":["Sende Benachrichtigungen \xfcber Projektereignisse an die Mattermost-Kan\xe4le."],"Send notifications for broken pipelines.":["Benachrichtigungen f\xfcr fehlerhafte Pipelines senden."],"Send notifications for the default branch.":["Benachrichtigungen f\xfcr die Standardbranch senden"],"Send notifications only when the pipeline status changes.":["Benachrichtigungen nur senden, wenn sich der Pipeline-Status \xe4ndert."],"Send report":["Bericht senden"],"Send service data":["Dienstdaten senden"],Sentry:["Sentry"],"Sentry API URL":["Sentry API URL"],"Sentry event":["Sentry Ereignis"],"Sentry issue not found.":["Sentry-Ticket nicht gefunden."],Sep:["Sept"],September:["September"],"SeriesFinalConjunction|and":["und"],"Serve repository static objects (for example, archives and blobs) from external storage.":["Bereitstellung von statischen Repository-Objekten (z.\xa0B. Archive und Blobs) aus einem externen Speicher."],"Server (optional)":["Server (optional)"],"Server supports batch API only, please update your Git LFS client to version 1.0.1 and up.":["Server unterst\xfctzt nur Batch-API, bitte aktualisiere deinen Git LFS-Client auf Version 1.0.1 oder h\xf6her."],"Server version":["Serverversion"],Service:["Dienst"],"Service Account":["Dienstkonto"],"Service Account Key":["Dienstkontoschl\xfcssel"],"Service Accounts keys authorize GitLab to deploy your Google Cloud project":["Dienstkontenschl\xfcssel autorisieren GitLab zur Bereitstellung deines Google Cloud-Projekts"],"Service Desk":["Service-Desk"],"Service Desk Ticket":["Service-Desk-Ticket"],"Service account":["Dienstkonto"],"Service account creation":["Erstellung eines Dienstkontos"],"Service account generated successfully":["Dienstkonto erfolgreich erstellt"],"Service account was successfully updated.":["Das Dienstkonto wurde erfolgreich aktualisiert."],"Service accounts":["Dienstkonten"],"ServiceAccounts|%{email} - unconfirmed":["%{email} \u2013 unbest\xe4tigt"],"ServiceAccounts|Add service account":["Dienstkonto hinzuf\xfcgen"],"ServiceAccounts|An error occurred creating the service account.":["Beim Erstellen des Dienstkontos ist ein Fehler aufgetreten."],"ServiceAccounts|An error occurred updating the service account.":["Beim Aktualisieren des Dienstkontos ist ein Fehler aufgetreten."],"ServiceAccounts|An error occurred while deleting the service account.":["Beim L\xf6schen des Dienstkontos ist ein Fehler aufgetreten."],"ServiceAccounts|An error occurred while fetching the service accounts.":["Ein Fehler ist w\xe4hrend des Abrufens der Dienstkonten aufgetreten."],"ServiceAccounts|Delete account":["Konto l\xf6schen"],"ServiceAccounts|Delete account and contributions":["Konto und Beitr\xe4ge l\xf6schen"],"ServiceAccounts|Edit":["Bearbeiten"],"ServiceAccounts|Manage access tokens":["Zugriffstoken verwalten"],"ServiceAccounts|Name":["Name"],"ServiceAccounts|No service accounts":["Keine Dienstkonten"],"ServiceAccounts|Personal access tokens":["Pers\xf6nliche Zugriffstoken"],"ServiceAccounts|Service accounts":["Dienstkonten"],"ServiceAccounts|Service accounts are non-human accounts that allow interactions between software applications, systems, or services. %{learnMore}":["Dienstkonten sind nicht-menschliche Konten, die Interaktionen zwischen Softwareanwendungen, Systemen oder Diensten erm\xf6glichen. %{learnMore}"],"ServiceAccounts|The service account is being deleted.":["Das Dienstkonto wird gel\xf6scht."],"ServiceAccounts|The service account was created.":["Das Dienstkonto wurde erstellt."],"ServiceAccounts|The service account was updated.":["Das Dienstkonto wurde aktualisiert."],"ServiceAccount|Group ID provided does not match the service account's group ID.":["Die angegebene Gruppen-ID stimmt nicht mit der Gruppen-ID des Dienstkontos \xfcberein."],"ServiceAccount|Group with the provided ID not found.":["Die Gruppe mit der angegebenen ID konnte nicht gefunden werden."],"ServiceAccount|No more seats are available to create Service Account User":["Keine weiteren Pl\xe4tze verf\xfcgbar, um eine(n) Dienstkontobenutzer(in) zu erstellen"],"ServiceAccount|Project ID provided does not match the service account's project ID.":["Die angegebene Projekt-ID stimmt nicht mit der Projekt-ID des Dienstkontos \xfcberein."],"ServiceAccount|Project with the provided ID not found.":["Das Projekt mit der angegebenen ID konnte nicht gefunden werden."],"ServiceAccount|User does not have permission to create a service account in this %{resource_type}.":["Der/die Benutzer(in) ist nicht berechtigt, ein Dienstkonto in diesem %{resource_type} zu erstellen."],"ServiceAccount|User does not have permission to create a service account.":["Der/die Benutzer(in) ist nicht berechtigt, ein Dienstkonto zu erstellen."],"ServiceAccount|User does not have permission to delete a service account.":["Der/die Benutzer(in) ist nicht berechtigt, ein Dienstkonto zu erstellen."],"ServiceAccount|User does not have permission to update a service account.":["Der/die Benutzer(in) ist nicht berechtigt, ein Dienstkonto zu aktualisieren."],"ServiceAccount|User is not a service account":["Benutzer(in) ist kein Dienstkonto."],"ServiceAccount|You are not authorized to update service accounts in this namespace.":["Du bist nicht berechtigt, Dienstkonten in diesem Namensraum zu aktualisieren."],"ServiceDesk|%{customEmail} with SMTP host %{smtpAddress} is %{badgeStart}verified%{badgeEnd}":["%{customEmail} mit SMTP-Host %{smtpAddress} ist %{badgeStart}verifiziert%{badgeEnd}"],"ServiceDesk|A connection to the specified host could not be made or an SSL issue occurred.":["Es konnte keine Verbindung zum angegebenen Host hergestellt werden oder es ist ein SSL-Problem aufgetreten."],"ServiceDesk|A verification email has been sent to a sub-address of your custom email address. This can take up to 30 minutes. The screen refreshes automatically.":["Eine Best\xe4tigungs-E-Mail wurde an eine Unteradresse deiner benutzerdefinierten E-Mail-Adresse gesendet. Dies kann bis zu 30\xa0Minuten dauern. Der Bildschirm wird automatisch aktualisiert."],"ServiceDesk|Add email addresses in the %{codeStart}Cc%{codeEnd} header of Service Desk emails to the issue.":["E-Mail-Adressen im %{codeStart}Cc%{codeEnd}-Header der Service Desk-E-Mails dem Ticket hinzuf\xfcgen."],"ServiceDesk|Add external participants from the %{codeStart}Cc%{codeEnd} header":["Externe Teilnehmer aus dem %{codeStart}Cc%{codeEnd}-Header hinzuf\xfcgen"],"ServiceDesk|Any project member can view new tickets.":["Jedes Projektmitglied kann neue Tickets anzeigen."],"ServiceDesk|CRAM-MD5":["CRAM-MD5"],"ServiceDesk|Cannot convert issue to ticket because no email was provided or the format was invalid.":["Problem kann nicht in Ticket konvertiert werden, da keine E-Mail angegeben wurde oder das Format ung\xfcltig ist."],"ServiceDesk|Cannot convert to ticket because Service Desk is disabled.":["Kann in kein Ticket umgewandelt werden, da Service-Desk deaktiviert ist."],"ServiceDesk|Cannot convert to ticket because it is already a ticket.":["Kann nicht in Ticket konvertiert werden, da es bereits ein Ticket ist."],"ServiceDesk|Cannot create custom email":["Benutzerdefinierte E-Mail kann nicht erstellt werden"],"ServiceDesk|Cannot update custom email":["Benutzerdefinierte E-Mail kann nicht aktualisiert werden"],"ServiceDesk|Check your forwarding settings and make sure the original email sender remains in the From header.":["Pr\xfcfe deine Weiterleitungseinstellungen und stelle sicher, dass der urspr\xfcngliche E-Mail-Absender im Absender-Header verbleibt."],"ServiceDesk|Common ports are 587 when using TLS, and 25 when not.":["Standardports sind: 587 mit TLS und 25 ohne TLS."],"ServiceDesk|Configure a custom email address":["Konfiguriere eine benutzerdefinierte E-Mail-Adresse"],"ServiceDesk|Connect a custom email address your customers can use to create Service Desk issues. Forward all emails from your custom email address to the Service Desk email address of this project. GitLab will send Service Desk emails from the custom address on your behalf using your SMTP credentials. %{linkStart}Learn more about prerequisites and the verification process%{linkEnd}.":["Verkn\xfcpfe eine benutzerdefinierte E-Mail-Adresse, mit der deine Kunden Service-Desk-Tickets erstellen k\xf6nnen. Leite alle E-Mails von deiner benutzerdefinierten E-Mail-Adresse an die Service-Desk-E-Mail-Adresse dieses Projekts weiter. GitLab sendet Service-Desk-E-Mails von der benutzerdefinierten Adresse in deinem Namen und mit deinen SMTP-Zugangsdaten. %{linkStart}Erfahre mehr \xfcber die Voraussetzungen und den Verifizierungsprozess%{linkEnd}."],"ServiceDesk|Convert issue to Service Desk ticket":["Problem in Service-Desk-Ticket umwandeln"],
"ServiceDesk|Converted issue to Service Desk ticket.":["Problem in Service-Desk-Ticket umgewandelt."],"ServiceDesk|Converts this issue to a Service Desk ticket.":["Konvertiert dieses Problem in ein Service-Desk-Ticket."],"ServiceDesk|Copy Service Desk email address":["Service-Desk-E-Mail-Adresse kopieren"],"ServiceDesk|Custom email address":["Benutzerdefinierte E-Mail-Adresse"],"ServiceDesk|Custom email address could not be verified.":["Die benutzerdefinierte E-Mail-Adresse konnte nicht verifiziert werden."],"ServiceDesk|Custom email address has already been verified.":["Die benutzerdefinierte E-Mail-Adresse wurde bereits verifiziert."],"ServiceDesk|Custom email address verification has already been processed and failed.":["Die \xdcberpr\xfcfung der benutzerdefinierten E-Mail-Adresse wurde bereits durchgef\xfchrt und ist fehlgeschlagen."],"ServiceDesk|Custom email already exists":["Die benutzerdefinierte E-Mail ist bereits vorhanden"],"ServiceDesk|Custom email disabled.":["Benutzerdefinierte E-Mail-Adresse ist deaktiviert."],"ServiceDesk|Custom email does not exist":["Die benutzerdefinierte E-Mail ist nicht vorhanden"],"ServiceDesk|Custom email enabled.":["Benutzerdefinierte E-Mail-Adresse ist aktiviert."],"ServiceDesk|Custom email is required and must be a valid email address.":["Die benutzerdefinierte E-Mail-Adresse ist erforderlich und muss ein g\xfcltiges Format besitzen."],"ServiceDesk|Email address your customers can use to send support requests. It must support sub-addressing.":["E-Mail-Adresse, an die deine Kunden Supportanfragen senden k\xf6nnen. Die Adresse muss Unteradressierung unterst\xfctzen."],"ServiceDesk|Enable Service Desk":["Service-Desk aktivieren"],"ServiceDesk|Enable custom email address":["Aktiviere benutzerdefinierte E-Mail-Adresse"],"ServiceDesk|External participants":["Externe Teilnehmer(innen)"],"ServiceDesk|Forward all emails to the custom email address to %{incomingEmail}.":["Leitet alle E-Mails an die benutzerdefinierte E-Mail-Adresse an %{incomingEmail} weiter."],"ServiceDesk|Incorrect From header":["Falscher Absender-Header"],"ServiceDesk|Incorrect forwarding target":["Falsches Weiterleitungsziel"],"ServiceDesk|Incorrect verification token":["Falsches Verifizierungstoken"],"ServiceDesk|Invalid credentials":["Ung\xfcltige Zugangsdaten"],"ServiceDesk|Keep custom email":["Benutzerdefinierte E-Mail-Adresse behalten"],"ServiceDesk|Let GitLab select a server-supported method (recommended)":["GitLab eine vom Server unterst\xfctzte Methode ausw\xe4hlen lassen (empfohlen)"],"ServiceDesk|Like the author, external participants receive Service Desk emails and can participate in the discussion.":["Wie der Autor erhalten auch externe Teilnehmer(innen) Service-Desk-E-Mails und k\xf6nnen an der Diskussion teilnehmen."],"ServiceDesk|Login":["Anmeldung"],"ServiceDesk|Minimum 8 characters long.":["Mindestens 8 Zeichen lang."],"ServiceDesk|New tickets are confidential by default":["Neue Tickets sind standardm\xe4\xdfig vertraulich"],"ServiceDesk|On public projects, tickets are always confidential by default.":["Bei \xf6ffentlichen Projekten sind Tickets standardm\xe4\xdfig immer vertraulich."],"ServiceDesk|Only project members with at least the Planner role can view new tickets.":["Nur Projektmitglieder mit mindestens der Rolle \u201ePlaner(in)\u201c k\xf6nnen neue Tickets anzeigen."],"ServiceDesk|Or reset and connect a new custom email address to this Service Desk.":["Oder setze eine neue benutzerdefinierte E-Mail-Adresse zur\xfcck und verbinde sie mit diesem Service-Desk."],"ServiceDesk|Parameters missing":["Parameter fehlen"],"ServiceDesk|Plain":["Einfach"],"ServiceDesk|Please share your feedback on this feature in the %{linkStart}feedback issue%{linkEnd}":["Bitte teile dein Feedback zu dieser Funktion im %{linkStart}Feedback-Ticket%{linkEnd}"],"ServiceDesk|Please try again. Check email forwarding settings and credentials, and then restart verification.":["Bitte erneut versuchen. \xdcberpr\xfcfe die Einstellungen und Zugangsdaten f\xfcr die E-Mail-Weiterleitung, und starte die Verifizierung erneut."],"ServiceDesk|Read timeout":["Zeit\xfcberschreitung beim Lesen"],"ServiceDesk|Reopen issues when an external participant comments":["Tickets erneut \xf6ffnen, wenn ein(e) externe(r) Teilnehmer(in) Kommentare hinzuf\xfcgt"],"ServiceDesk|Reset custom email":["Benutzerdefinierte E-Mail-Adresse zur\xfccksetzen"],"ServiceDesk|Reset custom email address and delete credentials":["Benutzerdefinierte E-Mail-Adresse zur\xfccksetzen und Zugangsdaten l\xf6schen"],"ServiceDesk|Reset custom email address.":["Benutzerdefinierte E-Mail-Adresse zur\xfccksetzen"],"ServiceDesk|SMTP address is required and must be resolvable.":["Die SMTP-Adresse ist erforderlich und muss aufl\xf6sbar sein."],"ServiceDesk|SMTP authentication method":["SMTP-Authentifizierungsmethode"],"ServiceDesk|SMTP host":["SMTP-Host"],"ServiceDesk|SMTP host issue":["SMTP-Host-Problem"],"ServiceDesk|SMTP password":["SMTP-Passwort"],"ServiceDesk|SMTP password is required and must be at least 8 characters long.":["Das SMTP-Passwort ist erforderlich und muss mindestens 8\xa0Zeichen lang sein."],"ServiceDesk|SMTP port":["SMTP-Port"],"ServiceDesk|SMTP port is required and must be a port number larger than 0.":["Der SMTP-Port ist erforderlich. Die Portnummer muss gr\xf6\xdfer als 0 sein."],"ServiceDesk|SMTP username":["SMTP-Benutzername"],"ServiceDesk|SMTP username is required.":["Der SMTP-Benutzername ist erforderlich."],"ServiceDesk|Save and test connection":["Verbindung speichern und testen"],"ServiceDesk|Saved custom email address and started verification.":["Benutzerdefinierte E-Mail-Adresse gespeichert und Verifizierung gestartet."],"ServiceDesk|Service Desk email address to forward emails to":["Service-Desk-E-Mail-Adresse, an die E-Mails weitergeleitet werden sollen"],"ServiceDesk|Service Desk setting missing":["Service-Desk-Einstellung fehlt"],"ServiceDesk|Service Desk setting or verification object missing":["Einstellung oder Verifizierungsobjekt fehlt"],"ServiceDesk|The SMTP server did not respond in time.":["Der SMTP-Server hat nicht rechtzeitig geantwortet."],"ServiceDesk|The given credentials (username and password) were rejected by the SMTP server, or you need to explicitly set an authentication method.":["Die angegebenen Zugangsdaten (Benutzername und Passwort) wurden vom SMTP-Server abgelehnt oder du musst explizit eine Authentifizierungsmethode festlegen."],"ServiceDesk|The received email didn't contain the verification token that was sent to your email address.":["Die empfangene E-Mail enthielt nicht das Verifizierungstoken, das an deine E-Mail-Adresse gesendet wurde."],"ServiceDesk|The verification email wasn't received in time. There is a 30 minutes timeframe for verification emails to appear in your instance's Service Desk. Make sure that you have set up email forwarding correctly.":["Die Verifizierungs-E-Mail wurde nicht rechtzeitig empfangen. Es braucht etwa 30\xa0Minuten, bis Verifizierungs-E-Mails im Service-Desk deiner Instanz erscheinen. Stelle sicher, dass du die E-Mail-Weiterleitung korrekt eingerichtet hast."],"ServiceDesk|This also adds an internal comment that mentions the assignees of the issue.":["Dadurch wird auch ein interner Kommentar hinzugef\xfcgt, in dem die Zust\xe4ndigen f\xfcr das Ticket erw\xe4hnt werden."],"ServiceDesk|This issue has been converted to a Service Desk ticket. The email address `%{email}` is the new author of this issue. GitLab didn't send a `thank_you` Service Desk email. The original author of this issue was `%{original_author}`.":["Dieses Problem wurde in ein Service-Desk-Ticket umgewandelt. Die E-Mail-Adresse `%{email}` ist der bzw. die neue Autor(in) dieses Problems. GitLab hat keine `thank_you`-Service-Desk-E-Mail gesendet. Der bzw. die urspr\xfcngliche Autor(in) dieses Tickets war `%{original_author}`."],"ServiceDesk|This issue has been reopened because it received a new comment from an external participant.":["Dieses Ticket wurde erneut ge\xf6ffnet, da es einen neuen Kommentar von einem externen Teilnehmer oder einer externen Teilnehmerin erhalten hat."],"ServiceDesk|Ticket visibility":["Ticket-Sichtbarkeit"],"ServiceDesk|Tickets created from Service Desk emails will appear here. Each comment becomes part of the email conversation.":["Aus Service-Desk-E-Mails erstellte Tickets werden hier angezeigt. Alle Kommentare werden in die E-Mail-Konversation aufgenommen."],"ServiceDesk|To use a custom email address for this Service Desk, you'll need to configure and verify an email address again.":["Um eine benutzerdefinierte E-Mail-Adresse f\xfcr diesen Service-Desk zu verwenden, musst du eine E-Mail-Adresse erneut konfigurieren und \xfcberpr\xfcfen."],"ServiceDesk|Use Service Desk to connect with your users and offer customer support through email right inside GitLab":["Verwende den Service-Desk, um dich mit deinen Benutzer(inne)n zu verbinden und Kundensupport per E-Mail direkt in GitLab anzubieten"],"ServiceDesk|User cannot manage project.":["Der/die Benutzer(in) darf das Projekt nicht verwalten."],"ServiceDesk|Verification email not received within timeframe":["Verifizierungs-E-Mail nicht innerhalb des Zeitrahmens erhalten"],"ServiceDesk|Verification failed":["\xdcberpr\xfcfung fehlgeschlagen"],"ServiceDesk|Verification started":["\xdcberpr\xfcfung gestartet"],"ServiceDesk|Verify %{customEmail} with SMTP host %{smtpAddress}:":["%{customEmail} mit SMTP-Host %{smtpAddress} verifizieren:"],"ServiceDesk|When enabled, Service Desk emails will be sent using the provided credentials.":["Wenn diese Option aktiviert ist, werden Service-Desk-E-Mails mit den angegebenen Zugangsdaten gesendet."],"ServiceDesk|You are about to %{strongStart}disable the custom email address%{strongEnd} %{customEmail} %{strongStart}and delete its credentials%{strongEnd}.":["Du bist dabei, die %{strongStart}benutzerdefinierte E-Mail-Adresse%{strongEnd} %{customEmail} %{strongStart}zu deaktivieren und ihre Zugangsdaten zu l\xf6schen%{strongEnd}."],"ServiceDesk|Your users can send emails to this address:":["Deine Benutzer(innen) k\xf6nnen E-Mails an diese Adresse senden:"],"ServicePing|Service ping is off":["Service Ping ist ausgeschaltet"],"ServicePing|This can be changed at any time in %{link_start}your settings%{link_end}.":["Dies kann jederzeit in %{link_start}deinen Einstellungen%{link_end} ge\xe4ndert werden."],"ServicePing|To help improve GitLab, we would like to periodically %{link_start}collect usage information%{link_end}.":["Um GitLab zu verbessern, m\xf6chten wir in regelm\xe4\xdfigen Abst\xe4nden %{link_start}Nutzungsinformationen sammeln%{link_end}."],"ServicePing|To view instance-level analytics, ask an admin to turn on %{docLinkStart}service ping%{docLinkEnd}.":["Bitte eine/-n Administrator(in), %{docLinkStart}Service Ping%{docLinkEnd} zu aktivieren, um Analysen auf Instanz-Ebene anzuzeigen."],"ServicePing|Turn on service ping":["Service Ping einschalten"],"ServicePing|Turn on service ping to review instance-level analytics.":["Aktiviere Service Ping, um Analysen auf Instanz-Ebene zu \xfcberpr\xfcfen."],"Session ID":["Session ID"],"Session ID copied to clipboard":["Sitzungs-ID in die Zwischenablage kopiert"],"SessionExpire|Please, sign in again. To avoid data loss, if you have unsaved edits, dismiss the modal and copy the unsaved text before sign in again.":["Bitte melde dich erneut an. Um Datenverlust zu vermeiden, schlie\xdfe das Modal und kopiere den nicht gespeicherten Text, bevor du dich erneut anmeldest, falls du ungespeicherte \xc4nderungen hast."],"SessionExpire|Your session has expired":["Deine Sitzung ist abgelaufen"],Sessions:["Sitzungen"],"Session|There was a error loading the user verification challenge. Refresh to try again.":["Beim Laden der Benutzer\xfcberpr\xfcfung ist ein Fehler aufgetreten. Aktualisiere die Seite, um es erneut zu versuchen."],"Set %{epic_ref} as the parent epic.":["%{epic_ref} als \xfcbergeordnetes Epic gesetzt."],"Set %{parent_ref} as this item's parent item.":["Lege %{parent_ref} als \xfcbergeordnetes Element dieses Elements fest."],"Set a default description template to be used for new issues. %{link_start}What are description templates?%{link_end}":["Lege eine Standardbeschreibungsvorlage fest, die f\xfcr neue Tickets verwendet werden soll. %{link_start}Was sind Beschreibungsvorlagen?%{link_end}"],"Set a group, access level or users who are required to deploy.":["W\xe4hle Gruppen, Zugriffsebenen oder Benutzer(innen) aus, die f\xfcr eine Bereitstellung erforderlich sind."],"Set a password on your account to pull or push via %{protocol}.":["Lege ein Passwort f\xfcr dein Konto fest, um mittels %{protocol} zu \xfcbertragen (push) oder abzurufen (pull)."],"Set as default":["Als Standard festlegen"],"Set due date":["F\xe4lligkeitsdatum setzen"],"Set health status":["Integrit\xe4tsstatus festlegen"],"Set health status to %{health_status}.":["Lege %{health_status} als Integrit\xe4tsstatus fest."],"Set iteration":["Iteration festlegen"],"Set limit to 0 to allow any file size.":["Setze das Limit auf 0, um beliebige Dateigr\xf6\xdfen zuzulassen."],"Set limits for web and API requests.":["Lege Grenzen f\xfcr Web- und API-Anfragen fest."],"Set milestone":["Meilenstein setzen"],"Set parent epic to an epic":["\xdcbergeordnetes Epic f\xfcr ein Epic bestimmen"],"Set parent item":["\xdcbergeordnetes Element festlegen"],"Set per-user rate limits for imports and exports of projects and groups.":["Lege Ratenlimit pro Benutzer(in) f\xfcr den Import und Export von Projekten und Gruppen fest."],"Set projects and maximum size limits, session duration, user options, and check feature availability for namespace plan.":["Lege Projekte und maximale Gr\xf6\xdfenbeschr\xe4nkungen, Sitzungsdauer, Benutzeroptionen fest und \xfcberpr\xfcfe die Funktionsverf\xfcgbarkeit f\xfcr den Namespace-Tarif."],"Set rate limits for package registry API requests that supersede the general user and IP rate limits.":["Lege Ratenlimits f\xfcr API-Anfragen f\xfcr die Paket-Registry fest, die die allgemeinen Benutzer- und IP-Ratenlimits ersetzen."],"Set rate limits for searches performed by web or API requests.":["Lege Ratenlimits f\xfcr Suchen fest, die von Web- oder API-Anfragen durchgef\xfchrt werden."],"Set severity":["Schweregrad festlegen"],"Set sign-in restrictions for all users.":["Lege Anmeldebeschr\xe4nkungen f\xfcr alle Benutzer(innen) fest."],"Set size limits for displaying diffs in the browser.":["Lege Gr\xf6\xdfenbeschr\xe4nkungen f\xfcr die Anzeige von Diffs im Browser fest."],"Set target branch":["Zielbranch setzen"],"Set target branch to %{branch_name}.":["Ziel-Branch zu %{branch_name} setzen."],"Set the Draft status":["Entwurfsstatus festlegen"],"Set the Ready status":["Setze den Status auf \u201eBereit\u201c"],"Set the default expiration time for job artifacts in all projects. Set to %{code_open}0%{code_close} to never expire artifacts by default. If no unit is written, it defaults to seconds. For example, these are all equivalent: %{code_open}3600%{code_close}, %{code_open}60 minutes%{code_close}, or %{code_open}one hour%{code_close}.":["Lege die Standardablaufzeit f\xfcr Job-Artefakte in allen Projekten fest. Auf %{code_open}0%{code_close} setzen, um Artefakte nie ablaufen zu lassen. Wenn keine Einheit angegeben wird, wird standardm\xe4\xdfig Sekunden verwendet. Diese Angaben sind dann zum Beispiel alle \xe4quivalent: %{code_open}3.600%{code_close}, %{code_open}60\xa0minutes%{code_close} oder %{code_open}one hour%{code_close}."],"Set the due date to %{due_date}.":["Lege %{due_date} als F\xe4lligkeitsdatum fest."],"Set the iteration to %{iteration_reference}.":["Lege %{iteration_reference} als Iteration fest."],"Set the maximum number of slices allowed to run concurrently during reindexing. Learn more about %{max_slices_running_link_start}maximum running slices configuration%{max_slices_link_end}.":["Lege die maximale Anzahl von Teilen fest, die w\xe4hrend der Reindexierung gleichzeitig ausgef\xfchrt werden d\xfcrfen. Erfahre mehr \xfcber die %{max_slices_running_link_start}maximale Konfiguration von ausgef\xfchrten Teilen%{max_slices_link_end}."],"Set the maximum session time for a web terminal.":["Lege die maximale Sitzungszeit f\xfcr ein Web-Terminal fest."],"Set the milestone to %{milestone_reference}.":["Lege %{milestone_reference} als Meilenstein fest."],"Set the per-user and per-IP address rate limits for the requests to Groups API.":["Lege die Ratenlimits pro Benutzer(in) und pro IP-Adresse f\xfcr die Anfragen an die Gruppen-API fest."],"Set the per-user and per-IP address rate limits for the requests to Projects API.":["Lege die Ratenbegrenzung pro Benutzer(in) und pro IP-Adresse f\xfcr die Anfragen an die Projekt-API fest."],"Set the per-user and per-IP address rate limits for the requests to Users API.":["Lege die Ratenlimits pro Benutzer(in) und pro IP-Adresse f\xfcr die Anfragen an die Benutzer(innen)-API fest."],"Set the per-user rate limit for notes created by web or API requests.":["Lege das Ratenlimit pro Benutzer(in) f\xfcr Notizen fest, die von Web- oder API-Anfragen erstellt wurden."],"Set the per-user rate limits for the requests to Organizations API.":["Lege die Ratenbegrenzungen pro Benutzer(in) f\xfcr Anfragen an die Organizations API fest."],"Set this %{work_item_type} as blocked by %{target}.":["Diesen %{work_item_type} als gesperrt durch %{target} einrichten."],"Set this %{work_item_type} as blocking %{target}.":["Diesen %{work_item_type} als Sperre f\xfcr %{target} einrichten."],"Set this number to 0 to disable the limit.":["Setze diese Zahl auf 0, um das Limit zu deaktivieren."],"Set time estimate":["Zeitsch\xe4tzung festlegen"],"Set time estimate to %{time_estimate}.":["Lege %{time_estimate} als gesch\xe4tzte Dauer fest."],"Set to 0 for no size limit.":["Setze dies auf 0, um die Gr\xf6\xdfenbegrenzung zu deaktivieren."],"Set to 0 to disable rate limits.":["Gib 0 ein, um die Ratenlimits zu deaktivieren."],"Set to 0 to disable the limit.":["Gib 0 ein, um das Limit zu deaktivieren."],"Set to 0 to disable the limits.":["Gib 0 ein, um die Limits zu deaktivieren."],"Set to 0 to disable timeout.":["Auf 0 setzen, um die Zeit\xfcberschreitung zu deaktivieren."],"Set to add to merge train when ready.":["Festgelegt, dass diese Merge Request zum Merge-Zug hinzugef\xfcgt wird, sobald sie bereit ist."],"Set to auto-merge":["Auf Auto-Merge setzen"],"Set to auto-merge.":["Auf Auto-Merge festgelegt."],"Set up":["Einrichten"],"Set up CI/CD":["CI/CD einrichten"],"Set up Jira Integration":["Jira Integration einrichten"],"Set up a WebAuthn device to enable two-factor authentication (2FA).":["Richte ein WebAuthn-Ger\xe4t ein, um die Zwei-Faktor-Authentifizierung (2FA) zu aktivieren."],"Set up assertions/attributes/claims (email, first_name, last_name) and NameID according to %{docsLinkStart}the documentation %{icon}%{docsLinkEnd}":["Richte notwendige Angaben (E-Mail-Adresse, Vorname, Nachname) und NameID gem\xe4\xdf %{docsLinkStart}der Dokumentation %{icon}%{docsLinkEnd} ein"],"Set up new device":["Neues Ger\xe4t einrichten"],"Set up root account":["Root-Konto einrichten"],"Set up your project to automatically push and/or pull changes to/from another repository. Branches, tags, and commits will be synced automatically.":["Richte dein Projekt so ein, dass \xc4nderungen automatisch an ein anderes Repository gesendet bzw. von diesem abgerufen werden. Branches, Tags und Commits werden automatisch synchronisiert."],"Set user cap":["Benutzerkapazit\xe4t festlegen"],"Set variables on protected branches and tags only.":["Variablen nur f\xfcr gesch\xfctzte Branches und Tags festlegen."],"Set weight":["Gewichtung festlegen"],"Set weight to %{weight}.":["Gewichtung auf %{weight} setzen."],"SetStatusModal|Clear status":["Status l\xf6schen"],"SetStatusModal|Clear status after":["Status zur\xfccksetzen nach"],"SetStatusModal|Displays that you are busy or not able to respond":["Zeigt an, dass du besch\xe4ftigt bist oder nicht antworten kannst"],"SetStatusModal|Edit status":["Status bearbeiten"],"SetStatusModal|Remove status":["Status entfernen"],"SetStatusModal|Set a status":["Einen Status setzen"],"SetStatusModal|Set status":["Status setzen"],"SetStatusModal|Set yourself as busy":["Setze deinen Status auf besch\xe4ftigt"],"SetStatusModal|Sorry, we weren't able to set your status. Please try again later.":["Leider konnten wir deinen Status nicht festlegen. Bitte versuche es sp\xe4ter erneut."],"SetStatusModal|Status message":["Statusmeldung"],"SetStatusModal|Status updated":["Status aktualisiert"],"SetStatusModal|What's your status?":["Wie ist dein Status?"],"SetStatusModal|Your status resets on %{date}.":["Dein Status wird am %{date} zur\xfcckgesetzt."],"Sets %{epic_ref} as parent epic.":["Setzt %{epic_ref} als \xfcbergeordnetes Epic."],"Sets checkin reminder frequency to %{frequency}.":["Legt die Check-in-Erinnerungsh\xe4ufigkeit auf %{frequency} fest."],"Sets health status to %{health_status}.":["Lege %{health_status} als Integrit\xe4tsstatus fest."],"Sets target branch to %{branch_name}.":["Legt %{branch_name} als Ziel-Branch fest."],"Sets the due date to %{due_date}.":["Legt das F\xe4lligkeitsdatum auf %{due_date} fest."],"Sets the iteration to %{iteration_reference}.":["Legt %{iteration_reference} als Iteration fest."],"Sets the milestone to %{milestone_reference}.":["Setzt den Meilenstein zu %{milestone_reference}."],"Sets the severity":["Legt den Schweregrad fest"],"Sets this merge request to auto-merge when ready.":["F\xfchrt f\xfcr diese Merge Request einen Auto-Merge durch, wenn bereit."],"Sets time estimate to %{time_estimate}.":["Setzt die Zeitsch\xe4tzung auf %{time_estimate}."],"Sets weight to %{weight}.":["\xc4ndert Gewichtung auf %{weight}."],Setting:["Einstellung"],"Setting enforced":["Einstellung erzwungen"],"Setting high package limits can impact database performance. Consider the size of your instance when configuring these values.":["Das Festlegen hoher Paketlimits kann die Datenbankleistung beeintr\xe4chtigen. Ber\xfccksichtigen beim Konfigurieren dieser Werte die Gr\xf6\xdfe deiner Instanz."],"Setting inherited":["Einstellung geerbt"],Settings:["Einstellungen"],"Settings for the License Compliance feature":["Einstellungen f\xfcr die Lizenzkonformit\xe4tsfunktion"],"Settings saved successfully.":["Einstellungen erfolgreich gespeichert."],"Settings|All direct and inherited members of the group or project":["Alle direkten und geerbten Mitglieder der Gruppe oder des Projekts"],"Settings|Expire from time of last session activity":["Ablauf nach Zeitpunkt der letzten Sitzungsaktivit\xe4t"],"Settings|Expire from time of session creation":["Ablauf nach Zeitpunkt der Sitzungserstellung"],"Settings|Expiry notification emails about group and project access tokens within this group should be sent to:":["Ablaufbenachrichtigungs-E-Mails \xfcber Gruppen- und Projektzugriffstoken innerhalb dieser Gruppe sollten an folgende Adresse gesendet werden:"],"Settings|Only direct members of the group or project":["Nur direkte Mitglieder der Gruppe oder des Projekts"],"Settings|Session duration, in minutes. Restart GitLab to apply changes.":["Sitzungsdauer in Minuten. Starte GitLab neu, um \xc4nderungen zu \xfcbernehmen."],"Settings|Session settings":["Sitzungseinstellungen"],"Settings|Session timeout duration":["Sitzungszeit\xfcberschreitung"],"Settings|Unable to load the merge request options settings. Try reloading the page.":["Die Einstellungen f\xfcr die Merge Request-Optionen k\xf6nnen nicht geladen werden. Versuche, die Seite neu zu laden."],"Settings|What is experiment?":["Was ist ein Experiment?"],Severity:["Schweregrad"],"Severity updated to %{severity}.":["Schweregrad aktualisiert auf %{severity}."],"SeverityWidget|Severity":["Schweregrad"],"SeverityWidget|Severity: %{severity}":["Schweregrad: %{severity}"],"SeverityWidget|There was an error while updating severity.":["Fehler beim Aktualisieren des Schweregrads."],Share:["Teilen"],"Share feedback on the experience":["Feedback zum Erlebnis teilen"],"Share the %{strong_open}GitLab single sign-on URL%{strong_close} with members so they can sign in to your group through your identity provider":["Teile die %{strong_open}Single-Sign-On-URL f\xfcr GitLab%{strong_close} mit Mitgliedern, damit sie sich \xfcber deinen Identit\xe4tsanbieter bei deiner Gruppe anmelden k\xf6nnen"],"Shared groups":["Geteilte Gruppen"],"Shared projects":["Geteilte Projekte"],"Shared projects could not be loaded. Refresh the page to try again.":["Geteilte Projekte konnten nicht geladen werden. Aktualisiere die Seite, um es erneut zu versuchen."],"Shared runners enabled cannot be enabled until identity verification is completed":["Gemeinsam genutzter Runner k\xf6nnen erst aktiviert werden, wenn die Identit\xe4tspr\xfcfung abgeschlossen ist"],"Shared secret":["Geteiltes Geheimnis"],"SharedRunnersMinutesSettings|Changes the compute usage for this group to zero.":["\xc4ndert die Compute-Nutzung f\xfcr diese Gruppe in null."],"SharedRunnersMinutesSettings|Changes the compute usage for this user to zero.":["\xc4ndert die Compute-Nutzung f\xfcr diese(n) Benutzer(in) in null."],"SharedRunnersMinutesSettings|Reset compute usage":["Rechennutzung zur\xfccksetzen"],"SharedRunnersMinutesSettings|Reset compute usage for this group.":["Compute-Nutzung f\xfcr diese Gruppe zur\xfccksetzen."],"SharedRunnersMinutesSettings|Reset compute usage for this user.":["Compute-Nutzung f\xfcr diese(n) Benutzer(in) zur\xfccksetzen."],"ShellOperations|Git SSH operations rate limits":["Grenzwerte f\xfcr Git SSH-Vorg\xe4nge"],"ShellOperations|Limit the number of Git operations a user can perform per minute, per repository.":["Begrenzt die Anzahl der Git-Vorg\xe4nge, die ein(e) Benutzer(in) pro Minute und pro Repository durchf\xfchren kann."],"ShellOperations|Maximum number of Git operations per minute":["Maximale Anzahl an Git-Vorg\xe4ngen pro Minute"],"Short name":["Kurzname"],"Should these changes be private?":["Sollten diese \xc4nderungen privat sein?"],"Should you ever lose your phone or access to your one time password secret, each of these recovery codes can be used one time each to regain access to your account. Please save them in a safe place, or you %{boldStart}will%{boldEnd} lose access to your account.":["Solltest du jemals den Zugriff auf dein Telefon oder das Einmalpasswort-Geheimnis verlieren, kann jeder dieser Wiederherstellungscodes einmal verwendet werden, um wieder Zugriff auf dein Konto zu erhalten. Bitte speichere sie an einem sicheren Ort ab, oder du %{boldStart}wirst%{boldEnd} den Zugriff auf dein Konto verlieren."],"Show %{count} closed %{itemText}":["%{count} geschlossene(n) %{itemText} anzeigen"],"Show %{count} more":["%{count} weitere anzeigen"],"Show Pipeline ID":["Pipeline-ID anzeigen"],"Show Pipeline IID":["Pipeline-IID anzeigen"],"Show all %{issuable_type}.":["Zeige alle %{issuable_type}."],"Show all activity":["Alle Aktivit\xe4ten anzeigen"],"Show all assignees":["Alle Beauftragten ansehen"],"Show all comments":["Alle Kommentare anzeigen"],"Show all epics":["Alle Epics anzeigen"],"Show all issues.":["Alle Tickets anzeigen"],"Show all merge requests.":["Alle Merge Requests anzeigen."],"Show all milestones":["Alle Meilensteine anzeigen"],"Show all reviewers":["Alle Pr\xfcfer anzeigen"],"Show all test cases.":["Alle Testf\xe4lle anzeigen."],"Show archived projects":["Archivierte Projekte anzeigen"],"Show archived projects only":["Nur archivierte Projekte anzeigen"],"Show changes":["\xc4nderungen anzeigen"],"Show closed epics":["Geschlossene Epics anzeigen"],"Show code in global search results":["Code in globalen Suchergebnissen anzeigen"],"Show command":["Befehl anzeigen"],"Show comments":["Kommentare anzeigen"],"Show comments on this file":["Kommentare zu dieser Datei anzeigen"],"Show comments only":["Nur Kommentare anzeigen"],"Show commits in global search results":["Commits in globalen Suchergebnissen anzeigen"],"Show current status of indexing.":[""],"Show details":["Details anzeigen"],"Show epics in global search results":["Epics in globalen Suchergebnissen anzeigen"],"Show file browser":["Dateibrowser anzeigen"],"Show file contents":["Dateiinhalt anzeigen"],"Show file tree browser":["Dateistrukturbrowser anzeigen"],"Show full blame":["Blame vollst\xe4ndig anzeigen"],"Show group milestones":["Gruppenmeilensteine anzeigen"],"Show issues in global search results":["Tickets in globalen Suchergebnissen anzeigen"],"Show labels":["Labels anzeigen"],"Show latest version":["Neuste Version zeigen"],"Show less":["Weniger anzeigen"],"Show merge requests in global search results":["Merge Requests in globalen Suchergebnissen anzeigen"],"Show more":["Mehr anzeigen"],"Show more breadcrumbs":["Mehr Breadcrumbs anzeigen"],"Show one file at a time":["Eine Datei nach der anderen anzeigen"],"Show open epics":["Offene Epics anzeigen"],"Show or hide draft merge requests in your merge requests list.":["Zeige Merge Requests im Entwurfsstatus in der Liste deiner Merge Requests an oder blende sie aus."],"Show or hide sidebar":["Men\xfcleiste anzeigen oder ausblenden"],"Show password":["Passwort anzeigen"],"Show project milestones":["Projektmeilensteine anzeigen"],"Show results":["Ergebnisse anzeigen"],"Show snippets in global search results":["Code-Schnipsel in globalen Suchergebnissen anzeigen"],"Show sub-group milestones":["Meilensteine der Untergruppe anzeigen"],"Show the Closed list":["Liste \u201eGeschlossen\u201c anzeigen"],"Show the Open list":["Liste \u201eGe\xf6ffnet\u201c anzeigen"],"Show users in global search results":["Benutzer(innen) in globalen Suchergebnissen anzeigen"],"Show whitespace changes":["Leerzeichen\xe4nderungen anzeigen"],"Show wikis in global search results":["Wikis in globalen Suchergebnissen anzeigen"],"Show your drafts":["Deinen Entwurf zeigen"],"Showing %d project.":["%d Projekt wird angezeigt.","%d Projekte werden angezeigt."],"Showing %{conflict}":["Zeige %{conflict}"],"Showing %{count} of %{total} projects":["Es werden %{count} von %{total} Projekten angezeigt"],"Showing %{count} project":["%{count} Projekt wird angezeigt.","%{count} Projekte werden angezeigt."],"Showing %{limit} of %{total_count} items. ":["%{limit} von %{total_count} Elementen werden angezeigt. "],"Showing %{pageSize} of %{total} %{issuableType}":["%{pageSize} von %{total} %{issuableType} werden angezeigt"],"Showing all epics":["Alle Epics werden angezeigt"],"Showing all issues":["Alle Tickets anschauen"],"Showing data for workflow items completed in this date range. Date range limited to %{maxDateRange} days.":["Zeigt Daten f\xfcr Workflow-Elemente an, die in diesem Datumsbereich fertiggestellt wurden. Der Datumsbereich ist auf %{maxDateRange} Tage begrenzt."],"Showing first 50 actions.":["Zeigt die ersten 50 Aktionen an."],"Showing version #%{versionNumber}":["Version #%{versionNumber}wird angezeigt"],"Side-by-side":["Nebeneinander"],"Sidebar|%{name}: %{value}":["%{name}: %{value}"],"Sidebar|Health status":["Gesundheitsstatus"],"Sidebar|No status":["Kein Status"],"Sidebar|None":["Keine"],"Sidebar|Select health status":["Integrit\xe4tsprobleme ausw\xe4hlen"],"Sidekiq job compression threshold (bytes)":["Sidekiq Job-Kompressionsschwelle (Bytes)"],"Sidekiq job size limit (bytes)":["Sidekiq Job-Gr\xf6\xdfenbeschr\xe4nkung (Bytes)"],"Sidekiq job size limits":["Sidekiq Job-Gr\xf6\xdfenbeschr\xe4nkungen"],"Sign in":["Anmelden"],"Sign in as a user with the matching email address, add the email to this account, or sign-up for a new account using the matching email.":["Melde dich als Benutzer(in) mit der passenden E-Mail-Adresse an, f\xfcge die E-Mail-Adresse diesem Konto hinzu oder melde dich mit der passenden E-Mail-Adresse f\xfcr ein neues Konto an."],"Sign in before continuing.":["Melde dich an, um fortzufahren."],"Sign in preview":["Anmeldevorschau"],"Sign in to GitLab":["Bei GitLab anmelden"],"Sign in using smart card":["Mit Smart Card anmelden"],"Sign in via 2FA code":["Mit 2FA Code anmelden"],"Sign in with single sign-on":["Mit Single Sign-on anmelden"],"Sign in with smart card":["Mit Smart Card anmelden"],"Sign in/Sign up pages":["Anmelde-/Registrierungsseite"],"Sign out":["Abmelden"],"Sign up":["Registrieren"],"Sign web-based commits":["Webbasierte Commits signieren"],"Sign-in count:":["Anzahl der Anmeldungen:"],"Sign-in page":["Anmeldeseite"],"Sign-in restrictions":["Anmeldebeschr\xe4nkungen"],"Sign-out page URL":["URL der Abmeldeseite"],"Sign-up restrictions":["Registrierungsbeschr\xe4nkungen"],"Sign-ups are currently disabled. Please contact a GitLab administrator if you need an account.":["Die Registrierung ist aktuell deaktiviert. Wende dich an eine(n) GitLab-Administrator(in), wenn du ein Konto ben\xf6tigst."],
"SignUp|By clicking %{button_text} or registering through a third party you accept the %{link_start}Terms of Use and acknowledge the Privacy Statement and Cookie Policy%{link_end}.":["Wenn du auf %{button_text} klickst oder dich \xfcber einen Drittanbieter registrierst, akzeptierst du die %{link_start}Nutzungsbedingungen und erkennst die Datenschutzerkl\xe4rung und die Cookie-Richtlinie%{link_end} an."],"SignUp|By clicking %{button_text} or registering through a third party you accept the GitLab %{link_start}Terms of Use and acknowledge the Privacy Statement and Cookie Policy%{link_end}.":["Indem du auf %{button_text} klickst oder dich \xfcber einen Drittanbieter registrierst, akzeptierst du die %{link_start}Nutzungsbedingungen von GitLab und erkennst die Datenschutz- und Cookie-Richtlinien%{link_end} an."],"SignUp|By signing in you accept the %{link_start}Terms of Use and acknowledge the Privacy Statement and Cookie Policy%{link_end}.":["Mit deiner Anmeldung akzeptierst du die %{link_start}Nutzungsbedingungen und erkennst die Datenschutz- und Cookie-Richtlinien an%{link_end}."],"SignUp|First name is too long (maximum is %{max_length} characters).":["Der Vorname ist zu lang (maximal %{max_length} Zeichen)."],"SignUp|Last name is too long (maximum is %{max_length} characters).":["Der Nachname ist zu lang (maximal %{max_length} Zeichen)."],"SignUp|Minimum length is %{minimum_password_length} characters.":["Das Passwort muss mindestens aus %{minimum_password_length} Zeichen bestehen."],"SignUp|Username is too long (maximum is %{max_length} characters).":["Benutzername ist zu lang (maximale Zeichenl\xe4nge betr\xe4gt %{max_length})."],"SignUp|Username is too short (minimum is %{min_length} characters).":["Der Nutzername ist zu kurz (mindestens %{min_length} Zeichen)."],"Signature key mismatch":["Nicht \xfcbereinstimmender Signaturschl\xfcssel"],"Signed in":["Angemeldet"],"Signed in as %{username}":["Angemeldet als %{username}"],"Signed in to GitLab":["Bei GitLab angemeldet"],"Signed in to GitLab as %{user_link}":["Bei GitLab als %{user_link} angemeldet"],"Signed in with %{authentication} authentication":["Mit %{authentication}-Authentifizierung angemeldet"],"Signing in using %{label} has been disabled":["Anmelden mit %{label} wurde deaktiviert"],"Signing in using your %{label} account has been disabled for security reasons. Please sign in to your GitLab account using another authentication method and reconnect to your %{label} account.":["Die Anmeldung mit deinem %{label}-Konto wurde aus Sicherheitsgr\xfcnden deaktiviert. Bitte melde dich mit einer anderen Authentifizierungsmethode in deinem GitLab-Konto an und verbinde dich erneut mit deinem %{label}-Konto."],"Signing in using your %{label} account without a pre-existing account in %{simple_url} is not allowed.":["Die Anmeldung mit deinem %{label}-Konto ohne ein bereits bestehendes Konto in %{simple_url} ist nicht zul\xe4ssig."],"SilentMode|All outbound communications are blocked. %{link_start}Learn more%{link_end}.":["S\xe4mtliche ausgehende Kommunikation ist blockiert. %{link_start}Mehr erfahren%{link_end}."],"SilentMode|Enable silent mode":["Stillen Modus aktivieren"],"SilentMode|Silent mode":["Stiller Modus"],"SilentMode|Silent mode %{status}":["Stiller Modus %{status}"],"SilentMode|Silent mode is enabled":["Stiller Modus ist aktiviert"],"SilentMode|Suppress outbound communication, such as emails, from GitLab.":["Unterdr\xfccke ausgehende Kommunikation, wie etwa E-Mails, von GitLab."],"SilentMode|There was an error updating the Silent Mode Settings.":["Fehler beim Aktualisieren der Einstellungen f\xfcr den stillen Modus."],"Similar issues":["\xc4hnliche Tickets"],"Simulate a pipeline created for the default branch":["Eine f\xfcr den Standard-Branch erstellte Pipeline simulieren"],"Single component can be selected for component filter to be able to filter by version.":["F\xfcr den Komponentenfilter k\xf6nnen einzelne Komponenten ausgew\xe4hlt werden, um nach Version filtern zu k\xf6nnen."],"Site profile failed to delete":["L\xf6schen des Seitenprofils fehlgeschlagen"],"Site profile not found for given parameters":["Seitenprofil f\xfcr die angegebenen Parameter nicht gefunden"],Sites:["Seiten"],Size:["Gr\xf6\xdfe"],"Size Limits":["Gr\xf6\xdfenlimit"],"Size limit":["Gr\xf6\xdfenlimit"],"Size limit per repository (MiB)":["Gr\xf6\xdfenlimit pro Repository (MiB)"],"Skip to input":["Bis Eingabe \xfcberspringen"],"Skip to main content":["Zum Hauptinhalt springen"],Skipped:["\xdcbersprungen"],"Skipped deployment to":["Bereitstellung \xfcbersprungen nach"],"Skipped indexes":["\xdcbersprungene Indizes"],"Slack logo":["Slack-Logo"],"SlackIntegration|- *Notifications:* Get notifications to your team's Slack channel about events happening inside your GitLab projects.":["- *Benachrichtigungen:* Erhalte im Slack-Kanal deines Teams Benachrichtigungen \xfcber Ereignisse in deinen GitLab-Projekten."],"SlackIntegration|- *Slash commands:* Quickly open, access, or close issues from Slack using the `%{slash_command}` command. Streamline your GitLab deployments with ChatOps.":["- *Slash-Befehle:* \xd6ffne, lese oder schlie\xdfe Tickets schnell von Slack aus mit dem Befehl `%{slash_command}`. Optimiere deine GitLab-Bereitstellungen mit ChatOps."],"SlackIntegration|Access request canceled":["Zugriffsanfrage abgebrochen"],"SlackIntegration|Are you sure you want to unlink this Slack Workspace from this integration? All projects inheriting these settings will also be unlinked. Groups and projects using custom settings will not be affected.":["M\xf6chtest du die Verkn\xfcpfung dieses Slack-Arbeitsbereichs mit dieser Integration wirklich aufheben? Die Verkn\xfcpfung aller Projekte, die diese Einstellungen \xfcbernehmen, wird ebenfalls aufgehoben. Gruppen und Projekte, die benutzerdefinierte Einstellungen verwenden, sind davon nicht betroffen."],"SlackIntegration|Client ID":["Kunden-ID"],"SlackIntegration|Client secret":["Kundengeheimnis"],"SlackIntegration|Configure your GitLab for Slack app.":["Konfiguriere deine \u201eGitLab f\xfcr Slack\u201c-App."],"SlackIntegration|Copy the %{link_start}settings%{link_end} from %{strong_open}%{settings_heading}%{strong_close} in your GitLab for Slack app.":["Kopiere die %{link_start}Einstellungen%{link_end} aus %{strong_open}%{settings_heading}%{strong_close} in deiner \u201eGitLab f\xfcr Slack\u201c-App."],"SlackIntegration|Create Slack app":["Slack-App erstellen"],"SlackIntegration|Create and read issue data and comments.":["Erstelle und lese Ticket-Daten und Kommentare."],"SlackIntegration|Download latest manifest file":["Neueste Manifestdatei herunterladen"],"SlackIntegration|Error exchanging OAuth token with Slack":["Fehler beim Austauschen des OAuth-Tokens mit Slack"],"SlackIntegration|Error exchanging OAuth token with Slack: %{error}":["Fehler beim Austauschen des OAuth-Tokens mit Slack: %{error}"],"SlackIntegration|Generated for %{host} by GitLab %{version}.":["Generiert f\xfcr %{host} von GitLab %{version}."],"SlackIntegration|GitLab for Slack":["GitLab f\xfcr Slack"],"SlackIntegration|GitLab for Slack app configured on the group or instance level and can only be modified there.":["GitLab ist f\xfcr die Slack-App auf Gruppen- oder Instanzebene konfiguriert und kann nur dort ge\xe4ndert werden."],"SlackIntegration|GitLab for Slack was successfully installed.":["GitLab f\xfcr Slack wurde erfolgreich installiert."],"SlackIntegration|GitLab slash commands":["Slash-Befehle in GitLab"],"SlackIntegration|Install GitLab for Slack app\u2026":["GitLab f\xfcr Slack-App installieren"],"SlackIntegration|Interact with GitLab without leaving your Slack workspace!":["Interagiere mit GitLab, ohne deinen Slack-Arbeitsbereich zu verlassen!"],"SlackIntegration|Perform deployments.":["Bereitstellungen durchf\xfchren."],"SlackIntegration|Project alias":["Projektalias"],"SlackIntegration|Reinstall GitLab for Slack app\u2026":["\u201eGitLab f\xfcr Slack\u201c-App neu installieren\xa0..."],"SlackIntegration|Run ChatOps jobs.":["ChatOps Jobs ausf\xfchren."],"SlackIntegration|See the list of available commands in Slack after setting up this integration by entering":["Erkunde die Liste der verf\xfcgbaren Befehle in Slack nach dem Einrichten dieser Integration durch Eingabe von"],"SlackIntegration|Select a GitLab project to link with your Slack workspace.":["W\xe4hle ein GitLab-Projekt aus, das mit deinem Slack-Arbeitsbereich verkn\xfcpft werden soll."],"SlackIntegration|Sends notifications about project events to Slack channels.":["Sendet Benachrichtigungen \xfcber Projektereignisse an Slack-Kan\xe4le."],"SlackIntegration|Signing secret":["Signiergeheimnis"],"SlackIntegration|Slack app not enabled on GitLab instance":["Slack-App ist in der GitLab-Instanz nicht aktiviert"],"SlackIntegration|Slack slash commands integration is deprecated":["Die Integration von Slack-Slash-Befehlen ist veraltet"],"SlackIntegration|Slack slash commands integration will be removed in GitLab 19.0. To run common GitLab operations from Slack, use the GitLab for Slack app instead.":["Die Integration von Slack-Slash-Befehlen wird in GitLab\xa019.0 entfernt. Um g\xe4ngige GitLab-Operationen \xfcber Slack auszuf\xfchren, verwende stattdessen die \u201eGitLab for Slack\u201c-App."],"SlackIntegration|Step 1: Create your GitLab for Slack app":["Schritt 1: Erstelle deine \u201eGitLab f\xfcr Slack\u201c-App"],"SlackIntegration|Step 2: Configure the app settings":["Schritt 2: Konfiguriere die App-Einstellungen"],"SlackIntegration|This integration allows users to perform common operations on their projects by entering slash commands in Slack.":["Diese Integration erm\xf6glicht es Benutzer(inne)n, allgemeine Vorg\xe4nge in diesem Projekt auszuf\xfchren, indem Slash-Befehle in Slack eingegeben werden."],"SlackIntegration|Unauthorized":["Nicht autorisiert"],"SlackIntegration|Update to the latest version":["Auf die neueste Version aktualisieren"],"SlackIntegration|Update to the latest version of GitLab for Slack to get notifications":["Update auf die neueste Version von GitLab f\xfcr Slack um Benachrichtigungen zu erhalten"],"SlackIntegration|Update to the latest version to receive notifications from GitLab.":["Aktualisiere auf die neueste Version, um Benachrichtigungen von GitLab zu erhalten."],"SlackIntegration|Update your Slack app":["Aktualisiere deine Slack-App"],"SlackIntegration|Used for authenticating API requests from the GitLab for Slack app.":["Wird zur Authentifizierung von API-Anfragen aus der \u201eGitLab f\xfcr Slack\u201c-App verwendet."],"SlackIntegration|Used for authenticating OAuth requests from the GitLab for Slack app.":["Wird zur Authentifizierung von OAuth-Anfragen aus der \u201eGitLab f\xfcr Slack\u201c-App verwendet."],"SlackIntegration|Used only for authenticating slash commands from the GitLab for Slack app. This method of authentication is deprecated by Slack.":["Wird nur zur Authentifizierung von Slash-Befehlen aus der \u201eGitLab f\xfcr Slack\u201c-App verwendet. Diese Authentifizierungsmethode wurde von Slack als veraltet gekennzeichnet."],"SlackIntegration|Verification token":["Verifikationstoken"],"SlackIntegration|When GitLab releases new features for the GitLab for Slack app, you might have to manually update your copy to use the new features.":["Wenn GitLab neue Funktionen f\xfcr die \u201eGitLab f\xfcr Slack\u201c-App ver\xf6ffentlicht, musst du deine Kopie m\xf6glicherweise manuell aktualisieren, um die neuen Funktionen nutzen zu k\xf6nnen."],"SlackIntegration|Workspace name":["Arbeitsbereichsname"],"SlackIntegration|You can now close this window and go to your Slack workspace.":["Du kannst dieses Fenster jetzt schlie\xdfen und zu deinem Slack-Arbeitsbereich wechseln."],"SlackIntegration|You don't have to reauthorize this application if the permission scope changes in future releases.":["Du musst diese Anwendung nicht erneut autorisieren, wenn sich der Berechtigungsbereich in zuk\xfcnftigen Versionen \xe4ndert."],"SlackIntegration|You may need to reinstall the GitLab for Slack app when we %{linkStart}make updates or change permissions%{linkEnd}.":["Du musst die GitLab f\xfcr Slack App neu installieren, wenn wir %{linkStart}Aktualisierungen vornehmen oder die Berechtigungen%{linkEnd} \xe4ndern."],"SlackIntegration|You must do this step only once.":["Du musst diesen Schritt nur einmal ausf\xfchren."],"SlackIntegration|cannot have more than %{limit} channels":["Kann nicht mehr als %{limit} Kan\xe4le haben"],"SlackIntegration|your-project-name-or-alias command":["your-project-name-or-alias-Befehl"],"SlackModal|Are you sure you want to change the project?":["Bist du sicher, dass du das Projekt \xe4ndern m\xf6chtest?"],"SlackModal|If you change the project, you'll lose any text entered in the form.":["Wenn du das Projekt \xe4nderst, verlierst du alle im Formular eingegebenen Texte."],"SlackModal|If you've entered some text, consider saving it somewhere to avoid losing any content.":["Wenn du einen Text eingegeben hast, solltest du ihn irgendwo speichern, um keine Inhalte zu verlieren."],"SlackService|1. %{slash_command_link_start}Add a slash command%{slash_command_link_end} in your Slack team using this information:":["1. %{slash_command_link_start}F\xfcge einen Slash-Befehl%{slash_command_link_end} in deinem Slack-Team hinzu, indem du diese Informationen verwendest:"],"SlackService|2. Paste the token from Slack in the %{strong_open}Token%{strong_close} field below.":["2. F\xfcge den Token von Slack in das Feld %{strong_open}Token%{strong_close} unten ein."],"SlackService|3. Select the %{strong_open}Active%{strong_close} checkbox, select %{strong_open}Save changes%{strong_close}, and start using slash commands in Slack!":["3. Aktiviere das Kontrollk\xe4stchen %{strong_open}aktiv%{strong_close}, w\xe4hle %{strong_open}\xc4nderungen speichern%{strong_close} und beginnen mit der Verwendung von Slash-Befehlen in Slack!"],"SlackService|After setup, get a list of available Slack slash commands by entering":["Nach der Einrichtung erh\xe4ltst du eine Liste der verf\xfcgbaren Slash-Befehle f\xfcr Slack, indem du folgendes eingibst"],"SlackService|Fill in the word that works best for your team.":["W\xe4hle ein Wort aus, das dein Team am besten beschreibt."],"SlackService|Perform common operations in this project by entering slash commands in Slack.":["F\xfchre allgemeine Operationen in diesem Projekt durch die Eingabe von Slash-Befehlen in Slack aus"],"Slack|%{asterisk}Channel notifications%{asterisk}":["%{asterisk}Kanal-Benachrichtigungen%{asterisk}"],"Slack|%{asterisk}Slash commands%{asterisk}":["%{asterisk}Slash Befehle%{asterisk}"],"Slack|%{emoji}Connected to GitLab account %{account}.":["%{emoji}Mit GitLab Konto %{account} verbunden."],"Slack|%{emoji}Welcome to GitLab for Slack!":["%{emoji}Willkommen bei GitLab f\xfcr Slack!"],"Slack|Connect your GitLab account":["Verbinde Dein GitLab-Konto"],"Slack|Control GitLab from Slack with %{startMarkup}slash commands%{endMarkup}. For a list of available commands, enter %{command}.":["Steuere GitLab von Slack aus mit %{startMarkup}Slash-Befehlen%{endMarkup}. Gib f\xfcr eine Liste der verf\xfcgbaren Befehle %{command} ein."],"Slack|GitLab for Slack now supports channel-based notifications. Let your team know when new issues are created or new CI/CD jobs are run.%{startMarkup}Learn more%{endMarkup}.":["GitLab f\xfcr Slack unterst\xfctzt jetzt kanalbasierte Benachrichtigungen. Teile deinem Team mit, wenn neue Tickets erstellt werden oder neue CI/CD-Jobs ausgef\xfchrt werden.%{startMarkup}Erfahre mehr%{endMarkup}."],"Slack|To start using notifications, %{startMarkup}enable the GitLab for Slack app integration%{endMarkup} in your project settings.":["Um mit der Verwendung von Benachrichtigungen zu beginnen, aktiviere %{startMarkup}GitLab f\xfcr Slack App Integration%{endMarkup} in Ihren Projekteinstellungen."],"Slack|To start using slash commands, connect your GitLab account.":["Verbinden dein GitLab Konto, um Slash Befehle zu verwenden."],"Slice multiplier":["Teile-Multiplikator"],Smartcard:["Smartcard"],"Smartcard authentication failed: client certificate header is missing.":["Smartcard-Authentifizierung fehlgeschlagen: Client-Zertifikat-Header fehlt."],"Smartcard authentication failed: login process exceeded the time limit.":["Smartcard-Authentifizierung fehlgeschlagen: Der Anmeldevorgang hat das Zeitlimit \xfcberschritten."],Snippet:["Code-Schnipsel"],Snippets:["Code-Schnipsel"],"Snippets with non-text files can only be edited via Git.":["Code-Schnipsel mit Nicht-Text-Dateien k\xf6nnen nur \xfcber Git bearbeitet werden."],"SnippetsEmptyState|Get started with snippets":["Erste Schritte mit Schnipseln"],"SnippetsEmptyState|New snippet":["Neuer Code-Schnipsel"],"SnippetsEmptyState|Store, share, and embed bits of code and text.":["Mit dieser Funktion kannst du Code- und Text-Abschnitte speichern, teilen und einbetten."],"SnippetsEmptyState|There are no snippets found":["Es wurden keine Code-Schnipsel gefunden"],"SnippetsEmptyState|There are no snippets to show.":["Es sind keine Code-Schnipsel, die man anzeigen k\xf6nnte."],"Snippets|%{spammable_titlecase} was submitted to Akismet successfully.":["%{spammable_titlecase} wurde erfolgreich an Askismet gesendet."],"Snippets|Add another file %{num}/%{total}":["Weitere Datei hinzuf\xfcgen %{num}/%{total}"],"Snippets|Delete file":["Datei l\xf6schen"],"Snippets|Describe what your snippet does or how to use it\u2026":["Beschreibe, was dein Code-Schnipsel bewirkt oder wie er funktioniert\u2026"],"Snippets|Description (optional)":["Beschreibung (optional)"],"Snippets|Error with Akismet. Please check the logs for more info.":["Fehler mit Akismet. Bitte \xfcberpr\xfcfe die Protokolle f\xfcr weitere Informationen."],"Snippets|File name (e.g. test.rb)":["Dateiname (z.\xa0B. test.rb)"],"Snippets|Files":["Dateien"],"Snippets|New snippet":["Neuer Schnipsel"],"Snippets|Snippet actions":["Code-Schnipsel-Aktionen"],"Snippets|Snippets":["Schnipsel"],"Snippets|Snippets are limited to %{total} files.":["Code-Schnipsel sind auf %{total} Dateien beschr\xe4nkt."],"Snippets|Snippets can't contain empty files. Ensure all files have content, or delete them.":["Code-Schnipsel d\xfcrfen keine leeren Dateien enthalten. Stelle sicher, dass alle Dateien Inhalt haben, oder l\xf6sche sie."],"Snippets|This snippet is hidden because its author has been banned":["Dieser Code-Schnipsel ist ausgeblendet, weil sein(e) Autor(in) gesperrt wurde"],Snowplow:["Snowplow"],"Snowplow tracking and Product event tracking cannot be enabled at the same time. Please disable one of them.":["Snowplow-Tracking und Produktereignis-Tracking k\xf6nnen nicht gleichzeitig aktiviert werden. Bitte deaktiviere eines der beiden."],"Soft wrap":["Lange Zeilen umbrechen"],"Software Developer":["Softwareentwickler(in)"],Solid:["Fest"],Solution:["L\xf6sung"],"Some changes are not shown":["Einige \xc4nderungen werden nicht angezeigt"],"Some changes are not shown.":["Einige \xc4nderungen werden nicht angezeigt."],"Some child epics may be hidden due to applied filters":["Einige untergeordnete Epics k\xf6nnten aufgrund der angewendeten Filter ausgeblendet sein"],"Some common domains are not allowed. %{learn_more_link}.":["Einige g\xe4ngige Domains sind nicht erlaubt. %{learn_more_link}."],"Some files cannot be displayed due to their file path encoding.":["Einige Dateien k\xf6nnen aufgrund ihrer Dateipfadkodierung nicht angezeigt werden."],"Some friendly information":["Einige freundliche Informationen"],"Someone edited the %{issuableType} at the same time you did. Review %{linkStart}the %{issuableType}%{linkEnd} and make sure you don't unintentionally overwrite their changes.":["Jemand hat diesen %{issuableType} zur selben Zeit wie du bearbeitet. \xdcberpr\xfcfe %{linkStart}den %{issuableType}%{linkEnd} und stelle sicher, dass du die \xc4nderungen nicht unbeabsichtigt \xfcberschreibst."],"Someone edited the file the same time you did. Please check out %{link_start}the file %{icon}%{link_end} and make sure your changes will not unintentionally remove theirs.":["Jemand hat die Datei zur gleichen Zeit bearbeitet wie du. Bitte \xfcberpr\xfcfe %{link_start}die Datei %{icon}%{link_end} und vergewissere dich, dass deine \xc4nderungen nicht unbeabsichtigt die der anderen Person entfernen."],"Someone edited this %{issueType} at the same time you did. The description has been updated and you will need to make your changes again.":["Jemand hat diese(s) %{issueType} zur selben Zeit wie du bearbeitet. Die Beschreibung wurde aktualisiert und du musst deine \xc4nderungen erneut vornehmen."],"Someone edited this %{model_name} at the same time you did. Please check out the %{link_to_model} and make sure your changes will not unintentionally remove theirs.":["Jemand hat dieses %{model_name} zur selben Zeit bearbeitet wie du. Bitte pr\xfcfe %{link_to_model} und stelle sicher, dass deine \xc4nderungen nicht unbeabsichtigt die anderen \xc4nderungen \xfcberschreiben."],"Someone edited this %{model_name} at the same time you did. Please refresh your browser and make sure your changes will not unintentionally remove theirs.":["Jemand hat dieses %{model_name} zur selben Zeit bearbeitet wie du. Bitte aktualisiere deinen Browser und stelle sicher, dass deine \xc4nderungen nicht unbeabsichtigt die anderen \xc4nderungen \xfcberschreiben."],"Someone edited this merge request at the same time you did. Please refresh the page to see changes.":["Jemand hat diese Merge Request zur gleichen Zeit bearbeitet. Bitte aktualisiere die Seite, um die \xc4nderungen zu sehen."],"Someone edited this milestone at the same time you did. Please refresh the page to see changes.":["Jemand hat diesen Meilenstein zur gleichen Zeit bearbeitet wie du. Bitte aktualisiere die Seite, um die \xc4nderungen anzuzeigen."],"Someone edited this test case at the same time you did. The description has been updated and you will need to make your changes again.":["Jemand hat diesen Testfall zur gleichen Zeit bearbeitet wie du. Die Beschreibung wurde aktualisiert und du musst deine \xc4nderungen erneut vornehmen."],"Someone signed in to your %{host} account from a new location":["Jemand hat sich von einem neuen Standort aus bei Deinem %{host} Konto angemeldet"],"Someone, hopefully you, has requested to reset the password for your GitLab account on %{link_to_gitlab}.":["Jemand, hoffentlich du, hat darum gebeten, das Passwort f\xfcr dein GitLab-Konto unter %{link_to_gitlab} zur\xfcckzusetzen."],"Something else":["Sonstige"],"Something went wrong":["Etwas ist schief gelaufen"],"Something went wrong fetching the scanner findings. Please try again.":["Beim Abrufen der Scannerergebnisse ist etwas schiefgelaufen. Bitte versuche es erneut."],"Something went wrong on our end":["Bei uns ist etwas schief gelaufen"],"Something went wrong on our end.":["Bei uns ist etwas schief gelaufen."],"Something went wrong on our end. Please try again!":["Auf unserer Seite ist etwas schiefgelaufen. Bitte versuche es erneut!"],"Something went wrong on our end. Please try again.":["Etwas ist bei Uns schief gelaufen. Bitte versuche es erneut."],"Something went wrong trying to change the locked state of the discussion":["Fehler beim \xc4ndern des Sperrzustandes der Diskussion."],"Something went wrong trying to load issue contacts.":["Beim Laden der Ticketkontakte ist ein Fehler aufgetreten."],"Something went wrong when deleting a comment. Please try again":["Beim L\xf6schen deines Kommentars ist etwas schiefgelaufen. Bitte versuche es erneut"],"Something went wrong when sending the incident link to Slack.":["Fehler beim Senden des Vorfall-Links an Slack."],"Something went wrong when updating a comment. Please try again":["Fehler beim Aktualisieren eines Kommentars. Versuche es erneut"],"Something went wrong while adding timeline event.":["Beim Hinzuf\xfcgen des Zeitleistenereignis ist etwas schief gelaufen."],"Something went wrong while adding your award. Please try again.":["Fehler beim Hinzuf\xfcgen deiner Auszeichnung. Versuche es erneut."],"Something went wrong while applying the batch of suggestions. Please try again.":["Fehler beim Anwenden des Vorschlagsbatches. Versuche es erneut."],"Something went wrong while applying the suggestion. Please try again.":["Fehler beim Anwenden des Vorschlags. Versuche es erneut."],"Something went wrong while archiving a requirement.":["Fehler beim Archivieren einer Anforderung"],"Something went wrong while closing the epic. Please try again later.":["Beim Schlie\xdfen des Epics ist etwas schief gelaufen. Bitte versuche es sp\xe4ter erneut."],"Something went wrong while closing the incident form.":["Fehler beim Schlie\xdfen des Vorfall-Formulars."],"Something went wrong while closing the merge request. Please try again later.":["Beim Schlie\xdfen des Merge Request ist ein Fehler aufgetreten. Bitte versuche es sp\xe4ter erneut."],"Something went wrong while creating a requirement.":["Fehler beim Erstellen einer Anforderung"],"Something went wrong while deleting description changes. Please try again.":["Fehler beim L\xf6schen von Beschreibungs\xe4nderungen. Versuche es erneut."],"Something went wrong while deleting the source branch. Please try again.":["Beim L\xf6schen des Quell Branches ist etwas schiefgelaufen. Bitte versuche es erneut."],"Something went wrong while deleting your note. Please try again.":["Fehler beim L\xf6schen deiner Notiz. Versuche es erneut."],"Something went wrong while deploying this environment. Please try again.":["Fehler beim Bereitstellen dieser Umgebung. Versuche es erneut."],"Something went wrong while editing your comment. Please try again.":["Beim Bearbeiten deines Kommentars ist etwas schiefgelaufen. Bitte versuche es erneut."],"Something went wrong while exporting requirements":["Beim Exportieren der Anforderungen ist ein Fehler aufgetreten"],"Something went wrong while fetching branches":["Beim Abrufen der Branches ist ein Fehler aufgetreten"],"Something went wrong while fetching comments. Please refresh the page.":["Beim Abrufen der Kommentare ist etwas schiefgelaufen. Bitte aktualisiere die Seite."],"Something went wrong while fetching comments. Please try again.":["Beim Abrufen der Kommentare ist etwas schiefgelaufen. Bitte versuche es erneut."],"Something went wrong while fetching description changes. Please try again.":["Fehler beim Abrufen von Beschreibungs\xe4nderungen. Versuche es erneut."],"Something went wrong while fetching projects":["Beim Abrufen von Projekten ist etwas schief gelaufen"],"Something went wrong while fetching projects.":["Beim Abrufen von Projekten ist etwas schief gelaufen."],"Something went wrong while fetching related merge requests.":["Beim Abrufen der verwandten Merge Request ist etwas schiefgelaufen."],"Something went wrong while fetching requirements count.":["Fehler beim Abrufen der Anforderungsanzahl"],"Something went wrong while fetching requirements list.":["Fehler beim Abrufen der Anforderungsliste"],"Something went wrong while fetching source branches.":["Beim Abrufen der Quellbranches ist ein Fehler aufgetreten."],"Something went wrong while fetching the environments for this merge request. Please try again.":["Beim Abrufen der Umgebungen f\xfcr diesen Merge-Request ist etwas schiefgelaufen. Bitte versuche es erneut."],"Something went wrong while fetching the packages list.":["Fehler beim Abrufen der Paketliste"],"Something went wrong while getting %{issuableType} confidentiality status.":["Beim Abrufen des %{issuableType}-Vertraulichkeitsstatus ist ein Fehler aufgetreten."],"Something went wrong while obtaining the Let's Encrypt certificate.":["Fehler beim Abrufen des \u201eLet's Encrypt\u201c-Zertifikats"],"Something went wrong while opening the incident form.":["Fehler beim \xd6ffnen des Vorfall-Formulars."],"Something went wrong while promoting the issue to an epic. Please try again.":["Beim Hochstufen des Epics ist etwas schief gegangen. Bitte versuche es erneut."],"Something went wrong while
ns|Start date":["Startdatum"],"SortOptions|Start later":["Sp\xe4ter starten"],"SortOptions|Start soon":["Baldiger Start"],"SortOptions|Title":["Titel"],"SortOptions|Weight":["Gewichtung"],Source:["Quelle"],"Source (branch or tag)":["Quelle (Branch oder Tag)"],"Source IP:":["Quell-IP:"],"Source branch":["Quellbranch"],"Source branch (%{branch}): %{pipelines}":["Quellbranch (%{branch}): %{pipelines}"],"Source branch does not exist":["Quellbranch existiert nicht"],"Source branch exists and contains commits.":["Quellbranch existiert und enth\xe4lt Commits."],"Source branch is protected from force push":["Quellbranch ist vor Push-Erzwingung gesch\xfctzt"],"Source branch name":["Name des Quell-Branchs"],"Source branch will be deleted.":["Quellbranch wird gel\xf6scht."],"Source branch will not be deleted.":["Quellbranch wird nicht gel\xf6scht."],"Source code (%{fileExtension})":["Quellcode (%{fileExtension})"],"Source is not available":["Quelle ist nicht verf\xfcgbar"],"Source name":["Quellenname"],"Source project":["Quellprojekt"],"Source project cannot be found.":["Quellprojekt kann nicht gefunden werden."],"Source-Branch":["Quellbranch"],"SourceBranchPattern|Source Branch Patterns":["Quellbranch-Muster"],'SourceEditor|"el" parameter is required for createInstance()':["\u201eel\u201c-Parameter ist f\xfcr createInstance() erforderlich"],"SourceEditor|%{name} is not registered.":["%{name} ist nicht registriert."],"SourceEditor|Extension definition should be either a class or a function":["Die Erweiterungsdefinition sollte entweder eine Klasse oder eine Funktion sein"],"SourceEditor|Extension definition should be either class, function, or an Array of definitions.":["Die Erweiterungsdefinition sollte entweder Klasse, Funktion oder ein Array von Definitionen sein."],"SourceEditor|Extensions Store is required to check for an extension.":["Extensions Store ist erforderlich, um nach einer Erweiterung zu suchen."],'SourceEditor|Name conflict for "%{prop}()" method.':["Namenskonflikt f\xfcr \u201e%{prop}()\u201c-Methode."],"SourceEditor|No extension for unuse has been specified.":["Es wurde keine Erweiterung f\xfcr \u201eunuse\u201c angegeben."],"SourceEditor|`definition` property is expected on the extension.":["Die Eigenschaft \u201edefinition\u201c wird f\xfcr die Erweiterung erwartet."],Sourcegraph:["Sourcegraph"],"SourcegraphAdmin|Block on private and internal projects":["Private und interne Projekte blockieren"],"SourcegraphAdmin|Configure the URL to a Sourcegraph instance which can read your GitLab projects.":["Konfiguriere die URL zu einer Sourcegraph-Instanz, die deine GitLab-Projekte lesen kann."],"SourcegraphAdmin|Enable Sourcegraph":["Sourcegraph aktivieren"],"SourcegraphAdmin|Enable code intelligence powered by %{link_start}Sourcegraph%{link_end} on your GitLab instance's code views and merge requests.":["Aktiviere Code-Intelligenz basierend auf %{link_start}Sourcegraph%{link_end} in den Codeansichten und Merge Requests deiner GitLab-Instanz."],"SourcegraphAdmin|Learn more.":["Mehr erfahren."],"SourcegraphAdmin|Only public projects have code intelligence enabled and communicate with Sourcegraph.":["Code-Intelligenz ist nur bei \xf6ffentlichen Projekten aktiviert. Diese kommunizieren mit Sourcegraph."],"SourcegraphAdmin|Save changes":["\xc4nderungen speichern"],"SourcegraphAdmin|Sourcegraph URL":["Sourcegraph-URL"],"SourcegraphAdmin|https://sourcegraph.example.com":["https://sourcegraph.example.com"],"SourcegraphPreferences|This feature is experimental and limited to public projects.":["Diese Funktion ist experimentell und beschr\xe4nkt auf \xf6ffentliche Projekte."],"SourcegraphPreferences|This feature is experimental.":["Diese Funktion ist experimentell."],"SourcegraphPreferences|Uses %{linkStart}Sourcegraph.com%{linkEnd}.":["Verwendet %{linkStart}Sourcegraph.com%{linkEnd}."],"SourcegraphPreferences|Uses a custom %{linkStart}Sourcegraph instance%{linkEnd}.":["Verwendet eine benutzerdefinierte %{linkStart}Sourcegraph-Instanz%{linkEnd}."],"Spam Check":["Spam-Pr\xfcfung"],"Spam Check API key":["Spam-Check API-Schl\xfcssel"],"Spam and Anti-bot Protection":["Spam- und Anti-Bot-Schutz"],"Spam log successfully submitted as ham.":["Spam-Protokoll erfolgreich als Ham \xfcbermittelt."],"Spam logs":["Spam-Protokolle"],"Specific branches":["Spezifische Branches"],'Specified URL cannot be used: "%{reason}"':["Angegebene URL kann nicht verwendet werden: \u201e%{reason}\u201c"],"Specify IP ranges that are always allowed for inbound traffic, for use with group-level IP restrictions. Runner and Pages daemon internal IPs should be listed here so that they can access project artifacts.":["Gib IP-Bereiche an, die immer f\xfcr eingehenden Datenverkehr zugelassen sind, zur Verwendung mit IP-Einschr\xe4nkungen auf Gruppenebene. Interne IPs von Runner und Pages-Daemon sollten hier aufgelistet werden, damit sie auf Projektartefakte zugreifen k\xf6nnen."],"Specify a regular expression for emails. New users with matching emails are not made external users.":["Gib einen regul\xe4ren Ausdruck f\xfcr E-Mails an. Neue Benutzer(innen) mit entsprechenden E-Mails werden nicht zu externen Benutzer(innen)."],"Specify the input values to use in this pipeline. Any inputs left unselected will use their default values.":["Gib die f\xfcr diese Pipeline zu verwendenden Eingabewerte an. F\xfcr nicht ausgew\xe4hlte Eingaben werden deren Standardwerte verwendet."],"Spent at can't be a future date and time.":["Verbracht am darf kein zuk\xfcnftiges Datum und keine zuk\xfcnftige Uhrzeit sein."],"Split cell":["Zelle teilen"],"Squash commit message":["Commit-Nachricht squashen"],"Squash commits":["Commits squashen"],"Squash commits when merge request is accepted.":["Squash Commits wenn Merge Request akzeptiert wird."],"Squash commits when merging":["Commits bei Zusammenf\xfchrung squashen"],"Squash option cannot be used with wildcard branch rules. Use an exact branch name.":[""],"SquashSettings|Allow":["Zulassen"],"SquashSettings|Checkbox is visible and selected by default.":["Kontrollk\xe4stchen ist sichtbar und standardm\xe4\xdfig ausgew\xe4hlt."],"SquashSettings|Checkbox is visible and unselected by default.":["Kontrollk\xe4stchen ist sichtbar und standardm\xe4\xdfig nicht ausgew\xe4hlt."],"SquashSettings|Default":["Standard"],"SquashSettings|Do not allow":["Nicht zulassen"],"SquashSettings|Encourage":["Auffordern"],"SquashSettings|No explicit squash settings. Inherits project squash settings when available.":["Keine expliziten Squash-Einstellungen. Falls verf\xfcgbar, werden die Squash-Einstellungen des Projekts \xfcbernommen."],"SquashSettings|Require":["Erzwingen"],"SquashSettings|Squashing is always performed. Checkbox is visible and selected, and users cannot change it.":["Squashing wird immer durchgef\xfchrt. Kontrollk\xe4stchen ist sichtbar und ausgew\xe4hlt, Benutzer(innen) k\xf6nnen es nicht \xe4ndern."],"SquashSettings|Squashing is never performed and the checkbox is hidden.":["Squashing wird nie durchgef\xfchrt, Kontrollk\xe4stchen ist nicht sichtbar."],"SquashTmIntegration|Secret token (optional)":["Secret Token (optional)"],"SquashTmIntegration|Squash TM webhook URL":["Squash TM Webhook-URL"],"SquashTmIntegration|Update Squash TM requirements when GitLab issues are modified.":["Squash TM-Anforderungen aktualisieren, wenn GitLab-Tickets ge\xe4ndert werden."],"Squashing combines multiple commits into a single commit on merge. This keeps your repository history clean and makes it easier to revert changes.":["Beim Squashen werden beim Zusammenf\xfchren mehrere Commits in einem Commit kombiniert. Somit bleibt dein Repository-Verlauf \xfcberschaubar und \xc4nderungen k\xf6nnen leichter r\xfcckg\xe4ngig gemacht werden."],"Stack trace":["Nachverfolgung von Verarbeitungsstapeln"],Stage:["Phase"],"Stage: %{stageName}":["Phase: %{stageName}"],Standard:["Standard"],Star:["Favorit","Favoriten"],"Star count":["Anzahl der Sterne"],"Star labels to start sorting by priority.":["Markiere Labels, um die Sortierung nach Priorit\xe4t zu starten."],Starred:["Favorit"],"Starred Projects":["Markierte Projekte"],"Starred Projects' Activity":["Aktivit\xe4t markierter Projekte"],"Starred projects":["Markierte Projekte"],Starrers:["Markierende"],Stars:["Sterne"],"Start Date":["Startdatum"],"Start Time":["Startzeit"],"Start a %{new_merge_request} with these changes":["%{new_merge_request} mit diesen \xc4nderungen"],"Start a Free Ultimate Trial":["Kostenlose Ultimate-Testversion beginnen"],"Start a review":["Review starten"],"Start a trial":["Kostenlose Testversion starten"],"Start another thread":["Weiteren Thread starten"],"Start by choosing a group to start exploring the merge requests in that group. You can then proceed to filter by projects, labels, milestones and authors.":["Beginne mit der Auswahl einer Gruppe, um die Merge Requests in dieser Gruppe zu erkunden. Du kannst dann nach Projekten, Etiketts, Meilensteinen und Autoren filtern."],"Start cleanup":["Bereinigung starten"],"Start date":["Startdatum"],"Start date:":["Startdatum:"],"Start free trial":["Kostenlose Testversion starten"],"Start internal thread":["Internen Thread starten"],"Start merge train":["Merge-Zug starten"],"Start merge train\u2026":["Merge-Zug starten\xa0\u2026"],"Start review":["Review starten"],"Start search":["Suche starten"],"Start thread":["Unterhaltung starten"],"Start time":["Startzeit"],"Start your free trial":["Kostenlose Testversion starten"],Started:["Begonnen"],"Started %{startDate}":["Begonnen am %{startDate}"],"Started %{startsIn}":["%{startsIn} gestartet"],"Started asynchronous removal of all repository check states.":["Asynchrone Entfernung aller Repository-Pr\xfcfstatus gestartet"],"Started escalation for this incident.":["Eskalation f\xfcr diesen Vorfall gestartet."],"Starting with GitLab 17.7, OpenSSL 3 will be used. All TLS connections require TLS 1.2 or higher. Weaker ciphers are no longer supported. Encryption must have at least of 112 bits of security. %{link_start}Learn more%{link_end}.":["Ab GitLab\xa017.7 wird OpenSSL\xa03 verwendet. Alle TLS-Verbindungen erfordern TLS\xa01.2 oder h\xf6her. Schw\xe4chere Chiffren werden nicht mehr unterst\xfctzt. Die Verschl\xfcsselung muss ein Sicherheitsniveau von mindestens 112\xa0Bit aufweisen. %{link_start}Mehr erfahren%{link_end}."],Starts:["Beginnt"],"Starts %{startDate}":["Beginnt am %{startDate}"],"Starts %{startsIn}":["Started in %{startsIn}"],"Starts escalations for this incident":["Startet Eskalationen f\xfcr diesen Vorfall"],"Starts on":["Beginnt am"],"Starts: %{startsAt}":["Beginn: %{startsAt}"],State:["Status"],"State or province is required.":["Die Angabe des Bundeslands ist erforderlich."],"State your message to activate":["Gib deine Nachricht an, um sie zu aktivieren"],"Static Application Security Testing (SAST)":["Statische Anwendungssicherheitstests (SAST)"],Statistics:["Statistiken"],Status:["Status"],"Status (optional)":["Status (optional)"],"Status alert":["Statuswarnung"],"Status checks":["Statuspr\xfcfungen"],"Status checks must pass.":["Status\xfcberpr\xfcfungen m\xfcssen bestanden werden."],"Status lists not available with your current license":["Statuslisten sind mit deiner aktuellen Lizenz nicht verf\xfcgbar"],"Status not found for given params":["Status f\xfcr angegebene Parameter nicht gefunden"],"Status not supported":["Status nicht unterst\xfctzt"],"Status page":["Statusseite"],"Status:":["Status:"],"Status: %{status}":["Status: %{status}"],"Status: %{title}":["Status: %{title}"],"StatusChecks|API to check":["Zu \xfcberpr\xfcfende API"],"StatusChecks|Edit secret":["Geheimnis bearbeiten"],"StatusChecks|Enter a new value to overwrite the current secret.":["Gib einen neuen Wert ein, um das aktuelle Geheimnis zu \xfcberschreiben."],"StatusChecks|Examples: QA, Security, Performance.":["Beispiele: QA, Sicherheit. Performance."],"StatusChecks|Invoke an external API as part of the pipeline process.":["Ruft eine externe API als Teil des Pipeline-Prozesses auf."],"StatusChecks|No changes were made to the status check.":["An der Statuspr\xfcfung wurden keine \xc4nderungen vorgenommen."],"StatusChecks|Service name":["Dienstname"],"StatusChecks|Unable to create status check. Please try again.":["Statuspr\xfcfung konnte nicht erstellt werden. Bitte erneut versuchen."],"StatusChecks|Unable to delete status check. Please try again.":["Statuspr\xfcfung konnte nicht gel\xf6scht werden. Bitte erneut versuchen."],"StatusChecks|Unable to update status check. Please try again.":["Statuspr\xfcfung konnte nicht aktualisiert werden. Bitte erneut versuchen."],"StatusCheck|%{failed} failed":["%{failed} fehlgeschlagen"],"StatusCheck|%{pending} pending":["%{pending} ausstehend"],"StatusCheck|A secret is currently configured for this status check.":["F\xfcr diese Statuspr\xfcfung ist derzeit ein Geheimnis konfiguriert."],"StatusCheck|API to check":["Zu \xfcberpr\xfcfende API"],"StatusCheck|Add status check":["Statuspr\xfcfung hinzuf\xfcgen"],"StatusCheck|An error occurred deleting the %{name} status check.":["Beim L\xf6schen der %{name}-Statuspr\xfcfung ist ein Fehler aufgetreten."],"StatusCheck|An error occurred fetching the status checks.":["Beim Abrufen der Statuspr\xfcfungen ist ein Fehler aufgetreten."],"StatusCheck|Apply this status check to all branches or a specific protected branch.":["Wende diese Statuspr\xfcfung auf alle Branches oder einen bestimmten gesch\xfctzten Branch an."],"StatusCheck|Check for a status response in merge requests. %{linkStart}Learn more%{linkEnd}.":["Pr\xfcfe auf eine Statusantwort in Merge Requests. %{linkStart}Mehr erfahren%{linkEnd}."],"StatusCheck|Collapse status checks":[""],"StatusCheck|Delete status check":["Statuspr\xfcfung l\xf6schen"],"StatusCheck|Delete status check?":["Statuspr\xfcfung l\xf6schen?"],"StatusCheck|Examples: QA, Security.":["Beispiele: QA, Sicherheit."],"StatusCheck|Expand status checks":[""],"StatusCheck|External API is already in use.":["Die externe API wird bereits verwendet."],"StatusCheck|Failed to load status checks":["Fehler beim Laden der Statuspr\xfcfungen"],"StatusCheck|HMAC Shared Secret":["HMAC geteiltes Geheimnis"],"StatusCheck|Invoke an external API as part of the pipeline.":["Ruft eine externe API als Teil der Pipeline auf."],"StatusCheck|Name already exists.":["Der Name existiert bereits."],"StatusCheck|No status checks are defined yet.":["Es wurden noch keine Statuspr\xfcfungen definiert."],"StatusCheck|Please provide a name.":["Gib einen Namen an."],"StatusCheck|Please provide a valid URL.":["Gib eine URL an."],"StatusCheck|Provide a shared secret. This secret is used to authenticate requests for a status check using HMAC.":["Gib ein geteiltes Geheimnis an. Dieses Geheimnis wird zur Authentifizierung von Anfragen f\xfcr eine Statuspr\xfcfung mit HMAC verwendet."],"StatusCheck|Service name":["Dienstname"],"StatusCheck|Shared secret cannot be longer than 255 characters.":["Das geteilte Geheimnis darf nicht l\xe4nger als 255\xa0Zeichen sein."],"StatusCheck|Status Check ID":["Status\xfcberpr\xfcfungs-ID"],"StatusCheck|Status checks":["Status\xfcberpr\xfcfungen"],"StatusCheck|Status checks all passed":["Alle Status\xfcberpr\xfcfungen bestanden"],"StatusCheck|Status checks are API calls to external systems that request the status of an external requirement.":["Status\xfcberpr\xfcfungen sind API-Aufrufe an externe Systeme, die den Status einer externen Anforderung anfragen."],"StatusCheck|Status checks are being fetched":["Status\xfcberpr\xfcfungen werden abgerufen"],"StatusCheck|Status to check":["Zu pr\xfcfender Status"],"StatusCheck|Target branch":["Zielbranch"],"StatusCheck|The specified external API is already in use by another status check.":["Die angegebene externe API wird bereits von einer anderen Statuspr\xfcfung verwendet."],"StatusCheck|URL parameters are hidden for security reasons. For details of URL parameters, see the configuration for the status check service.":["Die URL-Parameter sind aus Sicherheitsgr\xfcnden ausgeblendet. Weitere Informationen zu den URL-Parametern findest du in der Konfiguration des Statuspr\xfcfungsdienstes."],"StatusCheck|Update status check":["Statuspr\xfcfung aktualisieren"],"StatusCheck|What is status check?":["Was ist eine Statuspr\xfcfung?"],"StatusCheck|You are about to delete the %{name} status check.":["Du bist dabei, die Statuspr\xfcfung %{name} zu entfernen."],"StatusPage|AWS %{docsLink}":["AWS %{docsLink}"],"StatusPage|AWS Secret access key":["AWS Geheimer Zugriffsschl\xfcssel"],"StatusPage|AWS access key ID":["AWS Zugriffsschl\xfcssel ID"],"StatusPage|AWS region":["AWS Region"],"StatusPage|Active":["Aktiv"],"StatusPage|Bucket %{docsLink}":["Bucket %{docsLink}"],"StatusPage|Configure file storage settings to link issues in this project to an external status page.":["Konfiguriere die Dateispeichereinstellungen, um Tickets in diesem Projekt mit einer externen Statusseite zu verkn\xfcpfen."],"StatusPage|S3 Bucket name":["S3-Bucket-Name"],"StatusPage|Status page":["Statusseite"],"StatusPage|Status page URL":["URL der Statusseite"],"StatusPage|To publish incidents to an external status page, GitLab stores a JSON file in your Amazon S3 account at a location that your external status page service can access. Make sure to also set up %{docsLink}":["Um Vorf\xe4lle auf einer externen Statusseite zu ver\xf6ffentlichen, speichert GitLab eine JSON-Datei in deinem Amazon S3-Konto an einem Ort, auf den dein externer Statusseitendienst zugreifen kann. Stelle sicher, dass du auch die %{docsLink} einrichtest"],"StatusPage|configuration documentation":["Konfigurationsdokumentation"],"StatusPage|your status page frontend.":["Dein Statusseiten-Frontend"],Step:["Schritt"],"Step %{currentStep}":["Schritt %{currentStep}"],"Step %{currentStep} of %{stepCount}":["Schritt %{currentStep} von %{stepCount}"],"Step %{currentStep} of %{stepsTotal}":["Schritt %{currentStep} von %{stepsTotal}"],"Step %{step}":["Schritt %{step}"],"Step 1.":["Schritt 1."],"Step 2.":["Schritt 2."],"Step 3.":["Schritt 3."],"Step 4.":["Schritt 4."],"Step-up authentication already completed":["Step-up-Authentifizierung bereits abgeschlossen"],"Step-up authentication required":["Step-up-Authentifizierung erforderlich"],"Step-up authentication required.":["Step-up-Authentifizierung erforderlich."],"Step-up authentication session has expired. Please authenticate again.":["Die Step-up-Authentifizierungssitzung ist abgelaufen. F\xfchre erneut eine Authentifizierung durch."],"Still loading\u2026":["L\xe4dt noch\xa0\u2026"],"Stop impersonating":["Identit\xe4tswechsel stoppen"],"Stop this environment":["Stoppe diese Umgebung"],Stopped:["Gestoppt"],Storage:["Speicherplatz"],"Storage nodes for new repositories":["Speicherknoten f\xfcr neue Repositorys"],"Storage size":["Speicherkapazit\xe4t"],"Storage:":["Speicher:"],"StorageSize|Unknown":["Unbekannt"],"Stored version":["Gespeicherte Version"],"Strikethrough (%{modifierKey}%{shiftKey}X)":["Durchstreichen (%{modifierKey}%{shiftKey}X)"],"Strikethrough text":["Durchgestrichener Text"],Structural:["Strukturell"],"Sub-batch size":["Gr\xf6\xdfe der Teilcharge"],"Subdomains of the Pages root domain %{root_domain} are reserved and cannot be used as custom Pages domains.":["Subdomains der Pages-Stammdomain %{root_domain} sind reserviert und k\xf6nnen nicht als benutzerdefinierte Pages-Domains verwendet werden."],"Subgroup information":["Untergruppeninformation"],"Subgroup milestone":["Untergruppenmeilenstein"],"Subgroup navigation":["Untergruppennavigation"],"SubgroupCreationLevel|Roles allowed to create subgroups":["Rollen, die Untergruppen erstellen d\xfcrfen"],"SubgroupCreationlevel|Maintainers":["Betreuer(innen)"],"SubgroupCreationlevel|Owners":["Eigent\xfcmer(innen)"],Subgroups:["Untergruppen"],"Subgroups and projects":["Untergruppen und Projekte"],Subject:["Betreff"],"Subject Key Identifier:":["Schl\xfcsselkennung des Antragstellers:"],"Subkeys:":["Unterschl\xfcssel:"],Submit:["Absenden"],"Submit a review":["Eine Bewertung absenden"],"Submit as ham":["Als Ham absenden"],"Submit as spam":["Als Spam einreichen"],"Submit feedback and approve these changes.":["Feedback abgeben und diese \xc4nderungen genehmigen."],"Submit feedback that should be addressed before merging.":["Feedback abgeben, das vor dem Zusammenf\xfchren ber\xfccksichtigt werden sollte."],"Submit general feedback without explicit approval.":["Allgemeines Feedback ohne ausdr\xfcckliche Genehmigung abgeben."],"Submit review":["Review senden"],"Submit search":["Suche ausf\xfchren"],"Submit the current review.":["\xdcbermittle das aktuelle Review."],"Submit your review":["Review absenden"],"Submit/save changes":["\xc4nderungen absenden/speichern"],"Submitted as ham":["Als Ham abgesendet"],"Submitted the current review.":["Aktuelles Review wurde \xfcbermittelt."],Subscribe:["Abonnieren"],"Subscribe at group level":["Abonniere auf Gruppenebene"],"Subscribe at project level":["Abonniere auf Projektebene"],"Subscribe to RSS feed":["RSS-Feed abonnieren"],"Subscribe to calendar":["Kalender abonnieren"],"Subscribe to releases RSS feed":["RSS-Feed zu Releases abonnieren"],Subscribed:["Abonniert"],"Subscribed saved view limit exceeded.":["Limit f\xfcr abonnierte gespeicherte Ansichten \xfcberschritten."],"Subscribed to notifications.":["Benachrichtigungen abonniert."],"Subscribes to notifications.":["Abonniert Benachrichtigungen."],Subscription:["Abonnement"],"Subscription History":["Abonnementverlauf"],"Subscription can be synchronized.":["Abonnement kann synchronisiert werden."],"Subscription deletion failed.":["L\xf6schen des Abonnements fehlgeschlagen."],"Subscription for this instance cannot be synchronized. Contact GitLab customer support to obtain a license.":["Das Abonnement f\xfcr diese Instanz kann nicht synchronisiert werden. Wende dich an den GitLab-Kundensupport, um eine Lizenz zu erhalten."],"Subscription for this instance cannot be synchronized. Contact GitLab customer support to upgrade your license.":["Das Abonnement f\xfcr diese Instanz kann nicht synchronisiert werden. Wende dich an den GitLab-Kundensupport, um deine Lizenz zu aktualisieren."],"Subscription has not been synchronized recently. %{cta}":["Das Abonnement wurde in letzter Zeit nicht synchronisiert. %{cta}"],"Subscription has not yet been synchronized. %{cta}":["Das Abonnement wurde noch nicht synchronisiert. %{cta}"],"Subscription service outage":["Ausfall des Abonnementdienstes"],"Subscription successfully created.":["Abonnement erfolgreich erstellt."],"Subscription successfully deleted.":["Abonnement erfolgreich gel\xf6scht."],"Subscription synchronized successfully.":["Abonnement erfolgreich synchronisiert."],"SubscriptionBanner|Add new license":["Neue Lizenz hinzuf\xfcgen"],"SubscriptionBanner|Export license usage file":["Lizenznutzungsdatei exportieren"],"SubscriptionBanner|Upload new license":["Neue Lizenz hochladen"],"SubscriptionGroupsNew|Group URL %{error}":["Gruppen-URL %{error}"],"SubscriptionGroupsNew|Group name %{error}":["Gruppenname %{error}"],"SubscriptionGroupsNew|Select a group for your %{planName} subscription":["Gruppe f\xfcr dein %{planName}-Abonnement ausw\xe4hlen"],"SubscriptionGroupsNew|Select a group for your subscription.":["W\xe4hle eine Gruppe f\xfcr dein Abonnement."],"SubscriptionGroupsNew|The group does not have an active subscription with GitLab Credits":[""],"SubscriptionGroupsNew|The group is a top-level group on a Free tier":["Die Gruppe ist eine Hauptgruppe im kostenlosen Tarif"],"SubscriptionGroupsNew|Why can't I find my group?":["Warum kann ich meine Gruppe nicht finden?"],"SubscriptionGroupsNew|You're assigned the Owner role of the group":["Dir wurde die Eigent\xfcmerrolle f\xfcr die Gruppe zugewiesen"],"SubscriptionGroupsNew|Your group will be created at:":["Deine Gruppe wird erstellt unter:"],"SubscriptionGroupsNew|Your group will only be displayed in the list above if:":["Deine Gruppe wird in der obigen Liste nur angezeigt, wenn:"],"SubscriptionManagement|Changes to subscriptions from GitLab partners require assistance":["\xc4nderungen an Abonnements von GitLab-Partnern erfordern Hilfe"],"SubscriptionManagement|This subscription is managed through a GitLab Partner. To make changes to the subscription, contact the partner.":["Dieses Abonnement wird von einem GitLab-Partner verwaltet. Bitte wende dich an den Partner, um \xc4nderungen am Abonnement vorzunehmen."],"SubscriptionTableRow|*Access temporarily extended until %{temporaryExtensionEndDate}":["*Der Zugriff wurde vor\xfcbergehend verl\xe4ngert bis %{temporaryExtensionEndDate}"],"SubscriptionTable|Add seats":["Pl\xe4tze hinzuf\xfcgen"],"SubscriptionTable|An error occurred while loading the subscription details.":["Beim Laden der Abonnementdetails ist ein Fehler aufgetreten."],"SubscriptionTable|Billing":["Abrechnung"],"SubscriptionTable|Free":["Kostenlos"],"SubscriptionTable|GitLab allows you to continue using your subscription even if you exceed the number of seats you purchased. You will be required to pay for these seats upon renewal.":["Du kannst dein GitLab-Abonnement weiterhin nutzen, auch wenn du die Anzahl der erworbenen Pl\xe4tze \xfcberschritten hast. Diese Pl\xe4tze werden bei der Erneuerung mit abgerechnet."],"SubscriptionTable|Last updated at %{seatsLastUpdated} UTC":["Zuletzt aktualisiert um %{seatsLastUpdated} UTC"],"SubscriptionTable|Manage":["Verwalten"],"SubscriptionTable|Max seats used":["Maximale Anzahl genutzter Pl\xe4tze"],"SubscriptionTable|Next invoice":["N\xe4chste Rechnung"],"SubscriptionTable|Next subscription term start date":["Startdatum des Abonnements"],"SubscriptionTable|Refresh Seats":["Pl\xe4tze aktualisieren"],"SubscriptionTable|Renew":["Verl\xe4ngern"],"SubscriptionTable|Seats currently in use":["Aktuell genutzte Pl\xe4tze"],"SubscriptionTable|Seats in subscription":["Pl\xe4tze im Abonnement"],"SubscriptionTable|Seats owed":["\xdcberzogene Pl\xe4tze"],"SubscriptionTable|See usage":["Nutzung anzeigen"],"SubscriptionTable|Something went wrong trying to refresh seats":["Beim Versuch, die Pl\xe4tze zu aktualisieren, ist etwas schiefgelaufen"],"SubscriptionTable|Subscription end date":["Enddatum des Abonnements"],"SubscriptionTable|Subscription start date":["Startdatum des Abonnements"],"SubscriptionTable|This is the maximum number of users that have existed at the same time since this subscription started.":["Dies ist die maximale Anzahl parallel existierender Benutzer(innen), seitdem dieses Abonnement erstellt wurde."],"SubscriptionTable|This is the next date when the GitLab.com team is scheduled to get in contact with you to settle any outstanding balances.":["Dies ist das n\xe4chste Datum, an dem sich das GitLab.com-Team wegen der Begleichung ausstehender Betr\xe4ge an dich wenden wird."],"SubscriptionTable|This is the number of seats you will be required to purchase if you update to a paid plan.":["Dies ist die Anzahl der Pl\xe4tze, die du bei einem Update auf einen zahlungspflichtigen Tarif kaufen musst."],"SubscriptionTable|Trial":["Testversion"],"SubscriptionTable|Trial end date":["Enddatum der Testversion"],"SubscriptionTable|Trial start date":["Startdatum der Testversion"],"SubscriptionTable|Up to date":["Auf dem neuesten Stand"],"SubscriptionTable|Usage":["Verwendung"],"SubscriptionTable|Usage count is performed once a day at 12:00 PM.":["Die Nutzungsz\xe4hlung wird t\xe4glich um 12:00 Uhr durchgef\xfchrt."],Subscriptions:["Abonnements"],"Subscriptions|Activation date":["Aktivierungsdatum"],"Subscriptions|End date":["Enddatum"],"Subscriptions|End date:":["Enddatum:"],"Subscriptions|Last sync":["Letzte Synchronisierung"],"Subscriptions|None":["Keine"],"Subscriptions|Start date":["Startdatum"],"Subscription|Your subscription for %{strong}%{namespace_name}%{strong_close} has expired and you are now on %{pricing_link_start}the GitLab Free tier%{pricing_link_end}. Don't worry, your data is safe. Get in touch with our support team (%{support_email}). They'll gladly help with your subscription renewal.":["Dein Abonnement f\xfcr %{strong}%{namespace_name}%{strong_close} ist abgelaufen und du nutzt jetzt die %{pricing_link_start}kostenlose Stufe von GitLab%{pricing_link_end}. Mach dir keine Sorgen, deine Daten sind sicher. Wende dich an unser Support-Team (%{support_email}). Es hilft dir gerne bei der Erneuerung deines Abonnements."],Subtracted:["Subtrahiert"],Subtracts:["Subtrahiert"],Succeeded:["Erfolgreich"],Success:["Erfolg"],"Successful: %{successful}":["Erfolgreich: %{successful}"],"Successfully activated":["Erfolgreich aktiviert"],"Successfully approved":["Erfolgreich genehmigt"],"Successfully banned":["Erfolgreich gesperrt"],"Successfully blocked":["Erfolgreich gesperrt"],"Successfully confirmed":["Erfolgreich best\xe4tigt"],"Successfully connected to MCP server":[""],"Successfully created connection for semantic search. Indexing will start soon.":["Verbindung f\xfcr die semantische Suche erfolgreich erstellt. Indizierung beginnt demn\xe4chst."],"Successfully deactivated":["Erfolgreich deaktiviert"],"Successfully deleted WebAuthn device.":["Das WebAuthn-Ger\xe4t wurde erfolgreich gel\xf6scht."],"Successfully deleted requirement statuses":["Anforderungsstatus erfolgreich gel\xf6scht"],"Successfully deleted requirement statuses.":["Anforderungsstatus wurden erfolgreich gel\xf6scht."],"Successfully linked ID(s): %{item_ids}.":["ID(s) erfolgreich verkn\xfcpft: %{item_ids}."],"Successfully regenerated unique domain":["Individuelle Domain erfolgreich neu generiert"],"Successfully removed email.":["E-Mail erfolgreich entfernt."],"Successfully scheduled a pipeline to run. Go to the %{pipelines_link_start}Pipelines page%{pipelines_link_end} for details.":["Eine Pipeline-Ausf\xfchrung wurde erfolgreich geplant. Weitere Informationen findest du auf der %{pipelines_link_start}Seite \u201ePipelines\u201c%{pipelines_link_end}."],"Successfully synced %{synced_timeago}.":["%{synced_timeago} erfolgreich synchronisiert."],"Successfully trusted":["Erfolgreich als vertrauensw\xfcrdig eingestuft"],"Successfully unbanned":["Erfolgreich entsperrt"],"Successfully unblocked":["Erfolgreich gesperrt"],"Successfully unlinked IDs: %{item_ids}.":["Die Verkn\xfcpfung der folgenden IDs wurde erfolgreich aufgehoben: %{item_ids}."],"Successfully unlocked":["Erfolgreich entsperrt"],"Successfully untrusted":["Erfolgreich als nicht vertrauensw\xfcrdig eingestuft"],"Successfully updated %{last_updated_timeago}.":["%{last_updated_timeago} erfolgreich aktualisiert."],"Suggested change":["Vorgeschlagene \xc4nderung"],"SuggestedColors|Blue":["Blau"],"SuggestedColors|Blue-gray":["Blaugrau"],"SuggestedColors|Carrot orange":["Karottenorange"],"SuggestedColors|Charcoal grey":["Anthrazit"],"SuggestedColors|Crimson":["Purpur"],
"SuggestedColors|Current addition color":["Aktuelle Zusatzfarbe"],"SuggestedColors|Current removal color":["Aktuelle Farbe f\xfcr das Entfernen"],"SuggestedColors|Dark coral":["Korallenfarben"],"SuggestedColors|Dark sea green":["Dunkles Meeresgr\xfcn"],"SuggestedColors|Dark violet":["Dunkles Violett"],"SuggestedColors|Deep violet":["Tiefes Violett"],"SuggestedColors|Default addition color":["Standardfarbe f\xfcr das Hinzuf\xfcgen"],"SuggestedColors|Default removal color":["Standardfarbe f\xfcr das Entfernen"],"SuggestedColors|Gray":["Grau"],"SuggestedColors|Green-cyan":["Gr\xfcnblau"],"SuggestedColors|Lavender":["Lavendel"],"SuggestedColors|Magenta-pink":["Magenta-Pink"],"SuggestedColors|Orange":["Orange"],"SuggestedColors|Rose red":["Rosenrot"],"SuggestedColors|Titanium yellow":["Titangelb"],"SuggestedReviewers|Get suggestions for reviewers based on GitLab's machine learning tool.":["Erhalte Vorschl\xe4ge f\xfcr Reviewer basierend auf dem maschinellen Lerntool von GitLab."],"SuggestedReviewers|Learn about suggested reviewers":["Erfahre mehr \xfcber vorgeschlagene Pr\xfcfer(innen)"],"SuggestedReviewers|Suggested reviewers":["Vorgeschlagene Pr\xfcfer(innen)"],"SuggestedReviewers|Suggested reviewers help link":["Hilfelink f\xfcr vorgeschlagene Pr\xfcfer(innen)"],"SuggestedReviewers|Suggestions appear in the Reviewer section of the right sidebar":["Vorschl\xe4ge erscheinen im Reviewer-Bereich in der rechten Seitenleiste"],"Suggestion is not applicable as the suggestion was not found.":["Vorschlag wurde nicht gefunden und kann nicht angewendet werden."],"Suggestion(s)":["Vorschl\xe4ge"],Suggestions:["Vorschl\xe4ge"],"Suggestions accepted":["Vorschl\xe4ge angenommen"],"Suggestions are not applicable as one or more suggestions were not found.":["Vorschl\xe4ge k\xf6nnen nicht angewendet werden, da mindestens ein Vorschlag nicht gefunden wurde."],"Suggestions are not applicable as their lines cannot overlap.":["Vorschl\xe4ge k\xf6nnen nicht angewendet werden, da sich die entsprechenden Zeilen nicht \xfcberschneiden d\xfcrfen."],"Suggestions content placeholder":["Inhaltsplatzhalter f\xfcr Vorschl\xe4ge"],"Suggestions must all be on the same branch.":["Vorschl\xe4ge m\xfcssen sich alle auf demselben Branch befinden."],"Suggestions:":["Vorschl\xe4ge:"],Suite:["Suite"],"Summarize code changes":["Code\xe4nderungen zusammenfassen"],"Summarize the comments in the current issue.":["Fasse die Kommentare des aktuellen Tickets zusammen."],Summary:["Zusammenfassung"],"Summary generated by AI":["Zusammenfassung generiert von KI"],"Summary:":["Zusammenfassung:"],Sun:["So"],Sunday:["Sonntag"],"SuperSonics|Activate subscription":["Abonnement aktivieren"],"SuperSonics|Activation code":["Aktivierungscode"],"SuperSonics|Activation not possible due to seat mismatch":["Aktivierung aufgrund von Unstimmigkeiten im Zusammenhang mit Pl\xe4tzen nicht m\xf6glich"],"SuperSonics|Activation not possible due to true-up value mismatch":["Aktivierung aufgrund von Unstimmigkeiten in True-Up-Werten nicht m\xf6glich"],"SuperSonics|Add activation code":["Aktivierungscode hinzuf\xfcgen"],"SuperSonics|An error occurred during activation":["Bei der Aktivierung ist ein Fehler aufgetreten"],"SuperSonics|Cannot activate instance due to a connectivity issue":["Instanz kann aufgrund eines Verbindungsproblems nicht aktiviert werden"],"SuperSonics|Could not activate subscription":["Abonnement konnte nicht aktiviert werden"],"SuperSonics|Enter activation code":["Aktivierungscode eingeben"],"SuperSonics|Export license usage file":["Lizenznutzungsdatei exportieren"],"SuperSonics|I agree that my use of the GitLab Software is subject to the Subscription Agreement located at the %{linkStart}Terms of Service%{linkEnd}, unless otherwise agreed to in writing with GitLab.":["Ich erkl\xe4re mich damit einverstanden, dass meine Nutzung der GitLab-Software dem Abonnementvertrag unterliegt, der sich in den %{linkStart}Nutzungsbedingungen%{linkEnd} befindet, es sei denn, mit GitLab wurde schriftlich etwas anderes vereinbart."],"SuperSonics|Learn how to %{linkStart}activate your subscription%{linkEnd}.":["Erfahre, wie du %{linkStart}dein Abonnement aktivierst%{linkEnd}."],"SuperSonics|Learn more about %{activationLinkStart}activating your subscription%{activationLinkEnd}. If you need further assistance, %{supportLinkStart}contact GitLab Support%{supportLinkEnd}.":["Erfahre mehr dar\xfcber, wie du dein %{activationLinkStart}Abonnement aktivierst%{activationLinkEnd}. Wenn du weitere Hilfe ben\xf6tigst, %{supportLinkStart}wende dich an den GitLab-Support%{supportLinkEnd}."],"SuperSonics|Licensed to":["Lizenziert f\xfcr"],"SuperSonics|Offline license":["Offline-Lizenz"],"SuperSonics|Online license":["Online-Lizenz"],"SuperSonics|Received a license key? %{linkStart}Go to license settings%{linkEnd} to add it to your GitLab instance.":["Hast du einen Lizenzschl\xfcssel erhalten? %{linkStart}\xd6ffne die Lizenzeinstellungen%{linkEnd}, um ihn deiner GitLab-Instanz hinzuzuf\xfcgen."],"SuperSonics|Select that you agree before activating the subscription.":["Erteile deine Zustimmung, bevor du das Abonnement aktivierst."],"SuperSonics|Subscription":["Abonnement"],"SuperSonics|Subscription cannot be activated if %{silentModeDocsLinkStart}Silent Mode%{silentModeDocsLinkEnd} is enabled. Disable Silent Mode and try again.":["Das Abonnement kann nicht aktiviert werden, wenn %{silentModeDocsLinkStart}Stiller Modus%{silentModeDocsLinkEnd} aktiviert ist. Deaktiviere \u201eStiller Modus\u201c und versuche es erneut."],"SuperSonics|Subscription detail synchronization has started and will complete soon.":["Die Synchronisierung der Abonnementdetails wurde gestartet und wird in K\xfcrze abgeschlossen."],"SuperSonics|Subscription details":["Abonnementdetails"],"SuperSonics|Subscription details did not synchronize due to a possible connectivity issue with GitLab servers. %{connectivityHelpLinkStart}How do I check connectivity%{connectivityHelpLinkEnd}?":["Die Abonnementdetails wurden aufgrund eines m\xf6glichen Konnektivit\xe4tsproblems mit den GitLab-Servern nicht synchronisiert. %{connectivityHelpLinkStart}Wie kann ich die Konnektivit\xe4t pr\xfcfen%{connectivityHelpLinkEnd}?"],"SuperSonics|Subscription unavailable":["Abonnement nicht verf\xfcgbar"],"SuperSonics|Sync subscription details":["Abonnementdetails synchronisieren"],"SuperSonics|Synchronization started":["Synchronisierung gestartet"],"SuperSonics|The activation code is not valid. Please make sure to copy it exactly from the Customers Portal or confirmation email. Learn more about %{linkStart}activating your subscription%{linkEnd}.":["Der Aktivierungscode ist nicht g\xfcltig. Bitte kopiere ihn genau aus dem Kundenportal oder aus der Best\xe4tigungs-E-Mail. Erfahre mehr \xfcber die %{linkStart}Aktivierung deines Abonnements%{linkEnd}."],"SuperSonics|The activation code should be a 24-character alphanumeric string":["Der Aktivierungscode sollte eine 24-stellige alphanumerische Zeichenfolge sein"],"SuperSonics|There is a connectivity issue":["Ein Verbindungsproblem ist aufgetreten."],"SuperSonics|To activate your subscription, your instance needs to connect to GitLab. %{learnMoreLinkStart}Learn more%{learnMoreLinkEnd}.":["Um dein Abonnement zu aktivieren, musst du dich mit GitLab verbinden. %{learnMoreLinkStart}Mehr erfahren%{learnMoreLinkEnd}."],"SuperSonics|You can %{purchaseSubscriptionLinkStart}purchase a new subscription%{purchaseSubscriptionLinkEnd} and try again. If you need further assistance, please %{supportLinkStart}contact GitLab Support%{supportLinkEnd}.":["Du kannst ein %{purchaseSubscriptionLinkStart}neues Abonnement kaufen%{purchaseSubscriptionLinkEnd} und es erneut versuchen. Wenn du weitere Hilfe ben\xf6tigst, %{supportLinkStart}wende dich bitte an den GitLab-Support%{supportLinkEnd}."],"SuperSonics|You can sync your subscription data to ensure your details are up to date.":["Synchronisiere deine Abonnementdaten, um sicherzustellen, dass deine Details auf dem neuesten Stand sind."],"SuperSonics|You have a future dated license":["Du hast eine Lizenz mit einem zuk\xfcnftigen Datum"],"SuperSonics|You have added a license that activates on %{date}. Please see the subscription history table below for more details.":["Du hast erfolgreich eine Lizenz hinzugef\xfcgt, die am %{date} aktiviert wird. Weitere Informationen findest du in der folgenden Tabelle des Abonnementverlaufs."],"SuperSonics|You have applied a true-up for %{trueUpQuantity} %{trueUpQuantityUsers} but you need one for %{expectedTrueUpQuantity} %{expectedTrueUpQuantityUsers}. To pay for seat overages, contact your sales representative. For further assistance, contact %{licenseSupportLinkStart}GitLab support%{licenseSupportLinkEnd}.":["Du hast ein True-Up f\xfcr %{trueUpQuantity} %{trueUpQuantityUsers} beantragt, du ben\xf6tigst jedoch auch ein True-Up f\xfcr %{expectedTrueUpQuantity} %{expectedTrueUpQuantityUsers}. Wende dich an deinen Vertriebskontakt, um weitere Pl\xe4tze zu erwerben. Falls du weitere Hilfe ben\xf6tigst, wende dich an den %{licenseSupportLinkStart}GitLab-Support%{licenseSupportLinkEnd}."],"SuperSonics|You have successfully added a license that activates on %{date}. Please see the subscription history table below for more details.":["Du hast erfolgreich eine Lizenz hinzugef\xfcgt, die am %{date} aktiviert wird. Weitere Informationen findest du in der folgenden Tabelle des Abonnementverlaufs."],"SuperSonics|You may have entered an expired or ineligible activation code. To request a new activation code, %{purchaseSubscriptionLinkStart}purchase a new subscription%{purchaseSubscriptionLinkEnd} or %{supportLinkStart}contact GitLab Support%{supportLinkEnd} for further assistance.":["M\xf6glicherweise hast du einen abgelaufenen oder ung\xfcltigen Aktivierungscode eingegeben. Falls du einen neuen Aktivierungscode ben\xf6tigst, %{purchaseSubscriptionLinkStart}kaufe ein neues Abonnement%{purchaseSubscriptionLinkEnd} oder %{supportLinkStart}wende dich an den GitLab-Support%{supportLinkEnd}, um weitere Hilfe zu erhalten."],"SuperSonics|Your %{subscriptionEntryName} cannot be displayed at the moment. Please refresh the page to try again.":["Dein %{subscriptionEntryName} kann derzeit nicht angezeigt werden. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"SuperSonics|Your current GitLab installation has %{userCount} active %{userCountUsers}, which exceeds your new subscription seat count of %{licenseUserCount} by %{overageCount}. To activate your new subscription, %{purchaseLinkStart}purchase%{purchaseLinkEnd} an additional %{overageCount} %{overageCountSeats}, or %{deactivateLinkStart}deactivate%{deactivateLinkEnd} or %{blockLinkStart}block%{blockLinkEnd} %{overageCount} %{overageCountUsers}. For further assistance, contact %{licenseSupportLinkStart}GitLab support%{licenseSupportLinkEnd}.":["Deine aktuelle GitLab-Installation umfasst %{userCount} aktive %{userCountUsers}, was deine Anzahl neuer Abonnementpl\xe4tze von %{licenseUserCount} um %{overageCount} \xfcbersteigt. Um dein neues Abonnement zu aktivieren, %{purchaseLinkStart}kaufe%{purchaseLinkEnd} zus\xe4tzliche %{overageCount} %{overageCountSeats} oder %{deactivateLinkStart}deaktiviere%{deactivateLinkEnd} oder %{blockLinkStart}blockiere%{blockLinkEnd} insgesamt %{overageCount} %{overageCountUsers}. Wenn du weitere Hilfe ben\xf6tigst, wende dich an den %{licenseSupportLinkStart}GitLab-Support%{licenseSupportLinkEnd}."],"SuperSonics|Your future dated license was successfully added":["Deine Lizenz mit einem zuk\xfcnftigen Datum wurde erfolgreich hinzugef\xfcgt"],"SuperSonics|Your subscription cannot be located":["Dein Abonnement wurde nicht gefunden."],"SuperSonics|Your subscription is expired":["Dein Abonnement ist abgelaufen"],"SuperSonics|Your subscription was successfully activated. You can see the details below.":["Dein Abonnement wurde erfolgreich aktiviert. Du kannst die Details unten einsehen."],"SuperSonics|current subscription":["aktuelles Abonnement"],"SuperSonics|future subscriptions":["zuk\xfcnftige Abonnements"],"SuperSonics|past subscriptions":["fr\xfchere Abonnements"],Support:["Support"],"Support for custom certificates is disabled. Ask your system's administrator to enable it.":["Die Unterst\xfctzung f\xfcr benutzerdefinierte Zertifikate ist deaktiviert. Bitte deine(n) Systemadministrator(in) um Aktivierung."],"Support page URL":["URL der Support-Seite"],"Switch Branches":["Branches wechseln"],"Switch branch":["Branch wechseln"],"Switch branch/tag":["Zu Branch/Tag wechseln"],"Switch to plain text editing":["Zur Plain-Text-Bearbeitung wechseln"],"Switch to rich text editing":["Zur Rich-Text-Bearbeitung wechseln"],"Switch to the source to copy the file contents":["Wechsle zur Quelle, um den Dateiinhalt zu kopieren."],"Symbolic link":["Symbolischer Link"],"Sync LDAP":["LDAP synchronisieren"],"Sync changes":["\xc4nderungen synchronisieren"],Synced:["Synchronisiert"],Synchronization:["Synchronisierung"],"Synchronize LDAP":["LDAP synchronisieren"],"Synchronize your subscription.":["Synchronisiere dein Abonnement."],"Syncing\u2026":["Synchronisieren\u2026"],"Syntax is correct.":["Syntax ist korrekt."],"Syntax is incorrect.":["Syntax ist falsch."],"SynthaxHighlightingTheme|Dark":["Dunkel"],"SynthaxHighlightingTheme|Light":["Hell"],"SynthaxHighlightingTheme|Monokai":["Monokai"],"SynthaxHighlightingTheme|None":["Keine"],"SynthaxHighlightingTheme|Solarized Dark":["Solarized Dark"],"SynthaxHighlightingTheme|Solarized Light":["Solarized Light"],"System default (%{default})":["Systemstandard (%{default})"],"System default (automatic)":["Systemstandard (automatisch)"],"System exchange":["Systemaustausch"],"System header and footer":["Kopf- und Fu\xdfbereich des Systems"],"System hooks are triggered on sets of events like creating a project or adding an SSH key. You can also enable extra triggers, such as push events.":["System-Hooks werden bei Ereignissen wie dem Erstellen eines Projekts oder dem Hinzuf\xfcgen eines SSH-Schl\xfcssels ausgel\xf6st. Du kannst auch zus\xe4tzliche Ausl\xf6ser aktivieren, wie z.\xa0B. Push-Ereignisse."],"System information":["Systeminformationen"],"System output":["Systemausgabe"],"System started":["System gestartet"],"Systems Administrator":["Systemadministrator(in)"],TXT:["TXT"],Table:["Tabelle"],"Table of contents":["Inhaltsverzeichnis"],"Table size":["Tabellengr\xf6\xdfe"],"Tables containing block elements (like multiple paragraphs, lists or blockquotes, or task lists with text or multiple items) are not supported in Markdown and will be converted to HTML.":["Tabellen, die Blockelemente enthalten (wie mehrere Abs\xe4tze, Listen oder Blockzitate oder Aufgabenlisten mit Text oder mehreren Elementen) werden in Markdown nicht unterst\xfctzt und in HTML konvertiert."],Tag:["Tag"],"Tag does not exist":["Tag existiert nicht"],"Tag list:":["Tag Liste:"],"Tag name":["Tag-Name"],"Tag name cannot be one of the following: %{names}":["Das Tag darf keinen der folgenden Namen aufweisen: %{names}"],"Tag name copied to clipboard.":["Tag-Name in Zwischenablage kopiert."],"Tag name is required.":["Tag-Name ist erforderlich."],"Tag name should not be empty":["Tag-Name darf nicht leer sein"],"Tag name should not contain any control characters":["Tag-Name darf keine Steuerzeichen enthalten"],"Tag name should not contain any of the following: %{substrings}":["Der Tag-Name darf keine der folgenden Zeichenfolgen enthalten: %{substrings}"],"Tag name should not end with %{postfixes}":["Tag-Name darf nicht mit %{postfixes} enden"],"Tag name should not start with %{prefixes}":["Tag-Name darf nicht mit %{prefixes} beginnen"],"Tag push":["Tag-Push"],"Tag push events":["Tag-Push-Ereignisse"],"Tag this commit.":["Diesen Commit kennzeichnen."],'Tagged this commit to %{tag_name} with "%{message}".':["Dieser Commit wurde markiert als %{tag_name} mit \u201e%{message}\u201c."],"Tagged this commit to %{tag_name}.":["Dieser Commit wurde markiert als %{tag_name}."],Tags:["Tags"],"Tags are deleted until the timeout is reached. Any remaining tags are included the next time the policy runs. To remove the time limit, set it to 0.":["Tags werden gel\xf6scht, bis die Zeit\xfcberschreitung erreicht ist. Alle verbleibenden Tags werden beim n\xe4chsten Ausf\xfchren der Richtlinie einbezogen. Lege das Zeitlimit auf 0 fest, um es aufzuheben."],"Tags feed":["Tags-Feed"],'Tags this commit to %{tag_name} with "%{message}".':["Markiert diesen Commit als %{tag_name} mit \u201e%{message}\u201c."],"Tags this commit to %{tag_name}.":["Markiert diesen Commit als %{tag_name}."],"TagsPage|Are you sure you want to delete this tag?":["Willst du diesen Tag wirklich l\xf6schen?"],"TagsPage|Browse commits":["Commits durchsuchen"],"TagsPage|Browse files":["Dateien durchsuchen"],"TagsPage|Can't find HEAD commit for this tag":["HEAD-Commit f\xfcr dieses Tag kann nicht gefunden werden"],"TagsPage|Cancel":["Abbrechen"],"TagsPage|Cancel, keep tag":["Abbrechen, Tag behalten"],"TagsPage|Create release":["Release erstellen"],"TagsPage|Create tag":["Tag erstellen"],"TagsPage|Delete protected tag":["Gesch\xfctzten Tag l\xf6schen"],"TagsPage|Delete tag":["Tag l\xf6schen"],"TagsPage|Deleting the %{strongStart}%{tagName}%{strongEnd} protected tag cannot be undone.":["Das L\xf6schen des gesch\xfctzten Tags %{strongStart}%{tagName}%{strongEnd} kann nicht r\xfcckg\xe4ngig gemacht werden."],"TagsPage|Deleting the %{strongStart}%{tagName}%{strongEnd} tag cannot be undone.":["Das L\xf6schen des Tags %{strongStart}%{tagName}%{strongEnd} kann nicht r\xfcckg\xe4ngig gemacht werden."],"TagsPage|Do you want to create a release with the new tag? You can do that in the %{link_start}new release page%{link_end}.":["M\xf6chtest Du eine Ver\xf6ffentlichung mit dem neuen Tag erstellen? Du kannst das auf %{link_start}der neuen Ver\xf6ffentlichungsseite%{link_end} tun."],"TagsPage|Edit release":["Release bearbeiten"],"TagsPage|Existing branch name, tag, or commit SHA":["Existierender Branch, Tag oder Commit-SHA"],"TagsPage|Filter by tag name":["Filtere nach Tag-Namen"],"TagsPage|New tag":["Neuer Tag"],"TagsPage|Only a project maintainer or owner can delete a protected tag":["Nur ein(e) Projektbetreuer(in) oder -eigent\xfcmer(in) kann ein gesch\xfctztes Tag l\xf6schen"],"TagsPage|Optionally, add a message to the tag. Leaving this blank creates a %{link_start}lightweight tag.%{link_end}":["F\xfcge optional eine Nachricht zum Tag hinzu. Lasse dieses Feld leer, um einen %{link_start}Lightweight-Tag%{link_end} zu erstellen."],"TagsPage|Permanently delete protected tag?":["Gesch\xfctzten Tag dauerhaft l\xf6schen?"],"TagsPage|Permanently delete tag?":["Tag dauerhaft l\xf6schen?"],"TagsPage|Please type the following to confirm:":["Gib zur Best\xe4tigung Folgendes ein:"],"TagsPage|Repository has no tags yet":["Repository hat noch keine Tags"],"TagsPage|Tags":["Tags"],"TagsPage|Tags give the ability to mark specific points in history as being important":["Tags bieten die M\xf6glichkeit, bestimmte Punkte in dem Verlauf als wichtig zu markieren"],"TagsPage|Unable to load tags":["Tags k\xf6nnen nicht geladen werden"],"TagsPage|Use git tag command to add a new one:":["Verwende den Befehl git tag, um einen neuen Tag hinzuzuf\xfcgen:"],"TagsPage|Yes, delete protected tag":["Ja, gesch\xfctzten Tag l\xf6schen"],"TagsPage|Yes, delete tag":["Ja, Tag l\xf6schen"],"TagsPage|protected":["gesch\xfctzt"],"Tailor your views list":["Deine Ansichtenliste anpassen"],"Take a look at the documentation to discover all of GitLab\u2019s capabilities.":["Wirf einen Blick in die Dokumentation, um alle Funktionen von GitLab kennenzulernen."],Target:["Ziel"],"Target ID":["Ziel-ID"],"Target Path":["Zielpfad"],"Target branch":["Zielbranch"],"Target branch (%{branch}): %{pipelines}":["Zielbranch (%{branch}): %{pipelines}"],"Target branch: %{target_branch}":["Zielbranch: %{target_branch}"],"Target branches":["Zielbranches"],"Target group prevents forks that point outside this group":["Zielgruppe verhindert Gruppen-extern ausgerichtete Forks"],"Target project cannot be equal to source project":["Zielprojekt kann nicht gleich dem Quellprojekt sein"],"Target project must belong to source project organization":["Zielprojekt muss zur Organisation des Quellprojekts geh\xf6ren"],"Target roles":["Zielrollen"],"Target type":["Zieltyp"],"Target-Branch":["Zielbranch"],"Targeted Messages":["Zielnachrichten"],"Targeted message":["Gezielte Nachricht"],"TargetedMessages|Are you sure you want to delete this targeted message?":["M\xf6chtest du diese gezielte Nachricht wirklich l\xf6schen?"],"TargetedMessages|Contact us":["Kontaktiere uns"],"TargetedMessages|Create a new targeted message":["Neue gezielte Nachricht erstellen"],"TargetedMessages|Edit targeted message":["Gezielte Nachricht bearbeiten"],"TargetedMessages|Ends at":["Endet bei"],"TargetedMessages|Failed to assign namespaces due to error processing CSV: %{error_message}":["Fehler beim Zuweisen von Namensr\xe4umen aufgrund eines Fehlers bei der CSV-Verarbeitung: %{error_message}"],"TargetedMessages|For a limited time only, new customers can access all the benefits of Premium, plus advanced AI features for just $19. Contact our sales team today to take advantage while this offer lasts!":["Nur f\xfcr begrenzte Zeit k\xf6nnen Neukund(inn)en alle Vorteile von Premium sowie erweiterte KI-Funktionen f\xfcr nur 19\xa0USD nutzen. Kontaktiere noch heute unser Vertriebsteam, um dieses Angebot zu nutzen, solange es gilt!"],"TargetedMessages|Get access to Premium + GitLab Duo for $19 per user/month":["Erhalte Zugriff auf Premium + GitLab Duo f\xfcr 19\xa0USD pro Benutzer(in)/Monat"],"TargetedMessages|Must have at least one targeted namespace":["Muss mindestens einen Ziel-Namensraum haben"],"TargetedMessages|Namespace IDs":["Namensraum-IDs"],"TargetedMessages|New targeted message":["Neue gezielte Nachricht"],"TargetedMessages|Scheduled deletion of targeted message with id: %{id}.":["Geplante L\xf6schung der gezielten Nachricht mit der ID: %{id}."],"TargetedMessages|Select a target type":["Zieltyp ausw\xe4hlen"],"TargetedMessages|Starts at":["Beginnt bei"],"TargetedMessages|Target Type":["Zieltyp"],"TargetedMessages|Targeted message was successfully created.":["Die gezielte Nachricht wurde erfolgreich erstellt."],"TargetedMessages|Targeted message was successfully created. But %{invalid_namespace_ids_message}":["Gezielte Nachricht wurde erfolgreich erstellt. Jedoch: %{invalid_namespace_ids_message}"],"TargetedMessages|Targeted message was successfully updated.":["Die gezielte Nachricht wurde erfolgreich aktualisiert."],"TargetedMessages|Targeted message was successfully updated. But %{invalid_namespace_ids_message}":["Gezielte Nachricht wurde erfolgreich aktualisiert. Jedoch: %{invalid_namespace_ids_message}"],"TargetedMessages|Upload a csv file for targeted namespaces":["CSV-Datei f\xfcr Zielnamensr\xe4ume hochladen"],"TargetedMessages|the following namespace ids were invalid and have been ignored: %{invalid_ids_message}":["die folgenden Namensraum-IDs waren ung\xfcltig und wurden ignoriert: %{invalid_ids_message}"],"TargetedMessage|Namespace IDs are limited to a maximum of %{limit}.":["Das Limit f\xfcr Namensraum-IDs liegt bei %{limit}."],Task:["Aufgabe"],"Task list":["Aufgabenliste"],"Tasks|%{complete_count} of %{total_count} %{checklist_item_noun} completed":["%{complete_count} von %{total_count} %{checklist_item_noun} abgeschlossen"],"Tasks|%{complete_count}/%{total_count} %{checklist_item_noun}":["%{complete_count}/%{total_count} %{checklist_item_noun}"],Team:["Team"],"Team domain":["Team-Domain"],"TeamCityIntegration|A user with permissions to trigger a manual build.":["Ein(e) Benutzer(in) mit Berechtigungen zum Ausl\xf6sen eines manuellen Builds."],"TeamCityIntegration|TeamCity root URL (for example, `https://teamcity.example.com`).":["TeamCity-Root-URL (z.\xa0B. `https://teamcity.example.com`)."],"TeamCityIntegration|The build configuration ID of the TeamCity project.":["Die Build-Konfigurations-ID des TeamCity-Projekts."],"TeamCityIntegration|The password of the user.":["Das Passwort des Benutzers bzw. der Benutzerin."],"TeamcityIntegration|Trigger TeamCity CI after a merge request has been created or updated":["TeamCity-CI ausl\xf6sen, nachdem ein Merge Request erstellt oder aktualisiert wurde"],"TeamcityIntegration|Trigger TeamCity CI after every push to the repository, except branch delete":["TeamCity-CI nach jedem Push an das Repository ausl\xf6sen, au\xdfer bei L\xf6schen eines Branches"],"TelegramIntegration|Leave blank to use your current token.":["Lass dieses Feld leer, um dein aktuelles Token zu verwenden."],"TelegramIntegration|New token":["Neues Token"],"TelegramIntegration|Send notifications about project events to Telegram.":["Sende Benachrichtigungen \xfcber Projektereignisse zu Telegram."],"TelegramIntegration|Unique authentication token.":["Eindeutiges Authentifizierungstoken."],"Telephone number":["Telefonnummer"],"Tell us about your company":["Erz\xe4hle uns von deinem Unternehmen"],Template:["Vorlage"],"Template for GitLab Pages and Astro. Astro is a static site generator written in JavaScript.":["Vorlage f\xfcr GitLab Pages und Astro. Astro ist ein in JavaScript geschriebener Generator f\xfcr statische Sites."],"Template for GitLab Pages and Docusaurus. Docusaurus is a static site generator written in React.":["Vorlage f\xfcr GitLab Pages und Docusaurus. Docusaurus ist ein in React geschriebener Generator f\xfcr statische Sites."],"Template for GitLab Pages and Hugo. Hugo is a static site generator written in Go.":["Vorlage f\xfcr GitLab Pages und Hugo. Hugo ist ein in Go geschriebener Generator f\xfcr statische Sites."],"Template for GitLab Pages and Jekyll. Jekyll is a static site generator written in Ruby.":["Vorlage f\xfcr GitLab Pages und Jekyll. Jekyll ist ein in Ruby geschriebener Generator f\xfcr statische Sites."],"Template for GitLab Pages and Next.js. Next.js is a React framework for building web applications.":["Vorlage f\xfcr GitLab Pages und Next.js. Next.js ist ein React-Framework zum Entwickeln von Webanwendungen."],"Template for GitLab Pages and Nuxt. Nuxt is a Vue framework for building web applications.":["Vorlage f\xfcr GitLab Pages und Nuxt. Nuxt ist ein Vue-Framework zum Entwickeln von Webanwendungen."],"Template for GitLab Pages using plain HTML, CSS, and JavaScript.":["Vorlage f\xfcr GitLab Pages mit einfachem HTML, CSS und JavaScript."],"Template to append to all Service Desk issues":["Vorlage, die an alle Service-Desk-Tickets angeh\xe4ngt werden soll"],"Template: %{title}":["Vorlage: %{title}"],"TemplateRepository|Create common files more quickly, and standardize their format.":["Erstelle schneller gemeinsame Dateien und standardisiere deren Format."],Templates:["Vorlagen"],Terminal:["Konsole"],"Terminal for environment":["Konsole f\xfcr Umgebung"],Terms:["Begriffe"],"Terms and privacy":["Nutzungsbedingungen und Datenschutz"],"Terms of Service Agreement and Privacy Policy":["Nutzungsbedingungen und Datenschutzerkl\xe4rung"],"Terms of Service and Privacy Policy":["Nutzungsbedingungen und Datenschutzerkl\xe4rung"],"Terms of service":["Nutzungsbedingungen"],"Terraform Module Registry":["Terraform-Modul-Registry"],"Terraform in GitLab":["Terraform in GitLab"],"Terraform modules":["Terraform-Module"],"TerraformLimits|Maximum file size (in bytes) of Terraform state files. Set to 0 for no limit.":["Maximale Dateigr\xf6\xdfe (in Byte) von Terraform-Statusdateien. 0 bedeutet unbegrenzt."],"TerraformLimits|Terraform state size limit (bytes)":["Gr\xf6\xdfenlimit f\xfcr Terraform-Status (Byte)"],"TerraformSettings|Configure Terraform state settings and limits.":["Konfiguriere Einstellungen und Limits f\xfcr den Terraform-Status."],"TerraformSettings|Encrypt Terraform state files before storing them. When turned off, state files are stored unencrypted.":["Verschl\xfcssele Terraform-Statusdateien, bevor sie gespeichert werden. Wenn dies deaktiviert ist, werden Statusdateien unverschl\xfcsselt gespeichert."],"TerraformSettings|Terraform state":["Terraform-Status"],"TerraformSettings|Turn on Terraform state encryption":["Terraform-Statusverschl\xfcsselung einschalten"],"Terraform|%{name} successfully removed":["%{name} erfolgreich entfernt"],"Terraform|%{strong_start}%{number}%{strong_end} Terraform report failed to generate":["%{strong_start}%{number}%{strong_end}Terraform-Bericht konnte nicht erstellt werden","%{strong_start}%{number}%{strong_end}Terraform-Berichte konnten nicht erstellt werden"],"Terraform|%{strong_start}%{number}%{strong_end} Terraform report was generated in your pipelines":["%{strong_start}%{number}%{strong_end}Terraform-Bericht wurde in deinen Pipelines erstellt","%{strong_start}%{number}%{strong_end}Terraform-Berichte wurden in deinen Pipelines erstellt"],"Terraform|%{user} updated %{timeAgo}":["%{user} aktualisiert %{timeAgo}"],"Terraform|A Terraform report failed to generate.":["Ein Terraform-Bericht konnte nicht erstellt werden."],"Terraform|A Terraform report was generated in your pipelines.":["Ein Terraform-Bericht wurde in deinen Pipelines erstellt."],"Terraform|Actions":["Aktionen"],"Terraform|Alternatively, use the Terraform or OpenTofu CLI directly. You must use a personal access token with the scope set to api. %{linkStart}How do I create a personal access token?%{linkEnd}.":["Alternativ kannst du die Terraform- oder OpenTofu-CLI direkt verwenden. Du musst ein pers\xf6nliches Zugriffstoken mit dem Geltungsbereich \u201eapi\u201c verwenden. %{linkStart}Wie erstelle ich ein pers\xf6nliches Zugriffstoken?%{linkEnd}."],"Terraform|An error occurred while changing the state file":["Beim \xc4ndern der Statusdatei ist ein Fehler aufgetreten"],"Terraform|An error occurred while loading your Terraform States":["Beim Laden deiner Terraform-Status ist ein Fehler aufgetreten"],"Terraform|Are you sure you want to remove the Terraform State %{name}?":["M\xf6chtest du den Terraform-Status %{name} wirklich entfernen?"],"Terraform|Cancel":["Abbrechen"],"Terraform|Cannot remove a locked state":["Gesperrter Zustand kann nicht entfernt werden."],"Terraform|Collapse Terraform report details":[""],"Terraform|Copy Terraform init command":["Terraform init-Befehl kopieren"],"Terraform|Deletion in progress":["L\xf6schvorgang l\xe4uft"],"Terraform|Details":["Details"],"Terraform|Download JSON":["JSON herunterladen"],"Terraform|Expand Terraform report details":[""],"Terraform|Explore documentation":["Erkunde die Dokumentation"],"Terraform|Failed to load Terraform reports":["Fehler beim Laden der Terraform-Berichte"],"Terraform|Generating the report caused an error.":["Fehler beim Erstellen des Berichts"],"Terraform|Job status":["Jobstatus"],"Terraform|Loading Terraform reports\u2026":["Terraform-Berichte werden geladen\xa0\u2026"],"Terraform|Lock":["Sperren"],"Terraform|Locked":["Gesperrt"],"Terraform|Locked by %{user} %{timeAgo}":["Gesperrt von %{user} %{timeAgo}"],"Terraform|Locking state":["Sperrstatus"],"Terraform|Name":["Name"],"Terraform|Pipeline":["Pipeline"],"Terraform|Recommended. Run the following command with glab. You must use glab 1.66 or later:":["Empfohlen. F\xfchre den folgenden Befehl mit glab aus. Du musst glab 1.66 oder h\xf6her verwenden:"],"Terraform|Remove":["Entfernen"],"Terraform|Removed":["Entfernt"],"Terraform|Removing":["Wird entfernt"],"Terraform|Reported Resource Changes: %{addNum} to add, %{changeNum} to change, %{deleteNum} to delete":["Gemeldete Ressourcen\xe4nderungen: %{addNum} hinzuf\xfcgen, %{changeNum} \xe4ndern, %{deleteNum} l\xf6schen"],"Terraform|Support for periods (`.`) in Terraform state names might break existing states.":["Unterst\xfctzung f\xfcr Punkte (`.`) in Terraform-Zustandsnamen kann bestehende Zust\xe4nde unterbrechen."],"Terraform|Support for periods (`.`) in Terraform state names might break existing states. Refer to the %{link_start}troubleshooting%{link_end} to learn more.":["Unterst\xfctzung f\xfcr Punkte (`.`) in Terraform-Zustandsnamen kann bestehende Zust\xe4nde unterbrechen. Weitere Informationen findest du in der %{link_start}Problembehandlung%{link_end}."],"Terraform|Terraform init":["Terraform init"],"Terraform|Terraform states":["Terraform-Status"],"Terraform|The job %{strong_start}%{name}%{strong_end} failed to generate a report.":["Der Job %{strong_start}%{name}%{strong_end} konnte keinen Bericht erstellen."],"Terraform|The job %{strong_start}%{name}%{strong_end} generated a report.":["Der Job %{strong_start}%{name}%{strong_end} hat einen Bericht erstellt."],
"Terraform|To access this Terraform state from your local computer, use either GitLab CLI (glab) or the REST API.":["Um auf diesen Terraform-State von deinem lokalen Rechner aus zuzugreifen, verwende entweder die GitLab-CLI (glab) oder die REST-API."],"Terraform|To remove the State file and its versions, type %{name} to confirm:":["Um die Statusdatei und ihre Versionen zu entfernen, gib %{name} ein:"],"Terraform|Unknown User":["Unbekannte(r) Benutzer(in)"],"Terraform|Unlock":["Entsperren"],"Terraform|Unlocking state":["Status entsperren"],"Terraform|You are about to remove the state file %{name}. This will permanently delete all the State versions and history. The infrastructure provisioned previously will remain intact, and only the state file with all its versions will be removed. This action cannot be undone.":["Du bist im Begriff, die Statusdatei %{name} zu entfernen. Dadurch werden alle State-Versionen und der Verlauf dauerhaft gel\xf6scht. Die zuvor eingerichtete Infrastruktur bleibt erhalten und nur die Statusdatei mit allen Versionen wird entfernt. Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],"Terraform|You have insufficient permissions to delete this state":["Du hast nicht die n\xf6tigen Berechtigungen, um diesen Status zu l\xf6schen."],"Terraform|Your project doesn't have any Terraform state files":["Dein Projekt hat keine Terraform-Statusdateien"],Test:["Test"],"Test case":["Testfall"],"Test cases":["Testf\xe4lle"],"Test coverage value for this pipeline was calculated by the coverage value of %d job.":["Der Testabdeckungswert f\xfcr diese Pipeline wurde anhand des Abdeckungswerts von %d Job berechnet.","Der Testabdeckungswert f\xfcr diese Pipeline wurde durch Mittelung der resultierenden Abdeckungswerte von %d Jobs berechnet."],"Test coverage: %d hit":["Testabdeckung: %d Aufruf","Testabdeckung: %d Aufrufe"],"Test settings":["Testeinstellungen"],"Test summary":["Testzusammenfassung"],"TestCases|Move test case":["Testfall verschieben"],"TestCases|Moving test case":["Testfall wird verschoben"],"TestCases|New test case":["Neuer Testfall"],"TestCases|Search test cases":["Testf\xe4lle durchsuchen"],"TestCases|Something went wrong while adding test case to a to-do item.":["Beim Hinzuf\xfcgen eines Testfalls zu einer Aufgabe ist ein Fehler aufgetreten."],"TestCases|Something went wrong while creating a test case.":["Fehler beim Erstellen eines Testfalls"],"TestCases|Something went wrong while fetching test case.":["Beim Abrufen von Testf\xe4llen ist ein Fehler aufgetreten."],"TestCases|Something went wrong while fetching test cases list.":["Fehler beim Abrufen der Liste der Testf\xe4lle"],"TestCases|Something went wrong while marking test case to-do item as done.":["Bei der Markierung einer Testfallaufgabe als erledigt ist ein Fehler aufgetreten."],"TestCases|Something went wrong while moving test case.":["Beim Verschieben von Testf\xe4llen ist ein Fehler aufgetreten."],"TestCases|Something went wrong while updating the test case.":["Beim Aktualisieren des Testfalls ist ein Fehler aufgetreten."],"TestCases|Submit test case":["Testfall absenden"],"TestHooks|Ensure one of your projects has merge requests.":["Stelle sicher, dass eines deiner Projekte Merge Requests hat."],"TestHooks|Ensure the project has CI jobs.":["Versichere dich, dass das Projekt CI Jobs hat."],"TestHooks|Ensure the project has CI pipelines.":["Versichere dich, dass das Projekt CI Pipelines hat."],"TestHooks|Ensure the project has deployments.":["Stelle sicher, dass das Projekt Bereitstellungen enth\xe4lt."],"TestHooks|Ensure the project has issues.":["Versichere dich, dass das Projekt Tickets hat."],"TestHooks|Ensure the project has merge requests.":["Versichere dich, dass das Projekt Merge Requests hat."],"TestHooks|Ensure the project has notes.":["Stelle sicher, dass das Projekt Notizen enth\xe4lt."],"TestHooks|Ensure the project has releases.":["Stelle sicher, dass das Projekt \xfcber Ver\xf6ffentlichungen verf\xfcgt."],"TestHooks|Ensure the project has vulnerabilities.":["Stelle sicher, dass das Projekt \xfcber keine Sicherheitsl\xfccken verf\xfcgt."],"TestHooks|Ensure the wiki is enabled and has pages.":["Versichere dich, dass das Wiki aktiviert ist und Seiten hat."],"TestReports|%{count} errors":["%{count} Fehler"],"TestReports|%{count} failures":["%{count} Fehler"],"TestReports|%{count} tests":["%{count} Tests"],"TestReports|%{rate}%{sign} success rate":["%{rate}%{sign} Erfolgsrate"],"TestReports|Attachment":["Anhang"],"TestReports|Copy test name to rerun locally":["Testnamen kopieren, um ihn lokal erneut auszuf\xfchren"],"TestReports|Job artifacts are expired":["Job-Artefakte sind abgelaufen"],"TestReports|Jobs":["Jobs"],"TestReports|Learn how to upload pipeline test reports":["Erfahre, wie du Pipeline-Testberichte hochladen kannst"],"TestReports|Learn more about pipeline test reports":["Erfahre mehr \xfcber Pipeline-Testberichte"],"TestReports|No test cases were found in the test report.":["Im Testbericht wurden keine Testf\xe4lle gefunden."],"TestReports|Test reports require job artifacts but all artifacts are expired. %{linkStart}Learn more%{linkEnd}":["Testberichte erfordern Job-Artefakte, aber alle Artefakte sind abgelaufen. %{linkStart}Mehr erfahren%{linkEnd}"],"TestReports|There are no test cases to display.":["Es gibt keine Testf\xe4lle zum Anzeigen."],"TestReports|There are no test reports for this pipeline":["Es gibt keine Testberichte f\xfcr diese Pipeline"],"TestReports|There are no test suites to show.":["Es gibt keine Test-Suiten zum Anzeigen."],"TestReports|There are no tests to display":["Es gibt keine Tests anzuzeigen"],"TestReports|There was an error fetching the summary.":["Fehler beim Abrufen der Zusammenfassung"],"TestReports|There was an error fetching the test suite.":["Fehler beim Abrufen der Testsuite"],"TestReports|You can configure your job to use unit test reports, and GitLab displays a report here and in the related merge request.":["Du kannst deinen Job so konfigurieren, dass er Unit-Testberichte verwendet. GitLab zeigt hier und in der zugeh\xf6rigen Merge Request einen Bericht an."],Tests:["Tests"],Text:["Text"],"Text (optional)":["Text (optional)"],"Text added to the body of all email messages. %{character_limit} character limit":["Text, der dem Textk\xf6rper aller E-Mail-Nachrichten hinzugef\xfcgt wird. Max.%{character_limit} Zeichen"],"Text added to the body of user deactivation email messages. 1000 character limit.":["Zeichenfolge, die dem Textk\xf6rper von E-Mail-Nachrichten zur Deaktivierung von Benutzer(inne)n hinzugef\xfcgt wird. Maximal 1.000 Zeichen."],"TextEditor|Plain text editor":["Klartext-Editor"],"TextEditor|Rich text editor":["Rich-Text-Editor"],"Thank you for your business.":["Vielen Dank f\xfcr dein Gesch\xe4ft."],"Thank you for your report. A GitLab administrator will look into it shortly.":["Vielen Dank f\xfcr deine Meldung. Ein(e) GitLab-Administrator(in) wird sich der Sache in K\xfcrze widmen."],"Thank you for your support request! We are tracking your request as ticket #%{issue_iid}, and will respond as soon as we can.":["Vielen Dank f\xfcr deine Supportanfrage! Wir verfolgen deine Anfrage als Ticket #%{issue_iid} und werden so schnell wie m\xf6glich antworten."],"Thank you,":["Vielen Dank"],"Thanks for signing up to GitLab!":["Vielen Dank, dass du dich bei GitLab angemeldet hast!"],"Thanks for your purchase!":["Vielen Dank f\xfcr deinen Kauf!"],"That's OK, I don't want to renew":["Das ist OK, ich m\xf6chte nicht verl\xe4ngern"],"The %{plan_name} is no longer available to purchase. For more information about how this will impact you, check our %{faq_link_start}frequently asked questions%{faq_link_end}.":["Der %{plan_name} ist nicht mehr k\xe4uflich zu erwerben. Weitere Informationen dar\xfcber, wie sich dies auf dich auswirkt wird, findest du in unseren %{faq_link_start}h\xe4ufig gestellten Fragen%{faq_link_end}."],"The %{type} contains the following error:":["%{type} enth\xe4lt den folgenden Fehler:","%{type} enth\xe4lt die folgenden Fehler:"],"The API key used by GitLab for accessing the Spam Check service endpoint.":["Der API-Schl\xfcssel, der von GitLab f\xfcr den Zugriff auf den Endpunkt des Spam-Check-Dienstes verwendet wird."],"The Bugzilla logo is a trademark of the Mozilla Foundation in the U.S. and other countries.":["Das Bugzilla-Logo ist ein Markenzeichen der Mozilla Foundation in den USA und anderen L\xe4ndern."],"The CSV export will be created in the background. Once finished, it will be sent to %{email} in an attachment.":["Der CSV-Export wird im Hintergrund erstellt. Wenn der Vorgang abgeschlossen ist, wird die Datei in einem Anhang an %{email} gesendet."],"The GitLab instance can be reached but the credentials stored in Amazon Q are not valid. Please disconnect and start over.":["Die GitLab-Instanz ist erreichbar, aber die in Amazon Q gespeicherten Zugangsdaten sind ung\xfcltig. Bitte trenne die Verbindung und beginne erneut."],"The GitLab subscription service (customers.gitlab.com) is currently experiencing an outage. You can monitor the status and get updates at %{linkStart}status.gitlab.com%{linkEnd}.":["Der GitLab-Abonnementdienst (customers.gitlab.com) hat derzeit einen Ausfall. Du kannst den Status \xfcberwachen und Updates unter %{linkStart}status.gitlab.com%{linkEnd} erhalten."],"The GitLab user to which the Jira user %{jiraDisplayName} will be mapped":["Der/Die GitLab-Benutzer(in), dem/der der/die JIRA-Benutzer(in) %{jiraDisplayName} zugeordnet wird"],"The Hangouts Chat webhook (for example, `https://chat.googleapis.com/v1/spaces...`).":["Der Unify Circuit-Webhook (beispielsweise `https://chat.googleapis.com/v1/spaces...`)."],"The ID of the application.":["Die ID der Anwendung."],"The Issue Tracker is the place to add things that need to be improved or solved in a project":["Das Ticketsystem ist der Ort, um Dinge hinzuzuf\xfcgen, die in einem Projekt verbessert oder gel\xf6st werden m\xfcssen"],"The Issue Tracker is the place to add things that need to be improved or solved in a project. You can register or sign in to create issues for this project.":["Das Ticketsystem ist der Ort, um Dinge hinzuzuf\xfcgen, die in einem Projekt verbessert oder Probleme anzuf\xfchren, die gel\xf6st werden m\xfcssen. Du kannst dich registrieren oder anmelden, um Tickets f\xfcr dieses Projekt zu erstellen."],"The Kroki server that will be used to generate diagrams.":["Der Kroki-Server, der zum Generieren von Diagrammen verwendet wird."],"The Matrix access token (for example, `syt-zyx57W2v1u123ew11`).":["Das Matrix-Zugriffstoken (z.\xa0B. \u201esyt-zyx57W2v1u123ew11\u201c)."],"The Mattermost token.":["Das Mattermost-Token."],"The Microsoft Teams webhook (for example, `https://outlook.office.com/webhook/...`).":["Der Microsoft Teams-Webhook (beispielsweise `https://outlook.office.com/webhook/...`)."],"The Pivotal Tracker token.":["Das Pivotal Tracker-Token."],"The Planner role is suitable for team members who need to manage projects and track work items but do not need to contribute code.":["Die Rolle des Planers/der Planerin eignet sich f\xfcr Teammitglieder, die Projekte verwalten und Arbeitsaufgaben nachverfolgen m\xfcssen, aber keinen Code beisteuern m\xfcssen."],"The Pumble webhook (for example, `https://api.pumble.com/workspaces/x/...`).":["Der Pumble-Webhook (z.\xa0B. `https://api.pumble.com/workspaces/x/...`)."],"The Slack token.":["Der Slack-Token."],"The Snowplow cookie domain.":["Die Snowplow-Cookie-Domain."],"The Telegram bot token (for example, `123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11`).":["Der Telegram-Bot-Token (z.\xa0B. `123456: ABC-DEF1234ghIkl-zyx57W2v1u123ew11')."],"The URL should start with http:// or https://":["Die URL sollte mit \u201ehttp://\u201c oder \u201ehttps://\u201c beginnen"],"The URLs for connecting to Elasticsearch or OpenSearch. For clustering, add the URLs separated by commas.":["Die URLs f\xfcr die Verbindung zu Elasticsearch oder OpenSearch. F\xfcge zum Clustering die durch Kommas getrennten URLs hinzu."],"The Unify Circuit webhook (for example, `https://circuit.com/rest/v2/webhooks/incoming/...`).":["Der Unify Circuit-Webhook (beispielsweise `https://circuit.com/rest/v2/webhooks/incoming/...`)."],"The Web IDE extension host domain was restored to its default value.":["Die Web IDE-Erweiterungs-Host-Domain wurde auf den Standardwert zur\xfcckgesetzt."],"The XML file must be less than %{max_size} MB.":["Die XML-Datei muss kleiner als %{max_size}\xa0MB sein."],"The `/merge` quick action requires the SHA of the head of the branch.":["Die \u201e/merge\u201c-Schnellaktion erfordert den SHA des Branches."],"The `version` attribute is required.":["Das Attribut \u201eversion\u201c ist erforderlich."],"The adjacent work item's parent must match the moving work item's parent.":["Das \xfcbergeordnete Element der angrenzenden Arbeitsaufgabe muss mit dem \xfcbergeordneten Element der verschobenen Arbeitsaufgabe \xfcbereinstimmen."],"The application will be used where the client secret can be kept confidential. Native mobile apps and Single Page Apps are considered non-confidential.":["Die Anwendung wird dort verwendet, wo das Kundengeheimnis vertraulich behandelt werden kann. Native mobile Apps und Single-Page-Apps gelten als nicht vertraulich."],"The associated issue #%{issueId} has been closed as the error is now resolved.":["Das zugeh\xf6rige Ticket #%{issueId} wurde geschlossen, da der Fehler behoben wurde."],"The authentication token.":["Das Authentifizierungstoken."],"The base URL to the Harbor instance linked to the GitLab project. For example, `https://demo.goharbor.io`.":["Die Basis-URL zur Harbor-Instanz, die mit dem GitLab-Projekt verkn\xfcpft ist. Zum Beispiel \u201ehttps://demo.goharbor.io\u201c."],"The blob is too large to render":["Der Blob ist zu gro\xdf zum Rendern"],"The branch for this project has no active pipeline configuration.":["Der Branch f\xfcr dieses Projekt enth\xe4lt keine aktive Pipeline-Konfiguration."],"The branch or tag does not exist":["Der Branch oder Tag existiert nicht"],"The branch to merge into.":["Der Branch, in den zusammengef\xfchrt werden soll."],"The comment you are editing has been changed by another user. Would you like to keep your changes and overwrite the new description or discard your changes?":["Der Kommentar, den du bearbeitest, wurde von einem/einer anderen Benutzer(in) ge\xe4ndert. M\xf6chtest du deine \xc4nderungen beibehalten und die neue Beschreibung \xfcberschreiben oder deine \xc4nderungen verwerfen?"],"The commit does not exist":["Der Commit existiert nicht"],"The complete DevOps platform. One application with endless possibilities. Organizations rely on GitLab\u2019s source code management, CI/CD, security, and more to deliver software rapidly.":["Die vollst\xe4ndige DevOps-Plattform. Eine Anwendung mit endlosen M\xf6glichkeiten. Viele Unternehmen nutzen die Quellcodeverwaltung, die CI/CD- und Sicherheitsfunktionen und vieles mehr von GitLab, um Software schnell bereitzustellen."],"The connection will time out after %{timeout}. For repositories that take longer, use a clone/push combination.":["Die Verbindung wird nach %{timeout} beendet. Verwende eine Clone-/Push-Kombination f\xfcr Repositorys, die mehr Zeit ben\xf6tigen."],"The contact does not belong to the issue group's CRM source group":["Der Kontakt geh\xf6rt nicht zur CRM-Quellgruppe der Ticketgruppe"],"The content for this wiki page failed to load. To fix this error, reload the page.":["Der Inhalt f\xfcr diese Wiki-Seite konnte nicht geladen werden. Um diesen Fehler zu beheben, lade die Seite neu."],"The content for this wiki page failed to render.":["Der Inhalt f\xfcr diese Wiki-Seite konnte nicht gerendert werden."],"The content of this page is not encoded in UTF-8. Edits can only be made via the Git repository.":["Der Inhalt dieser Seite ist nicht mit UTF-8 kodiert. \xc4nderungen k\xf6nnen nur \xfcber das Git-Repository vorgenommen werden."],"The current epic":["Der aktuelle Epic"],"The current incident":["Der aktuelle Vorfall"],"The current issue":["Das aktuelle Ticket"],"The current ticket":["Das aktuelle Ticket"],"The current user is not authorized to access the job log.":["Der/die aktuelle Benutzer(in) ist nicht berechtigt, auf das Jobprotokoll zuzugreifen."],"The current user is not authorized to create a pipeline trigger token":["Der oder die aktuelle Benutzer(in) ist nicht berechtigt, ein Pipeline-Trigger-Token zu erstellen"],"The current user is not authorized to create the pipeline schedule":["Der/die aktuelle Benutzer(in) ist nicht berechtigt, den Pipelineplan zu erstellen."],"The current user is not authorized to create the pipeline schedule variables":["Der oder die aktuelle Benutzer(in) ist nicht berechtigt, die Pipeline-Zeitplan-Variablen zu erstellen"],"The current user is not authorized to manage the pipeline trigger token":["Der oder die aktuelle Benutzer(in) ist nicht berechtigt, das Pipeline-Trigger-Token zu verwalten"],"The current user is not authorized to remove the Pages deployment":["Der/die aktuelle Benutzer(in) ist nicht berechtigt, die Seitenbereitstellung zu entfernen"],"The current user is not authorized to set pipeline schedule variables":["Der oder die aktuelle Benutzer(in) ist nicht berechtigt, Pipeline-Zeitplan-Variablen festzulegen"],"The current user is not authorized to update the page settings":["Der aktuelle Benutzer bzw. die aktuelle Benutzerin ist nicht berechtigt, die Seiteneinstellungen zu aktualisieren"],"The current user is not authorized to update the pipeline schedule":["Der/die aktuelle Benutzer(in) ist nicht berechtigt, den Pipeline-Zeitplan zu aktualisieren"],"The current user is not authorized to update the pipeline schedule variables":["Der oder die aktuelle Benutzer(in) ist nicht berechtigt, die Pipeline-Zeitplan-Variablen zu aktualisieren"],"The current user is not authorized to update the pipeline trigger token":["Der oder die aktuelle Benutzer(in) ist nicht berechtigt, das Pipeline-Trigger-Token zu aktualisieren"],"The data in this pipeline is too old to be rendered as a graph. Please check the Jobs tab to access historical data.":["Die Daten in dieser Pipeline sind zu alt, um als Diagramm gerendert zu werden. Bitte \xfcberpr\xfcfe die Registerkarte \u201eJobs\u201c, um auf historische Daten zuzugreifen."],"The date when the release is ready.":["Das Datum, an dem die Ver\xf6ffentlichung fertig ist."],"The default CI/CD configuration file and path for new projects.":["Die Standard-CI/CD-Konfigurationsdatei und der Pfad f\xfcr neue Projekte."],"The default branch for this project has been changed. Please update your bookmarks.":["Der Standard-Branch f\xfcr dieses Projekt wurde ge\xe4ndert. Bitte aktualisiere deine Lesezeichen."],"The dependency list details information about the components used within your project.":["Die Abh\xe4ngigkeitsliste enth\xe4lt Informationen zu den in deinem Projekt verwendeten Komponenten."],"The deployment of this job to %{environmentLink} did not succeed.":["Die Bereitstellung dieses Jobs auf %{environmentLink} war nicht erfolgreich."],"The diagrams.net editor could not be loaded.":["Der diagrams.net-Editor konnte nicht geladen werden."],"The directory has been successfully created.":["Das Verzeichnus wurde erfolgreich erstellt."],"The discussion in this %{issuableDisplayName} is locked. Only project members can comment.":["Die Diskussion in diesem(r) %{issuableDisplayName} ist gesperrt. Nur Projektmitglieder k\xf6nnen kommentieren."],"The discussion in this %{issuable} is locked. Only project members can comment.":["Die Diskussion in diesem(r) %{issuable} ist gesperrt. Nur Projektmitglieder k\xf6nnen kommentieren."],"The discussion in this %{noteableTypeText} is locked.":["Die Diskussion in diesem(r) %{noteableTypeText} ist gesperrt."],"The discussion in this merge request is locked.":["Die Diskussion in dieser Merge Request ist gesperrt."],"The domain you entered is misformatted.":["Die von dir eingegebene Domain ist falsch formatiert."],"The domain you entered is not allowed.":["Die von dir eingegebene Domain ist nicht erlaubt."],"The download link will expire in 24 hours.":["Der Download-Link l\xe4uft in 24 Stunden ab."],"The environment tiers must be from %{environment_tiers}.":["Die Umgebungsebenen m\xfcssen von %{environment_tiers} sein."],"The errors we encountered were:":["Die folgenden Fehler wurden gefunden:"],"The file containing the export is not available yet; it may still be transferring. Please try again later.":["Die Datei, die den Export enth\xe4lt, ist noch nicht verf\xfcgbar; sie wird m\xf6glicherweise noch \xfcbertragen. Bitte versuche es sp\xe4ter erneut."],"The file could not be displayed because it is empty or larger than the maximum file size indexed (%{size}).":["Die Datei konnte nicht angezeigt werden, da sie leer oder gr\xf6\xdfer als die indexierte maximale Dateigr\xf6\xdfe ist (%{size})."],"The file could not be displayed because it is empty.":["Die Datei konnte nicht angezeigt werden, da sie leer ist."],"The file has been successfully created.":["Die Datei wurde erfolgreich erstellt."],"The file has been successfully deleted.":["Die Datei wurde erfolgreich gel\xf6scht."],"The file is locked.":["Die Datei ist gesperrt."],"The file is unlocked.":["Die Datei ist entsperrt."],"The file you're about to delete is tracked by LFS":["Die Datei, die du l\xf6schen m\xf6chtest, wird von LFS nachverfolgt"],"The finding is not a vulnerability because it is part of a test or is test data.":["Der Fund stellt keine Sicherheitsl\xfccke dar, da es sich um einen Teil eines Tests oder um Testdaten handelt."],"The following SSH key was deleted by an administrator, %{username}.":["Der folgende SSH-Schl\xfcssel wurde von einem/einer Administrator(in) gel\xf6scht, %{username}."],"The following files or directories can only be modified by the user who locked them.":["Die folgenden Dateien oder Verzeichnisse k\xf6nnen nur von dem/der Benutzer(in) ge\xe4ndert werden, der sie gesperrt hat."],"The following items will NOT be exported:":["Die folgenden Elemente werden NICHT exportiert:"],"The following items will be exported:":["Die folgenden Elemente werden exportiert:"],"The following personal access token was revoked by an administrator, %{username}.":["Das folgende pers\xf6nliche Zugriffstoken wurde von einem/einer Administrator widerrufen, %{username}."],"The following personal access token: %{token_names} was revoked, because a new policy to expire personal access tokens were set.":["Das pers\xf6nliche Zugriffstoken \u201e%{token_names}\u201c wurde widerrufen, da eine neue Richtlinie zum Ablauf pers\xf6nlicher Zugriffstoken festgelegt wurde.","Die pers\xf6nlichen Zugriffstoken \u201e%{token_names}\u201c wurden widerrufen, da eine neue Richtlinie zum Ablauf pers\xf6nlicher Zugriffstoken festgelegt wurde."],"The following personal access tokens have expired:":["Die folgenden pers\xf6nlichen Zugriffstoken sind abgelaufen:"],"The following users can also merge into this branch: %{branch}":["Die folgenden Benutzer(innen) k\xf6nnen auch in diesen Branch zusammenf\xfchren: %{branch}"],"The following users can also push to this branch: %{branch}":["Die folgenden Benutzer(innen) k\xf6nnen auch in diesen Branch pushen: %{branch}"],"The fork relationship has been removed.":["Die Beziehung des Forks wurde entfernt."],"The form contains the following error:":["Das Formular enth\xe4lt den folgenden Fehler:","Das Formular enth\xe4lt die folgenden Fehler:"],"The form contains the following warning:":["Das Formular enth\xe4lt die folgende Warnung:"],"The git server, Gitaly, is not available at this time. Please contact your administrator.":["Der Git-Server Gitaly ist zurzeit nicht verf\xfcgbar. Bitte wende dich an deinen Administrator."],"The global settings require you to enable Two-Factor Authentication for your account.":["Die globalen Einstellungen erforden die Aktivierung der Zwei-Faktor-Authentifizierung."],"The group export can be downloaded from:":["Der Gruppenexport kann unter folgender Adresse heruntergeladen werden:"],"The group has already been shared with this group":["Die Gruppe wurde bereits mit dieser Gruppe geteilt"],"The group settings for %{group_links} require you to enable Two-Factor Authentication for your account. You can %{leave_group_links}.":["Die Gruppeneinstellungen f\xfcr %{group_links} erfordern die Aktivierung der Zwei-Faktor-Authentifizierung in deinem Konto. Du kannst %{leave_group_links}."],"The group_project_ids parameter is only allowed for a group":["Der Parameter \u201egroup_project_ids\u201c ist nur f\xfcr eine Gruppe zul\xe4ssig"],"The hook URL has changed. This log entry cannot be retried.":["Die Hook-URL hat sich ge\xe4ndert. Dieser Protokolleintrag kann nicht wiederholt werden."],"The hostname of your PlantUML server.":["Der Hostname deines PlantUML-Servers."],"The hostname of your Snowplow collector.":["Der Hostname deines Snowplow-Sammlers."],"The hostname of your diagrams.net server.":["Der Hostname deines diagrams.net-Servers."],"The import cannot be canceled because it is %{project_status}":["Der Import kann nicht abgebrochen werden, da er %{project_status} ist"],"The import is not complete.":["Der Import ist nicht abgeschlossen."],"The import will time out after %{timeout}. For repositories that take longer, use a clone/push combination.":["Der Import wird nach %{timeout} beendet. Verwende eine Clone/Push-Kombination f\xfcr Repositorys, die l\xe4nger brauchen."],"The interval must be one of %{intervals}.":["Das Intervall muss eins von %{intervals} sein."],"The invitation can not be found with the provided invite token.":["Die Einladung kann mit dem bereitgestellten Einladungstoken nicht gefunden werden."],"The invitation could not be accepted.":["Die Einladung konnte nicht akzeptiert werden."],"The invitation could not be declined.":["Die Einladung konnte nicht abgelehnt werden."],"The invitation has already been accepted.":["Die Einladung konnte nicht akzeptiert werden."],"The invitation was successfully resent.":["Die Einladung wurwde erfolgreich erneut gesendet."],"The issue was successfully promoted to an epic. Redirecting to epic\u2026":["Das Ticket wurde erfolgreich zu einem Epic hochgestuft. Weiterleitung zum Epic\xa0\u2026"],"The last owner cannot be set to awaiting":["Der/die letzte Eigent\xfcmer(in) kann nicht auf \u201ewartend\u201c gesetzt werden."],"The latest artifacts created by jobs in the most recent successful pipeline will be stored.":["Die neuesten Artefakte, die durch Auftr\xe4ge in der letzten erfolgreichen Pipeline erstellt wurden, werden gespeichert."],"The latest pipeline failed for this merge request.":["Die neueste Pipeline f\xfcr diese Merge Request ist fehlgeschlagen."],"The license key is invalid.":["Der Lizenzschl\xfcssel ist ung\xfcltig."],"The license key is invalid. Make sure it is exactly as you received it from GitLab Inc.":["Der Lizenzschl\xfcssel ist ung\xfcltig. Stelle sicher, dass du ihn genau so eingegeben hast, wie du ihn von GitLab Inc. erhalten hast."],"The license was removed. GitLab has fallen back on the previous license.":["Die Lizenz wurde gel\xf6scht. GitLab hat auf die vorherige Lizenz zur\xfcckgegriffen."],"The license was removed. GitLab now no longer has a valid license.":["Die Lizenz wurde gel\xf6scht. GitLab hat ab jetzt keine g\xfcltige Lizenz mehr."],"The license was successfully uploaded and is now active. You can see the details below.":["Die Lizenz wurde erfolgreich hochgeladen und ist jetzt aktiv. Du kannst die Details unten sehen."],"The license was successfully uploaded and will be active from %{starts_at}. You can see the details below.":["Die Lizenz wurde erfolgreich hochgeladen und ist ab %{starts_at} aktiv. Weitere Details findest du unten."],"The license you uploaded is invalid. If the issue persists, contact support at %{link}.":["Die hochgeladene Lizenz ist ung\xfcltig. Wenn das Problem weiterhin besteht, wende dich an den Support unter %{link}."],"The map can not be displayed because there was an error loading the GeoJSON file.":["Die Karte kann nicht angezeigt werden, weil beim Laden der GeoJSON-Datei ein Fehler aufgetreten ist."],"The maximum amount of time users have to set up two-factor authentication before it's enforced.":["Die maximale Zeit, die Benutzer(innen) f\xfcr die Einrichtung der Zwei-Faktor-Authentifizierung haben, bevor sie gezwungen werden."],"The maximum compute minutes that jobs in a namespace can use on instance runners each month. 0 for unlimited.":["Die maximale Anzahl an Compute-Minuten, die Jobs in einem Namensraum jeden Monat auf Instanz-Runnern nutzen k\xf6nnen. 0 f\xfcr unbegrenzt."],"The maximum file size allowed is %{size}.":["Die maximal zul\xe4ssige Dateigr\xf6\xdfe betr\xe4gt %{size}."],"The maximum file size for job artifacts archive.":["Die maximale Dateigr\xf6\xdfe f\xfcr das Job-Artefakt-Archiv."],"The maximum file size for job artifacts.":["Die maximale Dateigr\xf6\xdfe f\xfcr Job-Artefakte."],"The maximum file size in megabytes for individual job artifacts.":["Die maximale Dateigr\xf6\xdfe in Megabyte f\xfcr einzelne Job-Artefakte."],"The maximum file size is %{size}.":["Die maximale Dateigr\xf6\xdfe betr\xe4gt %{size}."],"The maximum number of approval policies allowed per security policy configuration can exceed the limit for the instance. Set to 0 to use instance limit.":["Die maximal zul\xe4ssige Anzahl von Genehmigungsrichtlinien pro Sicherheitsrichtlinienkonfiguration kann das Limit f\xfcr die Instanz \xfcberschreiten. Setze den Wert auf 0, um das Instanzlimit zu verwenden."],"The maximum number of pipeline execution policies allowed per security policy configuration can exceed the limit for the instance. Set to 0 to use instance limit.":["Die maximal zul\xe4ssige Anzahl von Pipeline-Ausf\xfchrungsrichtlinien pro Sicherheitsrichtlinienkonfiguration kann das Limit f\xfcr die Instanz \xfcberschreiten. Setze den Wert auf 0, um das Instanzlimit zu verwenden."],"The maximum number of scan execution policies allowed per security policy configuration can exceed the limit for the instance. Set to 0 to use instance limit.":["Die maximal zul\xe4ssige Anzahl von Scan-Ausf\xfchrungsrichtlinien pro Sicherheitsrichtlinienkonfiguration kann das Limit f\xfcr die Instanz \xfcberschreiten. Setze den Wert auf 0, um das Instanzlimit zu verwenden."],"The maximum number of tags that a single worker accepts for cleanup. If the number of tags goes above this limit, the list of tags to delete is truncated to this number. To remove this limit, set it to 0.":["Die maximale Anzahl von Tags, die ein einzelner Arbeitsvorgang zum Bereinigen zul\xe4sst. Wenn die Anzahl der Tags diesen Grenzwert \xfcberschreitet, wird die Liste der zu l\xf6schenden Tags auf diese Anzahl gek\xfcrzt. Um diese Begrenzung zu entfernen, setzen man sie auf 0."],"The maximum number of vulnerability management policies allowed per security policy configuration can exceed the limit for the instance. Set to 0 to use instance limit.":["Die maximal zul\xe4ssige Anzahl von Sicherheitsl\xfcckenmanagement-Richtlinien pro Sicherheitsrichtlinienkonfiguration kann das Limit f\xfcr die Instanz \xfcberschreiten. Setze den Wert auf 0, um das Instanzlimit zu verwenden."],"The merge checks are incomplete because the latest pipeline failed, the pipeline status cannot be verified, or the merge request target branch was changed. You should run a new pipeline before merging.":["Die Merge-Pr\xfcfungen sind unvollst\xe4ndig, da die letzte Pipeline fehlgeschlagen ist, der Pipeline-Status nicht \xfcberpr\xfcft werden kann oder der Zielbranch des Merge Requests ge\xe4ndert wurde. Du solltest vor dem Zusammenf\xfchren eine neue Pipeline ausf\xfchren."],"The merge conflicts for this merge request cannot be resolved through GitLab. Please try to resolve them locally.":["Die Merge-Konflikte dieser Merge Request konnten durch GitLab nicht gel\xf6st werden. Bitte versuche, diese lokal zu l\xf6sen."],"The merge conflicts for this merge request have already been resolved.":["Die Merge-Konflikte dieser Merge Request wurden schon gel\xf6st."],"The merge conflicts for this merge request have already been resolved. Please return to the merge request.":["Die Merge-Konflikte dieser Merge Request wurden schon gel\xf6st. Bitte geh zur Merge Request zur\xfcck."],"The merge request approvals are currently syncing.":["Die Genehmigungen f\xfcr Merge Requests werden derzeit synchronisiert."],"The metric must be one of %{metrics}.":["Die Metrik muss eine von %{metrics} sein."],
"The name of the CI/CD configuration file. A path relative to the root directory is optional (for example %{code_open}my/path/.myfile.yml%{code_close}).":["Der Name der CI/CD-Konfigurationsdatei. Ein Pfad zum Stammverzeichnis ist optional (z.\xa0B. %{code_open}my/path/.myfile.yml%{code_close})."],"The namespace storage size (%{current_size}) exceeds the limit of %{size_limit} by %{exceeded_size}. You won't be able to push new code to this project. Please contact your GitLab administrator for more information.":["Die Speichergr\xf6\xdfe des Namensraums (%{current_size}) \xfcberschreitet das Limit von %{size_limit} um %{exceeded_size}. Du kannst f\xfcr dieses Projekt keinen neuen Code mehr pushen. Wende dich bitte an deine(n) GitLab-Administrator(in), um weitere Informationen zu erhalten."],"The number of changes to fetch from GitLab when cloning a repository. Lower values can speed up pipeline execution. Set to %{code_open}0%{code_close} or blank to fetch all branches and tags for each job":["Die Anzahl der \xc4nderungen, die beim Klonen eines Repositorys aus GitLab abgerufen werden sollen. Niedrigere Werte k\xf6nnen die Pipelineausf\xfchrung beschleunigen. Auf %{code_open}0%{code_close} oder leer setzen, um alle Branches und Tags f\xfcr jeden Job abzurufen"],"The number of direct members in the current group. Members in subgroups are not included. %{link_start}What is a direct member%{link_end}?":["Die Anzahl der direkten Mitglieder in der aktuellen Gruppe. Mitglieder in Untergruppen sind nicht inbegriffen. %{link_start}Was ist ein direktes Mitglied%{link_end}?"],"The number of documents waiting for full indexing. This includes new content, project imports, transfers, and search migrations that require complete reindexing.":["Die Anzahl der Dokumente, die auf eine vollst\xe4ndige Indexierung warten. Dazu z\xe4hlen neuer Inhalt, Projektimporte, \xdcbertragungen und Suchmigrationen, die eine vollst\xe4ndige Neuindexierung erfordern."],"The number of documents waiting for updates to existing indexed content. These represent changes to previously indexed files, commits, or metadata.":["Die Anzahl der Dokumente, die auf Aktualisierungen des vorhandenen indexierten Inhalts warten. Dazu z\xe4hlen \xc4nderungen an bereits indexierten Dateien, Commits und Metadaten."],"The number of items that failed after being retried once. Items in the dead queue are not automatically retried. %{help_link_start}Reindex these items manually%{help_link_end} or contact GitLab Support with relevant logs for help.":["Die Anzahl der Elemente, bei denen nach einer Wiederholung ein Fehler aufgetreten ist. Elemente in der Abbruch-Warteschlange werden nicht automatisch wiederholt. %{help_link_start}Indiziere diese Elemente manuell erneut%{help_link_end} oder wende dich mit den relevanten Protokollen an den GitLab-Support, um Hilfe zu erhalten."],"The number of projects that have no repository data indexed. A value of 0 means all projects have had repository data indexed at least once, though some may need updates. This metric tracks only projects completely missing repository data from the index, not those needing incremental updates.":["Die Anzahl von Projekten, f\xfcr die keine Repository-Daten indexiert sind. Der Wert \u201e0\u201c gibt an, dass f\xfcr alle Projekte mindestens einmal Repository-Daten indexiert wurden, auch wenn einige m\xf6glicherweise Aktualisierungen erfordern. Diese Metrik verfolgt nur Projekte, f\xfcr die Repository-Daten vollst\xe4ndig im Index fehlen, und nicht solche, die inkrementelle Aktualisierungen erfordern."],"The number of times an upload record could not find its file":["Die Angabe, wie oft die Datei zu einem Upload-Datensatz nicht gefunden wurde"],"The only thread is resolved":["Der einzelne Thread wurde gel\xf6st","Alle %{resolvableDiscussionsCount} Threads gel\xf6st"],"The page could not be displayed because it timed out.":["Die Seite konnte nicht angezeigt werden, da sie abgelaufen ist."],"The parent group is archived. This group and its data are %{strong_open}read-only%{strong_close}.":["Die \xfcbergeordnete Gruppe wurde archiviert. Diese Gruppe und ihre Daten sind %{strong_open}schreibgesch\xfctzt%{strong_close}."],"The parent group is archived. This project and its data are %{strong_open}read-only%{strong_close}.":["Die \xfcbergeordnete Gruppe wurde archiviert. Dieses Projekt und seine Daten sind %{strong_open}schreibgesch\xfctzt%{strong_close}."],"The parent group is pending deletion. This group will be %{strongOpen}permanently deleted%{strongClose} on %{date}.":["Die \xfcbergeordnete Gruppe steht zur L\xf6schung an. Diese Gruppe wird am %{date} %{strongOpen}endg\xfcltig gel\xf6scht%{strongClose}."],"The parent group is pending deletion. This project will be %{strongOpen}permanently deleted%{strongClose} on %{date}.":["Die \xfcbergeordnete Gruppe steht zur L\xf6schung an. Dieses Projekt wird am %{date} %{strongOpen}endg\xfcltig gel\xf6scht%{strongClose}."],"The password for your GitLab account on %{gitlab_url} has successfully been changed.":["Das Passwort f\xfcr dein GitLab-Konto auf %{gitlab_url} wurde erfolgreich ge\xe4ndert."],"The password for your GitLab account on %{link_to_gitlab} has successfully been changed.":["Das Passwort f\xfcr dein GitLab-Konto auf %{link_to_gitlab} wurde erfolgreich ge\xe4ndert."],"The pipeline has been deleted":["Die Pipeline wurde gel\xf6scht"],"The policy is associated with a non-existing pipeline configuration file.":["Die Richtlinie ist mit einer nicht existierenden Pipeline-Konfigurationsdatei verkn\xfcpft."],"The policy is disabled":["Die Richtlinie ist deaktiviert"],"The policy is enabled":["Die Richtlinie ist deaktiviert"],"The project has already been added to your dashboard.":["Das Projekt ist bereits zu deinem Dashboard hinzugef\xfcgt worden."],"The project is still being deleted. Please try again later.":["Das Projekt wird immer noch gel\xf6scht. Bitte versuche es sp\xe4ter erneut."],"The project size exceeds the export limit.":["Die Projektgr\xf6\xdfe \xfcberschreitet das Exportlimit."],"The project visibility may have been made more restrictive if the parent group's visibility changed while the deletion was scheduled.":["Die Sichtbarkeit des Projekts wurde m\xf6glicherweise eingeschr\xe4nkt, wenn sich die Sichtbarkeit der \xfcbergeordneten Gruppe w\xe4hrend des geplanten L\xf6schvorgangs ge\xe4ndert hat."],"The project was successfully forked.":["Das Projekt wurde erfolgreich geforkt."],"The project was successfully imported.":["Das Projekt wurde erfolgreich importiert."],"The project-group link could not be removed.":["Der Projektgruppen-Link konnte nicht entfernt werden."],"The related CI build failed.":["Der zugeh\xf6rige CI-Build ist fehlgeschlagen."],"The remote mirror URL is invalid.":["Die Remote-Spiegel-URL ist ung\xfcltig."],"The remote mirror took to long to complete.":["Der Remote-Mirror hat zu lange gebraucht, um abzuschlie\xdfen."],"The remote repository is being updated...":["Das Remote-Repository wird aktualisiert..."],"The report artifact provided by the CI build couldn't be parsed.":["Das vom CI-Build bereitgestellte Berichtsartefakt konnte nicht geparst werden."],"The report has been successfully prepared.":["Der Bericht wurde erfolgreich erstellt."],"The repository for this project does not exist.":["Das Repository f\xfcr dieses Projekt existiert nicht."],"The repository for this project is empty":["Das Repository f\xfcr dieses Projekt ist leer"],"The repository is being updated...":["Das Repository wird aktualisiert..."],"The repository must be accessible over %{code_open}http://%{code_close}, %{code_open}https://%{code_close} or %{code_open}git://%{code_close}.":["Das Repository muss zug\xe4nglich sein \xfcber: %{code_open}http: //%{code_close}, %{code_open}https: //%{code_close} oder %{code_open}git: //%{code_close}."],"The repository must be accessible over %{code_open}http://%{code_close}, %{code_open}https://%{code_close}, %{code_open}ssh://%{code_close} or %{code_open}git://%{code_close}.":["Das Repository muss zug\xe4nglich sein \xfcber: %{code_open}http: //%{code_close}, %{code_open}https: //%{code_close}, %{code_open}ssh: //%{code_close} oder %{code_open}git: //%{code_close}."],"The requested `version` attribute format is not correct. Use formats such as `1.0.0` or `v1.0.0`.":["Das angeforderte Attributformat `version` ist nicht korrekt. Verwende Formate wie `1.0.0` oder `v1.0.0`."],"The resource that you are attempting to access does not exist or you don't have permission to perform this action.":["Die Ressource, auf die du zuzugreifen versuchst, existiert nicht oder du bist nicht berechtigt, diese Aktion auszuf\xfchren."],"The scan has been created.":["Der Scan wurde erstellt."],"The secret is only available when you create the application or renew the secret.":["Das Secret ist nur verf\xfcgbar, wenn du die Anwendung erstellst oder das Secret erneuerst."],"The selected image is not a valid SVG diagram":["Das ausgew\xe4hlte Bild ist kein g\xfcltiges SVG-Diagramm"],"The selected image is not an asset uploaded in the application":["Das ausgew\xe4hlte Bild ist kein Asset, das in die Anwendung hochgeladen wurde"],"The selected image is too large.":["Das ausgew\xe4hlte Bild ist zu gro\xdf."],"The selected project is not available":["Das ausgew\xe4hlte Projekt ist nicht verf\xfcgbar"],"The selected projects use different configuration profiles. Choosing a new profile will replace their existing ones.":["Die ausgew\xe4hlten Projekte verwenden unterschiedliche Konfigurationsprofile. Wenn du ein neues Profil ausw\xe4hlst, werden die vorhandenen ersetzt."],"The snippet can be accessed without any authentication.":["Der Code-Schnipsel kann ohne Authentifizierung aufgerufen werden."],"The snippet can be accessed without any authentication. To embed snippets, a project must be public.":["Der Code-Schnipsel kann ohne Authentifizierung aufgerufen werden. Um Code-Schnipsel einzubetten, muss ein Projekt \xf6ffentlich sein."],"The snippet is visible only to me.":["Der Code-Schnipsel ist nur f\xfcr mich sichtbar."],"The snippet is visible only to project members.":["Der Code-Schnipsel ist nur f\xfcr Projekt-Mitglieder einsehbar."],"The snippet is visible to any logged in user except external users.":["Der Code-Schnipsel ist f\xfcr alle angemeldeten Benutzer(innen) sichtbar, au\xdfer f\xfcr externe Benutzer(inne)n."],"The source project is a fork":["Das Quellprojekt ist ein Fork"],"The source project of this merge request has been removed.":["Das Quellprojekt dieses Merge Requests wurde entfernt."],"The source topic and the target topic are identical.":["Das Quellenthema und das Zielthema sind identisch."],"The source topic and the target topic must belong to the same organization.":["Das Quellthema und das Zielthema m\xfcssen zur selben Organisation geh\xf6ren."],"The source topic is not a topic.":["Das Quellthema ist kein Thema."],"The specified tab is invalid, please select another":["Die angegebene Registerkarte ist ung\xfcltig. W\xe4hle eine andere Registerkarte aus."],"The start date must be earlier than the end date.":["Das Anfangsdatum muss vor dem Enddatum liegen."],"The subdomain setting.":["Die Subdomain-Einstellung."],"The tag name can't be changed for an existing release.":["Der Tag-Name kann f\xfcr eine vorhandene Version nicht ge\xe4ndert werden."],"The target topic is not a topic.":["Das Zielthema ist kein Thema."],"The time period in seconds that the maximum requests per project limit applies to.":["Die Zeitspanne in Sekunden, f\xfcr die die maximale Anzahl an Anfragen pro Projektlimit gilt."],"The update action will time out after %{number_of_minutes} minutes. For big repositories, use a clone/push combination.":["Die Aktualisierungsaktion wird nach %{number_of_minutes} Minuten abgebrochen. Verwende f\xfcr gro\xdfe Repositorys eine Clone-/Push-Kombination."],"The uploaded file was invalid. Supported file extensions are %{extensions}.":["Die hochgeladene Datei war ung\xfcltig. Unterst\xfctzte Dateierweiterungen sind %{extensions}."],"The user is being deleted.":["Der/Die Benutzer(in) wird gel\xf6scht."],"The user map has been saved. Continue by selecting the projects you want to import.":["Die Benutzerzuordnung wurde gespeichert. W\xe4hle jetzt die Projekte aus, die du importieren m\xf6chtest."],"The user map is a mapping of the FogBugz users that participated on your projects to the way their email address and usernames will be imported into GitLab. You can change this by populating the table below.":["Die Benutzerzuordnung legt fest, wie die E-Mail-Adressen und Benutzernamen der FogBuz-Benutzer(innen), die an deinem Projekt teilnehmen, in GitLab importiert werden. Du kannst dies \xe4ndern, indem du die Tabelle unten ausf\xfcllst."],"The user you are trying to approve is not pending approval":["F\xfcr den/die Benutzer(in), den/die du genehmigen m\xf6chtest, steht keine Genehmigung aus"],"The user you are trying to deactivate has been active in the past %{minimum_inactive_days} days and cannot be deactivated":["Der/Die Benutzer(in), den/die du deaktivieren m\xf6chtest, war in den letzten %{minimum_inactive_days} Tagen aktiv und kann nicht deaktiviert werden."],'The value must be a valid JSON array format: [1,2,3] or [{"key": "value"}]':['Der Wert muss ein g\xfcltiges JSON-Array-Format haben: [1,2,3] oder [{\\"key\\": \\"value\\"}]'],"The value must match the defined regular expression.":["Der Wert muss dem definierten regul\xe4ren Ausdruck entsprechen."],"The value of the provided variable exceeds the %{count} character limit":["Der angegebene Variablenwert ist zu lang (Limit: %{count} Zeichen)."],"The views that appear in your tabs at the top are specific to you. Add, reorder, and remove views to create the best setup for your needs.":["Die Ansichten, die in deinen Tabs ganz oben erscheinen, sind auf dich zugeschnitten. Du kannst Ansichten nach Belieben hinzuf\xfcgen, neu anordnen und entfernen."],"The vulnerability is known, and has not been remediated or mitigated, but is considered to be an acceptable business risk.":["Die Sicherheitsl\xfccke ist bekannt und wurde nicht behoben oder gemindert, wird aber als akzeptables Gesch\xe4ftsrisiko betrachtet."],"The vulnerability is known, and has not been remediated or mitigated, but is considered to be in a part of the application that will not be updated.":["Die Sicherheitsl\xfccke ist bekannt und wurde nicht behoben oder gemindert. Sie wird jedoch als Teil der Anwendung betrachtet, der nicht aktualisiert wird."],"The vulnerability is no longer detected. Verify the vulnerability has been fixed or removed before changing its status.":["Die Sicherheitsl\xfccke wird nicht mehr erkannt. \xdcberpr\xfcfe, ob sie behoben oder entfernt wurde, bevor du den Status \xe4nderst."],"The vulnerability is no longer detected. Verify the vulnerability has been remediated before changing its status.":["Die Sicherheitsl\xfccke wird nicht mehr erkannt. \xdcberpr\xfcfe, ob sie behoben wurde, bevor du den Status \xe4nderst."],"There are currently no merge request branch targets":["Zurzeit gibt es keine Merge Request Branchziele"],"There are currently no mirrored repositories.":["Derzeit gibt es keine gespiegelten Repositorys."],"There are no GPG keys associated with this account.":["Mit diesem Konto sind keine GPG-Schl\xfcssel verkn\xfcpft."],"There are no GPG keys with access to your account.":["Mit deinem Konto sind keine GPG-Schl\xfcssel verkn\xfcpft."],"There are no SSH keys associated with this account":["Mit diesem Konto sind keine SSH-Schl\xfcssel verkn\xfcpft"],"There are no SSH keys with access to your account":["Es gibt keine SSH-Schl\xfcssel mit Zugriff auf dein Konto"],"There are no approval rules for the given `represent_as` parameter. Use a valid User/Group/Role name instead.":["F\xfcr den angegebenen Parameter \u201erepresent_as\u201c existieren keine Genehmigungsregeln. Verwende stattdessen einen g\xfcltigen Benutzer-/Gruppen-/Rollennamen."],"There are no archived requirements":["Es gibt keine archivierten Anforderungen"],"There are no archived test cases":["Es gibt keine archivierten Testf\xe4lle"],"There are no attributes for this project's group.":["F\xfcr die Gruppe dieses Projekts gibt es keine Attribute."],"There are no attributes in this category.":["In dieser Kategorie gibt es keine Attribute."],"There are no changed labels":["Es gibt keine ge\xe4nderten Labels"],"There are no changes":["Es gibt keine \xc4nderungen"],"There are no charts configured for this page":["F\xfcr diese Seite sind keine Diagramme konfiguriert"],"There are no closed epics":["Es gibt keine geschlossenen Epics"],"There are no closed issues":["Es gibt keine geschlossenen Tickets"],"There are no closed merge requests":["Es gibt keine geschlossenen Merge Requests"],"There are no comments to summarize.":["Es sind keine zusammenzufassenden Kommentare vorhanden."],"There are no commits yet":["Es sind noch keine Commits vorhanden."],"There are no commits yet.":["Es sind noch keine Commits vorhanden."],"There are no custom project templates set up for this GitLab instance. They are enabled from GitLab's Admin area. Contact your GitLab instance administrator to setup custom project templates.":["F\xfcr diese GitLab-Instanz sind keine benutzerdefinierten Projektvorlagen eingerichtet. Diese Vorlagen werden im Adminbereich von GitLab aktiviert. Wende dich an deinen GitLab-Instanzadministrator, um benutzerdefinierte Projektvorlagen einzurichten."],"There are no issues to show":["Es gibt keine Tickets die angezeigt werden k\xf6nnen"],"There are no issues with the selected labels":["Es gibt keine Tickets mit den ausgew\xe4hlten Labels"],"There are no matching files":["Es gibt keine passenden Dateien"],"There are no open epics":["Es gibt keine offenen Epics"],"There are no open issues":["Es gibt keine offenen Tickets"],"There are no open merge requests":["Es gibt keine offenen Merge Requests"],"There are no open requirements":["Es gibt keine offenen Anforderungen"],"There are no open test cases":["Es gibt keine offenen Testf\xe4lle"],"There are no packages yet":["Es gibt noch keine Pakete"],"There are no secure files yet.":["Hier sind noch keine sicheren Dateien."],"There are no spam logs":["Es gibt keine Spam-Protokolle"],"There are no topics to show":["Es gibt keine Themen zum Anzeigen"],"There are no variables yet.":["Es gibt noch keine Variablen."],"There are running deployments on the environment. Please retry later.":["Es werden Bereitstellungen in der Umgebung ausgef\xfchrt. Bitte versuche es sp\xe4ter erneut."],"There are several file size limits in place for the package registry.":["Es gelten mehrere Gr\xf6\xdfenbeschr\xe4nkungen f\xfcr die Paket-Registry."],"There are several rate limits in place to protect the system.":["Es gelten mehrere Ratenbeschr\xe4nkungen, um das System zu sch\xfctzen."],"There are several size limits in place.":["Es gelten mehrere Gr\xf6\xdfenbeschr\xe4nkungen."],"There is already a repository with that name on disk":["Es gibt bereits ein Repository mit diesem Namen auf der Festplatte"],"There is no data available.":["Es sind keine Daten verf\xfcgbar."],"There is no data available. Please change your selection.":["Es sind keine Daten verf\xfcgbar. Bitte \xe4ndere deine Auswahl."],"There is no job log to troubleshoot.":["Es gibt kein Jobprotokoll zur Fehlerbehebung."],"There is too much data to calculate. Please change your selection.":["Zu viele Daten f\xfcr die Berechnung vorhanden. \xc4ndere deine Auswahl."],"There was a problem creating the incident. Please try again.":["Es gab ein Problem beim Erstellen des Vorfalls. Bitte versuche es erneut."],"There was a problem fetching CRM contacts.":["Beim Abrufen von CRM-Kontakten ist ein Fehler aufgetreten."],"There was a problem fetching CRM organizations.":["Es gab ein Problem beim Abrufen von CRM-Organisationen."],"There was a problem fetching authors.":["Es gab ein Problem beim Abrufen der Autor(inn)en."],"There was a problem fetching branches.":["Fehler beim Abrufen der Branches."],"There was a problem fetching emoji.":["Es gab ein Problem beim Abrufen von Emojis."],"There was a problem fetching environments.":["Beim Abrufen der Umgebungen ist ein Problem aufgetreten."],"There was a problem fetching epics.":["Es gab ein Problem beim Abrufen von Epics."],"There was a problem fetching failed jobs":["Fehler beim Abrufen von fehlgeschlagenen Jobs"],"There was a problem fetching groups.":["Es gab ein Problem beim Abrufen von Gruppen."],"There was a problem fetching iterations.":["Beim Abrufen von Iterationen ist ein Problem aufgetreten."],"There was a problem fetching labels.":["Fehler beim Abrufen der Labels."],"There was a problem fetching latest labels.":["Beim Abrufen der neuesten Labels ist ein Problem aufgetreten."],"There was a problem fetching milestones.":["Fehler beim Abrufen der Meilensteine."],"There was a problem fetching namespaces.":["Es gab ein Problem beim Abrufen der Namensr\xe4ume."],"There was a problem fetching project branches.":["Fehler beim Abrufen der Projekt-Branches."],"There was a problem fetching project tags.":["Fehler beim Abrufen der Projekt-Tags."],"There was a problem fetching project users.":["Fehler beim Abrufen der Projektbenutzer(innen)."],"There was a problem fetching projects.":["Beim Abrufen der Projekte ist ein Problem aufgetreten"],"There was a problem fetching recent groups.":["Beim Abrufen von k\xfcrzlichen Gruppen ist ein Problem aufgetreten."],"There was a problem fetching recent projects.":["Beim Abrufen von k\xfcrzlichen Projekten ist ein Problem aufgetreten."],"There was a problem fetching releases.":["Beim Abrufen von Ver\xf6ffentlichungen ist ein Problem aufgetreten."],"There was a problem fetching the CI/CD job token permissions.":["Beim Abrufen der CI/CD-Job-Token-Berechtigungen ist ein Problem aufgetreten."],"There was a problem fetching the job token scope value":["Beim Abrufen des Werts f\xfcr den Geltungsbereich des Job-Tokens ist ein Problem aufgetreten"],"There was a problem fetching the keep latest artifacts setting.":["Es gab ein Problem beim Abrufen der Einstellung \u201eNeueste Artefakte beibehalten\u201c."],"There was a problem fetching the latest minimum override role.":["Beim Abrufen des neuesten niedrigsten \xdcberschreibungsrolle ist ein Fehler aufgetreten."],"There was a problem fetching the parent items.":["Beim Abrufen der \xfcbergeordneten Elemente ist ein Problem aufgetreten."],"There was a problem fetching the pipeline summary.":["Beim Abrufen der Pipeline-Zusammenfassung ist ein Fehler aufgetreten."],"There was a problem fetching the projects":["Beim Abrufen der Projekte ist ein Problem aufgetreten"],"There was a problem fetching users.":["Es gab ein Problem beim Abrufen von Benutzer(inne)n."],"There was a problem loading this project's readme content.":["Beim Laden des Readme-Inhalts dieses Projekts ist ein Problem aufgetreten."],"There was a problem sending the confirmation email":["Beim Versand der Best\xe4tigungs-E-Mail ist ein Fehler aufgetreten"],"There was a problem updating the keep latest artifacts setting.":["Es gab ein Problem beim Aktualisieren der Einstellung \u201eNeueste Artefakte beibehalten\u201c."],"There was a problem updating the minimum override setting.":["Beim Aktualisieren der Einstellung zur niedrigsten \xdcberschreibung ist ein Problem aufgetreten."],"There was an error fetching configuration for charts":["Beim Abrufen der Konfiguration f\xfcr Diagramme ist ein Fehler aufgetreten"],"There was an error fetching data for the selected stage":["Fehler beim Abrufen der Daten f\xfcr die ausgew\xe4hlte Phase."],"There was an error fetching data for the tasks by type chart":["Fehler beim Abrufen der Daten f\xfcr das Diagramm \u201eAufgaben nach Typ\u201c."],"There was an error fetching inputs for this job.":["Beim Abrufen der Eingaben f\xfcr diesen Job ist ein Fehler aufgetreten."],"There was an error fetching label data for the selected group":["Fehler beim Abrufen der Label-Daten f\xfcr die ausgew\xe4hlte Gruppe."],"There was an error fetching median data for stages":["Fehler beim Abrufen der Median-Daten f\xfcr die Phasen."],"There was an error fetching merge requests. Please try again.":["Beim Abrufen der Merge Requests ist ein Fehler aufgetreten. Bitte versuche es erneut."],"There was an error fetching projects":["Es gab einen Fehler beim Abrufen von Projekten"],"There was an error fetching stage total counts":["Beim Abrufen der Gesamtz\xe4hlungen der Stufe ist ein Fehler aufgetreten"],"There was an error fetching the cancelable jobs.":["Es gab einen Fehler beim Laden der Jobs"],"There was an error fetching the deploy freezes.":["Fehler beim Abrufen der Bereitstellungs-Freezes."],"There was an error fetching the environments information.":["Fehler beim Abrufen der Umgebungsinformationen."],"There was an error fetching the job.":["Beim Abrufen des Jobs ist ein Fehler aufgetreten."],"There was an error fetching the jobs for your project.":["Beim Abrufen der Anzahl der Jobs f\xfcr dein Projekt ist ein Fehler aufgetreten."],"There was an error fetching the jobs.":["Beim Laden der Jobs ist ein Fehler aufgetreten."],"There was an error fetching the number of jobs for your project.":["Beim Abrufen der Jobanzahl f\xfcr dein Projekt ist ein Fehler aufgetreten."],"There was an error fetching the number of jobs.":["Beim Abrufen der Jobanzahl ist ein Fehler aufgetreten."],"There was an error fetching the top labels for the selected group":["Fehler beim Abrufen der Top-Labels f\xfcr die ausgew\xe4hlte Gruppe."],"There was an error fetching the variables.":["Fehler beim Abrufen der Variablen."],"There was an error fetching this merge request's pipelines.":["Beim Abrufen der Pipelines f\xfcr diesen Merge Request ist ein Fehler aufgetreten."],"There was an error fetching value stream analytics stages.":["Beim Datenabruf der Analysephasen der Wertsch\xf6pfungskette ist ein Fehler aufgetreten."],"There was an error gathering the chart data":["Fehler beim Sammeln der Diagrammdaten."],"There was an error generating commit message.":["Fehler beim Generieren der commit Nachricht."],"There was an error importing the Jira project.":["Fehler beim Importieren des Jira-Projekts."],"There was an error loading more labels":["Beim Laden weiterer Label ist ein Fehler aufgetreten"],"There was an error loading related feature flags":["Beim Laden verwandter Funktionsflags ist ein Fehler aufgetreten"],"There was an error loading users activity calendar.":["Beim Laden des Benutzeraktivit\xe4ts-Kalenders ist ein Fehler aufgetreten."],"There was an error removing the e-mail.":["Es gab einen Fehler beim Entfernen der E-Mail-Adresse."],"There was an error retrieving LDAP groups. Please try again.":["Beim Abrufen der LDAP-Gruppen ist ein Fehler aufgetreten. Bitte versuche es nochmal."],"There was an error retrieving the Jira users.":["Fehler beim Abrufen der Jira-Benutzer(innen)."],"There was an error retrying the job.":["Bei der Wiederholung des Jobs ist ein Fehler aufgetreten."],"There was an error running the job. Please try again.":["Beim Ausf\xfchren des Jobs ist ein Fehler aufgetreten. Bitte versuche es erneut."],"There was an error saving your changes.":["Es gab einen Fehler beim Speichern deiner \xc4nderungen."],"There was an error subscribing to this label.":["Beim Abonnieren dieses Labels ist ein Fehler aufgetreten."],"There was an error summarizing your pending comments.":["Bei der Zusammenfassung deiner ausstehenden Kommentare ist ein Fehler aufgetreten."],"There was an error updating your display preferences.":["Es gab einen Fehler beim Aktualisieren deiner Anzeigeeinstellungen."],"There was an error updating your show drafts preference.":["Es gab einen Fehler beim Aktualisieren deiner Einstellungen zum Anzeigen von Entw\xfcrfen."],"There was an error when subscribing to this label.":["Beim Abonnieren dieses Labels ist ein Fehler aufgetreten."],"There was an error when unsubscribing from this label.":["Beim Abmelden von der Abonnierung dieses Labels ist ein Fehler aufgetreten."],"There was an error while fetching value stream analytics data.":["Beim Datenabruf von Wertsch\xf6pfungskette-Analysedaten ist ein Fehler aufgetreten."],"There was an error while running this job again":["Beim erneuten Ausf\xfchren dieses Jobs ist ein Fehler aufgetreten."],"There was an error with the reCAPTCHA. Please solve the reCAPTCHA again.":["Es ist ein Fehler mit dem reCAPTCHA aufgetreten. Bitte l\xf6se das reCAPTCHA erneut."],"These branches already have an open merge request: %{link_to_mr}. Select a different source or target branch.":["Diese Branchen haben bereits einen offenen Merge Request: %{link_to_mr}. W\xe4hle einen anderen Quell- oder Ziel-Branch aus."],"These dates affect how your epics appear in the roadmap. Set a fixed date or one inherited from the milestones assigned to issues in this epic.":["Diese Daten beeinflussen die Darstellung deiner Epics in der Roadmap. Lege ein festes Datum oder ein Datum der Meilensteine\xa0\u2013 welche einem der Tickets in diesem Epic zugewiesen wurden\xa0\u2013 fest."],"These examples show common methods of triggering a pipeline with a pipeline trigger token. The URL and ID for this project is prefilled.":["Diese Beispiele zeigen g\xe4ngige Methoden zum Ausl\xf6sen einer Pipeline mit einem Pipeline-Trigger-Token. URL und ID f\xfcr dieses Projekt werden vorausgef\xfcllt."],"These existing issues have a similar title. It might be better to comment there instead of creating another similar issue.":["Es gibt bereits Tickets mit \xe4hnlichem Namen. Es k\xf6nnte besser sein, dort zu kommentieren, anstatt ein weiteres, \xe4hnliches Ticket zu erstellen."],"These guidelines are displayed on the group's or project's members page, and are visible to users who can manage team member permissions.":["Diese Richtlinien werden auf der Mitglieder-Seite der Gruppe oder des Projekts angezeigt und sind f\xfcr Benutzer(innen) sichtbar, die die Berechtigungen f\xfcr Teammitglieder verwalten k\xf6nnen."],"These guidelines for public avatars are displayed on the user settings page.":["Diese Richtlinien f\xfcr \xf6ffentliche Avatare werden auf der Seite der Benutzereinstellungen angezeigt."],"These merge requests need a review from you.":["Diese Merge-Anfragen erfordern eine Review durch dich."],"These runners are shared across projects in this group.":["Diese Runner werden von allen Projekten in dieser Gruppe gemeinsam genutzt."],"These variables are inherited from the parent group.":["Diese Variablen werden von der \xfcbergeordneten Gruppe geerbt."],"These will be sent to %{email} in an attachment once finished.":["Diese werden in einem Anhang an %{email} gesendet, sobald sie fertig sind."],"Things to be aware of before transferring:":["Dinge, die du vor der \xdcbertragung beachten solltest:"],"Third Party Advisory Link":["Link zu Drittanbieter-Hinweisen"],"This %{issuable} belongs to an archived project and is read-only.":["%{issuable} geh\xf6rt zu einem archivierten Projekt und ist schreibgesch\xfctzt."],"This %{issuable} is hidden because its author has been banned.":["%{issuable} ist ausgeblendet, weil der/die Autor(in) gesperrt wurde"],"This %{issuable} is locked. Only %{strong_open}project members%{strong_close} can comment.":["%{issuable} ist gesperrt. Nur %{strong_open}Projektmitglieder%{strong_close} k\xf6nnen Kommentare erstellen."],"This %{issuable} would exceed the maximum number of linked %{issuables} (%{limit}).":["Dieses %{issuable} w\xfcrde die maximale Anzahl der verkn\xfcpften %{issuables} (%{limit}) \xfcberschreiten."],"This Cron pattern is invalid":["Dieses Cron-Muster ist ung\xfcltig"],"This MCP server does not support dynamic client registration. Please configure the OAuth client ID for this server.":[""],"This MCP server does not use OAuth authentication":[""],"This PDF is too large to display. Please download to view.":["Diese PDF ist zu gro\xdf, um sie anzuzeigen. Bitte lade sie herunter."],"This URL already exists.":["Diese URL existiert bereits."],"This action can lead to data loss. To prevent accidental actions we ask you to confirm your intention.":["Diese Aktion kann zu Datenverlust f\xfchren. Um versehentliche Aktionen zu verhindern, bitten wir dich, deine Absicht zu best\xe4tigen."],"This action cannot be undone, and will permanently delete the %{key} SSH key":["Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden und l\xf6scht den SSH-Schl\xfcssel %{key} dauerhaft."],
"This action cannot be undone, and will permanently delete the %{key} SSH key. All commits signed using this SSH key will be marked as unverified.":["Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden und l\xf6scht den SSH-Schl\xfcssel %{key} dauerhaft. Alle mit diesem SSH-Schl\xfcssel signierten Commits werden als unbest\xe4tigt markiert."],"This action is destructive. Disabling semantic search will remove all indexed data. If you reconnect in the future, a full index will be performed.":["Diese Aktion ist destruktiv. Beim Deaktivieren der semantischen Suche werden alle indizierten Daten entfernt. Wenn du die Verbindung sp\xe4ter erneut herstellst, wird eine vollst\xe4ndige Indizierung durchgef\xfchrt."],"This action will permanently delete this group, including its subgroups and projects, on %{date}. Scheduled pipelines will not run during deletion.":["Durch diese Aktion wird diese Gruppe einschlie\xdflich ihrer Untergruppen und Projekte am %{date} dauerhaft gel\xf6scht. Geplante Pipelines werden w\xe4hrend der L\xf6schung nicht ausgef\xfchrt."],"This action will permanently delete this project, including all its resources, on %{date}. Scheduled pipelines will not run during deletion.":["Durch diese Aktion wird dieses Projekt einschlie\xdflich aller enthaltener Ressourcen am %{date} dauerhaft gel\xf6scht. Geplante Pipelines werden w\xe4hrend der L\xf6schung nicht ausgef\xfchrt."],"This also resolves all related threads":["Dadurch werden auch alle zugeh\xf6rigen Diskussionen gel\xf6st."],"This also resolves this thread":["Mit dieser Aktion wird dieser Thread ebenfalls aufgel\xf6st."],"This application is provided by GitLab.":["Diese Anwendung wird von GitLab bereitgestellt."],"This application will be able to:":["Diese Anwendung wird in der Lage sein:"],"This archive has been requested too many times. Try again later.":["Dieses Archiv wurde zu oft angefordert. Versuche es sp\xe4ter erneut."],"This attachment has been truncated to avoid exceeding the maximum allowed attachment size of %{size_limit}. %{written_count} of %{count} %{issuables} have been included. Consider re-exporting with a narrower selection of %{issuables}.":["Dieser Anhang wurde abgeschnitten, um zu vermeiden, dass die maximal zul\xe4ssige Anhangsgr\xf6\xdfe von %{size_limit} \xfcberschritten wird. %{written_count} von %{count} %{issuables} wurden ber\xfccksichtigt. Ziehe einen erneuten Export mit einer engeren Auswahl an %{issuables} in Betracht."],"This attachment has been truncated to avoid exceeding the maximum allowed attachment size of %{size_limit}. %{written_count} of %{count} projects have been included.":["Dieser Anhang wurde abgeschnitten, um zu vermeiden, dass die maximal zul\xe4ssige Anhangsgr\xf6\xdfe von %{size_limit} \xfcberschritten wird. %{written_count} von %{count} Projekten wurden ber\xfccksichtigt."],"This attachment has been truncated to avoid exceeding the maximum allowed attachment size of %{size_limit}. %{written_count} of %{total_count} %{object_type} have been included. Consider re-exporting with a narrower selection of %{object_type}.":["Dieser Anhang wurde abgeschnitten, um die maximal zul\xe4ssige Anhangsgr\xf6\xdfe von %{size_limit} nicht zu \xfcberschreiten. %{written_count} von %{total_count} %{object_type} wurden aufgenommen. Erw\xe4ge einen erneuten Export mit einer engeren Auswahl von %{object_type}."],"This attachment has been truncated to avoid exceeding the maximum allowed attachment size of %{size_limit}. %{written_count} of %{total_count} projects have been included.":["Dieser Anhang wurde abgeschnitten, um zu vermeiden, dass die maximal zul\xe4ssige Anhangsgr\xf6\xdfe von %{size_limit} \xfcberschritten wird. %{written_count} von %{total_count} Projekten wurden ber\xfccksichtigt."],"This authentication method is not supported. Use a different authentication method.":["Diese Authentifizierungsmethode wird nicht unterst\xfctzt. Verwende eine andere Authentifizierungsmethode."],"This block is self-referential":["Dieser Block ist selbstreferenzierend"],"This branch has diverged from upstream.":["Dieser Branch ist vom Upstream abgewichen."],"This change will remove %{strongOpen}ALL%{strongClose} Premium and Ultimate features for %{strongOpen}ALL%{strongClose} SaaS customers and make tests start failing.":["Diese \xc4nderung entfernt %{strongOpen}ALLE%{strongClose} Premium- und Ultimate-Funktionen f\xfcr %{strongOpen}ALLE%{strongClose} SaaS-Kunden und f\xfchrt dazu, dass Tests nicht l\xe4nger funktionieren."],"This chart could not be displayed":["Dieses Diagramm konnte nicht angezeigt werden"],"This clears repository check states for all projects in the database and cannot be undone. Are you sure?":["Dies l\xf6scht den Status der Repository-Pr\xfcfung f\xfcr alle Projekte in der Datenbank und kann nicht r\xfcckg\xe4ngig gemacht werden. Bist du sicher?"],"This code snippet contains everything reflected in the configuration form. Copy and paste it into %{linkStart}.gitlab-ci.yml%{linkEnd} file and save your changes. Future %{scanType} scans will use these settings.":["Dieser Codeschnipsel enth\xe4lt alles, was im Konfigurationsformular angegeben ist. Kopiere und f\xfcge es in die %{linkStart}.gitlab-ci.yml%{linkEnd}-Datei ein und speichere deine \xc4nderungen. Zuk\xfcnftige %{scanType}-Scans verwenden diese Einstellungen."],"This command is used for explaining vulnerabilities and can only be invoked from a vulnerability detail page.":["Dieser Befehl wird verwendet, um Sicherheitsl\xfccken zu erkl\xe4ren. Er kann nur auf der Detailseite von Sicherheitsl\xfccken ausgef\xfchrt werden."],"This command is used for troubleshooting jobs and can only be invoked from a failed job log page.":["Dieser Befehl wird zur Fehlerbehebung bei Jobs verwendet und kann nur von einer Protokollseite eines fehlgeschlagenen Jobs aufgerufen werden."],"This comment changed after you started editing it. Review the %{startTag}updated comment%{endTag} to ensure information is not lost.":["Dieser Kommentar wurde ge\xe4ndert, nachdem du mit der Bearbeitung begonnen hast. \xdcberpr\xfcfe den %{startTag}aktualisierten Kommentar%{endTag}, um sicherzustellen, dass keine Informationen verloren gegangen sind."],"This comment was generated by AI":["Dieser Kommentar wurde von der KI generiert"],"This commit is part of merge request %{link_to_merge_request}. Comments created here will be created in the context of that merge request.":["Dieser Commit ist Teil des Merge Request %{link_to_merge_request}. Hier erstellte Kommentare werden im Kontext dieses Merge Request erstellt."],"This commit was created in the GitLab UI, and signed with a GitLab-verified signature.":["Dieser Commit wurde in der GitLab-UI angelegt und mit einer von GitLab gepr\xfcften Signatur signiert."],"This commit was previously signed with a verified signature and verified committer email address. However the committer email address is no longer verified to the same user.":["Dieser Commit war zuvor mit einer verifizierten Signatur und einer verifizierten E-Mail-Adresse des Committers signiert. Die E-Mail-Adresse des Committers ist jedoch nicht mehr dem/der gleichen Benutzer(in) zugeordnet."],"This commit was signed with a %{strong_open}verified%{strong_close} signature and the committer email is verified to belong to the same user.":["Dieser Commit wurde mit einer %{strong_open}verifizierten%{strong_close} Signatur signiert, und die E-Mail-Adresse des/der Committer(in) wurde verifiziert und geh\xf6rt derselben Person."],"This commit was signed with a certificate issued by top-level group Certificate Authority (CA) and the committer email was verified to belong to the same user.":["Dieser Commit wurde mit einem Zertifikat signiert, das von der Zertifizierungsstelle (ZS) der Hauptgruppe ausgestellt wurde, und die Committer-E-Mail wurde verifiziert, dass sie dem- oder derselben Benutzer(in) geh\xf6rt."],"This commit was signed with a different user's verified signature.":["Dieser Commit wurde mit einer verifizierten Signatur eines anderen Benutzers/einer anderen Benutzerin signiert."],"This commit was signed with a verified signature and the committer email was verified to belong to the same user.":["Dieser Commit wurde mit einer verifizierten Signatur signiert und die Committer-E-Mail wurde verifiziert, dass sie demselben/derselben Benutzer(in) geh\xf6rt."],"This commit was signed with a verified signature, but the committer email is not verified.":["Dieser Commit wurde mit einer verifizierten Signatur signiert, aber die E-Mail des/der Committer(in) ist nicht verifiziert."],"This commit was signed with an %{strong_open}unverified%{strong_close} signature.":["Dieser Commit wurde mit einer %{strong_open}nicht verifizierten%{strong_close} Signatur signiert."],"This commit was signed with an unverified signature.":["Dieser Commit wurde mit einer ungepr\xfcften Signatur signiert."],"This commit was signed with multiple signatures.":["Dieser Commit wurde mit mehreren Signaturen signiert."],"This content could not be displayed because it is stored in LFS. You can %{linkStart}download it%{linkEnd} instead.":["Dieser Inhalt konnte nicht angezeigt werden, da er in LFS gespeichert ist. Du kannst ihn stattdessen %{linkStart}herunterladen%{linkEnd}."],"This credential has expired":["Diese Zugangsdaten sind abgelaufen."],"This deployment is not waiting for approvals.":["Diese Bereitstellung wartet nicht auf Zustimmungen."],"This deployment job does not run automatically and must be started manually, but it's older than the latest deployment, and therefore can't run.":["Dieser Bereitstellungsjob wird nicht automatisch ausgef\xfchrt und muss manuell gestartet werden, ist aber \xe4lter als die letzte Bereitstellung und kann daher nicht ausgef\xfchrt werden."],"This deployment job does not run automatically and must be started manually, but you do not have access to this job's protected environment. The job can only be started by a project member allowed to deploy to the environment.":["Dieser Bereitstellungs-Job wird nicht automatisch ausgef\xfchrt und muss manuell gestartet werden, aber du hast keinen Zugriff auf die gesch\xfctzte Umgebung dieses Jobs. Der Job kann nur von einem Projektmitglied gestartet werden, das in der Umgebung bereitstellen darf."],"This device has already been registered with us.":["Dieses Ger\xe4t wurde bereits registriert."],"This device has not been registered with us.":["Dieses Ger\xe4t wurde noch nicht bei uns registriert."],"This diff is collapsed.":["Dieser Diff ist reduziert."],'This directory cannot be locked while %{locker} has a lock on "%{path}". %{additionalPhrase}':["Dieses Verzeichnis kann nicht gesperrt werden, w\xe4hrend %{locker} \u201e%{path}\u201c sperrt. %{additionalPhrase}"],"This domain is not verified. You will need to verify ownership before access is enabled.":["Diese Domain ist nicht verifiziert. Du musst die Inhaberschaft best\xe4tigen, bevor der Zugriff aktiviert wird."],"This email supersedes any previous emails about scheduled deletion you may have received for %{project_link}.":["Diese E-Mail ersetzt alle fr\xfcheren E-Mails \xfcber geplante L\xf6schungen, die du m\xf6glicherweise f\xfcr %{project_link} erhalten hast."],"This email supersedes any previous emails about scheduled deletion you may have received for %{project_name}.":["Diese E-Mail ersetzt alle fr\xfcheren E-Mails \xfcber geplante L\xf6schungen, die du m\xf6glicherweise f\xfcr %{project_name} erhalten hast."],"This endpoint has been requested too many times. Try again later.":["Dieser Endpunkt wurde zu oft angefordert. Versuche es sp\xe4ter erneut."],"This environment has no deployments yet.":["Diese Umgebung hat noch keine Bereitstellungen."],"This environment is being deployed":["Diese Umgebung wird bereitgestellt"],"This environment is being re-deployed":["Diese Umgebung wird erneut bereitgestellt"],"This environment is not protected.":["Diese Umgebung ist nicht gesch\xfctzt."],"This environment's canary ingress has been updated recently. Please retry later.":["Der Canary-Ingress dieser Umgebung wurde k\xfcrzlich aktualisiert. Bitte versuche es sp\xe4ter erneut."],"This epic already has the maximum number of child epics.":["Dieses Epic enth\xe4lt bereits die maximale Anzahl an untergeordneten Epics."],"This epic cannot be added. An epic cannot be added to itself.":["Dieses Epic kann nicht hinzugef\xfcgt werden. Ein Epic kann nicht zu sich selbst hinzugef\xfcgt werden."],"This epic cannot be added. It is already an ancestor of the parent epic.":["Dieses Epic kann nicht hinzugef\xfcgt werden. Es ist bereits ein Vorfahre des \xfcbergeordneten Epic."],"This epic cannot be added. It is already assigned to the parent epic.":["Dieses Epic kann nicht hinzugef\xfcgt werden. Es ist bereits dem \xfcbergeordneten Epic zugewiesen."],"This epic cannot be added. One or more epics would exceed the maximum depth (%{max_depth}) from its most distant ancestor.":["Dieses Epic kann nicht hinzugef\xfcgt werden. Ein oder mehrere Epics w\xfcrden die maximale Tiefe (%{max_depth}) von ihrem am weitesten entfernten Vorfahren \xfcberschreiten."],"This feature requires an Ultimate plan %{linkStart}Learn more%{linkEnd}.":["Diese Funktion erfordert den Ultimate-Tarif %{linkStart}Mehr erfahren%{linkEnd}."],"This feature requires local storage to be enabled":["Um diese Funktion verwenden zu k\xf6nnen, muss der lokale Speicher aktiviert werden."],"This field is auto-calculated based on the progress score of its direct children. You can overwrite this value but it will be replaced by the auto-calculation anytime the progress score of its direct children are updated.":["Dieses Feld wird automatisch anhand des Fortschrittswerts der direkt untergeordneten Felder berechnet. Du kannst diesen Wert \xfcberschreiben, aber er wird jedes Mal durch die automatische Berechnung ersetzt, wenn die Fortschrittsbewertung der direkt untergeordneten Felder aktualisiert wird."],"This field is required":["Dieses Feld ist erforderlich"],"This field is required.":["Dieses Feld ist erforderlich."],"This file was linked in the page URL and will appear as the first one in the list":["Diese Datei wurde in der Seiten-URL verkn\xfcpft und erscheint als erste in der Liste"],"This file was modified for readability, and can't accept suggestions. Edit it directly.":["Diese Datei wurde aus Gr\xfcnden der Lesbarkeit ge\xe4ndert und kann keine Vorschl\xe4ge annehmen. Bearbeite sie direkt."],"This form is disabled in preview":["Dieses Formular ist in der Vorschau deaktiviert"],"This graph shows commit history with branches and merges arranged from newest to oldest. Each dot represents a commit, with lines showing how code changes flow between different branches.":["Dieser Graph zeigt den Commit-Verlauf mit Branches und Merges, sortiert vom neuesten zum \xe4ltesten Commit. Jeder Punkt stellt ein Commit dar, und die Linien stellen den Fluss von Code-\xc4nderungen zwischen verschiedenen Branches dar."],"This group":["Diese Gruppe"],"This group and all its data will be %{strongOpen}permanently deleted%{strongClose} on %{date}.":["Diese Gruppe und alle ihre Daten werden am %{date} %{strongOpen}endg\xfcltig gel\xf6scht%{strongClose}."],"This group and its contents, including subgroups and projects, will be permanently deleted on %{date}. After this point, your data cannot be recovered. Scheduled pipelines will not run during deletion.":["Diese Gruppe und ihre Inhalte, inklusive Untergruppen und Projekte, werden am %{date} dauerhaft gel\xf6scht. Danach k\xf6nnen deine Daten nicht mehr wiederhergestellt werden. Geplante Pipelines werden w\xe4hrend der L\xf6schung nicht ausgef\xfchrt."],"This group and its subgroups are being deleted.":["Diese Gruppe und ihre Untergruppen werden gel\xf6scht."],"This group can't be deleted because it is linked to a subscription. To delete this group, %{linkStart}link the subscription%{linkEnd} with a different group.":["Diese Gruppe kann nicht gel\xf6scht werden, da sie mit einem Abonnement verkn\xfcpft ist. Um diese Gruppe zu l\xf6schen, %{linkStart}verkn\xfcpfe das Abonnement%{linkEnd} mit einer anderen Gruppe."],"This group can't be transferred because it is linked to a subscription. To transfer this group, %{linkStart}link the subscription%{linkEnd} with a different group.":["Diese Gruppe kann nicht entfernt werden, da sie mit einem Abonnement verkn\xfcpft ist. Um diese Gruppe zu entfernen, %{linkStart}verkn\xfcpfe das Abonnement%{linkEnd} mit einer anderen Gruppe."],"This group cannot be invited to a project inside a group with enforced SSO":["Diese Gruppe kann nicht zu einem Projekt innerhalb einer Gruppe mit erzwungenem SSO eingeladen werden"],"This group does not have any group runners yet.":["Diese Gruppe hat noch keine Gruppen-Runner."],"This group has no active access tokens.":["Diese Gruppe hat keine aktiven Zugriffstoken."],"This group has no inactive access tokens.":["Diese Gruppe hat keine inaktiven Zugriffstoken."],"This group is archived. Its subgroups, projects, and data are %{strong_open}read-only%{strong_close}.":["Diese Gruppe wurde archiviert. Ihre Untergruppen, Projekte und Daten sind %{strong_open}schreibgesch\xfctzt%{strong_close}."],"This group is linked to a subscription":["Diese Gruppe ist mit einem Abonnement verkn\xfcpft"],"This group is not permitted to create compliance violations":["Dieser Gruppe ist es nicht gestattet, Konformit\xe4ts-Verst\xf6\xdfe zu erstellen"],"This group is scheduled for deletion on %{date}. This action will permanently delete this group, including its subgroups and projects, %{strongOpen}immediately%{strongClose}. This action cannot be undone.":["Diese Gruppe steht zur L\xf6schung am %{date} aus. Durch diese Aktion wird diese Gruppe, einschlie\xdflich ihrer Untergruppen und Projekte, %{strongOpen}sofort%{strongClose} endg\xfcltig gel\xf6scht. Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],"This group requires additional authentication. Please sign in with your OAuth provider to continue.":["Diese Gruppe erfordert keine zus\xe4tzliche Authentifizierung. Melde dich bei deinem OAuth-Anbieter an, um fortzufahren."],"This group will be restored from scheduled deletion.":["Diese Gruppe wird aus der geplanten L\xf6schung wiederhergestellt."],"This incident is already escalated with '%{escalation_policy_name}'.":["Dieser Vorfall wurde bereits mit \u201e%{escalation_policy_name}\u201c eskaliert."],"This instance is now read-only. Don't worry, your data is safe. To change to GitLab Free and restore write access to this instance, delete your expired license.":["Diese Instanz ist jetzt schreibgesch\xfctzt. Keine Sorge, deine Daten sind nicht verloren. L\xf6sche deine abgelaufene Lizenz, um zu GitLab Free zu wechseln und den Schreibzugriff auf diese Instanz wiederherzustellen."],"This invitation was sent to %{mail_to_invite_email}, but you are signed in as %{link_to_current_user} with email %{mail_to_current_user}.":["Diese Einladung wurde an %{mail_to_invite_email} gesendet, doch du bist als %{link_to_current_user} mit der E-Mail-Adresse %{mail_to_current_user} angemeldet."],'This is a "Ghost User", created to hold all issues authored by users that have since been deleted. This user cannot be removed.':["Dies ist ein(e) sogenannte(r) \u201eGhost User(in)\u201c, der/die s\xe4mtliche Tickets besitzt, die von inzwischen gel\xf6schten Benutzer(inne)n verfasst wurden. Diese(r) Benutzer(in) kann nicht entfernt werden."],"This is a %{role_type} role.":["Dies ist eine %{role_type}-Rolle."],"This is a %{role_type}.":["Dies ist ein(e) %{role_type}."],"This is a Jira user.":["Dies ist ein(e) Jira-Benutzer(in)."],"This is a child pipeline within the parent pipeline":["Dies ist eine untergeordnete Pipeline innerhalb der \xfcbergeordneten Pipeline"],"This is a delayed job to run in %{remainingTime}":["Dies ist ein in %{remainingTime} auszuf\xfchrender verz\xf6gerter Job"],"This is a list of devices that have logged into your account. Revoke any sessions that you do not recognize.":["Dies ist eine Liste der Ger\xe4te, die sich bei deinem Konto angemeldet haben. Beende alle Sitzungen, die du nicht erkennst."],"This is a security log of authentication events involving your account.":["Dies ist ein Sicherheitsprotokoll der Authentifizierungsereignisse f\xfcr dein Konto."],"This is an automated message. Please don't reply to this message.":["Dies ist eine automatische Nachricht. Bitte antworte nicht auf diese Nachricht."],"This is really just a warning":["Das ist wirklich nur eine Warnung"],"This is required and must be defined.":["Dies ist erforderlich und muss definiert werden."],"This is some information. %{linkStart}Learn more%{linkEnd}.":["Dies sind einige Informationen. %{linkStart}Mehr erfahren%{linkEnd}."],"This is the highest peak of users on your installation since the license started.":["Dies ist die h\xf6chste Anzahl an Benutzer(inne)n, die deine Installation seit Beginn der Lizenz genutzt haben."],"This is the number of %{billableUsersLinkStart}billable users%{billableUsersLinkEnd} on your installation, and this is the minimum number you need to purchase when you renew your license.":["Dies ist die Anzahl der %{billableUsersLinkStart}abrechenbaren Benutzer(innen)%{billableUsersLinkEnd} in deiner Installation, und dies ist die Mindestanzahl, die du kaufen musst, wenn du deine Lizenz verl\xe4ngerst."],"This is the number of %{billable_users_link_start}billable users%{billable_users_link_end} on your installation, and this is the minimum number you need to purchase when you renew your license.":["Dies ist die Anzahl der %{billable_users_link_start}abrechenbaren Benutzer(innen)%{billable_users_link_end} in deiner Installation, und dies ist die Mindestanzahl, die du kaufen musst, wenn du deine Lizenz erneuerst."],"This is the only time the secret is accessible. Copy the secret and store it securely.":["Dies ist das einzige Mal, dass das Geheimnis zug\xe4nglich ist. Kopiere das Geheimnis und speichere es sicher."],"This is your current session":["Dies ist deine aktuelle Sitzung"],"This issue cannot be assigned to a confidential epic because it is public.":["Diese Frage kann nicht zu einem vertraulich Epic zugewiesen werden, da sie \xf6ffentlich ist."],"This issue cannot be made public because it belongs to a confidential epic.":["Dieses Ticket kann nicht ver\xf6ffentlicht werden, da es zu einem vertraulichen Epic geh\xf6rt."],"This issue is currently blocked by the following issues:":["Dieses Ticket wird derzeit durch die folgenden Tickets blockiert:"],"This issue is hidden because its author has been banned.":["Dieses Ticket ist ausgeblendet, weil der/die Autor(in) gebannt wurde."],"This issue is in a child epic of the filtered epic":["Dieses Ticket befindet sich in einem untergeordneten Epic des gefilterten Epics"],"This item belongs to a descendant of the filtered parent.":["Dieses Element geh\xf6rt zu einem Nachfolger des gefilterten \xfcbergeordneten Elements."],"This item is disabled":["Dieses Element ist deaktiviert"],"This iteration contains confidential items you do not have access to.":["Diese Iteration enth\xe4lt vertrauliche Elemente, auf die du keinen Zugriff hast."],"This job could not start because it could not retrieve the needed artifacts%{punctuation}%{invalid_dependencies}":["Dieser Job konnte nicht gestartet werden, da die ben\xf6tigten Artefakte nicht abgerufen werden konnten%{punctuation}%{invalid_dependencies}"],"This job depends on upstream jobs that need to succeed in order for this job to be triggered":["Dieser Job h\xe4ngt von Upstream-Jobs ab, die erfolgreich ausgef\xfchrt werden m\xfcssen, damit dieser Job getriggert wird"],'This job deploys to the protected environment "%{environment}", which requires approvals. You can approve or reject the deployment on the deployment details page.':["Dieser Job wird in der gesch\xfctzten Umgebung \u201e%{environment}\u201c bereitgestellt, f\xfcr die Genehmigungen erforderlich sind. Du kannst die Bereitstellung auf der Seite mit den Bereitstellungsdetails genehmigen oder ablehnen."],"This job does not have a trace.":["Dieser Job hat keine Ablaufverfolgung."],"This job does not run automatically and must be started manually, but you do not have access to it.":["Dieser Job wird nicht automatisch ausgef\xfchrt und muss manuell gestartet werden, aber du hast keinen Zugriff darauf."],"This job does not start automatically and must be started manually.":["Dieser Job startet nicht automatisch und muss manuell gestartet werden."],"This job does not start automatically and must be started manually. You can add CI/CD variables below for last-minute configuration changes before starting the job.":["Dieser Job wird nicht automatisch gestartet und muss manuell gestartet werden. Unten kannst du CI/CD-Variablen f\xfcr kurzfristige Konfigurations\xe4nderungen hinzuf\xfcgen, bevor du den Job startest."],"This job has been canceled":["Dieser Job wurde abgebrochen"],"This job has been skipped":["Dieser Job wurde \xfcbersprungen"],"This job has not been triggered yet":["Dieser Job wurde noch nicht getriggert"],"This job has not started yet":["Dieser Job hat noch nicht begonnen"],"This job is an out-of-date deployment to %{environmentLink} using cluster %{clusterNameOrLink} and namespace %{kubernetesNamespace}.":["Dieser Job ist eine veraltete Bereitstellung in %{environmentLink} und verwendet den Cluster %{clusterNameOrLink} und den Namensraum %{kubernetesNamespace}."],"This job is an out-of-date deployment to %{environmentLink} using cluster %{clusterNameOrLink} and namespace %{kubernetesNamespace}. View the %{deploymentLink}.":["Dieser Job ist eine veraltete Bereitstellung in %{environmentLink} und verwendet den Cluster %{clusterNameOrLink} und den Namensraum %{kubernetesNamespace}. %{deploymentLink} anzeigen."],"This job is an out-of-date deployment to %{environmentLink} using cluster %{clusterNameOrLink}.":["Dieser Job ist eine veraltete Bereitstellung in %{environmentLink} und verwendet den Cluster %{clusterNameOrLink}."],"This job is an out-of-date deployment to %{environmentLink} using cluster %{clusterNameOrLink}. View the %{deploymentLink}.":["Dieser Job ist eine veraltete Bereitstellung in %{environmentLink} und verwendet den Cluster %{clusterNameOrLink}. %{deploymentLink} anzeigen."],"This job is an out-of-date deployment to %{environmentLink}.":["Dieser Job ist eine veraltete Bereitstellung f\xfcr %{environmentLink}."],"This job is an out-of-date deployment to %{environmentLink}. View the %{deploymentLink}.":["Dieser Job ist eine veraltete Bereitstellung in %{environmentLink}. %{deploymentLink} anzeigen."],"This job is archived.":["Dieser Job ist archiviert."],"This job is creating a deployment to %{environmentLink} using cluster %{clusterNameOrLink} and namespace %{kubernetesNamespace}.":["Dieser Job erstellt eine Bereitstellung in %{environmentLink} mit dem Cluster %{clusterNameOrLink} und dem Namensraum %{kubernetesNamespace}."],"This job is creating a deployment to %{environmentLink} using cluster %{clusterNameOrLink} and namespace %{kubernetesNamespace}. This will overwrite the %{deploymentLink}.":["Dieser Job erstellt eine Bereitstellung in %{environmentLink} mit dem Cluster %{clusterNameOrLink} und dem Namensraum %{kubernetesNamespace}. Dabei wird %{deploymentLink} \xfcberschrieben."],"This job is creating a deployment to %{environmentLink} using cluster %{clusterNameOrLink}.":["Dieser Job erstellt eine Bereitstellung in %{environmentLink} mit dem Cluster %{clusterNameOrLink}."],"This job is creating a deployment to %{environmentLink} using cluster %{clusterNameOrLink}. This will overwrite the %{deploymentLink}.":["Dieser Job erstellt eine Bereitstellung in %{environmentLink} mit dem Cluster %{clusterNameOrLink}. Dabei wird %{deploymentLink} \xfcberschrieben."],"This job is creating a deployment to %{environmentLink}.":["Dieser Job erstellt eine Bereitstellung f\xfcr %{environmentLink}."],"This job is creating a deployment to %{environmentLink}. This will overwrite the %{deploymentLink}.":["Dieser Job erstellt eine Bereitstellung in %{environmentLink}. Dabei wird %{deploymentLink} \xfcberschrieben."],"This job is deployed to %{environmentLink} using cluster %{clusterNameOrLink} and namespace %{kubernetesNamespace}.":["Dieser Job wird in %{environmentLink} mit dem Cluster %{clusterNameOrLink} und dem Namensraum %{kubernetesNamespace} bereitgestellt."],"This job is deployed to %{environmentLink} using cluster %{clusterNameOrLink}.":["Dieser Job wird in %{environmentLink} mit dem Cluster %{clusterNameOrLink} bereitgestellt."],"This job is deployed to %{environmentLink}.":["Dieser Job wird in %{environmentLink} bereitgestellt."],"This job is in pending state and is waiting to be picked by a runner":["Dieser Job befindet sich im Status \u201eausstehend\u201c und wartet darauf, durch einen Runner ausgew\xe4hlt zu werden"],"This job is in the process of canceling":["Dieser Job wird gerade abgebrochen"],"This job is performing tasks that must complete before it can start":["Dieser Job erledigt Aufgaben, die abgeschlossen werden m\xfcssen, bevor er starten kann"],"This job is preparing to start":["Dieser Job bereitet sich auf den Start vor"],"This job is waiting for resource: ":["Dieser Job wartet auf Ressource: "],"This job requires a manual action":["Dieser Job erfordert eine manuelle Aktion"],"This job will automatically run after its timer finishes. Often they are used for incremental roll-out deploys to production environments. When unscheduled it converts into a manual action.":["Dieser Job wird automatisch ausgef\xfchrt, sobald sein Timer abl\xe4uft. Meistens werden sie f\xfcr inkrementelle Rollout Deploys zu Produktivumgebungen verwendet. Beim Abbrechen wird er in eine manuelle Aktion umgewandelt."],"This label is archived and not available for use. Unarchive to use it again.":["Dieses Label ist archiviert und kann nicht verwendet werden. Du musst die Archivierung aufheben, um es erneut zu verwenden."],"This license has already expired.":["Diese Lizenz ist bereits abgelaufen."],"This link points to external content":["Dieser Link verweist auf externe Inhalte."],"This link will redirect you to %{url}. If this URL looks wrong, please go back or close this window. Do you want to continue?":["Dieser Link f\xfchrt zu %{url}. Wenn dir diese URL merkw\xfcrdig vorkommt, kehre zur\xfcck oder schlie\xdfe dieses Fenster. M\xf6chtest du fortfahren?"],"This may expose confidential information as the selected fork is in another namespace that can have other members.":["Dies kann vertrauliche Informationen offenlegen, da sich der ausgew\xe4hlte Zweig in einem anderen Namensraum befindet, der andere Mitglieder haben kann."],"This means you can not push code until you create an empty repository or import existing one.":["Dies bedeutet, dass du keinen Code pushen kannst, bevor du kein leeres Repository erstellt oder ein existierendes importiert hast."],"This merge request does not have accessibility reports":["Diese Merge Request hat keine Barrierefreiheitsberichte"],"This merge request does not have codequality reports":["Dieser Merge Request hat keine Code-Qualit\xe4tsberichte"],"This merge request has reached the maximum limit of %{limit} versions and cannot be updated further. Close this merge request and create a new one instead.":["Dieser Merge Request hat die maximale Anzahl von %{limit} Versionen erreicht und kann nicht weiter aktualisiert werden. Schlie\xdfe diesen Merge Request und erstelle stattdessen einen neuen."],"This merge request has too many diff commits, and can't be updated. Close this merge request and create a new one.":["Dieser Merge Request enth\xe4lt zu viele Diff-Commits und kann nicht aktualisiert werden. Schlie\xdfe diesen Merge Request und erstelle einen neuen."],"This merge request is closed. To apply this suggestion, edit this file directly.":["Dieser Merge Request wurde geschlossen. Bearbeite diese Datei direkt, um den Vorschlag anzuwenden."],"This merge request is from a private project to a public project.":["Dieser Merge Request verl\xe4uft von einem privaten Projekt zu einem \xf6ffentlichen Projekt."],"This merge request is from a private project to an internal project.":["Dieser Merge Request verl\xe4uft von einem privaten Projekt zu einem internen Projekt."],"This merge request is from an internal project to a public project.":["Dieser Merge Request verl\xe4uft von einem internen Projekt zu einem \xf6ffentlichen Projekt."],"This merge request is hidden because its author has been banned.":["Diese Merge-Anfrage ist verborgen, weil sein(e) Autor(in) gesperrt wurde."],
"This merge request was merged. To apply this suggestion, edit this file directly.":["Dieser Merge Request wurde zusammengef\xfchrt. Bearbeite diese Datei direkt, um den Vorschlag anzuwenden."],"This only applies to repository indexing operations.":["Dies gilt nur f\xfcr die Indizierung von Repositorys."],"This page is hosted on GitLab pages but contains user-generated content and may contain malicious code. Do not accept unless you trust the author and source.":["Diese Seite wird auf GitLab Pages gehostet, enth\xe4lt jedoch von Benutzer(inne)n generierte Inhalte und kann sch\xe4dlichen Code enthalten. Akzeptiere nicht, es sei denn, Du vertraust dem Autor und der Quelle."],"This page is unavailable because you are not allowed to read information across multiple projects.":["Diese Seite ist nicht verf\xfcgbar, da du nicht Informationen \xfcber mehrere Projekte hinweg lesen darfst."],"This parent item does not exist or you don't have sufficient permission.":["Dieses \xfcbergeordnete Element existiert nicht oder du hast keine ausreichende Berechtigung."],"This pipeline makes use of a predefined CI/CD configuration enabled by %{strongStart}Auto DevOps.%{strongEnd}":["Diese Pipeline nutzt eine vordefinierte CI/CD-Konfiguration mit Unterst\xfctzung von %{strongStart}Auto DevOps%{strongEnd}."],"This pipeline makes use of a predefined CI/CD configuration enabled by Auto DevOps.":["Diese Pipeline nutzt eine vordefinierte CI/CD-Konfiguration, die durch Auto DevOps aktiviert wird."],"This pipeline ran for an agent session":["Diese Pipeline wurde f\xfcr eine Agentensitzung ausgef\xfchrt"],"This pipeline was created by a schedule":["Diese Pipeline wurde durch einen Zeitplan erstellt"],"This pipeline was created by a schedule.":["Diese Pipeline wurde durch einen Zeitplan erstellt."],"This pipeline was created by an API call authenticated with a trigger token":["Diese Pipeline wurde durch einen API-Aufruf erstellt, der mit einem Triggertoken authentifiziert wurde."],"This pipeline was triggered using the api":["Diese Pipeline wurde mithilfe der API ausgel\xf6st"],"This policy needs %{approvals} approval because %{rules}":["Diese Richtlinie erfordert %{approvals} Genehmigung wegen %{rules}","Diese Richtlinie erfordert %{approvals} Genehmigungen wegen %{rules}"],"This process deletes the project repository and all related resources.":["Dieser Prozess l\xf6scht das Projekt-Repository und alle zugeh\xf6rigen Ressourcen."],"This project and all its data will be %{strongOpen}permanently deleted%{strongClose} on %{date}.":["Dieses Projekt und alle seine Daten werden am %{date} %{strongOpen}endg\xfcltig gel\xf6scht%{strongClose}."],"This project cannot be %{visibilityLevel} because the visibility of %{openShowLink}%{name}%{closeShowLink} is %{visibility}.":["Dieses Projekt kann nicht %{visibilityLevel} sein, da die Sichtbarkeit von %{openShowLink}%{name}%{closeShowLink} wie folgt lautet: %{visibility}."],"This project cannot be %{visibilityLevel} because the visibility of %{openShowLink}%{name}%{closeShowLink} is %{visibility}. To make this project %{visibilityLevel}, you must first %{openEditLink}change the visibility%{closeEditLink} of the parent group.":["Dieses Projekt kann nicht %{visibilityLevel} sein, weil die Sichtbarkeit von %{openShowLink}%{name}%{closeShowLink} %{visibility} lautet. Um dieses Projekt %{visibilityLevel} zu machen, musst du zuerst %{openEditLink}die Sichtbarkeit%{closeEditLink} der \xfcbergeordneten Gruppe \xe4ndern."],"This project does not have %{service_desk_link_start}Service Desk%{service_desk_link_end} enabled, so the user who created the issue will no longer receive email notifications about new activity.":["Der %{service_desk_link_start}Service-Desk%{service_desk_link_end} ist f\xfcr dieses Projekt nicht aktiviert. Darum erhalten Benutzer(innen), die ein Ticket erstellen, keine E-Mail-Benachrichtigungen \xfcber neue Aktivit\xe4ten."],"This project does not have a wiki homepage yet":["Dieses Projekt hat derzeit noch keine Wiki-Startseite"],"This project does not have any project runners yet.":["Dieses Projekt hat noch keine Projekt-Runner."],"This project does not include diff previews in email notifications.":["Dieses Projekt enth\xe4lt keine Diff-Vorschauen in E-Mail-Benachrichtigungen."],"This project has no active access tokens.":["Dieses Projekt hat keine aktiven Zugriffstoken."],"This project has no inactive access tokens.":["Dieses Projekt hat keine inaktiven Zugriffstoken."],"This project is %{strongStart}NOT%{strongEnd} a fork, and has the following:":["Dieses Projekt ist %{strongStart}KEINE%{strongEnd} Fork und umfasst Folgendes:"],"This project is %{strongStart}NOT%{strongEnd} a fork. This process deletes the project repository and all related resources.":["Dieses Projekt ist %{strongStart}KEINE%{strongEnd} Fork. Dieser Prozess l\xf6scht das Projekt-Repository und alle zugeh\xf6rigen Ressourcen."],"This project is archived and read-only. To resume pull mirroring, unarchive the project.":["Dieses Projekt ist archiviert und schreibgesch\xfctzt. Entpacke das Projekt, um die Pull-Spiegelung fortzusetzen."],"This project is archived. Its data is %{strong_open}read-only%{strong_close}.":["Dieses Projekt ist archiviert. Seine Daten sind %{strong_open}schreibgesch\xfctzt%{strong_close}."],"This project is being deleted.":["Dieses Projekt wird gel\xf6scht."],"This project is licensed under the %{strong_start}%{license_name}%{strong_end}.":["Dieses Projekt ist unter %{strong_start}%{license_name}%{strong_end} lizenziert."],"This project is mirrored from %{link}.":["Dieses Projekt wird von %{link} gespiegelt."],"This project is public. Non-members can guess the Service Desk email address, because it contains the group and project name. %{linkStart}How do I create a custom email address?%{linkEnd}":["Dieses Projekt ist \xf6ffentlich. Nicht-Mitglieder k\xf6nnen die Service-Desk E-Mail-Adresse erraten, da sie den Gruppen- und Projektnamen enth\xe4lt. %{linkStart}Wie kann ich eine benutzerdefinierte E-Mail-Adresse erstellen?%{linkEnd}"],"This project is scheduled for deletion on %{date}. This action will permanently delete this project, including all its resources, %{strongOpen}immediately%{strongClose}. This action cannot be undone.":["Dieses Projekt steht zur L\xf6schung am %{date} aus. Durch diese Aktion wird dieses Projekt, einschlie\xdflich seiner Ressourcen, %{strongOpen}sofort%{strongClose} endg\xfcltig gel\xf6scht. Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],"This project manages its dependencies using %{strong_start}%{manager_name}%{strong_end}":["Die Abh\xe4ngigkeiten dieses Projekts werden mit %{strong_start}%{manager_name}%{strong_end} verwaltet."],"This project path either does not exist or you do not have access.":["Dieser Projektpfad existiert nicht oder du hast keinen Zugriff."],"This project reached the limit of custom domains. (Max %d)":["Dieses Projekt hat das Limit benutzerdefinierter Domains erreicht. (maximal %d)"],"This project was scheduled for deletion, but failed with the following message:":["Dieses Projekt wurde zum L\xf6schen vorgesehen, dies ist jedoch mit der folgenden Meldung fehlgeschlagen:"],"This project will be restored from scheduled deletion.":["Dieses Projekt wird aus der geplanten L\xf6schung wiederhergestellt."],"This release was created with a date in the past. Evidence collection at the moment of the release is unavailable.":["Dieser Release wurde mit einem Datum in der Vergangenheit erstellt. Die Beweissammlung zum Zeitpunkt der Ver\xf6ffentlichung ist nicht verf\xfcgbar."],"This repository has never been checked.":["Dieses Repository wurde noch nie \xfcberpr\xfcft."],"This repository is currently empty. A new Auto DevOps pipeline will be created after a new file has been pushed to a branch.":["Dieses Repository ist derzeit leer. Eine neue Auto-DevOps-Pipeline wird erstellt, wenn eine neue Datei in einen Branch verschoben wurde."],"This repository was last checked %{last_check_timestamp}. The check %{strong_start}failed.%{strong_end} See the 'repocheck.log' file for error messages.":["Dieses Repository wurde zuletzt um %{last_check_timestamp} \xfcberpr\xfcft. Diese \xdcberpr\xfcfung ist %{strong_start}fehlgeschlagen%{strong_end}. Du findest die Fehlermeldungen in der Datei \u201erepocheck.log\u201c."],"This repository was last checked %{last_check_timestamp}. The check passed.":["Dieses Repository wurde zuletzt um %{last_check_timestamp} \xfcberpr\xfcft. Das Pr\xfcfungsergebnis war positiv."],"This setting can be overridden in each project.":["Diese Einstellung kann in jedem Projekt \xfcberschrieben werden."],"This setting has been configured at the instance level and cannot be overridden per group":["Diese Einstellung wurde auf Systemebene konfiguriert und kann nicht pro Gruppe \xfcberschrieben werden."],"This setting is allowed for forked projects only":["Diese Einstellung ist nur f\xfcr geforkte Projekte zul\xe4ssig"],"This setting is configured for the group. To make changes, contact a user with required %{linkStart}permissions%{linkEnd}.":["Diese Einstellung ist f\xfcr die Gruppe konfiguriert. Wende dich an eine(n) Benutzer(in) mit den erforderlichen %{linkStart}Berechtigungen%{linkEnd}, um \xc4nderungen vorzunehmen."],"This setting is configured for the group. To make changes, contact a user with required permissions.":["Diese Einstellung ist f\xfcr die Gruppe konfiguriert. Wende dich an eine(n) Benutzer(in) mit den erforderlichen Berechtigungen, um \xc4nderungen vorzunehmen."],"This setting is configured for the group. To make changes, go to %{linkStart}group repository settings%{linkEnd}.":["Diese Einstellung ist f\xfcr die Gruppe konfiguriert. Gehe zu den %{linkStart}Repository-Einstellungen der Gruppe%{linkEnd}, um \xc4nderungen vorzunehmen."],"This setting is configured for the group. To make changes, go to group repository settings.":["Diese Einstellung ist f\xfcr die Gruppe konfiguriert. Gehe zu den Repository-Einstellungen der Gruppe, um \xc4nderungen vorzunehmen."],"This stage has one or more manual jobs that require confirmation before retrying. Do you want to proceed?":["In dieser Phase gibt es einen oder mehrere manuelle Jobs, die vor dem erneuten Versuch best\xe4tigt werden m\xfcssen. M\xf6chtest du fortfahren?"],"This status cannot be applied to the selected item.":["Dieser Status kann nicht auf das ausgew\xe4hlte Element angewendet werden."],"This suggestion already matches its content.":["Dieser Vorschlag entspricht bereits seinem Inhalt."],"This title already exists.":["Dieser Titel existiert bereits."],"This user":["Diese(r) Benutzer(in)"],"This user cannot be unlocked manually from GitLab":["Diese(r) Benutzer(in) kann nicht manuell von GitLab entblockt werden"],"This user does not have a one-time password authenticator registered.":["Diese(r) Benutzer(in) hat keinen Authentifikator f\xfcr Einmal-Passw\xf6rter registriert."],"This user has an unconfirmed email address (%{email}). You may force a confirmation.":["Diese(r) Benutzer(in) hat eine unbest\xe4tigte E-Mail-Adresse (%{email}). Du kannst eine Best\xe4tigung erzwingen."],"This user has an unconfirmed email address. You may force a confirmation.":["Diese(r) Benutzer(in) hat eine unbest\xe4tigte E-Mail-Adresse. Du kannst eine Best\xe4tigung erzwingen."],"This user has no active %{accessTokenTypePlural}.":["F\xfcr diese(n) Benutzer(in) gibt es keine g\xfcltigen %{accessTokenTypePlural}."],"This user has no identities":["Diese(r) Benutzer(in) hat keine Identit\xe4ten"],"This user has previously committed to the %{name} project.":["Diese(r) Benutzer(in) hat bereits Commits f\xfcr das Projekt %{name} \xfcbermittelt."],"This user has the %{access} role in the %{name} group.":["Diese(r) Benutzer(in) hat die Rolle %{access} in der Gruppe %{name}."],"This user has the %{access} role in the %{name} project.":["Diese(r) Benutzer(in) hat die Rolle %{access} im Projekt %{name}."],"This user is exempt from identity verification.":["F\xfcr diese(n) Benutzer(in) gilt eine Ausnahmeregelung bei der Identit\xe4tsverifizierung."],"This user is the author of this %{noteable}.":["Diese(r) Benutzer(in) ist der/die Autor(in) von %{noteable}."],"This user is the author of this %{workItemType}.":["Dieser/diese Benutzer(in) ist Autor(in) von %{workItemType}."],"This user is the author of this page.":["Dieser/diese Benutzer(in) ist Autor(in) dieser Seite."],"This value is not valid.":["Dieser Wert ist nicht g\xfcltig."],"This vulnerability was automatically resolved because its vulnerability type was disabled in this project or removed from GitLab's default ruleset. For details about SAST rule changes, see https://docs.gitlab.com/ee/user/application_security/sast/rules#important-rule-changes.":["Diese Sicherheitsl\xfccke wurde automatisch beendet, da der Sicherheitsl\xfcckentyp in diesem Projekt deaktiviert oder aus dem GitLab-Standardregelsatz entfernt wurde. Einzelheiten zu SAST-Regel\xe4nderungen findest du unter https://docs.gitlab.com/ee/user/application_security/sast/rules#important-rule-changes."],"This will permanently delete the designated account manager.":["Hierdurch wird der/die designierte Kontomanager(in) dauerhaft gel\xf6scht."],"This will rebase all commits from the source branch onto the target branch.":["Dadurch werden alle Commits aus dem Quellbranch in den Zielbranch rebased."],"This will remove the fork relationship between this project and %{fork_source}.":["Bei diesem Vorgang wird die Fork-Beziehung zwischen diesem Projekt und %{fork_source} entfernt."],"This will remove the fork relationship between this project and other projects in the fork network.":["Bei diesem Vorgang wird die Fork-Beziehung zwischen diesem Projekt und anderen Projekten im Fork-Netzwerk entfernt."],"Thread options":["Unterhaltungsoptionen"],"Thread to reply to cannot be found":["Thread zum Antworten kann nicht gefunden werden"],"Threshold in bytes at which to compress Sidekiq job arguments.":["Schwellenwert in Bytes, ab dem Sidekiq-Job-Argumente komprimiert werden sollen."],"Threshold in bytes at which to reject Sidekiq jobs. Set this to 0 to if you don't want to limit Sidekiq jobs.":["Schwellenwert in Bytes, ab dem Sidekiq-Jobs abgelehnt werden sollen. Setze diesen Wert auf 0, wenn du Sidekiq-Jobs nicht einschr\xe4nken m\xf6chtest."],Thu:["Do"],Thursday:["Donnerstag"],"Ticket cannot be found.":["Ticket wurde nicht gefunden."],"TierBadgePopover|Enhance team productivity":["Verbessere die Teamproduktivit\xe4t"],"TierBadgePopover|Explore paid plans":["Kostenpflichtige Tarife kennenlernen"],"TierBadgePopover|Start a free trial":["Kostenlose Testversion starten"],"TierBadgePopover|This group and all its related projects use the %{tier} GitLab tier. %{copyEnd}":["Diese Gruppe und alle verbundenen Projekte verwenden die GitLab-Stufe %{tier}. %{copyEnd}"],"TierBadgePopover|This project uses the %{tier} GitLab tier. %{copyEnd}":["Dieses Projekt verwendet die GitLab-Stufe %{tier}. %{copyEnd}"],"TierBadgePopover|Want to enhance team productivity and access advanced features like Merge Approvals, Push rules, Epics, Code Review Analytics, and Container Scanning? Try all GitLab has to offer for free for %{duration} days. No credit card required.":["M\xf6chtest du die Produktivit\xe4t deiner Teams steigern und erweiterte Funktionen wie Merge-Genehmigungen, Push-Regeln, Epics, Code-Review-Analysen und Container-Scans nutzen? Teste den kompletten Funktionsumfang von GitLab %{duration} Tage lang kostenlos. Keine Kreditkarte erforderlich."],"TierBadge|Free":["Kostenlos"],Time:["Zeit"],"Time (in hours) that users are allowed to skip forced configuration of two-factor authentication.":["Dauer (in Stunden), f\xfcr die der/die Benutzer(in) die erzwungene Konfiguration der Zwei-Faktor-Authentifizierung \xfcberspringen darf."],"Time Display|12-hour: 2:34 PM":["12 Stunden: 2:34 PM"],"Time Display|24-hour: 14:34":["24 Stunden: 14:34 Uhr"],"Time Display|System":["System"],"Time based: Yes":["Zeitbasiert: Ja"],"Time before an issue gets scheduled":["Zeit bis ein Ticket geplant wird"],"Time before an issue starts implementation":["Zeit bis die Implementierung f\xfcr ein Ticket beginnt"],"Time between merge request creation and merge/close":["Zeit zwischen Anlegen und Mergen/Schlie\xdfen eines Merge Requests"],"Time estimate":["Gesch\xe4tzte Zeit"],"Time estimate: %{estimate}":["Gesch\xe4tzte Zeit: %{estimate}"],"Time from first comment to last commit":["Zeit vom ersten Kommentar zum letzten Commit"],"Time from first commit until first comment":["Zeit vom ersten Commit bis zum ersten Kommentar"],"Time from last commit to merge":["Zeit vom letzten Commit bis zur Zusammenf\xfchrung"],"Time of import: %{importTime}":["Zeitpunkt des Imports: %{importTime}"],"Time remaining":["Verbleibende Zeit"],"Time spent":["Ben\xf6tigte Zeit"],"Time spent can't be zero.":["Die aufgewendete Zeit darf nicht Null sein."],"Time spent must be formatted correctly. For example: 1h 30m.":["Die aufgewendete Zeit muss korrekt formatiert werden. Zum Beispiel: 1h 30m."],"Time spent must start with a number.":["Der Zeitaufwand muss mit einer Zahl beginnen."],"Time to Merge":["Dauer bis zum Merge"],"Time to merge":["Dauer bis zur Zusammenf\xfchrung"],"Time to restore service":["Zeit bis zur Wiederherstellung des Dienstes"],"Time to subtract exceeds the total time spent":["Dauer bis Subtrahieren ist l\xe4nger als die Gesamtdauer"],"Time tracking":["Zeiterfassung"],"Time tracking report":["Bericht zur Zeiterfassung"],"Time unit":["Zeiteinheit"],"Time until first merge request":["Zeit bis zum ersten Merge Request"],"Time zone":["Zeitzone"],"TimeTrackingEstimated|Est":["Gesch\xe4tzt"],"TimeTrackingReport|From the start of":["Ab dem Anfang von"],"TimeTrackingReport|Run report":["Bericht ausf\xfchren"],"TimeTrackingReport|Something went wrong. Please try again.":["Etwas ist schief gelaufen. Bitte versuche es erneut."],"TimeTrackingReport|Source":["Quelle"],"TimeTrackingReport|Spent at":["Verbracht bei"],"TimeTrackingReport|Summary":["Zusammenfassung"],"TimeTrackingReport|Time spent":["Verbrachte Zeit"],"TimeTrackingReport|To the end of":["Bis zum Ende von"],"TimeTrackingReport|Total time spent: ":["Insgesamt verbrachte Zeit: "],"TimeTrackingReport|User":["Benutzer(in)"],"TimeTrackingReport|Username":["Benutzername"],"TimeTracking|%{spentStart}Spent: %{spentEnd}":["%{spentStart}Verbraucht: %{spentEnd}"],"TimeTracking|%{time} over":["%{time} vergangen"],"TimeTracking|%{time} remaining":["%{time} verbleibend"],"TimeTracking|Add an %{estimateStart}estimate%{estimateEnd} or %{timeSpentStart}time spent%{timeSpentEnd}.":["F\xfcge eine %{estimateStart}Sch\xe4tzung%{estimateEnd} oder %{timeSpentStart}die ben\xf6tigte Zeit%{timeSpentEnd} hinzu."],"TimeTracking|Add estimate":["Sch\xe4tzung hinzuf\xfcgen"],"TimeTracking|Add time entry":["Zeiteintrag hinzuf\xfcgen"],"TimeTracking|An error occurred while removing the timelog.":["Beim Entfernen des Zeitprotokolls ist ein Fehler aufgetreten."],"TimeTracking|An error occurred while saving the time estimate.":["Beim Speichern der Zeitsch\xe4tzung ist ein Fehler aufgetreten."],"TimeTracking|Delete time spent":["Zeitaufwand l\xf6schen"],"TimeTracking|Edit estimate":["Sch\xe4tzung bearbeiten"],"TimeTracking|Edit time estimate":["Zeitsch\xe4tzung bearbeiten"],"TimeTracking|Enter time as a total duration (for example, 1mo 2w 3d 5h 10m), or specify hours and minutes (for example, 75:30).":["Gib die Zeit entweder als Gesamtdauer (z.\xa0B. 1\xa0Monat, 2\xa0Wochen, 3\xa0Tage, 5\xa0Stunden, 10\xa0Minuten) oder als Stunden und Minuten an (z.\xa0B. 75:30)."],"TimeTracking|Estimate":["Sch\xe4tzung"],"TimeTracking|Estimated:":["Gesch\xe4tzt:"],"TimeTracking|How do I estimate and track time?":["Wie kann ich die Zeit absch\xe4tzen und nachverfolgen?"],"TimeTracking|Over by %{timeRemainingHumanReadable}":["\xdcberschritten um %{timeRemainingHumanReadable}"],"TimeTracking|Set estimate":["Sch\xe4tzung festlegen"],"TimeTracking|Set estimated time to complete this %{issuableTypeName}.":["Lege die gesch\xe4tzte Bearbeitungsdauer f\xfcr dieses/diesen %{issuableTypeName} fest."],"TimeTracking|Set time estimate":["Gesch\xe4tzte Dauer festlegen"],"TimeTracking|Spent":["Verbracht"],"TimeTracking|Time remaining: %{timeRemainingHumanReadable}":["Zeit verbleibend: %{timeRemainingHumanReadable}"],"TimeTracking|Track time spent on this %{issuableTypeName}.":["Verfolge die aufgewendete Zeit f\xfcr %{issuableTypeName} nach."],"TimeTracking|View time tracking report":["Zeiterfassungsbericht anzeigen"],"Timeago|%s day ago":["vor %s Tag","vor %s Tagen"],"Timeago|%s day remaining":["%s Tag verbleibend","%s Tage verbleibend"],"Timeago|%s hour ago":["vor %s Stunde","vor %s Stunden"],"Timeago|%s hour remaining":["%s Stunde verbleibend","%s Stunden verbleibend"],"Timeago|%s minute ago":["vor %s Minute","vor %s Minuten"],"Timeago|%s minute remaining":["%s Minute verbleibend","%s Minuten verbleibend"],"Timeago|%s month ago":["vor %s Monat","vor %s Monaten"],"Timeago|%s month remaining":["%s Monat verbleibend","%s Monate verbleibend"],"Timeago|%s second ago":["vor %s Sekunde","vor %s Sekunden"],"Timeago|%s second remaining":["%s Sekunde verbleibend","%s Sekunden verbleibend"],"Timeago|%s week ago":["vor %s Woche","vor %s Wochen"],"Timeago|%s week remaining":["%s Woche verbleibend","%s Wochen verbleibend"],"Timeago|%s year ago":["vor %s Jahr","vor %s Jahren"],"Timeago|%s year remaining":["%s Jahr verbleibend","%s Jahre verbleibend"],"Timeago|Past due":["\xdcberf\xe4llig"],"Timeago|in %s day":["in %s Tag","in %s Tagen"],"Timeago|in %s hour":["in %s Stunde","in %s Stunden"],"Timeago|in %s minute":["in %s Minute","in %s Minuten"],"Timeago|in %s month":["in %s Monat","in %s Monaten"],"Timeago|in %s second":["in %s Sekunde","in %s Sekunden"],"Timeago|in %s week":["in %s Woche","in %s Wochen"],"Timeago|in %s year":["in %s Jahr","in %s Jahren"],"Timeago|just now":["vor kurzem"],"Timeago|right now":["gerade jetzt"],"Timeframe cannot exceed %{limit} years for work item queries":["Der Zeitraum darf %{limit}\xa0Jahre f\xfcr Abfragen von Arbeitsaufgaben nicht \xfcberschreiten."],Timeline:["Zeitleiste"],"Timeline event added successfully.":["Timeline-Ereignis erfolgreich hinzugef\xfcgt."],"Timeline|Turn recent updates view off":["Ansicht der letzten Aktualisierungen ausschalten"],"Timeline|Turn recent updates view on":["Ansicht der letzten Updates einschalten"],"Timelog doesn't exist or you don't have permission to delete it":["Das Zeitprotokoll existiert nicht oder du hast nicht die Erlaubnis, es zu l\xf6schen"],Timeout:["Zeit\xfcberschreitung"],"Timeout connecting to the Google API. Please try again.":["Zeit\xfcberschreitung bei der Verbindung zur Google API. Versuche es erneut."],"Timeout for moderately fast Gitaly operations (in seconds). Provide a value between Default timeout and Fast timeout.":["Zeit\xfcberschreitung f\xfcr mittelschnelle Gitaly-Operationen (in Sekunden). Gib einen Wert zwischen der Standard-Zeit\xfcberschreitung und der schnellen Zeit\xfcberschreitung ein."],"Timeout for most Gitaly operations (in seconds).":["Zeit\xfcberschreitung f\xfcr die meisten Gitaly-Operationen (in Sekunden)."],"Timeout for the fastest Gitaly operations (in seconds).":["Zeit\xfcberschreitung f\xfcr die schnellsten Gitaly-Operationen (in Sekunden)."],"Timeout: Element not found":["Zeit\xfcberschreitung: Element wurde nicht gefunden"],Timezone:["Zeitzone"],"Time|A":["A"],"Time|AM":["Vormittags"],"Time|P":["P"],"Time|PM":["Nachmittags"],"Time|a":["a"],"Time|am":["Vormittags"],"Time|hr":["Std.","Stdn."],"Time|min":["Min.","Min."],"Time|p":["p"],"Time|pm":["Nachmittags"],"Time|s":["Sek."],"Tip: Add a %{linkStart}CODEOWNERS%{linkEnd} to automatically add approvers based on file paths and file types.":["Tipp: F\xfcge einen %{linkStart}CODEOWNERS%{linkEnd} hinzu, um Genehmigungsberechtigte basierend auf Dateipfaden und Dateitypen automatisch hinzuzuf\xfcgen."],"Tip: Hover over a job to see the jobs it depends on to run.":["Tipp: Bewege den Mauszeiger \xfcber einen Job, um die Jobs anzuzeigen, von denen die Ausf\xfchrung abh\xe4ngt."],Title:["Titel"],"Title (required)":["Titel (notwendig)"],"Title:":["Titel:"],Titles:["Titel"],To:["Bis"],"To %{link_to_help} of your domain, add the above key to a TXT record within your DNS configuration within seven days.":["Um %{link_to_help} deiner Domain zu erhalten, f\xfcge den oben genannten Schl\xfcssel innerhalb von sieben Tagen zu einem TXT-Eintrag in deiner DNS-Konfiguration hinzu."],"To GitLab":["Zu GitLab"],"To accept this invitation, create an account or sign in.":["Erstelle ein Konto oder melde dich bei deinem Konto an, um diese Einladung anzunehmen."],"To accept this invitation, sign in or create an account.":["Melde dich an oder erstelle ein Konto, um diese Einladung anzunehmen."],"To accept this invitation, sign in.":["Melde dich an, um diese Einladung anzunehmen."],"To access this domain create a new DNS record":["Um auf diese Domain zuzugreifen, erstelle einen neuen DNS-Eintrag"],"To add a custom suffix, set up a Service Desk email address. %{linkStart}Learn more%{linkEnd}.":["Um ein benutzerdefiniertes Suffix hinzuzuf\xfcgen, richte eine E-Mail-Adresse f\xfcr den Service-Desk ein. %{linkStart}Mehr erfahren%{linkEnd}."],"To add active contacts, use /add_contacts.":["Verwende /add_contacts, um aktive Kontakte hinzuzuf\xfcgen."],"To add the entry manually, provide the following details to the application on your phone.":["Gib die folgenden Details in der App auf deinem Telefon ein, um den Eintrag manuell hinzuzuf\xfcgen."],"To allow %{strongOpen}%{provider}%{strongClose} to manage your GitLab account %{strongOpen}%{username}%{strongClose} (%{email}) after you sign in successfully using single sign-on, select %{strongOpen}Authorize%{strongClose}.":["Um %{strongOpen}%{provider}%{strongClose} zu erlauben, dein GitLab-Konto %{strongOpen}%{username}%{strongClose} (%{email}) zu verwalten, nachdem du dich mit Single Sign-On angemeldet hast, w\xe4hle %{strongOpen}Authorisieren%{strongClose} aus."],"To approve this merge request, please enter your password. This project requires all approvals to be authenticated.":["Um diesen Merge Request zu genehmigen, gib bitte dein Passwort ein. Dieses Projekt erfordert die Authentifizierung aller Genehmigungen."],"To avoid future interruption to notifications for %{project_or_group}, update your notification preferences.":["Aktualisiere deine Benachrichtigungseinstellungen, um eine zuk\xfcnftige Unterbrechung der Benachrichtigungen f\xfcr %{project_or_group} zu vermeiden."],"To avoid long-running queries, large tables were skipped.":["Um eine lange Ausf\xfchrungsdauer f\xfcr Abfragen zu vermeiden, wurden gro\xdfe Tabellen \xfcbersprungen."],"To configure a path_prefix, please add a license to your project.":["Bitte f\xfcge eine Lizenz zu deinem Projekt hinzu, um einen path_prefix zu konfigurieren."],"To connect an SVN repository, check out %{svn_link}.":["Um ein SVN-Repository zu verbinden, lies %{svn_link}."],"To continue using GitLab Enterprise Edition, upload the %{codeOpen}.gitlab-license%{codeClose} file or enter the license key you have received from GitLab Inc.":["Lade die %{codeOpen}.gitlab-Lizenzdatei%{codeClose} hoch oder gib den Lizenzschl\xfcssel ein, den du von GitLab Inc. erhalten hast, um GitLab Enterprise Edition weiterhin zu verwenden."],"To continue, please update your password. After you update, you'll be directed to sign in again.":["Um fortzufahren, aktualisiere bitte dein Passwort. Nachdem du es aktualisiert hast, wirst du wieder zur Anmeldeseite weitergeleitet."],"To continue, you need to select the link in the confirmation email we sent to verify your email address. If you didn't get our email, select %{strongStart}Resend confirmation email.%{strongEnd}":["Um fortzufahren, musst du den Link in der Best\xe4tigungs-E-Mail, welche wir dir gesendet haben, aufrufen und deine E-Mail-Adresse verifizieren. Wenn du unsere E-Mail nicht erhalten haben solltest, kannst du dir die %{strongStart}Best\xe4tigungs-E-Mail erneut senden%{strongEnd} lassen."],"To create another group, reduce the number of groups you have, or upgrade to a paid tier.":["Um eine weitere Gruppe zu erstellen, reduziere die Anzahl deiner Gruppen oder f\xfchre ein Upgrade auf eine kostenpflichtige Version durch."],"To delete the item from the UI:":["So l\xf6schst du das Element aus der UI:"],"To disable the setting, set this value to 0.":["Um die Einstellung zu deaktivieren, setze diesen Wert auf 0."],"To enhance security, enable Admin Mode. Admin Mode requires users to re-authenticate before accessing the Admin area.":["Um die Sicherheit zu erh\xf6hen, aktiviere den Admin-Modus. Der Admin-Modus erfordert, dass sich Benutzer(innen) erneut authentifizieren, bevor sie auf den Adminbereich zugreifen."],"To ensure %{project_link} is unscheduled for deletion, check that activity has been logged by GitLab. For example:":["\xdcberpr\xfcfe, ob die Aktivit\xe4t von GitLab protokolliert wurde, um sicherzustellen, dass die geplante L\xf6schung von %{project_link} aufgehoben wurde. Zum Beispiel:"],"To ensure %{project_name} is unscheduled for deletion, check that activity has been logged by GitLab. For example:":["\xdcberpr\xfcfe, ob die Aktivit\xe4t von GitLab protokolliert wurde, um sicherzustellen, dass die geplante L\xf6schung von %{project_name} aufgehoben wurde. Zum Beispiel:"],"To ensure no loss of access to personal content, only use this account for matters related to %{group_name}.":["Um sicherzustellen, dass du den Zugriff auf pers\xf6nliche Inhalte nicht verlierst, verwende dieses Konto nur f\xfcr Angelegenheiten, die mit %{group_name} zu tun haben."],"To ensure the highest security standards, we verify the source of all slash commands.":["Um die h\xf6chsten Sicherheitsstandards zu gew\xe4hrleisten, verifizieren wir die Quelle aller Slash-Befehle."],"To find the state of this project's repository at the time of any of these versions, check out %{link_start}the tags%{link_end}":["Um den Status des Repositorys dieses Projekts zum Zeitpunkt einer dieser Versionen zu finden, sieh dir %{link_start}die Tags%{link_end} an"],"To further protect your account, consider configuring a %{mfa_link_start}two-factor authentication%{mfa_link_end} method.":["Mit einer %{mfa_link_start}Zwei-Faktor-Authentifizierungsmethode%{mfa_link_end} kannst du die Sicherheit deines Kontos verbessern."],"To further protect your account, consider configuring a two-factor authentication method: %{mfa_link}.":["Mit einer Zwei-Faktor-Authentifizierungsmethode kannst du die Sicherheit deines Kontos verbessern: %{mfa_link}."],"To get a valid comparison, select two different branches.":["Um einen aussagekr\xe4ftigen Vergleich zu erhalten, w\xe4hle zwei verschiedene Branches aus."],"To get started you enter your FogBugz URL and login information below. In the next steps, you'll be able to map users and select the projects you want to import.":["Gib zun\xe4chst deine FogBuz-URL und -Anmeldeinformationen unten ein. In den n\xe4chsten Schritten kannst du Benutzer(innen) zuordnen und die Projekte f\xfcr den Import ausw\xe4hlen."],"To get started, click the link below to confirm your account.":["Um zu beginnen, klicke auf den unten stehenden Link, um dein Konto zu best\xe4tigen."],"To get started, clone the repository or upload some files.":["Klone zun\xe4chst das Repository oder lade Dateien hoch."],"To get started, please enter your Gitea host URL and a %{link_to_personal_token}.":["Gib zun\xe4chst deine Gitea-Host-URL und ein %{link_to_personal_token} ein."],"To get started, use the link below to confirm your account.":["Um zu beginnen, verwende den unten stehenden Link, um dein Konto zu best\xe4tigen."],"To keep this project going, create a new issue":["Um dieses Projekt voranzutreiben, erstelle ein neues Ticket"],"To keep this project going, create a new merge request":["Um dieses Projekt am Laufen zu halten, erstelle eine neue Merge Request"],"To learn more about this project, read %{link_to_wiki}":["Weitere Informationen zu diesem Projekt findest du unter %{link_to_wiki}"],"To manage seats for all members associated with this group and its subgroups and projects, visit the %{link_start}usage quotas page%{link_end}.":["Um die Pl\xe4tze f\xfcr alle Mitglieder dieser Gruppe und ihrer Untergruppen und Projekte zu verwalten, besuche die Seite %{link_start}Kontingente%{link_end}."],"To manage your passkeys and other authentication methods, visit %{two_factor_link}":["Informationen zur Verwaltung von Passkeys und anderen Authentifizierungsmethoden findest du unter %{two_factor_link}"],
"To merge, either the title or description must reference a Jira issue.":["Um einen Merge durchzuf\xfchren, muss entweder der Titel oder die Beschreibung auf ein Jira-Ticket verweisen."],"To move or copy an entire GitLab project from another GitLab installation to this one, navigate to the original project's settings page, generate an export file, and upload it here.":["Um ein komplettes GitLab-Projekt von einer GitLab-Installation zu einer anderen umzuziehen oder zu kopieren, navigiere zur Einstellungsseite des Originalprojektes, erzeuge eine Export-Datei und lade sie hier hoch."],"To only use CI/CD features for an external repository, choose %{strong_open}CI/CD for external repo%{strong_close}.":["W\xe4hle %{strong_open}CI/CD f\xfcr externes Repo%{strong_close}, um nur CI/CD-Funktionen f\xfcr ein externes Repository zu verwenden."],"To pass variables to the triggered pipeline, add %{code_start}variables[VARIABLE]=VALUE%{code_end} to the API request.":["Um Variablen an die ausgel\xf6ste Pipeline zu \xfcbergeben, f\xfcge der API-Anfrage %{code_start}Variablen[VARIABLE]=VALUE%{code_end} hinzu."],"To personalize your GitLab experience, we'd like to know a bit more about you. We won't share this information with anyone.":["Um deine GitLab-Erfahrung zu personalisieren, m\xf6chten wir etwas mehr \xfcber dich erfahren. Wir geben diese Informationen nicht an Dritte weiter."],"To prevent your project from being placed in a read-only state, %{manage_storage_link_start}manage your storage use%{storage_link_end} or %{support_link_start}contact support%{link_end} immediately.":["Um zu verhindern, dass dein Projekt in einen schreibgesch\xfctzten Zustand versetzt wird, solltest du deine %{manage_storage_link_start}deine Speichernutzung verwalten%{storage_link_end} oder %{support_link_start}sofort den Support kontaktieren%{link_end}."],"To prevent your project from being placed in a read-only state, manage your storage use: %{manage_storage_link} or contact support immediately: %{support_link}.":["Um zu verhindern, dass dein Projekt in einen schreibgesch\xfctzten Zustand versetzt wird, solltest du deine Speichernutzung verwalten (%{manage_storage_link}) oder sofort den Support kontaktieren (%{support_link})."],"To protect this issue's confidentiality, %{linkStart}fork this project%{linkEnd} and set the fork's visibility to private.":["Um die Vertraulichkeit dieses Tickets zu sch\xfctzen, %{linkStart}forke dieses Projekt%{linkEnd} und setze die Sichtbarkeit der Fork auf privat."],"To protect this issue's confidentiality, a private fork of this project was selected.":["Um die Vertraulichkeit dieses Tickets zu sch\xfctzen, wurde ein privater Fork dieses Projekts ausgew\xe4hlt."],"To reactivate your account, %{gitlab_link_start}sign in to GitLab.%{link_end}":["%{gitlab_link_start}Melde dich bei GitLab an%{link_end}, um dein Konto zu reaktivieren."],"To reactivate your account, sign in to GitLab at %{gitlab_url}.":["Melde dich unter %{gitlab_url} bei GitLab an, um dein Konto zu reaktivieren."],"To remove the %{link_start}read-only%{link_end} state and regain write access, ask your top-level group owner(s) to reduce the number of users in your top-level group to %{free_limit} users or less, or to upgrade to a paid tier which do not have user limits.":["Um den %{link_start}Schreibschutz%{link_end} aufzuheben und den Schreibzugriff wiederherzustellen, bitte den/die Eigent\xfcmer(innen) der Gruppe der obersten Ebene, die Anzahl der Benutzer(innen) in deiner Gruppe der obersten Ebene auf maximal %{free_limit} Benutzer(innen) zu reduzieren oder ein Upgrade auf einen kostenpflichtigen Tarif ohne Benutzer-Limit durchzuf\xfchren."],"To remove the %{link_start}read-only%{link_end} state and regain write access, you can reduce the number of users in your top-level group to %{free_limit} users or less. You can also upgrade to a paid tier, which do not have user limits. If you need additional time, you can start a free %{duration}-day trial which includes unlimited users.":["Um den %{link_start}Schreibschutz%{link_end} aufzuheben und den Schreibzugriff wiederherzustellen, kannst du die Anzahl der Benutzer(innen) in deiner Gruppe der obersten Ebene auf maximal %{free_limit} Benutzer(innen) reduzieren. Du kannst auch ein Upgrade auf einen kostenpflichtigen Tarif ohne Benutzer-Limits durchf\xfchren. Wenn du mehr Zeit ben\xf6tigst, kannst du eine kostenlose %{duration}-Tage-Testversion starten, die unbegrenzt viele Benutzer(innen) umfasst."],"To remove the read-only state, reduce git repository and git LFS storage.":["Reduziere den Speicher des Git-Repositorys und des Git LFS, um den Schreibschutz aufzuheben."],"To resolve the problem, check the query syntax and try again.":[""],'To resolve the problem, refine your search criteria. Select a group or project or use double quotes for multiple keywords (for example, %{code_open}"your search"%{code_close}).':["Verfeinere deine Suchkriterien, um das Problem zu beheben. W\xe4hle eine Gruppe oder ein Projekt aus oder verwende doppelte Anf\xfchrungszeichen f\xfcr mehrere Keywords (z.\xa0B. %{code_open}\u201edeine Suche\u201c%{code_close})."],"To run CI/CD pipelines with JetBrains TeamCity, input the GitLab project details in the TeamCity project Version Control Settings.":["Um CI/CD-Pipelines mit JetBrains TeamCity auszuf\xfchren, gib die GitLab-Projektdetails in den Versionskontrolleinstellungen des TeamCity-Projekts ein."],"To see all the user's personal access tokens you must impersonate them first.":["Um alle pers\xf6nlichen Zugriffstoken des/der Benutzers(in) anzuzeigen, musst du zuerst zu deren/dessen Identit\xe4t wechseln."],"To see this project's operational details, %{linkStart}upgrade its group plan to Premium%{linkEnd}. You can also remove the project from the dashboard.":["Um die operativen Details dieses Projekts anzuzeigen, %{linkStart} aktualisiere seinen Gruppenplan auf Premium%{linkEnd}. Du kannst das Projekt auch aus dem Dashboard entfernen."],"To see this project's operational details, contact an owner of group %{groupName} to upgrade the plan. You can also remove the project from the dashboard.":["Wende dich an eine(n) Eigent\xfcmer(in) der Gruppe %{groupName}, um die Betriebsdetails dieses Projekts anzuzeigen und den Plan zu aktualisieren. Du kannst das Projekt auch aus dem Dashboard entfernen."],"To set up SAML authentication for your group through an identity provider like Azure, Okta, Onelogin, Ping Identity, or your custom SAML 2.0 provider:":["So richtest du die SAML-Authentifizierung f\xfcr deine Gruppe \xfcber einen Identit\xe4tsanbieter wie Azure, Okta, Onelogin, Ping Identity oder deinen benutzerdefinierten SAML 2.0-Anbieter ein:"],"To set up this integration:":["Um diese Integration einzurichten:"],"To specify the notification level per project of a group you belong to, visit the project page and change the notification level there.":["Um in einer Gruppe, der du angeh\xf6rst, die Benachrichtigungsstufe einzelner Projekte festzulegen, musst du die Projektseite besuchen und die Benachrichtigungsstufe dort anpassen."],"To start using GitLab Enterprise Edition, upload the %{codeOpen}.gitlab-license%{codeClose} file or enter the license key you have received from GitLab Inc.":["Um die GitLab Enterprise Edition zu verwenden, lade die Datei %{codeOpen}.gitlab-license%{codeClose} hoch oder gib den Lizenzschl\xfcssel ein, den du von GitLab Inc. erhalten hast."],"To submit your changes in a merge request, create a new fork.":["Um deine \xc4nderungen in einem Merge Request zu \xfcbermitteln, erstelle einen neuen Fork."],"To submit your changes in a merge request, switch to one of these forks or create a new fork.":["Um deine \xc4nderungen in einem Merge Request zu \xfcbermitteln, wechsle zu einem dieser Forks oder erstelle einen neuen Fork."],"To unsubscribe from this issue, please paste the following link into your browser:":["F\xfcge den folgenden Link in deinem Browser ein, um dieses Ticket abzubestellen:"],"To update Snippets with multiple files, you must use the `files` parameter":["Verwende den Parameter \u201efiles\u201c, um Code-Schnipsel mit mehreren Dateien zu aktualisieren."],"To use Service Desk in this project, you must %{linkStart}activate the issue tracker%{linkEnd}.":["Um den Service-Desk in diesem Projekt nutzen zu k\xf6nnen, musst du den %{linkStart}Issue-Tracker aktivieren%{linkEnd}."],"To use the additional formats, you must start the required %{container_link_start}companion containers%{container_link_end}.":["Um die zus\xe4tzlichen Formate zu verwenden, musst du die erforderlichen %{container_link_start}Begleitcontainer%{container_link_end} starten."],"To use the system's default, set this value to 0.":["Um die Standardeinstellung des Systems zu verwenden, setze diesen Wert auf 0."],"To view all %{scannedResourcesCount} scanned URLs, %{linkStart}please download the CSV file%{linkEnd}":["Um alle %{scannedResourcesCount} gescannten URLs anzuzeigen, %{linkStart}lade bitte die CSV-Datei herunter%{linkEnd}"],"To view usage, refresh this page in a few minutes.":["Aktualisiere diese Seite in ein paar Minuten, um die Nutzung anzuzeigen."],"To widen your search, change or remove filters above":["\xc4ndere oder entferne die obigen Filter, um deine Suche zu erweitern."],"To widen your search, change or remove filters above.":["\xc4ndere oder entferne die obigen Filter, um deine Suche zu erweitern."],"To-Do List":["Aufgabenliste"],"To-do items":["To-Do-Elemente"],Today:["Heute"],"Today's highlights":["Highlights des Tages"],"Todos| What actions create to-do items?":["Mit welchen Aktionen wird eine To-do-Liste erstellt?"],"Todos|%{count} selected":["%{count} ausgew\xe4hlt","%{count} ausgew\xe4hlt"],"Todos|%{day}, %{time}":["%{day}, %{time}"],"Todos|(removed)":["(entfernt)"],"Todos|Action failed. Try again later.":["Die Aktion ist fehlgeschlagen. Versuche es sp\xe4ter erneut."],"Todos|Added approver":["Genehmiger hinzugef\xfcgt"],"Todos|Alert":["Alarm"],"Todos|All":["Alle"],"Todos|All your pending to-do items across GitLab.":["Alle deine ausstehenden Aufgabenelemente in GitLab."],"Todos|Approval required":["Genehmigung erforderlich"],"Todos|Assigned":["Zugewiesen"],"Todos|Assignments":["Zuweisungen"],"Todos|At":["Um"],"Todos|Build failed":["Build fehlgeschlagen"],"Todos|Category":["Kategorie"],"Todos|Clear all":["Alle l\xf6schen"],"Todos|Could not merge":["Konnte nicht zusammengef\xfchrt werden"],"Todos|Design":["Gestaltung&nbsp;"],"Todos|Done":["Erledigt"],"Todos|Due %{when}":["F\xe4llig am %{when}"],"Todos|Due today":["Heute f\xe4llig"],"Todos|Everything":["Alles"],"Todos|Failed adding todo. Try again later.":["Hinzuf\xfcgen des To-dos fehlgeschlagen. Versuche es sp\xe4ter erneut."],"Todos|Failed builds":["Fehlgeschlagene Builds"],"Todos|Failed to snooze todo. Try again later.":["Aussetzen des Aufgabenelements fehlgeschlagen. Versuche es sp\xe4ter erneut."],"Todos|Failed to un-snooze todo. Try again later.":["Deaktivieren der Aussetzung des Aufgabenelements fehlgeschlagen. Versuche es sp\xe4ter erneut."],"Todos|Filter to-do items":["Aufgabenelemente filtern"],"Todos|For one hour":["F\xfcr eine Stunde"],"Todos|Getting started with GitLab Duo":["Erste Schritte mit GitLab Duo"],"Todos|Give yourself a pat on the back!":["Klopf dir selbst auf die Schulter!"],"Todos|Good job! Looks like you don't have anything left on your To-Do List":["Gute Arbeit! Sieht so aus, als ob du nichts mehr auf deiner To-Do Liste hast"],'Todos|Henceforth, you shall be known as "To-Do Destroyer"':["Fortan sollst du als \u201eTo-Do-Zerst\xf6rer\u201e bekannt sein."],"Todos|Hidden":["Ausgeblendet"],"Todos|Isn't an empty To-Do List beautiful?":["Ist eine leere To-Do-Liste nicht wunderbar?"],"Todos|Issue":["Ticket"],"Todos|It's how you always know what to work on next.":["So wei\xdft du immer, woran du als n\xe4chstes arbeiten musst."],"Todos|Items assigned to you.":["Dir zugewiesene Elemente."],"Todos|Items where you were mentioned (@username).":["Elemente, bei denen du erw\xe4hnt wurdest (@benutzername)"],"Todos|Label priority":["Priorit\xe4t des Labels"],"Todos|Leave feedback":["Feedback hinterlassen"],"Todos|Mark as done":["Als erledigt markieren"],"Todos|Mark as done failed. Try again later.":["Als erledigt markieren ist fehlgeschlagen. Versuche es sp\xe4ter erneut."],"Todos|Mark selected items as done":["Ausgew\xe4hlte Elemente als erledigt markieren"],"Todos|Mark selected items as pending":["Ausgew\xe4hlte Elemente als ausstehend markieren"],"Todos|Marked":["Markiert"],"Todos|Marked 1 to-do as done":["1\xa0Aufgabe als erledigt markiert","%d\xa0Aufgaben als erledigt markiert"],"Todos|Member access request":["Mitgliederzugriffsanfrage"],"Todos|Mentioned":["Erw\xe4hnt"],"Todos|Mentions":["Erw\xe4hnungen"],"Todos|Merge request":["Merge Request"],"Todos|Merge requests that cannot be merged due to conflicts or other issues.":["Merge Requests, die aufgrund von Konflikten oder anderen Problemen nicht zusammengef\xfchrt werden k\xf6nnen."],"Todos|Merge requests that require your review or approval.":["Merge Requests, f\xfcr die deine Pr\xfcfung oder Genehmigung erforderlich ist."],"Todos|Merge requests with failed pipelines.":["Merge Requests mit fehlgeschlagenen Pipelines."],"Todos|Merge train removed":["Merge-Zug entfernt"],"Todos|Not sure where to go next? Take a look at your %{assignedIssuesLinkStart}assigned issues%{assignedIssuesLinkEnd} or %{mergeRequestLinkStart}merge requests%{mergeRequestLinkEnd}.":["Du bist nicht sicher, was du als N\xe4chstes tun sollst? Wirf einen Blick auf die %{assignedIssuesLinkStart}dir zugewiesenen Tickets%{assignedIssuesLinkEnd} oder %{mergeRequestLinkStart}Merge Requests%{mergeRequestLinkEnd}."],"Todos|Nothing left to do. High five!":["Nichts mehr zu tun. High five!"],"Todos|OKR checkin requested":["OKR-Check-in angefragt"],"Todos|Previously snoozed":["Zuvor ausgesetzt"],"Todos|Raw text search is not currently supported":["Die Rohtextsuche wird derzeit nicht unterst\xfctzt"],"Todos|Raw text search is not currently supported. Please use the available search tokens.":["Die Rohtextsuche wird derzeit nicht unterst\xfctzt. Verwende die verf\xfcgbaren Such-Token."],"Todos|Reason":["Grund"],"Todos|Recommended":["Empfohlen"],"Todos|Remove snooze":["Aussetzung entfernen"],"Todos|Remove snooze for selected items":["Aussetzungsfunktion f\xfcr ausgew\xe4hlte Elemente entfernen"],"Todos|Removed from Merge Train":["Aus Merge-Zug entfernt"],"Todos|Removed snooze from 1 to-do":["Schlummerfunktion von einer Aufgabe entfernt","Schlummerfunktion von %d Aufgaben entfernt"],"Todos|Requested reviews":["Angeforderte Reviews"],"Todos|Restored 1 to-do":["1\xa0Aufgabe wiederhergestellt","%d\xa0Aufgaben wiederhergestellt"],"Todos|Review requested":["Review angefordert"],"Todos|Review submitted":["Review abgesendet"],"Todos|SSH key":["SSH-Schl\xfcssel"],"Todos|SSH key expired":["SSH-Schl\xfcssel abgelaufen"],"Todos|SSH key expiring soon":["SSH-Schl\xfcssel l\xe4uft bald ab"],"Todos|Select all":["Alle ausw\xe4hlen"],"Todos|Select this item to sign in with SAML and view it.":["W\xe4hle dieses Element aus, um dich mit SAML anzumelden und es anzuzeigen."],"Todos|Snooze":["Aussetzen"],"Todos|Snooze date can't be in the past.":["Aussetzungsdatum darf nicht in der Vergangenheit liegen."],"Todos|Snooze selected items":["Ausgew\xe4hlte Elemente aussetzen"],"Todos|Snooze until":["Aussetzen bis"],"Todos|Snooze...":["Aussetzen..."],"Todos|Snoozed":["Ausgesetzt"],"Todos|Snoozed 1 to-do":["1 ausgesetzte Aufgabe","%d ausgesetzte Aufgaben"],"Todos|Snoozed until %{date}":["Ausgesetzt bis zum %{date}"],"Todos|Snoozed until %{day}, %{time}":["Ausgesetzt bis %{day}, %{time}"],"Todos|Snoozed until %{time}":["Ausgesetzt bis %{time}"],"Todos|Snoozed until tomorrow, %{time}":["Ausgesetzt bis morgen, %{time}"],"Todos|Someone":["Jemand"],"Todos|Something went wrong. Please try again.":["Etwas ist schiefgelaufen. Bitte versuche es erneut."],"Todos|Sorry, your filter produced no results":["Dein Filter ergab le
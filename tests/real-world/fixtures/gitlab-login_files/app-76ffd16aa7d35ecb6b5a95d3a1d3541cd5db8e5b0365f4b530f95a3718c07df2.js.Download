ontributionEvent|Commented on snippet %{noteableLink}.":["Code-Schnipsel %{noteableLink} kommentiert."],"ContributionEvent|Created project %{resourceParentLink}.":["Projekt %{resourceParentLink} erstellt."],"ContributionEvent|Created resource.":["Ressource erstellt."],"ContributionEvent|Created wiki page %{targetLink} in %{resourceParentLink}.":["Wiki-Seite %{targetLink} unter %{resourceParentLink} erstellt."],"ContributionEvent|Deleted branch %{refLink} in %{resourceParentLink}.":["Gel\xf6schter Branch %{refLink} in %{resourceParentLink}."],"ContributionEvent|Deleted milestone in %{resourceParentLink}.":["Gel\xf6schter Meilenstein in %{resourceParentLink}."],"ContributionEvent|Deleted resource.":["Ressource gel\xf6scht."],"ContributionEvent|Deleted tag %{refLink} in %{resourceParentLink}.":["Gel\xf6schter Tag %{refLink} in %{resourceParentLink}."],"ContributionEvent|Deleted wiki page in %{resourceParentLink}.":["Gel\xf6schte Wiki-Seite in %{resourceParentLink}."],"ContributionEvent|Joined project %{resourceParentLink}.":["Projekt %{resourceParentLink} beigetreten."],"ContributionEvent|Left project %{resourceParentLink}.":["Projekt %{resourceParentLink} verlassen."],"ContributionEvent|Made a private contribution.":["Hat einen privaten Beitrag geleistet."],"ContributionEvent|Opened Epic %{targetLink} in %{resourceParentLink}.":["Epic %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened incident %{targetLink} in %{resourceParentLink}.":["Vorfall %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened issue %{targetLink} in %{resourceParentLink}.":["Ticket %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened key result %{targetLink} in %{resourceParentLink}.":["Schl\xfcsselergebnis %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened merge request %{targetLink} in %{resourceParentLink}.":["Merge Request %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened milestone %{targetLink} in %{resourceParentLink}.":["Meilenstein %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened objective %{targetLink} in %{resourceParentLink}.":["Ziel %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened requirement %{targetLink} in %{resourceParentLink}.":["Anforderung %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened task %{targetLink} in %{resourceParentLink}.":["Aufgabe %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Opened test case %{targetLink} in %{resourceParentLink}.":["Testfall %{targetLink} unter %{resourceParentLink} er\xf6ffnet."],"ContributionEvent|Pushed a new branch %{refLink} in %{resourceParentLink}.":["Einen neuen Branch %{refLink} nach %{resourceParentLink} gepusht."],"ContributionEvent|Pushed a new tag %{refLink} in %{resourceParentLink}.":["Einen neuen Tag %{refLink} nach %{resourceParentLink} gepusht."],"ContributionEvent|Pushed to branch %{refLink} in %{resourceParentLink}.":["In den Branch %{refLink} in %{resourceParentLink} gepusht."],"ContributionEvent|Pushed to tag %{refLink} in %{resourceParentLink}.":["In den Tag %{refLink} in %{resourceParentLink} gepusht."],"ContributionEvent|Removed due to membership expiration from %{resourceParentLink}.":["Aufgrund des Ablaufs der Mitgliedschaft von %{resourceParentLink} entfernt."],"ContributionEvent|Reopened Epic %{targetLink} in %{resourceParentLink}.":["Epic %{targetLink} in %{resourceParentLink} erneut ge\xf6ffnet."],"ContributionEvent|Reopened incident %{targetLink} in %{resourceParentLink}.":["Vorfall %{targetLink} in %{resourceParentLink} erneut ge\xf6ffnet."],"ContributionEvent|Reopened issue %{targetLink} in %{resourceParentLink}.":["Ticket %{targetLink} in %{resourceParentLink} erneut ge\xf6ffnet."],"ContributionEvent|Reopened key result %{targetLink} in %{resourceParentLink}.":["Schl\xfcsselergebnis %{targetLin
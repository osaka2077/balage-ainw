"KubernetesDashboard|Trigger reconciliation":["Abgleich ausl\xf6sen"],"KubernetesDashboard|View projects":["Projekte anzeigen"],"KubernetesDashboard|You can select an agent from a project's environment page.":["Du kannst einen Agenten auf der Umgebungsseite eines Projekts ausw\xe4hlen."],"KubernetesDashboard|unknown":["unbekannt"],"KubernetesLogs|Agent ID":["Agenten-ID"],"KubernetesLogs|Container":["Container"],"KubernetesLogs|Namespace":["Namensraum"],"KubernetesLogs|No logs available for container %{containerName} of pod %{podName}":["F\xfcr den Container %{containerName} des Pods %{podName} sind keine Protokolle verf\xfcgbar."],"KubernetesLogs|No logs available for pod %{podName}":["F\xfcr den Pod %{podName} sind keine Protokolle verf\xfcgbar"],"KubernetesLogs|Pod":["Pod"],LDAP:["LDAP"],"LDAP Synchronization":["LDAP-Synchronisation"],"LDAP settings":["LDAP Einstellungen"],"LDAP sync in progress. This could take a few minutes. Refresh the page to see the changes.":["LDAP Synchronisation l\xe4uft. Dies kann einige Minuten dauern. Aktualisiere die Seite, um die \xc4nderungen zu sehen."],"LDAP synchronizations":["LDAP-Synchronisation"],"LDAP uid:":["LDAP-UID:"],"LDAP|%{dateTime} (%{timeAgo})":["%{dateTime} (%{timeAgo})"],"LDAP|(Inactive because syncing with an LDAP user filter is not included in the current license)":["(Inaktiv, da die Synchronisierung mit einem LDAP-Benutzerfilter nicht in der aktuellen Lizenz enthalten ist)"],"LDAP|Active synchronizations":["Aktive Synchronisierungen"],"LDAP|Active synchronizations (%{count})":["Aktive Synchronisierungen (%{count})"],"LDAP|Add synchronization":["Synchronisierung hinzuf\xfcgen"],"LDAP|As %{human_access} on %{provider_label} server":["Wie %{human_access} auf dem Server %{provider_label}"],"LDAP|Config for LDAP server %{provider} is not present in GitLab":["Konfiguration f\xfcr LDAP-Server %{provider} nicht in GitLab vorhanden"],"LDAP|Could not fetch LDAP groups. Please try again.":["LDAP-Gruppen konnten nicht abgerufen werden. Bitte erneut versuchen."],"LDAP|Custom admin role":["Benutzerdefinierte Admin-Rolle"],"LDAP|Default, minimum permission level for LDAP group members of %{group_name}.":["Standard, Mindestberechtigungsstufe f\xfcr LDAP-Gruppenmitglieder von %{group_name}."],"LDAP|Ended at:":["Beendet um:"],"LDAP|Group cn":["Gruppen-CN"],"LDAP|If you do not belong to this LDAP user filter you will lose ownership of %{group_name}.":["Wenn du nicht zu diesem LDAP-Benutzerfilter geh\xf6rst, verlierst du die Inhaberschaft an %{group_name}."],"LDAP|If you select an LDAP group you do not belong to you will lose ownership of %{group_name}.":["Wenn du eine LDAP-Gruppe ausw\xe4hlst, der du nicht angeh\xf6rst, verlierst du die Inhaberschaft an %{group_name}."],"LDAP|LDAP access":["LDAP-Zugang"],"LDAP|LDAP group cn":["LDAP-Gruppe cn"],"LDAP|LDAP server":["LDAP-Server"],"LDAP|LDAP user filter":["LDAP-Benutzerfilter"],"LDAP|Last successful sync:":["Letzte erfolgreiche Synchronisierung:"],"LDAP|Never synced":["Nie synchronisiert"],"LDAP|No LDAP synchronizations":["Keine LDAP-Synchronisation"],"LDAP|Select LDAP group":["LDAP-Gruppe ausw\xe4hlen"],"LDAP|Select a server to fetch groups.":["W\xe4hle einen Server zum Abrufen von Gruppen aus."],"LDAP|Select server":["Server ausw\xe4hlen"],"LDAP|Server":["Server"],"LDAP|Start typing":["Eingabe"],"LDAP|Started at:":["Gestartet um:"],"LDAP|Sync created at:":["Synchronisierung erstellt um:"],"LDAP|Sync error:":["Synchronisierungsfehler:"],"LDAP|Sync method":["Synchronisierungsmethode"],"LDAP|Synchronize %{group_name}'s members with this LDAP group.":["Mitglieder von %{group_name} mit dieser LDAP-Gruppe synchronisieren."],"LDAP|This query must use valid %{ldap_link_start}LDAP Search Filter Syntax%{ldap_link_end}. Synchronize %{group_name}'s members with this LDAP user filter.":["Diese Abfrage muss eine g\xfcltige %{ldap_link_start}LDAP-Suchfiltersyntax%{ldap_link_end} verwenden. Synchronisiere Mitglieder von %{group_name} mit diesem LDAP-Benutzerfilter."],"LDAP|Total runtime:":["Gesamte Laufzeit:"],"LDAP|User filter":["Benutzerfilter"],"LDAP|View more information on %{linkStart}user filters%{linkEnd}.":["Weitere Informationen \xfcber %{linkStart}Benutzerfilter%{linkEnd} anzeigen"],"LDAP|You can manage permission levels for individual group members in the Members tab.":["Du kannst die Berechtigungsstufen f\xfcr einzelne Gruppenmitglieder auf der Registerkarte \u201eMitglieder\u201c verwalten."],LFS:["LFS"],"LFS objects":["LFS Objekte"],"LFS objects detected. Git supports adding a `.gitattributes` file in subdirectories, but GitLab only checks for this file in the root directory of the default branch. Dismiss this message if your LFS is configured in subdirectories, on a different branch, or is working correctly.":["LFS-Objekte erkannt. Git unterst\xfctzt das Hinzuf\xfcgen einer .gitattributes-Datei in Unterverzeichnissen, GitLab sucht jedoch nur im Stammverzeichnis des Standard-Branches nach dieser Datei. Verwirf diese Meldung, wenn dein LFS in Unterverzeichnissen oder in einem anderen Branch konfiguriert ist oder ordnungsgem\xe4\xdf funktioniert."],"LFSStatus|Disabled":["Deaktiviert"],"LFSStatus|Enabled":["Aktiviert"],Label:["Label"],"Label %{labelName} was not found":["Label %{labelName} wurde nicht gefunden"],"Label '%{command_label}' for command id '%{command}' must not start with '%{prefix}'":["Label \u201e%{command_label}\u201c f\xfcr Befehls-ID \u201e%{command}\u201c darf nicht mit \u201e%{prefix}\u201c beginnen"],"Label actions dropdown":["Dropdown-Men\xfc f\xfcr die Label-Aktionen"],"Label added: %{labels}":["Bezeichnung hinzugef\xfcgt: %{labels}","Bezeichnungen hinzugef\xfcgt: %{labels}"],"Label name":["Name des Labels"],"Label priority":["Priorit\xe4t des Labels"],"Label was created":["Etikett wurde erstellt"],"Label was successfully updated.":["Etikett wurde erfolgreich aktualisiert."],"LabelSelect|%{firstLabelName} +%{remainingLabelCount} more":["%{firstLabelName} +%{remainingLabelCount} weitere"],"LabelSelect|%{labelsString}, and %{remainingLabelCount} more":["%{labelsString} und %{remainingLabelCount} weitere"],"LabelSelect|Labels":["Labels"],Labels:["Labels"],"Labels can be applied to issues and merge requests to categorize them":["Labels k\xf6nnen zu Tickets und Merge-Anfragen hinzugef\xfcgt werden, um diese zu kategorisieren"],"Labels can be applied to issues and merge requests. Group labels are available for any project within the group.":["Labels k\xf6nnen auf Tickets und Merge Requests angewendet werden. Gruppenlabels sind f\xfcr jedes Projekt innerhalb der Gruppe verf\xfcgbar."],"Labels can be applied to issues and merge requests. Star a label to make it a priority label.":["Labels k\xf6nnen auf Tickets und Merge Requests angewendet werden. Markiere ein Label mit einem Stern, um es zu einem vorrangigen Label zu machen."],"Labels can be applied to issues, merge requests, and epics. Group labels are available for any project within the group.":["Labels k\xf6nnen auf Tickets, Merge Requests und Epics angewendet werden. Gruppenlabels sind f\xfcr jedes Projekt innerhalb der Gruppe verf\xfcgbar."],"Labels to be notified for. Valid options are `match_any` and `match_all`. The default value is `match_any`.":["Labels, zu denen Benachrichtigungen gesendet werden sollen. G\xfcltige Optionen sind `match_any` und `match_all`. Der Standardwert ist `match_any`."],"Labels to send notifications for. Leave blank to receive notifications for all events.":["Labels, f\xfcr die Benachrichtigungen gesendet werden sollen. Leer lassen, um Benachrichtigungen f\xfcr alle Ereignisse zu erhalten."],"Labels with no issues in this iteration:":["Labels ohne Tickets in dieser Iteration:"],"Labels|%{spanStart}Promote label%{spanEnd} %{labelTitle} %{spanStart}to Group Label?%{spanEnd}":["%{spanStart}Label%{spanEnd} %{labelTitle} %{spanStart}zu Gruppenlabel hochstufen?%{spanEnd}"],"Labels|An error occurred while archiving the label.":["Beim Archivieren des Labels ist ein Fehler aufgetreten."],"Labels|Label actions":["Label-Aktionen"],"Labels|Label actions dropdown":["Auswahl-Liste f\xfcr Label-Aktionen"],"Labels|Label archived.":["Label archiviert."],"Labels|Label unarchived.":["Archivierung des Labels aufgehoben."],"Labels|Promote Label":["Label hochstufen"],"Labels|Promote to group label":["Zum Gruppenlabel hochstufen"],"Labels|Promoting %{labelTitle} will make it available for all projects inside %{groupName}. Existing project labels with the same title will be merged. If a group label with the same title exists, it will also be merged. This action cannot be reversed.":["Das Hochstufen von %{labelTitle} macht es f\xfcr alle Projekte in %{groupName} verf\xfcgbar. Existierende Projektlabels mit dem selben Titel werden zusammengef\xfchrt. Falls ein Gruppenlabel mit dem selben Namen existiert, wird es ebenfalls zusammengef\xfchrt. Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],"Label|Assignee":["Beauftragte(r)"],"Label|Reviewer":["Pr\xfcfer(in)"],"Lacking permissions to the blocking merge request":["Fehlende Berechtigungen f\xfcr die blockierende Merge-Anfrage"],"Lacking permissions to update the merge request":["Fehlende Berechtigungen zum Aktualisieren der Merge-Anfrage"],Language:["Sprache"],"Language Server restrictions enabled":["Einschr\xe4nkungen f\xfcr Sprachserver aktiviert"],"Language type":["Sprachtyp"],"Large File Storage":["Large File Storage"],"Last %d day":["Letzten %d Tag","Letzten %d Tage"],"Last %{days} days":["Letzte %{days} Tage"],"Last 2 weeks":["Letze 2 Wochen"],"Last 24 hours":["Letzte 24 Stunden"],"Last Accessed On":["Letzter Zugriff am"],"Last GitLab Duo activity":["Letzte GitLab Duo-Aktivit\xe4t"],"Last GitLab activity":["Letzte GitLab-Aktivit\xe4t"],"Last Used":["Zuletzt verwendet"],"Last Used IPs":["Zuletzt verwendete IPs"],"Last accessed on":["Letzter Zugriff am"],"Last activity":["Letzte Aktivit\xe4t"],"Last activity:":["Letzte Aktivit\xe4t:"],"Last attempted number:":["Nummer des letzten Versuchs:"],"Last comment by %{author} %{timeago}":["Letzter Kommentar von %{author} %{timeago}"],"Last commit":["Letzter Commit"],"Last contact":["Letzter Kontakt"],"Last edited":["Zuletzt bearbeitet"],"Last event":["Letztes Ereignis"],"Last login":["Letzter Login"],"Last modified":["Zuletzt ge\xe4ndert"],"Last month":["Letzter Monat"],"Last name":["Nachname"],"Last name is required.":["Nachname ist erforderlich."],"Last repository check (%{last_check_timestamp}) failed. See the 'repocheck.log' file for error messages.":["Letzte Repository-\xdcberpr\xfcfung (%{last_check_timestamp}) fehlgeschlagen. Fehlermeldungen findest du in der Datei \u201erepocheck.log\u201c."],"Last scan":["Letzter Scan"],"Last seen":["Zuletzt gesehen"],"Last sign-in":["Letzte Anmeldung"],"Last sign-in IP:":["Zuletzt angemeldet mit IP:"],"Last sign-in at:":["Zuletzt angemeldet um:"],"Last successful update":["Letzte erfolgreiche Aktualisierung"],"Last successful update %{time}.":["Letzte erfolgreiche Aktualisierung %{time}."],"Last update":["Letzte Aktualisierung"],"Last update attempt":["Letzter Aktualisierungsversuch"],"Last updated":["Letzte Aktualisierung"],"Last updated %{time} ago":["Zuletzt aktualisiert vor %{time}"],"Last updated date":["Datum der letzten Aktualisierung"],"Last used":["Zuletzt verwendet"],"Last used %{last_used_at} ago":["Zuletzt verwendet vor %{last_used_at}"],"Last used date":["Datum der letzten Nutzung"],"Last week":["Letzte Woche"],"Last year":["Letztes Jahr"],"LastPushEvent|Copy branch name":["Branch-Name kopieren"],"LastPushEvent|You pushed to":["Du hast gepusht zu"],"LastPushEvent|at":["am"],"Latest pipeline for the most recent commit on this ref":["Neueste Pipeline f\xfcr den letzten Commit auf diesem Ref"],"Latest version":["Neueste Version"],"Launch a ready-to-code development environment for your project.":["Starte eine einsatzbereite Entwicklungsumgebung f\xfcr dein Projekt."],"Launch board":["Board starten"],"Layout|Fixed":["Fixiert"],"Layout|Fluid":["Anpassbar"],"Lead time":["Abarbeitungsdauer"],"Lead time for changes":["Vorlaufzeit f\xfcr \xc4nderungen"],"Learn GitLab":["GitLab lernen"],"Learn More":["Mehr erfahren"],"Learn about how your subscription works %{url}":["Erfahre mehr \xfcber die Funktionsweise deines Abonnements %{url}"],"Learn about signing commits":["Erfahre mehr \xfcber Signierung von Commits"],"Learn about signing commits with SSH keys.":["Erfahre mehr \xfcber die Signierung von Commits mit SSH-Schl\xfcsseln."],"Learn how to %{link_start}contribute to the built-in templates%{link_end}":["Erfahre, wie du %{link_start}zu den integrierten Vorlagen%{link_end} beitr\xe4gst"],"Learn how to %{no_packages_link_start}publish and share your packages%{no_packages_link_end} with GitLab.":["Erfahre, wie du deine %{no_packages_link_start}Packages ver\xf6ffentlichen und teilen kannst%{no_packages_link_end}, mit GitLab."],"Learn more":["Mehr erfahren"],"Learn more about %{name}":["Erfahre mehr \xfcber %{name}"],"Learn more about Auto DevOps":["Erfahre mehr \xfcber Auto-DevOps"],"Learn more about GitLab":["Erfahre mehr \xfcber GitLab"],"Learn more about Service Desk":["Erfahre mehr \xfcber den Service-Desk"],"Learn more about X.509 signed commits":["Erfahre mehr \xfcber X.509 signierte Commits"],"Learn more about authentication requirements: ":["Weitere Informationen zu den Authentifizierungsanforderungen: "],"Learn more about custom project templates":["Weitere Informationen zu benutzerdefinierten Projektvorlagen"],"Learn more about deploying to a cluster":["Erfahre mehr \xfcber das Bereitstellen zu einem Cluster"],"Learn more about free user limits":["Erfahre mehr \xfcber die Limits f\xfcr kostenlose Benutzer(innen)"],"Learn more about group-level project templates":["Erfahre mehr \xfcber Projektvorlagen auf Gruppenebene"],"Learn more about groups.":["Erfahre mehr \xfcber Gruppen."],"Learn more about importing GitLab projects by using direct transfer":["Weitere Infos zum Importieren von GitLab-Projekten per direkter \xdcbertragung"],"Learn more about linking epics":["Erfahre mehr \xfcber das Verkn\xfcpfung von Epics"],"Learn more about linking issues":["Erfahre mehr \xfcber das Verkn\xfcpfung von Tickets"],"Learn more about linking issues and incidents":["Erfahre mehr \xfcber das Verkn\xfcpfung von Tickets und Vorf\xe4llen"],"Learn more about linking tickets":["Mehr \xfcber das Verkn\xfcpfen von Tickets erfahren"],"Learn more about max seats used":["Erfahre mehr \xfcber die maximal verwendeten Pl\xe4tze"],"Learn more about seats owed":["Erfahre mehr \xfcber geschuldete Pl\xe4tze"],"Learn more about shards and replicas in the %{configuration_link_start}advanced search configuration%{configuration_link_end} documentation. Changes don't take place until you %{recreated_link_start}recreate%{recreated_link_end} the index.":["Erfahre mehr \xfcber Fragmente und Repliken in der Dokumentation zur %{configuration_link_start}erweiterten Konfiguration der Suche%{configuration_link_end}. \xc4nderungen werden erst vorgenommen, wenn du den Index %{recreated_link_start}neu erstellst%{recreated_link_end}."],"Learn more about the Ultimate security suite":["Erfahre mehr \xfcber die Ultimate-Sicherheits-Suite"],"Learn more about vulnerability management on non-default branches and tags.":["Erfahre mehr \xfcber das Sicherheitsl\xfcckenmanagement f\xfcr nicht standardm\xe4\xdfige Branches und Tags."],"Learn more.":["Mehr erfahren."],"Learn more: %{url}":["Erfahre mehr: %{url}"],"Learn what Duo Chat can do.":["Lerne die Funktionen von Duo Chat kennen."],"LearnGitLab|10 best practices for using GitLab Duo":["10\xa0Best Practices zur Verwendung von GitLab Duo"],"LearnGitLab|Add code":["Code hinzuf\xfcgen"],"LearnGitLab|Add code owners":["Code-Eigent\xfcmer(innen) hinzuf\xfcgen"],"LearnGitLab|Add code to this project's repository":["Code zum Repository dieses Projekts hinzuf\xfcgen"],"LearnGitLab|Agentic Chat:":["Agenten-Chat:"],"LearnGitLab|Agents:":["Agenten:"],"LearnGitLab|Analyze your application for vulnerabilities with DAST":["Analyse deine Anwendung auf Schwachstellen mit DAST"],"LearnGitLab|Answer complex questions with context-aware chat that understands your code, pipelines, and projects.":["Beantworte komplexe Fragen mit kontextbezogenem Chat, der deinen Code, deine Pipelines und deine Projekte versteht."],"LearnGitLab|Assign a GitLab Duo seat to your colleagues":["GitLab Duo-Platz deinen Kolleg(inn)en zuweisen"],"LearnGitLab|Code completion:":["Codevervollst\xe4ndigung:"],"LearnGitLab|Code generation:":["Codegenerierung:"],"LearnGitLab|Complete these tasks first so you can enjoy GitLab's features to their fullest.":["F\xfchre diese Schritte aus, um den vollen Funktionsumfang von GitLab nutzen zu k\xf6nnen."],"LearnGitLab|Complete these tasks first so you can enjoy GitLab's features to their fullest:":["F\xfchre diese Schritte aus, um den vollen Funktionsumfang von GitLab nutzen zu k\xf6nnen:"],"LearnGitLab|Configure a project":["Konfiguriere ein Projekt."],"LearnGitLab|Configure your project":["Dein Projekt konfigurieren"],"LearnGitLab|Context-aware suggestions:":["Kontextbezogene Vorschl\xe4ge:"],"LearnGitLab|Create a repository":["Ein Repository erstellen"],"LearnGitLab|Create a workflow, and learn how GitLab features work together.":["Erstelle einen Workflow und entdecke das Zusammenspiel der verschiedenen GitLab-Funktionen."],"LearnGitLab|Create a workflow, and learn how GitLab features work together:":["Erstelle einen Workflow und entdecke das Zusammenspiel der verschiedenen GitLab-Funktionen:"],"LearnGitLab|Create an issue":["Ticket erstellen"],"LearnGitLab|Enable require merge approvals":["\u201eMerge-Genehmigungen vorschreiben\u201c aktivieren"],"LearnGitLab|End tutorial":["Tutorial beenden"],"LearnGitLab|Enroll":["Registrieren"],"LearnGitLab|Explore these resources to learn essential features and best practices.":["Erkunde diese Ressourcen, um mehr \xfcber grundlegende Funktionen zu erfahren und Best Practices zu lernen."],"LearnGitLab|Flows:":["Flows:"],"LearnGitLab|Follow these steps to get familiar with the GitLab workflow.":["Befolge diese Schritte, um dich mit dem GitLab-Workflow vertraut zu machen."],"LearnGitLab|Generates code based on a natural language code comment block. Write a comment, then press Enter to generate code based on the context of your comment, and the rest of your code.":["Generiert Code basierend auf einem Kommentarblock in nat\xfcrlicher Sprache. Schreibe einen Kommentar und dr\xfccke die Eingabetaste, um Code basierend auf dem Kontext deines Kommentars und dem restlichen Code zu generieren."],"LearnGitLab|Get familiar with GitLab Duo":["Erste Schritte mit GitLab Duo"],"LearnGitLab|Get familiar with GitLab Duo Agent Platform":["Erste Schritte mit der GitLab Duo Agent Platform"],"LearnGitLab|Get started":["Los geht's"],"LearnGitLab|GitLab Credits:":["GitLab Credits:"],"LearnGitLab|GitLab Duo Code Suggestions":["GitLab Duo \u2013 Codevorschl\xe4ge"],"LearnGitLab|GitLab University":["GitLab University"],"LearnGitLab|Handle specific tasks autonomously, from searching across projects to creating commits.":["Erledige spezifische Aufgaben autonom, von der Suche \xfcber Projekte hinweg bis zum Erstellen von Commits."],"LearnGitLab|In this tutorial, we explore 10 tips and best practices to integrate GitLab Duo Chat into your AI-native DevSecOps workflows and refine your prompts for the best results.":["In diesem Tutorial behandeln wir 10\xa0Tipps und Best Practices zur Integration von GitLab Duo Chat in deine KI-nativen DevSecOps-Workflows und verfeinern deine Prompts f\xfcr optimale Ergebnisse."],"LearnGitLab|Included in trial":["In der Testversion enthalten"],"LearnGitLab|Included in trial. Use GitLab to deploy your application, monitor its health, and keep it secure.":["In der Testversion enthalten. Mit GitLab kannst du deine Anwendung bereitstellen, ihre Integrit\xe4t \xfcberwachen und Sicherheitsfunktionen optimieren."],"LearnGitLab|Invite your colleagues":["Kolleg(inn)en einladen"],"LearnGitLab|Learn GitLab":["GitLab kennenlernen"],"LearnGitLab|Learn about GitLab Credits":["Erfahre mehr \xfcber GitLab Credits"],"LearnGitLab|Learn more":["Mehr erfahren"],"LearnGitLab|Let you automate entire workflows by combining agents into sequences that run in your IDE or directly in GitLab CI/CD.":["Erm\xf6glicht dir die Automatisierung ganzer Workflows, indem Agenten in Sequenzen kombiniert werden, die in deiner IDE oder direkt in GitLab CI/CD ausgef\xfchrt werden."],"LearnGitLab|Next steps":["N\xe4chste Schritte"],"LearnGitLab|Open the WebIDE":["WebIDE \xf6ffnen"],"LearnGitLab|Plan and execute work together":["Arbeit gemeinsam planen und ausf\xfchren"],"LearnGitLab|Quick start":["Schnellstart"],"LearnGitLab|Scan dependencies for licenses":["Abh\xe4ngigkeiten auf Lizenzen pr\xfcfen"],"LearnGitLab|Scan dependencies for vulnerabilities":["Abh\xe4ngigkeiten auf Schwachstellen pr\xfcfen"],"LearnGitLab|Secure your deployment":["Sichere deine Bereitstellung"],"LearnGitLab|Set up your code":["Richte deinen Code ein"],"LearnGitLab|Set up your first project's CI/CD":["CI/CD f\xfcr dein erstes Projekt einrichten"],"LearnGitLab|Start a free trial of GitLab Ultimate":["Starte eine kostenlose Testversion von GitLab Ultimate"],"LearnGitLab|Submit a merge request (MR)":["Merge Request (MR) senden"],"LearnGitLab|Suggests completions to the current line you are typing. Use it to complete one or a few lines of code.":["Schl\xe4gt Vervollst\xe4ndigungen f\xfcr die aktuelle Zeile vor. Nutze diese Funktion, um eine oder mehrere Codezeilen zu vervollst\xe4ndigen."],"LearnGitLab|Support for multiple languages:":["Unterst\xfctzung f\xfcr mehrere Sprachen:"],"LearnGitLab|Try the walkthrough in a new tab":["Walkthrough auf einem neuen Tab testen"],"LearnGitLab|Try walkthrough":["Walkthrough testen"],"LearnGitLab|Upload files":["Dateien hochladen"],"LearnGitLab|Use GitLab to deploy your application, monitor its health, and keep it secure:":["Mit GitLab kannst du deine Anwendung bereitstellen, ihre Integrit\xe4t \xfcberwachen und Sicherheitsfunktionen optimieren:"],"LearnGitLab|Use the built-in editor, WebIDE, or upload code using your preferred method.":["Verwende den integrierten Editor, WebIDE oder lade Code mit deiner bevorzugten Methode hoch."],"LearnGitLab|Use the command line":["Befehlszeile verwenden"],"LearnGitLab|Uses open files in your IDE, content before and after the cursor, filename, and extension type to provide relevant suggestions.":["Verwendet ge\xf6ffnete Dateien in deiner IDE, Inhalte vor und nach dem Cursor, Dateinamen und Erweiterungstyp, um relevante Vorschl\xe4ge bereitzustellen."],"LearnGitLab|Works with various programming languages supported by your development environment.":["Funktioniert mit unterschiedlichen Programmiersprachen, die von deiner Entwicklungsumgebung unterst\xfctzt werden."],"LearnGitLab|You don't have sufficient access to perform this action":["Du hast keinen Zugriff, um diese Aktion auszuf\xfchren"],"LearnGitLab|You don't have sufficient access to perform this action: ":["Du hast keinen Zugriff, um diese Aktion auszuf\xfchren: "],"LearnGitLab|Your team is growing! You've successfully invited new team members to the %{projectName} project.":["Dein Team w\xe4chst! Du hast erfolgreich neue Teammitglieder zum Projekt %{projectName}eingeladen."],"LearnGitLab|Your trial includes a pool of GitLab Credits shared across your team. Use them to access GitLab Duo Agent Platform features like AI Agents, Flows, and enhanced Chat.":["Deine Testversion beinhaltet ein Kontingent von GitLab Credits, das von deinem Team gemeinsam genutzt wird. Verwende sie, um auf Funktionen der GitLab Duo Agent Platform wie KI-Agenten, Flows und erweiterten Chat zuzugreifen."],"LearnGitlab|- Included in trial":["In der Testversion enthalten"],"LearnGitlab|Contact your administrator to enable this action.":["Wende dich an deine/-n Administrator(in), um diese Funktion zu aktivieren."],"LearnGitlab|Contact your administrator to start a free Ultimate trial.":["Kontaktiere deinen Administrator, um eine kostenlose Ultimate-Testversion zu starten."],"LearnGitlab|End tutorial":["Tutorial beenden"],"LearnGitlab|There was a problem trying to end the Learn GitLab tutorial. Please try again.":["Beim Beenden des Tutorials \u201eGitLab lernen\u201c ist ein Problem aufgetreten. Bitte erneut versuchen."],"LearnGitlab|View administrator list":["Administratorliste anzeigen"],"LearnGitlab|You've ended the Learn GitLab tutorial.":["Du hast das Tutorial \u201eGitLab lernen\u201c beendet."],Leave:["Verlassen"],"Leave edit mode? All unsaved changes will be lost.":["Bearbeitungsmodus verlassen? Alle nicht gespeicherten \xc4nderungen werden verloren gehen."],"Leave feedback":["Kommentar hinterlassen"],"Leave feedback.":["Hinterlasse Kommentar."],"Leave group":["Verlasse die Gruppe"],"Leave project":["Verlasse das Projekt"],"Legacy Web IDE":["Alte Web-IDE"],"Legacy burndown chart":["Legacy-Abarbeitungsdiagramm"],"Legacy license":["Legacy-Lizenz"],"Less Details":["Weniger Details"],"Let's Encrypt does not accept emails on example.com":["Let's Encrypt akzeptiert keine E-Mails von example.com"],"Let's Encrypt is a free, automated, and open certificate authority (CA) that gives digital certificates in order to enable HTTPS (SSL/TLS) for websites. Learn more about Let's Encrypt configuration by following the %{docs_link_start}documentation on GitLab Pages%{docs_link_end}.":["Let's Encrypt ist eine kostenlose, automatisierte und offene Zertifizierungsstelle (CA), die digitale Zertifikate ausstellt, um HTTPS (SSL/TLS) f\xfcr Webseiten zu aktivieren. Weitere Informationen zur Konfiguration von Let's Encrypt findest du in der Dokumentation zu %{docs_link_start}GitLab Pages%{docs_link_end}."],License:["Lizenz"],"License Compliance":["Lizenzkonformit\xe4t"],"License Compliance| Used by %{dependencies}":["Verwendet von %{dependencies}"],"License compliance":["Lizenzkonformit\xe4t"],"License does not provide access to Code Suggestions.":["Die Lizenz bietet keinen Zugriff auf Codevorschl\xe4ge."],"License includes access to Code Suggestions, but you lack the necessary permissions to use this feature.":["Die Lizenz umfasst den Zugriff auf Codevorschl\xe4ge, dir fehlen jedoch die erforderlichen Berechtigungen, um diese Funktion zu verwenden."],"License includes access to Code Suggestions.":["Die Lizenz beinhaltet den Zugriff auf Codevorschl\xe4ge."],"License information source":["Lizenzinformationsquelle"],"License key":["Lizenzschl\xfcssel"],"License overview":["Lizenz\xfcbersicht"],"LicenseCompliance|Acceptable for use in this project":["Zul\xe4ssig f\xfcr die Verwendung in diesem Projekt"],"LicenseCompliance|Allowed":["Erlaubt"],"LicenseCompliance|Collapse License Compliance details":[""],"LicenseCompliance|Denied":["Verweigert"],"LicenseCompliance|Expand License Compliance details":[""],"LicenseCompliance|License Compliance detected %d license":["Lizenzkonformit\xe4t hat %d Lizenz erkannt","Lizenzkonformit\xe4t hat %d Lizenzen erkannt"],"LicenseCompliance|License Compliance detected %d license and policy violation":["Lizenzkonformit\xe4t hat %d Lizenz- und Richtlinienverletzung erkannt.","Lizenzkonformit\xe4t hat %d Lizenz- und Richtlinienverletzungen erkannt."],"LicenseCompliance|License Compliance detected %d license and policy violation for the source branch only":["Lizenzkonformit\xe4t hat %d Lizenz- und Richtlinienverletzung nur f\xfcr den Quellbranch erkannt","Lizenzkonformit\xe4t hat %d Lizenz- und Richtlinienverletzungen nur f\xfcr den Quellbranch erkannt"],"LicenseCompliance|License Compliance detected %d license and policy violation for the source branch only; approval required":["Lizenzkonformit\xe4t hat %d Lizenz- und Richtlinienverletzung nur f\xfcr den Quellbranch erkannt. Zustimmung erforderlich.","Lizenzkonformit\xe4t hat %d Lizenz- und Richtlinienverletzungen nur f\xfcr den Quellbranch erkannt. Zustimmung erforderlich."],"LicenseCompliance|License Compliance detected %d license for the source branch only":["Lizenzkonformit\xe4t hat %d Lizenz nur f\xfcr den Quellbranch erkannt.","Lizenzkonformit\xe4t hat %d Lizenzen nur f\xfcr den Quellbranch erkannt."],"LicenseCompliance|License Compliance detected %d new license":["Lizenzkonformit\xe4t hat %d neue Lizenz erkannt.","Lizenzkonformit\xe4t hat %d neue Lizenzen erkannt."],"LicenseCompliance|License Compliance detected %d new license and policy violation":["Lizenzkonformit\xe4t hat %d neue Lizenz- und Richtlinienverletzung erkannt.","Lizenzkonformit\xe4t hat %d neue Lizenz- und Richtlinienverletzungen erkannt."],"LicenseCompliance|License Compliance detected %d new license and policy violation; approval required":["Lizenzkonformit\xe4t hat %d neue Lizenz- und Richtlinienverletzung erkannt. Zustimmung erforderlich.","Lizenzkonformit\xe4t hat %d neue Lizenz- und Richtlinienverletzungen erkannt. Zustimmung erforderlich."],"LicenseCompliance|License Compliance detected no licenses for the source branch only":["Lizenzkonformit\xe4t hat keine Lizenzen nur f\xfcr den Quellbranch erkannt."],"LicenseCompliance|License Compliance detected no new licenses":["Lizenzkonformit\xe4t hat keine neuen Lizenzen erkannt."],"LicenseCompliance|No policy matches this license":["Keine Richtlinie stimmt mit dieser Lizenz \xfcberein"],"LicenseCompliance|Out-of-compliance with the project's policies and should be removed":["Verst\xf6\xdft gegen die Richtlinien des Projekts und sollte entfernt werden"],"LicenseCompliance|Uncategorized":["Nicht kategorisiert"],"LicenseConfigurationSource|License configuration source set to PMDB":["Quelle f\xfcr Lizenzkonfiguration auf PMDB festgelegt"],"LicenseConfigurationSource|License configuration source set to SBOM":["Quelle f\xfcr Lizenzkonfiguration auf SBOM festgelegt"],"LicenseConfigurationSource|Something went wrong. Please try again.":["Etwas ist schiefgelaufen. Bitte versuche es erneut."],"LicenseManagement|Allowed":["Erlaubt"],"LicenseManagement|Denied":["Verweigert"],"LicenseManagement|Uncategorized":["Unkategorisiert"],"LicenseScanningReport|The following SBOM reports could not be parsed. Therefore the list of components and their licenses may be incomplete.":["Die folgenden SBOM-Berichte konnten nicht geparst werden. Daher ist die Liste der Komponenten und ihrer Lizenzen m\xf6glicherweise unvollst\xe4ndig."],"Licensed Enterprise Edition features can be used if the project namespace's plan includes the feature, or if the project is public.":["Lizenzierte Enterprise Edition-Funktionen k\xf6nnen verwendet werden, wenn der Plan des Projektnamensraums die Funktion enth\xe4lt oder wenn das Projekt \xf6ffentlich ist."],"Licensed Features":["Lizenzierte Features"],"Licensed to:":["Lizensiert an:"],Licenses:["Lizenzen"],"Licenses|Drag your license file here or %{linkStart}select a file to upload%{linkEnd}.":["Ziehe deine Lizenzdatei hierher oder %{linkStart}w\xe4hle eine Datei zum Hochladen aus%{linkEnd}."],"Licenses|Drop your license file to start the upload.":["Ziehe deine Lizenzdatei hier rein, um mit dem Hochladen zu beginnen."],"Licenses|Error: You are trying to upload something other than a file":["Fehler: Du versuchst, etwas anderes als eine Datei hochzuladen"],"Licenses|The file could not be uploaded.":["Die Datei konnte nicht hochgeladen werden."],"Licenses|This package also includes a license which was not identified by the scanner.":["Dieses Paket enth\xe4lt auch eine Lizenz, die vom Scanner nicht erkannt wurde.","Dieses Paket enth\xe4lt auch %{count} Lizenzen, die vom Scanner nicht erkannt wurden."],"Lifecycle can only have a maximum of %{limit} statuses.":["Lebenszyklus kann nur maximal %{limit}\xa0Status haben."],"Limit display of time tracking units to hours.":["Anzeige der Zeiterfassungseinheiten auf Stunden begrenzen."],"Limit sign in from multiple IP addresses":["Beschr\xe4nke die Anmeldung von mehreren IP-Adressen"],"Limit the number of inbound incident management alerts that can be sent to a project.":["Begrenze die Anzahl der eingehenden Vorfall-Management-Alarme, die an ein Projekt gesendet werden k\xf6nnen."],"Limit the number of issues and epics per minute a user can create through web and API requests.":["Limitiert die Anzahl der Tickets und Epics pro Minute, die ein(e) Benutzer(in) \xfcber Web- und API-Anfragen erstellen kann."],"Limit the number of pipeline creation requests per minute. This limit includes pipelines created through the UI, the API, and by background processing.":["Begrenze die Anzahl der Pipeline-Erstellungsanfragen pro Minute. Dieser Grenzwert umfasst Pipelines, die \xfcber die Benutzeroberfl\xe4che, die API und durch die Hintergrundverarbeitung erstellt wurden."],
"Limit the number of project or group members a user can delete per minute through API requests.":["Begrenze die Anzahl der Projekt- oder Gruppenmitglieder, die ein(e) Benutzer(in) pro Minute mittels API-Anfragen l\xf6schen kann."],"Limit the size of Sidekiq jobs stored in Redis.":["Begrenze die Gr\xf6\xdfe der Sidekiq-Jobs, die in Redis gespeichert sind."],"Limiting mode":["Begrenzungsmodus"],"Limits how many API requests an IP address can make to artifact manager endpoints within a 15-second window.":["Begrenzt, wie viele API-Anfragen eine IP-Adresse an Artefakt-Manager-Endpunkte innerhalb eines 15-min\xfctigen Zeitfensters t\xe4tigen kann."],Line:["Linie","Linien"],"Line changes":["Zeilen\xe4nderungen"],"LinearIntegration|Linear workspace URL (for example, https://linear.app/example)":["Lineare Arbeitsbereich-URL (zum Beispiel https://linear.app/example)"],"LinearIntegration|The Linear logo is a trademark of Linear Orbit Inc. in the U.S. and other countries.":["Das Linear-Logo ist eine Marke von Linear Orbit Inc. in den USA und anderen L\xe4ndern."],"LinearIntegration|URL must point to a workspace URL like https://linear.app/example":["Die URL muss auf eine Arbeitsbereichs-URL wie https://linear.app/example verweisen."],"LinearIntegration|Use Linear as this project's issue tracker.":["Verwende Linear als Ticketsystem f\xfcr dieses Projekt."],"LinearIntegration|Workspace URL":["Arbeitsbereich-URL"],"LinearIntegration|https://linear.app/example":["https://linear.app/example"],Link:["Link"],"Link %{issuableType}s together to show that they're related or that one is blocking others.":["Verkn\xfcpfe %{issuableType} miteinander, um zu zeigen, dass sie verwandt sind oder andere blockieren."],"Link %{issuableType}s together to show that they're related.":["Verkn\xfcpfe %{issuableType} miteinander, um zu zeigen, dass sie verwandt sind."],"Link (optional)":["Link-Adresse (optional)"],"Link Sentry to GitLab to discover and view the errors your application generates.":["Verkn\xfcpfe Sentry mit GitLab, um die von deiner Anwendung generierten Fehler zu entdecken und anzuzeigen."],"Link an external wiki from the project's sidebar.":["Verkn\xfcpfe ein externes Wiki aus der Men\xfcleiste des Projekts."],"Link copied to clipboard.":["Link in die Zwischenablage kopiert."],"Link does not exist":["Verbindung existiert nicht"],"Link items blocked by this item":["Elemente verkn\xfcpfen, die von diesem Element blockiert werden"],"Link items blocking this item":["Elemente verkn\xfcpfen, die dieses Element blockieren"],"Link items related to this item":["Elemente verkn\xfcpfen, die sich auf dieses Element beziehen"],"Link text":["Linktext"],"Link title":["Link-Titel"],"Link title is required":["Ein Link-Titel ist erforderlich."],"Link to diff file copied.":["Link zur Diff-Datei kopiert."],"Link to go to GitLab pipeline documentation":["Link zur Dokumentation f\xfcr die GitLab-Pipeline"],"Link to heading '%{heading}'":["Link zur \xdcberschrift \u201e%{heading}\u201c"],"Link to your Grafana instance.":["Link zu deiner Grafana-Instanz."],"Linked epics":["Verkn\xfcpfte Epics"],"Linked items":["Verkn\xfcpfte Elemente"],LinkedIn:["LinkedIn"],"LinkedIn:":["LinkedIn:"],"LinkedResources|Add":["Hinzuf\xfcgen"],"LinkedResources|Add a resource link":["Ressourcenlink hinzuf\xfcgen"],"LinkedResources|Cancel":["Abbrechen"],"LinkedResources|Error creating resource link for the incident: %{error}":["Fehler beim Erstellen des Ressourcenlinks f\xfcr den Vorfall: %{error}"],"LinkedResources|Error deleting the linked resource for the incident: %{error}":["Fehler beim L\xf6schen der verkn\xfcpften Ressource f\xfcr den Vorfall: %{error}"],"LinkedResources|Fetching linked resources":["Abrufen verkn\xfcpfter Ressourcen"],"LinkedResources|Link":["Link"],"LinkedResources|Remove":["Entfernen"],"LinkedResources|Resources":["Ressourcen"],"LinkedResources|Something went wrong while creating the resource link for the incident.":["Beim Erstellen des Ressourcenlinks f\xfcr den Vorfall ist ein Fehler aufgetreten."],"LinkedResources|Something went wrong while deleting the linked resource for the incident.":["Beim L\xf6schen der verkn\xfcpften Ressource f\xfcr den Vorfall ist ein Fehler aufgetreten."],"LinkedResources|Something went wrong while fetching linked resources for the incident.":["Beim Abrufen verkn\xfcpfter Ressourcen f\xfcr den Vorfall ist ein Fehler aufgetreten."],"LinkedResources|Text (Optional)":["Text (Optional)"],"LinkedResources|Use this space to add links to the resources your team needs as they work to resolve the incident.":["Verwende diesen Bereich, um Links zu den Ressourcen hinzuzuf\xfcgen, die dein Team ben\xf6tigt, um den Vorfall zu l\xf6sen."],Links:["Links"],List:["Liste"],"List available repositories":["Verf\xfcgbare Repositorys auflisten"],"List of suitable GCP locations":["Liste geeigneter GCP-Standorte"],"List of users allowed to exceed the rate limit. Example: username1, username2":["Liste der Benutzer(innen), die das Ratenlimit \xfcberschreiten d\xfcrfen. Beispiel: username1, username2"],"List of users who are allowed to exceed the rate limit. Example: username1, username2":["Liste der Benutzer(innen), die das Ratenlimit \xfcberschreiten d\xfcrfen. Beispiel: username1, username2"],"List options":["Optionen auflisten"],"List settings":["Einstellungen auflisten"],"List the merge requests that must be merged before this one.":["Liste die Merge Requests auf, die vor diesem gemerged werden m\xfcssen."],"List the visible events for %{project_link} using the %{events_api_link}.":["Liste der sichtbaren Ereignisse f\xfcr %{project_link} unter Verwendung von %{events_api_link}."],"List view":["Listenansicht"],"List your Bitbucket Server repositories":["Liste deine Bitbucket-Server-Repositorys auf"],"List your Gitea repositories":["Liste deine Gitea-Repositories auf"],"Load %{count} more":["Zeige %{count} weitere"],"Load embedded view":["Eingebettete Ansicht laden"],"Load more":["Mehr laden"],"Load more users":["Weitere Benutzer(innen) laden"],Loading:["Lade"],"Loading %{count} more...":["Zeige %{count} weitere..."],"Loading %{name}":["%{name} wird geladen"],"Loading accounts":["Konten werden geladen"],"Loading blame information":["Blame-Informationen werden geladen"],"Loading custom roles":["Benutzerdefinierte Rollen werden geladen"],"Loading file actions":["Dateiaktionen werden geladen"],"Loading files, directories, and submodules in the path %{path} for commit reference %{ref}":["Dateien, Ordner und Submodule im Pfad %{path} f\xfcr die Commit-Referenz %{ref} werden geladen."],"Loading full blame\u2026":["Blame komplett laden\xa0\u2026"],"Loading groups":["Gruppen werden geladen"],"Loading items":["Items werden geladen"],"Loading more":["Mehr wird geladen"],"Loading more items":["Mehr Items werden geladen"],"Loading pipeline status":["Pipeline-Status wird geladen"],"Loading snippet":["Lade Code-Schnipsel"],"Loading the Web IDE":["Laden der Web IDE"],"Loading users":["Benutzer(innen) werden geladen"],"Loading\u2026":["Laden\u2026"],Local:["Lokal"],"Local time is displayed.":["Ortszeit wird angezeigt."],Localization:["Lokalisierung"],Location:["Standort"],"Location:":["Ort:"],Lock:["Sperren"],"Lock %{issuableType}":["%{issuableType} sperren"],"Lock directory?":["Verzeichnis sperren?"],"Lock discussion":["Diskussion sperren"],"Lock file?":["Datei sperren?"],"Lock label after a merge request is merged":["Label sperren, nachdem ein Merge Request zusammengef\xfchrt wurde"],"Lock memberships to LDAP synchronization":["Beschr\xe4nke Mitgliedschaften auf die LDAP-Synchronisierung"],"Lock memberships to SAML Group Links synchronization":["Sperre Mitgliedschaften f\xfcr die Synchronisierung von SAML-Gruppenlinks"],"Lock not found":["Sperrung nicht gefunden"],"Lock on merge":["Sperren beim Zusammenf\xfchren"],"Lock status":["Sperrstatus"],"Lock the discussion":["Diskussion schliessen"],"Lock to current projects":["Auf aktuelle Projekte beschr\xe4nken"],Locked:["Gesperrt"],"Locked by %{locker}":["Von %{locker} gesperrt"],"Locked by %{locker}. You do not have permission to unlock this":["Von %{locker} gesperrt. Du verf\xfcgst \xfcber keine Berechtigung zum Entsperren."],"Locked files":["Gesperrte Dateien"],"Locked the discussion.":["Die Diskussion wurde gesperrt."],"Locking discussion":["Diskussion wird gesperrt"],"Locks the discussion.":["Diskussion sperren."],"LoggedOutMarketingHeader|Contact Sales":["Vertrieb kontaktieren"],"LoggedOutMarketingHeader|Pricing":["Preise"],"LoggedOutMarketingHeader|Why GitLab":["Gr\xfcnde, die f\xfcr GitLab sprechen"],"Login with smartcard":["Mit Smartcard einloggen"],Logo:["Logo"],"Logo was successfully removed.":["Logo wurde erfolgreich entfernt."],"Logo will be removed. Are you sure?":["Logo wird entfernt. Bist du sicher?"],Logs:["Protokolle"],"LogsViewer|Enter full screen":["Vollbildmodus aufrufen"],"LogsViewer|Exit full screen":["Vollbildmodus beenden"],"LogsViewer|Scroll to bottom":["Zum Seitenende scrollen"],"LogsViewer|Scroll to top":["Zum Seitenanfang scrollen"],"Low - S4":["Niedrig \u2013 S4"],"Low vulnerabilities present":["Schwachen Sicherheitsl\xfccken vorhanden"],MB:["MB"],MD5:["MD5"],"MFA for contributors":["MFA f\xfcr Mitwirkende"],"MLExperimentTracking|Delete experiment?":["Experiment l\xf6schen?"],"MRApprovals|Approvals":["Genehmigungen"],"MRApprovals|Approved by":["Genehmigt von"],"MRApprovals|Approvers":["Genehmigungsberechtigte"],"MRApprovals|Commented by":["Kommentiert von"],"MRDiffFile|Changes are too large to be shown.":["\xc4nderungen sind zu gro\xdf, um angezeigt zu werden."],"MRDiffFile|View file @ %{commitSha}":["Datei @ %{commitSha} anzeigen"],"MRDiff|Show changes only":["Nur \xc4nderungen zeigen"],"MRDiff|Show full file":["Vollst\xe4ndige Datei anzeigen"],"Macbook Touch ID on Edge":["MacBook Touch ID im Edge"],"Made this %{type} confidential.":["Dieses %{type} wurde vertraulich gemacht."],Mailgun:["Mailgun"],"Mailgun HTTP webhook signing key":["Mailgun-HTTP-Webhook-Signaturschl\xfcssel"],"Mailgun events":["Mailgun-Ereignisse"],Maintainer:["Betreuer(in)"],"Maintenance mode":["Wartungsmodus"],"MaintenanceMode|By disabling maintenance mode your banner message will be lost.":["Wenn der Wartungsmodus deaktiviert wird, geht die Bannernachricht verloren."],"MaintenanceMode|There was an error updating the Maintenance Mode Settings":["Beim Aktualisieren der Einstellungen f\xfcr den Wartungsmodus ist ein Fehler aufgetreten"],"Make a copy":["Kopie erstellen"],"Make adjustments to how your GitLab instance is set up.":["Nimm Anpassungen an der Einrichtung deiner GitLab-Instanz vor."],"Make changes to the diagram":["\xc4nderungen am Diagramm vornehmen"],"Make everyone on your team more productive regardless of their location. GitLab Geo creates read-only mirrors of your GitLab instance so you can reduce the time it takes to clone and fetch large repos.":["Mache alle in deinem Team unabh\xe4ngig von ihrem Standort produktiver. GitLab Geo erstellt schreibgesch\xfctzte Mirror deiner GitLab-Instanz, sodass du die Zeit zum Klonen und Abrufen gro\xdfer Repositorys reduzieren kannst."],"Make new users external by default":["Neue Benutzer(innen) standardm\xe4\xdfig als extern festlegen"],"Make protected CI/CD variables and runners available in merge request pipelines. Protected resources will only be available in merge request pipelines if both the source and target branches of the merge request are protected.":["Stelle gesch\xfctzte CI/CD-Variablen und Runners in Merge Request-Pipelines zur Verf\xfcgung. Gesch\xfctzte Ressourcen sind nur dann in Merge Request-Pipelines verf\xfcgbar, wenn sowohl die Quell- als auch Ziel-Branches des Merge Requests gesch\xfctzt sind."],"Make sure you choose a strong, unique password.":["Achte darauf, dass du ein sicheres, eindeutiges Passwort w\xe4hlst."],"Make sure you have the correct permissions to link your project.":["Stelle sicher, dass du \xfcber die erforderlichen Berechtigungen verf\xfcgst, um dein Projekt zu verkn\xfcpfen."],"Make sure you save it - you won't be able to access it again.":["Vergiss nicht, deine Arbeit zu speichern. Sp\xe4ter kannst du nicht mehr darauf zugreifen."],"Make sure you trust %{strong_start}%{client_name}%{strong_end} before authorizing.":["Stelle vor der Autorisierung sicher, dass du %{strong_start}%{client_name}%{strong_end} vertraust."],"Makes this %{type} confidential.":["Macht dieses %{type} vertraulich."],"Malformed .git-blame-ignore-revs":["Fehlerhafte .git-blame-ignore-revs"],Manage:["Verwalten"],"Manage %{workspace} labels":["%{workspace} Labels verwalten"],"Manage access":["Zugriff verwalten"],"Manage applications that can use GitLab as an OAuth provider, and applications that you've authorized to use your account.":["Verwalte Anwendungen, die GitLab als OAuth-Anbieter verwenden k\xf6nnen, und Anwendungen, denen du die Verwendung deines Kontos erlaubt hast."],"Manage applications that use GitLab as an OAuth provider.":["Verwalte Anwendungen, die GitLab als OAuth-Anbieter verwenden."],"Manage applications that you've authorized to use your account.":["Verwalte Anwendungen, die du f\xfcr die Verwendung deines Kontos autorisiert hast."],"Manage branch rules":["Branch-Regeln verwalten"],"Manage comment templates":["Kommentarvorlagen verwalten"],"Manage configuration":["Konfiguration verwalten"],"Manage dependency scanning behavior for all projects in your GitLab instance":["Verhalten der Abh\xe4ngigkeits-Scans f\xfcr alle Projekte in deiner GitLab-Instanz verwalten"],"Manage deployments":["Bereitstellungen verwalten"],"Manage framework":["Frameworks verwalten"],"Manage group labels":["Gruppenlabels verwalten"],"Manage members":["Mitglieder verwalten"],"Manage milestones":["Meilensteine verwalten"],"Manage project labels":["Projektlabel verwalten"],"Manage projects.":["Projekte verwalten."],"Manage rules":["Regeln verwalten"],"Manage secret detection behavior for all projects in your GitLab instance":["Konfiguriere die Erkennung von Geheimnissen f\xfcr alle Projekte in deiner GitLab-Instanz"],"Manage security policy settings in your GitLab instance":["Verwalte die Sicherheitsrichtlinieneinstellungen in deiner GitLab-Instanz"],"Manage security scan data retention settings":[""],"Manage statuses":["Status verwalten"],"Manage templates\u2026":["Vorlagen verwalten\xa0\u2026"],"Manage two-factor authentication":["Zwei-Faktor-Authentifizierung verwalten"],"Manage usage":["Nutzung verwalten"],"Manage your subscription":["Dein Abonnement verwalten"],"Managed Account":["Verwaltetes Konto"],"Managing code":["Codeverwaltung"],"Managing users":["Benutzer(innen) verwalten"],Manifest:["Manifest"],"Manifest file":["Manifest-Datei"],"Manifest file import":["Manifestdateiimport"],"Manifest import":["Manifest importieren"],"ManifestImport|Import manifest files cannot exceed %{size} MB":["Import-Manifestdateien d\xfcrfen nicht gr\xf6\xdfer als %{size}\xa0MB sein"],"ManifestImport|Manifest file import":["Manifestdatei-Import"],"ManifestImport|Please upload a manifest file.":["Bitte lade eine Manifestdatei hoch."],"ManifestImport|Unable to upload the file. Please upload a valid XML file.":["Die Datei konnte nicht hochgeladen werden. Bitte lade eine g\xfcltige XML-Datei hoch."],"ManifestImport|You don't have enough permissions to import projects in the selected group":["Du verf\xfcgst nicht \xfcber ausreichende Berechtigungen, um Projekte in der ausgew\xe4hlten Gruppe zu importieren."],Manual:["Manuell"],"Manual Variables":["Manuelle Variablen"],"ManualVariables|There are no manually-specified variables for this pipeline":["Es gibt keine manuell angegebenen Variablen f\xfcr diese Pipeline"],"ManualVariables|When you %{helpPageUrlStart}run a pipeline manually%{helpPageUrlEnd}, you can specify additional CI/CD variables to use in that pipeline run.":["Wenn du %{helpPageUrlStart}eine Pipeline manuell ausf\xfchrst%{helpPageUrlEnd}, kannst du zus\xe4tzliche CI/CD-Variablen angeben, die in dieser Pipeline-Ausf\xfchrung verwendet werden sollen."],"Manuall
"last commit:":["Letzter Commit:"],latest:["letzte"],"latest deployment":["neuste Bereitstellung"],"latest version":["neuste Version"],"leave %{group_name}":["%{group_name} verlassen"],"less than a minute":["weniger als eine Minute"],"less than or equal to":["kleiner als oder gleich"],"level: %{level}":["Level: %{level}"],"lfs objects":["LFS-Objekte"],license:["Lizenz","Lizenzen"],"limit of %{project_limit} reached":["Limit von %{project_limit} erreicht"],line:["Zeile","Zeilen"],"load it anyway":["trotzdem laden"],"locked by %{path_lock_user_name} %{created_at}":["gesperrt durch %{path_lock_user_name} %{created_at}"],"locked until %{timestamp}":["gesperrt bis %{timestamp}"],main:["Haupt-"],"math|Display anyway":["Trotzdem anzeigen"],"math|Displaying this math block may cause performance issues on this page.":["Die Anzeige dieses Mathematikblocks k\xf6nnte Performance-Probleme auf dieser Seite verursachen."],"math|There was an error rendering this math block. %{katexMessage}":["Es gab einen Fehler beim Rendern dieses Mathematikblocks. %{katexMessage}"],"math|This math block exceeds %{maxMathChars} characters, and may cause performance issues on this page.":["Dieser Mathematikblock \xfcberschreitet %{maxMathChars} Zeichen und k\xf6nnte Leistungsprobleme auf dieser Seite verursachen."],"math|Too many expansions. Consider using multiple math blocks.":["Zu viele Erweiterungen. Erw\xe4ge, mehrere Mathematikbl\xf6cke zu verwenden."],"max_resources_per_workspace must be an empty hash if shared_namespace is specified":["max_resources_per_workspace muss ein leerer Hash sein, wenn shared_namespace angegeben ist"],member:["Mitglied","Mitglieder"],"merge request":["Merge Request","Merge Requests"],merged:["zusammengef\xfchrt"],"mergedCommitsAdded| (commits were squashed)":[" (Commits wurden gesquasht)"],"metadata is too large (maximum is %{max_size} characters)":["Metadaten sind zu gro\xdf (h\xf6chstens %{max_size}\xa0Zeichen)"],milestone:["Meilenstein"],"milestone should belong
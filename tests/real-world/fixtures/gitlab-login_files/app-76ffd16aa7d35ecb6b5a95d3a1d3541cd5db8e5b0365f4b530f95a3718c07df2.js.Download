nk} on branch %{branch}, built by pipeline %{pipeline}, and published to the registry %{datetime}":["Paket von Commit %{link} auf Branch %{branch} aktualisiert, von Pipeline %{pipeline} erstellt und in der Registry ver\xf6ffentlicht am %{datetime}"],"PackageRegistry|Packages":["Pakete"],"PackageRegistry|Packages and assets cleanup is ready to be executed when the next cleanup job runs.":["Die Bereinigung von Paketen und Assets kann ausgef\xfchrt werden, wenn der n\xe4chste Bereinigungsjob ausgef\xfchrt wird."],"PackageRegistry|Packages and assets will not be deleted until cleanup runs in %{nextRunAt}.":["Pakete und Assets werden nicht gel\xf6scht, bis die Bereinigung in %{nextRunAt} ausgef\xfchrt wird."],"PackageRegistry|Packages deleted successfully":["Pakete erfolgreich gel\xf6scht"],"PackageRegistry|Pending deletion":["L\xf6schung steht aus"],"PackageRegistry|Permanently delete":["L\xf6sche dauerhaft"],"PackageRegistry|Permanently delete assets":["Assets dauerhaft l\xf6schen"],"PackageRegistry|Pip Command":["Pip-Befehl"],"PackageRegistry|Processing":["Verarbeitung"],"PackageRegistry|Project-level":["Projektebene"],"PackageRegistry|Protected packages":["Gesch\xfctzte Pakete"],"PackageRegistry|Publish packages if their name or version matches this regex.":["Pakete ver\xf6ffentlichen, wenn der Name oder die Version mit dieser Regex \xfcbereinstimmt."],"PackageRegistry|Published %{date}":["Ver\xf6ffentlicht am: %{date}"],"PackageRegistry|Published by %{author}, %{date}":["Ver\xf6ffentlicht von: %{author}, am: %{date}"],"PackageRegistry|Published to %{projectName} by %{author}, %{date}":["Ver\xf6ffentlicht in Projekt %{projectName} von: %{author}, am: %{date}"],"PackageRegistry|Published to %{projectName}, %{date}":["Ver\xf6ffentlicht in Projekt %{projectName}, am: %{date}"],"PackageRegistry|Published to the %{project} Terraform Module Registry %{datetime}":["Ver\xf6ffentlicht in der %{project} Terraform-Modul-Registry %{datetime}"],"PackageRegistry|Published to the %
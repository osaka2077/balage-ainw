ain requirements. %{docs_link_start}Learn more%{docs_link_end}.":["Anfragen f\xfcr Seiten unter %{code_start}%{help_text_url}%{code_end} leiten an die URL weiter. Das Ziel muss bestimmte Anforderungen erf\xfcllen. %{docs_link_start}Mehr erfahren%{docs_link_end}."],"Requests per period":["Anfragen pro Periode"],"Require additional authentication for administrative tasks.":["Zus\xe4tzliche Authentifizierung f\xfcr administrative Aufgaben erforderlich."],"Require email verification when account is locked.":["E-Mail-Verifizierung anfordern, wenn das Konto gesperrt ist."],"Require expiration date":["Ablaufdatum vorgeben"],"Require users to verify their email address when their account is locked.":["Benutzer(innen) m\xfcssen ihre E-Mail-Adresse verifizieren, wenn ihr Konto gesperrt ist."],"Required approvals (%{approvals_given} of %{required} given)":["Erforderliche Genehmigungen (%{approvals_given} von %{required} erteilt)"],"Required approvals (%{approvals_given} of %{required} given, you've approved)":["Erforderliche Genehmigungen (%{approvals_given} von %{required} erteilt, deine Genehmigung liegt vor)"],"Required in this branch.":["In diesem Branch erforderlich."],"Required in this project.":["In diesem Projekt erforderlich."],"Required only if you are not using role instance credentials.":["Nur erforderlich, wenn du keine Rolleninstanzzugangsdaten verwendest."],"Required only if you are using AssumeRole for authorization across accounts.":["Nur erforderlich, wenn du AssumeRole f\xfcr die konten\xfcbergreifende Autorisierung verwendest."],Requirement:["Anforderung"],"Requirement %{reference} has been added":["Anforderung %{reference} wurde hinzugef\xfcgt"],"Requirement %{reference} has been archived":["Anforderung %{reference} wurde archiviert"],"Requirement %{reference} has been reopened":["Anforderung %{reference} wurde erneut ge\xf6ffnet"],"Requirement %{reference} has been updated":["Anforderung %{reference} wurde aktualisiert"],"Requirement status is nil.":["Der Anforderungsstatus ist Null."],Requirements:["Anforderungen"],"Requirements can be based on users, stakeholders, system, software, or anything else you find important to capture.":["Anforderungen k\xf6nnen Benutzer(innen), Stakeholder(innen), Systeme, Software oder alles andere, was du als wichtig erachtest, als Basis verwenden."],"Requirement|Legacy requirement ID: %{legacyId}":["Legacy-Anforderungs-ID: %{legacyId}"],"Requirement|Legacy requirement IDs are being deprecated. Update your links to reference this item's new ID %{id}.":["Legacy-Anforderungs-IDs sind veraltet. Aktualisiere deine Links so, dass sie auf die neue ID %{id} dieses Elements verweisen."],"Requirement|Requirements have become work items and the legacy requirement IDs are being deprecated. Update your links to reference this item's new ID %{id}.":["Anforderungen hei\xdfen inzwischen Arbeitsaufgaben, und die fr\xfcheren Anforderungs-IDs sind veraltet. Aktualisiere deine Links so, dass sie auf die neue ID dieses Elements (%{id}) verweisen."],"Requires %d approval":["Ben\xf6tigt %d Genehmigung","Ben\xf6tigt %d Genehmigungen"],"Requires %d approval from eligible users.":["Erfordert %d Zustimmung von berechtigten Benutzer(inne)n.","Erfordert %d Zustimmungen von berechtigten Benutzer(inne)n."],"Requires %{count} approval from %{names}.":["Ben\xf6tigt %{count} die Zustimmung von %{names}.","Ben\xf6tigt %{count} Zustimmungen von %{names}."],"Requires you to deploy or set up cloud-hosted Sentry.":["Erfordert, dass du Cloud-gehostete Sentry bereitstellst oder einrichtest."],"Requires your primary GitLab email address. If you want to confirm a secondary email address, go to %{emails_link_start}Emails%{emails_link_end}":["Erfordert deine prim\xe4re GitLab-E-Mail-Adresse. Wenn du eine sekund\xe4re E-Mail-Adresse best\xe4tigen m\xf6chtest, gehe zu %{emails_link_start}E-Mails%{emails_link_end}"],"Requires your primary or verified secondary GitLab email address.":["Erfordert deine prim\xe4re oder verifizierte sekund\xe4re GitLab-E-Mail-Adresse."],Resend:["Erneut senden"],"Resend Request":["Anfrage erneut senden"],"Resend confirmation e-mail":["Best\xe4tigungs-E-Mail erneut senden"],"Resend confirmation email":["Best\xe4tigungs-E-Mail erneut versenden"],"Resend invite":["Einladung erneut senden"],"Resend it":["Erneut senden"],"Resend unlock instructions":["Erneut Anweisungen zum Entsperren senden"],Reset:["Zur\xfccksetzen"],"Reset approvals on push":["Genehmigungen beim Push zur\xfccksetzen"],"Reset error tracking access token":["Zugriffstoken f\xfcr die Fehlernachverfolgung zur\xfccksetzen"],"Reset file":["Datei zur\xfccksetzen"],"Reset filters":["Filter zur\xfccksetzen"],"Reset password":["Passwort zur\xfccksetzen"],"Reset registration token":["Registrierungs-Token zur\xfccksetzen"],"Reset template":["Vorlage zur\xfccksetzen"],"Reset to project defaults":["Auf Projekt-Defaults zur\xfccksetzen"],"Reset token":["Token zur\xfccksetzen"],"Resize sidebar":["Gr\xf6\xdfe der Men\xfcleiste \xe4ndern"],Resolve:["Beenden"],"Resolve all with new issue":["Alle mit neuem Ticket l\xf6sen"],"Resolve any conflicts. %{linkStart}How do I fix them?%{linkEnd}":["Konflikte l\xf6sen. %{linkStart}Wie kann ich sie beheben?%{linkEnd}"],"Resolve conflicts":["Konflikte l\xf6sen"],"Resolve discussions":["Diskussionen beenden"],"Resolve locally":["Lokal l\xf6sen"],"Resolve source branch %{source_branch_name} conflicts using interactive mode to select %{use_ours} or %{use_theirs}, or manually using %{edit_inline}.":["L\xf6se die Konflikte im Quellbranch %{source_branch_name} im interaktiven Modus, indem du %{use_ours} oder %{use_theirs} ausw\xe4hlst, oder manuell mittels %{edit_inline}."],"Resolve thread":["Thread l\xf6sen"],"Resolve, @%{username}":[""],Resolved:["Abgeschlossen"],"Resolved 1 discussion.":["1 Diskussion gel\xf6st."],"Resolved all discussions.":["Alle Diskussionen gel\xf6st."],"Resolved by":["Gel\xf6st durch"],"Resolved by ":["Gel\xf6st durch "],"Resolved by %{name}":["Von %{name} gel\xf6st"],"Resource link added":["Ressourcen-Link hinzugef\xfcgt"],"ResourceAccessTokensInstanceSettings|Defines how long, in days, to wait before deleting inactive project and group access tokens. If blank, inactive project and group access tokens are not deleted.":["Definiert, wie viele Tage gewartet werden soll, bevor inaktive Projekt- und Gruppenzugriffstoken gel\xf6scht werden. Wenn das Feld leer ist, werden inaktive Projekt- und Gruppenzugriffstoken nicht gel\xf6scht."],"ResourceAccessTokensInstanceSettings|Inactive project and group access token retention period":["Aufbewahrungsfrist f\xfcr inaktive Projekt- und Gruppenzugriffstoken"],"ResourceListItem|Scheduled for deletion on %{date}":["Geplante L\xf6schung am %{date}"],Resources:["Ressourcen"],Response:["Antwort"],"Response didn't include `service_desk_address`":["`service_desk_address` fehlte in Antwort"],"Response initiated":["Reaktion eingeleitet"],"Response text":["Antworttext"],"Restart merge train pipelines with the merged changes.":["Merge-Zug-Pipelines mit den zusammengef\xfchrten \xc4nderungen neu starten."],Restore:["Wiederherstellen"],"Restore deployment":["Bereitstellung wiederherstellen"],"Restore group":["Gruppe wiederherstellen"],"Restore project":["Projekt wiederherstellen"],"Restore this version":["Diese Version wiederherstellen"],"Restrict access by IP address":["Zugriff mithilfe einer IP-Adresse beschr\xe4nken"],"Restrict global search to authenticated users only":["Globale Suche auf authentifizierte Benutzer(innen) einschr\xe4nken"],"Restrict membership by email domain":["Mitgliedschaft nach E-Mail-Domain einschr\xe4nken"],"Restricted access":["Eingeschr\xe4nkter Zugriff"],"Restricted access and user cap cannot be turned on. The group or one of its subgroups or projects is shared externally.":["Eingeschr\xe4nkter Zugriff und Benutzerkapazit\xe4t k\xf6nnen nicht aktiviert werden. Die Gruppe oder eine ihrer Untergruppen oder Projekte wird extern geteilt."],"Restricted shift times are not available for hourly shifts":["Eingeschr\xe4nkte Schichtzeiten sind f\xfcr Stundenschichten nicht verf\xfcgbar"],"Resubmit request":["Anfrage erneut senden"],"Results limit reached":["Ergebnislimit erreicht"],"Results pending\u2026":["Ergebnisse ausstehend \u2026"],Resume:["Fortsetzen"],Retry:["Wiederholen"],"Retry all failed or cancelled jobs":["Alle fehlgeschlagenen oder abgebrochenen Auftr\xe4ge wiederholen"],"Retry downstream pipeline":["Downstream-Pipeline wiederholen"],"Retry interval for failed namespaces":["Intervall f\xfcr Wiederholungsversuche f\xfcr fehlgeschlagene Namensr\xe4ume"],"Retry job":["Job wiederholen"],"Retry migration":["Migration erneut durchf\xfchren"],"Retry on failure":["Bei Fehlschlag erneut versuchen"],"Retry verification":["Wiederhole die \xdcberpr\xfcfung"],"Returned to you":["An dich zur\xfcckgesendet"],"Reveal values":["Werte anzeigen"],"Revert this commit":["Diesen Commit zur\xfccksetzen"],"Revert this merge request":["Merge Request zur\xfccksetzen"],"Review App|View app":["App anzeigen"],"Review App|View latest app":["Letzte App anzeigen"],"Review and edit media":["Medien pr\xfcfen und bearbeiten"],"Review approval":["Review-Genehmigung"],"Review changes":["\xc4nderungen pr\xfcfen"],"Review discarded":["Review verworfen"],"Review requested":["Review angefordert"],"Review requested from %{reviewerName}":["Review durch %{reviewerName} angefordert"],"Review settings":[""],"Review started":["Review begonnen"],"Review the changes locally.":["\xdcberpr\xfcfe die \xc4nderungen lokal."],'Review the process for configuring service providers in your identity provider \u2014 in this case, GitLab is the "service provider" or "relying party".':["\xdcberpr\xfcfe den Prozess zum Konfigurieren von Dienstanbietern bei deinem Identit\xe4tsanbieter. In diesem Fall ist GitLab der \u201eDienstanbieter\u201c oder die \u201evertrauende Seite\u201c."],"Review the target project before submitting to avoid exposing %{source} changes.":["\xdcberpr\xfcfe das Zielprojekt vor der Einreichung, um %{source}-\xc4nderungen zu vermeiden."],"Review time":["Reviewdauer"],"Review time is the amount of time since the first comment in a merge request.":["Die \xdcberpr\xfcfungszeit ist der Zeitraum seit dem ersten Kommentar in einem Merge Request."],Reviewed:["\xdcberpr\xfcft"],Reviewer:["Pr\xfcfer(in)","%d Pr\xfcfer(innen)"],"Reviewer commented":["Pr\xfcfer(in) hat kommentiert"],Reviewers:["Pr\xfcfer(innen)"],"Reviewers left feedback, or requested changes from you, on these merge requests.":["Pr\xfcfer(innen) haben zu dieser Merge-Anfrage Feedback hinterlassen oder \xc4nderungen von dir angefordert."],"Reviewers needed":["Reviewer ben\xf6tigt"],Reviews:["Reviews"],Revoke:["Widerrufen"],"Revoke Key":["Schl\xfcssel widerrufen"],Revoked:["Widerrufen"],"Revoked access token %{access_token_name}!":["Zugriffstoken %{access_token_name} widerrufen!"],"Revoked impersonation token %{token_name}!":["Identit\xe4tswechseltoken %{token_name} wiederrufen!"],'Revoked personal access token "%{personal_access_token_name}".':["Pers\xf6nliches Zugriffstoken \u201e%{personal_access_token_name}\u201c widerrufen."],"Rich text editor":["Rich-Text-Editor"],"RightSidebar|Copy email address":["E-Mail-Adresse kopieren"],"RightSidebar|Issue email":["Ticket-E-Mail-Adresse"],Roadmap:["Fahrplan"],"Roadmap settings":["Roadmap-Einstellungen"],Role:["Rolle"],"Role is required.":["Rolle ist erforderlich."],"Role promotions":["Rollen-Promotions"],Roles:["Rollen"],"Roles and permissions":["Rollen und Berechtigungen"],"Roll up totals may reflect child items you don\u2019t have access to.":["Rollup-Summen k\xf6nnen untergeordnete Elemente widerspiegeln, auf die du keinen Zugriff hast."],Rollback:["Zur\xfccksetzen"],"Root Moved Permanently redirection response":["Weiterleitungsantwort \u201eRoot dauerhaft verschoben\u201c"],Ruby:["Ruby"],"Rule name is already taken.":["Regelname ist bereits vergeben."],Run:["Ausf\xfchren"],"Run %{code_start}git fsck%{code_end} periodically in all project and wiki repositories to look for silent disk corruption issues.":["F\xfchre regelm\xe4\xdfig %{code_start}git fsck%{code_end} in allen Projekt- und Wiki-Repositorys aus, um nach Tickets mit stiller Festplattenbesch\xe4digung zu suchen."],"Run CI/CD pipelines for external repositories":["CI-/CD-Pipelines f\xfcr externe Repositorys ausf\xfchren"],"Run CI/CD pipelines with Jenkins when you push to a repository, or when a merge request is created, updated, or merged.":["CI/CD-Pipelines mit Jenkins ausf\xfchren, wenn du in ein Repository pushst oder ein Merge Request erstellst, aktualisierst oder zusammengef\xfchrt wird."],"Run CI/CD pipelines with Jenkins.":["F\xfchre CI/CD-Pipelines mit Jenkins aus."],"Run a new pipeline for this merge request":["Neue Pipeline f\xfcr diese Merge Request ausf\xfchren"],"Run a pipeline":["Pipeline ausf\xfchren"],"Run again":["Erneut ausf\xfchren"],"Run all manual":["Alle manuell ausf\xfchren"],"Run container scanning job whenever a container image with the latest tag is pushed.":["F\xfchre einen Container-Scan-Job aus, wenn ein Container-Image mit dem neuesten Tag gepusht wird."],"Run has already a model version":["Die Ausf\xfchrung hat bereits eine Modellversion"],"Run housekeeping":["Bereinigung starten"],"Run housekeeping tasks to automatically optimize Git repositories. Disabling this option will cause performance to degenerate over time.":["F\xfchre Housekeeping-Aufgaben aus, um die Git-Repositorys automatisch zu optimieren. Die Deaktivierung dieser Option f\xfchrt dazu, dass die Leistung mit der Zeit nachl\xe4sst."],"Run job":["Job ausf\xfchren"],"Run manual or delayed jobs":["Manuelle oder verz\xf6gerte Jobs ausf\xfchren"],"Run pipeline":["Pipeline ausf\xfchren"],"Run this job again in order to create the necessary resources.":["F\xfchre diesen Job erneut aus, um die erforderlichen Ressourcen zu erstellen."],"Run untagged jobs":["Unmarkierte Jobs ausf\xfchren"],"Run with eid not found":["Ausf\xfchrung mit EID nicht gefunden"],"Run with id not found":["Ausf\xfchrung mit ID nicht gefunden"],Runner:["Runner"],"Runner tokens":["Runner-Token"],"Runner was not updated.":["Runner wurde nicht aktualisiert."],"Runner was successfully updated.":["Runner wurde erfolgreich aktualisiert."],"RunnerTags|No matching results":["Keine passenden Ergebnisse"],"RunnerTags|No tags exist":["Keine Tags vorhanden"],"RunnerTags|Select runner tags":["Runner-Tags ausw\xe4hlen"],Runners:["Runner"],"Runners are processes that pick up and execute CI/CD jobs for GitLab.":["Runner sind Prozesse, die CI/CD-Jobs f\xfcr GitLab aufnehmen und ausf\xfchren."],"Runners|%d selected runner deleted":["%d ausgew\xe4hlter Runner gel\xf6scht","%d ausgew\xe4hlte Runner gel\xf6scht"],"Runners|%d selected runner paused":["%d ausgew\xe4hlter Runner angehalten","%d ausgew\xe4hlte Runner angehalten"],"Runners|%d selected runner unpaused":["Anhalten von %d ausgew\xe4hltem Runner aufgehoben","Anhalten von %d ausgew\xe4hlten Runners aufgehoben"],"Runners|%{count} runners in this group":["%{count} Runner in dieser Gruppe"],"Runners|%{highlightStart}%{duration}%{highlightEnd} second":["%{highlightStart}%{duration}%{highlightEnd} Sekunde","%{highlightStart}%{duration}%{highlightEnd} Sekunden"],"Runners|%{linkStart}Create a new runner%{linkEnd} to get started.":["%{linkStart}Erstelle einen neuen Runner%{linkEnd}, um zu beginnen."],"Runners|%{linkStart}View available zones%{linkEnd}. Must have the format %{format}. Example: %{example}.":["%{linkStart}Verf\xfcgbare Zonen anzeigen%{linkEnd}. Muss das Format %{format} haben. Beispiel: %{example}."],"Runners|%{linkStart}Where's my project ID?%{linkEnd} Can be 6 to 30 lowercase letters, digits, or hyphens. Must start with a letter and end with a letter or number. Example: %{example}.":["%{linkStart}Wo finde ich meine Projekt-ID?%{linkEnd} Kann aus 6 bis 30\xa0Kleinbuchstaben, Ziffern oder Bindestrichen bestehen. Muss mit einem Buchstaben beginnen und mit einem Buchstaben oder einer Zahl enden. Beispiel: %{example}."],"Runners|%{percentage} spot.":["%{percentage} Spot."],"Runners|%{strongStart}%{count}%{strongEnd} runner selected":["%{strongStart}%{count}%{strongEnd} Runner ausgew\xe4hlt","%{strongStart}%{count}%{strongEnd} Runner ausgew\xe4hlt"],"Runners|%{strongStart}%{count}%{strongEnd} runner will be permanently deleted and no longer available for projects or groups in the instance. Are you sure you want to continue?":["%{strongStart}%{count}%{strongEnd} Runner wird dauerhaft gel\xf6scht und wird f\xfcr Projekte oder Gruppen in der Instanz nicht mehr verf\xfcgbar sein. Bist du dir sicher, dass du fortfahren willst?","%{strongStart}%{count}%{strongEnd} Runner werden dauerhaft gel\xf6scht und werden f\xfcr Projekte oder Gruppen in der Instanz nicht mehr verf\xfcgbar sein. Bist du dir sicher, dass du fortfahren willst?"],"Runners|%{upgradeLinkStart}Upgrade GitLab Runner%{upgradeLinkEnd} to match your GitLab version. %{versionLinkStart}Major and minor versions%{versionLinkEnd} must match.":["%{upgradeLinkStart}Aktualisiere den GitLab-Runner%{upgradeLinkEnd} auf deine GitLab-Version. %{versionLinkStart}Haupt- und Nebenversionen%{versionLinkEnd} m\xfcssen \xfcbereinstimmen."],"Runners|%{upgradeLinkStart}Upgrade GitLab Runner%{upgradeLinkEnd} to match your GitLab version. This upgrade is highly recommended for this runner and may contain security or compatibility fixes. %{versionLinkStart}Major and minor versions%{versionLinkEnd} must match.":["%{upgradeLinkStart}Aktualisiere den GitLab-Runner%{upgradeLinkEnd} auf deine GitLab-Version. Dieses Upgrade wird f\xfcr diesen Runner dringend empfohlen und kann Sicherheits- oder Kompatibilit\xe4tsverbesserungen enthalten. %{versionLinkStart}Haupt- und Nebenversionen%{versionLinkEnd} m\xfcssen \xfcbereinstimmen."],"Runners|+%{count} more":["+%{count} weitere"],"Runners|1. Configure your Google Cloud project":["1. Google Cloud-Projekt konfigurieren"],"Runners|1. Environment":["1. Umgebung"],"Runners|1.2 Node Pools":["1.2 Knoten-Pools"],"Runners|1.2 Set up the Node pools for your Kubernetes cluster.":["1.2 Richte die Knoten-Pools f\xfcr deinen Kubernetes-Cluster ein."],"Runners|2. Install and register GitLab Runner":["2. GitLab Runner installieren und registrieren"],"Runners|2. Set up GitLab Runner":["2. GitLab Runner einrichten"],"Runners|75th percentile":["75.\xa0Perzentil"],"Runners|90th percentile":["90.\xa0Perzentil"],"Runners|99th percentile":["99.\xa0Perzentil"],"Runners|A capacity of 1 enables warm HA through Auto Scaling group re-spawn. A capacity of 2 enables hot HA because the service is available even when a node is lost. A capacity of 3 or more enables hot HA and manual scaling of runner fleet.":["Eine Kapazit\xe4t von 1 erm\xf6glicht warme Hochverf\xfcgbarkeit durch Neuerstellung der automatisch skalierenden Gruppe. Eine Kapazit\xe4t von 2 erm\xf6glicht hei\xdfe Hochverf\xfcgbarkeit, da der Dienst auch dann verf\xfcgbar ist, wenn ein Knoten ausf\xe4llt. Eine Kapazit\xe4t von 3 oder mehr erm\xf6glicht hei\xdfe Hochverf\xfcgbarkeit und manuelle Skalierung der Runner-Flotte."],"Runners|A new version is available":["Eine neue Version ist verf\xfcgbar"],"Runners|A periodic background task deletes runners that haven't contacted GitLab in more than %{elapsedTime}. Only runners registered in this group are deleted. Runners in subgroups and projects are not. %{linkStart}Can I view how many runners were deleted?%{linkEnd}":["Ein regelm\xe4\xdfiger Hintergrundtask l\xf6scht Runners, die GitLab seit mehr als %{elapsedTime} nicht kontaktiert haben. Nur in dieser Gruppe registrierte Runners werden gel\xf6scht. Runners in Untergruppen und Projekten aber nicht. %{linkStart}Kann ich sehen, wie viele Runners gel\xf6scht wurden?%{linkEnd}"],"Runners|A runner configuration is where you configure runners based on your requirements. Each runner in this table represents a %{linkStart}single runner entry%{linkEnd} in the %{codeStart}config.toml%{codeEnd}. Multiple runners can be linked to the same configuration. When there are multiple runners in a configuration, the one that contacted GitLab most recently displays here.":["In einer Runner-Konfiguration konfigurierst du Runner basierend auf deinen Anforderungen. Jeder Runner in dieser Tabelle repr\xe4sentiert einen %{linkStart}einzelnen Runner-Eintrag%{linkEnd} in der %{codeStart}config.toml%{codeEnd}. Mehrere Runner k\xf6nnen mit derselben Konfiguration verkn\xfcpft werden. Wenn mehrere Runner in einer Konfiguration vorhanden sind, wird hier derjenige angezeigt, der GitLab zuletzt kontaktiert hat."],"Runners|Active":["Aktiv"],"Runners|Active runners":["Aktive Runner"],"Runners|Add Node Pool":["Knoten-Pool hinzuf\xfcgen"],
"Runners|Add notes such as the runner owner or what it should be used for.":["F\xfcge Notizen hinzu, z. B. den/der Eigent\xfcmer(in) des Runners oder wof\xfcr er verwendet werden soll."],"Runners|Add notes such as the runner owner or what it should be used for. Users with runner update permissions see this note.":["F\xfcge Notizen wie zum Beispiel den Eigent\xfcmer oder die Eigent\xfcmerin des Runners hinzu oder wof\xfcr er verwendet werden soll. Benutzer(innen) mit Berechtigungen zum Aktualisieren des Runners sehen diese Notiz."],"Runners|Add tags to specify jobs that the runner can run. %{helpLinkStart}Learn more%{helpLinkEnd}.":["F\xfcge Tags hinzu, um Jobs festzulegen, die der Runner ausf\xfchren kann. %{helpLinkStart}Mehr erfahren%{helpLinkEnd}."],"Runners|Admin area \u203a Runners":["Adminbereich \u203a Runners"],"Runners|Administrator":["Administrator(in)"],"Runners|After GitLab Runner is installed and registered, an autoscaling fleet of runners can execute your CI/CD jobs in Google Cloud. Based on demand, a runner manager creates temporary runners.":["Nachdem ein GitLab Runner installiert und registriert wurde, steht eine Autoscaling-Flotte von Runnern zur Verf\xfcgung, um deine CI/CD-Jobs in Google Cloud auszuf\xfchren. Je nach Bedarf erstellt ein Runner-Manager tempor\xe4re Runner."],"Runners|All":["Alle"],"Runners|All group runners that have not contacted GitLab in more than %{elapsedTime} are deleted permanently. This task runs periodically in the background.":["Alle Gruppen-Runner, die GitLab l\xe4nger als %{elapsedTime} nicht kontaktiert haben, werden dauerhaft gel\xf6scht. Diese Aufgabe wird regelm\xe4\xdfig im Hintergrund ausgef\xfchrt."],"Runners|Amazon Linux 2 Docker HA with manual scaling and optional scheduling. %{percentage} spot.":["Amazon Linux 2 Docker HA mit manueller Skalierung und optionalem Scheduling. %{percentage} Spot."],"Runners|Amazon Linux 2 Docker HA with manual scaling and optional scheduling. Non-spot.":["Amazon Linux 2 Docker HV mit manueller Skalierung und optionaler Zeitplanung. Non-spot."],"Runners|An error has occurred fetching instructions":["Beim Abrufen der Anleitung ist ein Fehler aufgetreten"],"Runners|An error occurred while creating the runner. Please try again.":["Beim Erstellen des Runners ist ein Fehler aufgetreten. Bitte versuche es erneut."],"Runners|An error occurred while deleting. Some runners may not have been deleted.":["Beim L\xf6schen ist ein Fehler aufgetreten. Einige Runners wurden m\xf6glicherweise nicht gel\xf6scht."],"Runners|An error occurred while pausing. Some runners may not have been paused.":["Beim Anhalten ist ein Fehler aufgetreten. Einige Runners wurden m\xf6glicherweise nicht angehalten."],"Runners|An error occurred while unpausing. Some runners may not have been unpaused.":["Beim Aufheben des Anhaltens ist ein Fehler aufgetreten. Das Anhalten einiger Runners wurde m\xf6glicherweise nicht aufgehoben."],"Runners|An upgrade is available for this runner":["F\xfcr diesen Runner ist ein Upgrade verf\xfcgbar"],"Runners|An upgrade is recommended for this runner":["F\xfcr diesen Runner ist ein Upgrade empfohlen"],"Runners|Apply the Terraform script":["Terraform-Skript anwenden"],"Runners|Arch/Platform":["Arch/Plattform"],"Runners|Architecture":["Architektur"],"Runners|Are you sure you want to disable instance runners for %{groupName}?":["M\xf6chtest du die Instanz-Runner f\xfcr %{groupName} wirklich deaktivieren?"],"Runners|Assign":["Zuweisen"],"Runners|Assign this runner to projects":["Diesen Runner Projekten zuweisen"],"Runners|Assigned Group":["Zugewiesene Gruppe"],"Runners|Assigned project runners":["Zugewiesene Projekt Runners"],"Runners|Associated with one or more projects":["Mit einem oder mehreren Projekten verbunden"],"Runners|Available":["Verf\xfcgbar"],"Runners|Available Runners":["Verf\xfcgbare Runner"],"Runners|Available to all projects":["F\xfcr alle Projekte verf\xfcgbar"],"Runners|Available to all projects and subgroups in the group":["F\xfcr alle Projekte und Untergruppen in der Gruppe verf\xfcgbar"],"Runners|Before you begin":["Bevor du beginnst"],"Runners|Capacity of 1 enables warm HA through Auto Scaling group re-spawn. Capacity of 2 enables hot HA because the service is available even when a node is lost. Capacity of 3 or more enables hot HA and manual scaling of runner fleet.":["Eine Kapazit\xe4t von 1 erm\xf6glicht eine warme Hochverf\xfcgbarkeit mittels Neuerstellung der Auto-Scaling-Gruppe. Eine Kapazit\xe4t von 2 erm\xf6glicht eine hei\xdfe Hochverf\xfcgbarkeit, da der Dienst auch bei Ausfall eines Knotens verf\xfcgbar ist. Eine Kapazit\xe4t von 3 oder mehr erm\xf6glicht eine hei\xdfe Hochverf\xfcgbarkeit sowie eine manuelle Skalierung der Runner-Flotte."],"Runners|Choose an executor when prompted by the command line. Executors run builds in different environments. %{linkStart}Not sure which one to select?%{linkEnd}":["W\xe4hle einen Executor aus, wenn du von der Befehlszeile aufgefordert wirst. Executoren f\xfchren Builds in verschiedenen Umgebungen aus. %{linkStart}Nicht sicher, welche du w\xe4hlen sollst?%{linkEnd}"],"Runners|Choose your preferred GitLab Runner":["W\xe4hle deinen bevorzugten GitLab Runner aus"],"Runners|Clear selection":["Auswahl l\xf6schen"],"Runners|Cloud":["Cloud"],"Runners|Command to register runner":["Befehl zum Registrieren des Runners"],"Runners|Configuration":["Konfiguration"],"Runners|Container":["Container"],"Runners|Containers":["Container"],"Runners|Copy Terraform configuration":["Terraform-Konfiguration kopieren"],"Runners|Copy and paste the following command into your command line to register the runner.":["Kopiere und f\xfcge den folgenden Befehl in deine Kommandozeile ein, um den Runner zu registrieren."],"Runners|Copy command":["Befehl kopieren"],"Runners|Copy commands":["Befehle kopieren"],"Runners|Copy instructions":["Anweisungen kopieren"],"Runners|Copy registration token":["Registrierungs-Token kopieren"],"Runners|Create":["Erstellen"],"Runners|Create a %{codeStart}main.tf%{codeEnd} file with the following Terraform configuration. Save this file in the directory most suitable to your Terraform environment. If you don't have a directory, create a new project, and then follow the guidelines to %{linkStart}set up Terraform with GitLab%{linkEnd}.":["Erstelle eine %{codeStart}main.tf%{codeEnd}-Datei mit der folgenden Terraform-Konfiguration. Speicher diese Datei im f\xfcr deine Terraform-Umgebung am besten geeigneten Verzeichnis. Falls kein Verzeichnis vorhanden ist, erstelle ein neues Projekt und befolge anschlie\xdfend die Anweisungen zum %{linkStart}Einrichten von Terraform mit GitLab%{linkEnd}."],"Runners|Create a group runner":["Erstelle einen Gruppen-Runner"],"Runners|Create a group runner to generate a command that registers the runner with all its configurations.":["Erstelle einen Gruppen-Runner, um einen Befehl zu generieren, der den Runner mit allen seinen Konfigurationen registriert."],"Runners|Create a project runner":["Erstelle einen Projekt-Runner"],"Runners|Create a project runner to generate a command that registers the runner with all its configurations.":["Erstelle einen Projekt-Runner, um einen Befehl zu generieren, der den Runner mit allen seinen Konfigurationen registriert."],"Runners|Create an instance runner":["Erstelle einen Instanz-Runner"],"Runners|Create an instance runner to generate a command that registers the runner with all its configurations.":["Erstelle einen Instanz-Runner, um einen Befehl zu generieren, der den Runner mit allen seinen Konfigurationen registriert."],"Runners|Create group runner":["Gruppen-Runner erstellen"],"Runners|Create instance runner":["Instanz-Runner erstellen"],"Runners|Create project runner":["Projekt-Runner erstellen"],"Runners|Create runner":["Runner erstellen"],"Runners|Created %{timeAgo}":["Erstellt %{timeAgo}"],"Runners|Created by %{user}":["Erstellt von %{user}"],"Runners|Created by %{user} %{timeAgo}":["Erstellt von %{user} %{timeAgo}"],"Runners|Creating runners with runner registration tokens is disabled. %{linkStart}Learn more%{linkEnd}.":["Das Erstellen von Runnern mit Registrierungstoken f\xfcr Runner ist deaktiviert. %{linkStart}Mehr erfahren%{linkEnd}."],"Runners|Creator":["Ersteller(in)"],"Runners|Date range limited to %{dateRange} days":["Datumszeitraum limitiert auf %{dateRange} Tage"],"Runners|Delete %d runner":["%d Runner l\xf6schen","%d Runner l\xf6schen"],"Runners|Delete %{count} runners?":["%{count} Runner l\xf6schen?"],"Runners|Delete runner":["Runner l\xf6schen"],"Runners|Delete runner %{name}?":["Runner %{name} l\xf6schen?"],"Runners|Delete selected":["Ausgew\xe4hlte l\xf6schen"],"Runners|Deploy GitLab Runner in AWS":["Bereitstellen von GitLab Runner in AWS"],"Runners|Description":["Beschreibung"],"Runners|Don't see what you are looking for? See the full list of options, including a fully customizable option %{linkStart}here%{linkEnd}.":["Du findest nicht, wonach du suchst? Die vollst\xe4ndige Liste der Optionen, einschlie\xdflich einer vollst\xe4ndig anpassbaren Option, findest du %{linkStart}hier%{linkEnd}."],"Runners|Download and install binary":["Bin\xe4rdatei herunterladen und installieren"],"Runners|Download latest binary":["Neueste Bin\xe4rdatei herunterladen"],"Runners|Enable stale runner cleanup":["Aktiviere die Bereinigung veralteter Runner"],"Runners|Enable stale runner cleanup?":["Die Bereinigung veralteter Runner aktivieren?"],"Runners|Ensure that %{linkStart}billing is enabled%{linkEnd} for your Google Cloud project.":["Stelle sicher, dass die %{linkStart}Abrechnung%{linkEnd} f\xfcr dein Google Cloud-Projekt aktiviert ist."],"Runners|Ensure you have the %{linkStart}Owner%{linkEnd} IAM role on your Google Cloud project.":["Stelle sicher, dass du die IAM-Rolle %{linkStart}Eigent\xfcmer(in)%{linkEnd} in deinem Google Cloud-Projekt hast."],"Runners|Enter the job timeout in seconds. Must be a minimum of 600 seconds.":["Gib die Zeit\xfcberschreitung f\xfcr den Job in Sekunden ein. Die erforderliche Mindestdauer ist 600\xa0Sekunden."],"Runners|Environment in Google Cloud where runners execute CI/CD jobs. Runners are created in temporary virtual machines based on demand. To improve security, use a Google Cloud project for CI/CD only.":["Umgebung in Google Cloud, in der Runner CI/CD-Jobs ausf\xfchren. Runner werden je nach Bedarf in tempor\xe4ren virtuellen Maschinen erstellt. Verwende ein Google Cloud-Projekt nur f\xfcr CI/CD, um die Sicherheit zu verbessern."],"Runners|Executor":["Executor"],"Runners|Existing runners are not affected. To permit runner registration for all groups, enable this setting in the Admin area in Settings &gt; CI/CD.":["Bestehende Runner sind nicht betroffen. Um die Runner-Registrierung f\xfcr alle Gruppen zuzulassen, aktiviere diese Einstellung im Admin-Bereich unter Einstellungen &gt; CI/CD."],"Runners|Existing runners are not affected. To permit runner registration for all projects, enable this setting in the Admin area in Settings &gt; CI/CD.":["Bestehende Runner sind nicht betroffen. Um die Runner-Registrierung f\xfcr alle Projekte zuzulassen, aktiviere diese Einstellung im Adminbereich unter Einstellungen &gt; CI/CD."],"Runners|Export as CSV":["Als CSV exportieren"],"Runners|Failed adding runner to project":["Fehler beim Hinzuf\xfcgen eines Runners zum Projekt"],"Runners|Failed unassigning runner from project":["Zuweisung des Runners an das Projekt konnte nicht aufgehoben werden"],"Runners|Fetch GitLab Runner release version data from GitLab.com":["Fetch GitLab Runner Release-Daten von GitLab.com"],"Runners|Filter projects":["Projekte filtern"],"Runners|Fleet dashboard":["Fleet-Dashboard"],"Runners|For most CI/CD jobs, use a %{linkStart}N2D standard machine type%{linkEnd}. Must have the format %{format}. Example: %{example}.":["Verwende f\xfcr die meisten CI/CD-Jobs einen %{linkStart}N2D-Standardmaschinentyp%{linkEnd}. Muss das Format %{format} haben. Beispiel: %{example}."],"Runners|Get started with runners":["Einstieg mit Runners"],"Runners|GitLab Runner must be installed before you can register a runner. %{linkStart}How do I install GitLab Runner?%{linkEnd}":["GitLab Runner muss installiert sein, bevor du einen Runner registrieren kannst. %{linkStart}Wie installiere ich GitLab Runner?%{linkEnd}"],"Runners|Go to %{groupLink} to enable them.":["\xd6ffne %{groupLink} f\xfcr Aktivierungsoptionen."],"Runners|Go to first invalid form field":["Zum ersten ung\xfcltigen Formularfeld gehen"],"Runners|Google Cloud project ID":["Google Cloud-Projekt-ID"],"Runners|Group":["Gruppe"],"Runners|Group area \u203a Runners":["Gruppenbereich \u203a Runner"],"Runners|Group runners are turned off":["Gruppen-Runner sind deaktiviert"],"Runners|Group runners are turned off for this project. Turn them on to use them.":["Gruppen-Runner sind f\xfcr dieses Projekt deaktiviert. Aktiviere sie, um sie zu verwenden."],"Runners|How is this calculated?":["Wie wird dieser Wert berechnet?"],"Runners|IP Address":["IP-Adresse"],"Runners|Idle":["Leerlauf"],"Runners|Image Type":["Image-Typ"],"Runners|Image Type help":["Hilfe zum Image-Typ"],"Runners|Image Type is required.":["Image-Typ ist erforderlich."],"Runners|Image Type must have the right format.":["Image-Typ muss das richtige Format haben."],"Runners|In GitLab Runner 15.6, the use of registration tokens and runner parameters in the 'register' command was deprecated. They have been replaced by authentication tokens. %{linkStart}How does this impact my current registration workflow?%{linkEnd}":["In GitLab Runner 15.6 ist die Verwendung von Registrierungstoken und Runner-Parametern im \u201eregister\u201c-Befehl veraltet. Sie wurden durch Authentifizierungstoken ersetzt. %{linkStart}Wie wirkt sich dies auf meinen aktuellen Registrierungsworkflow aus?%{linkEnd}"],"Runners|In the directory with that Terraform configuration file, run the following command to apply the configuration.":["F\xfchre im Verzeichnis mit dieser Terraform-Konfigurationsdatei den folgenden Befehl aus, um die Konfiguration anzuwenden."],"Runners|Install GitLab Runner":["GitLab Runner installieren"],"Runners|Install a runner":["Einen Runner installieren"],"Runners|Install the %{gcloudLinkStart}Google Cloud CLI%{gcloudLinkEnd} and %{terraformLinkStart}Terraform%{terraformLinkEnd}.":["Installiere die %{gcloudLinkStart}Google Cloud CLI%{gcloudLinkEnd} und %{terraformLinkStart}Terraform%{terraformLinkEnd}."],"Runners|Instance":["Instanz"],"Runners|Instance runners are disabled in the group settings.":["Instanz-Runner sind in den Gruppeneinstellungen deaktiviert."],"Runners|Instance runners are disabled.":["Instanz-Runner sind deaktiviert."],"Runners|Instance runners are turned off":["Instanz-Runner sind deaktiviert"],"Runners|Instance runners are turned off for this project. Turn them on to use them.":["Instanz-Runner sind f\xfcr dieses Projekt deaktiviert. Aktiviere sie, um sie zu verwenden."],"Runners|Instance runners are turned off in the group settings.":["Instanz-Runner sind in den Gruppeneinstellungen deaktiviert."],"Runners|Instance runners will be disabled for all projects and subgroups in this group.":["Instanz-Runner werden f\xfcr alle Projekte und Untergruppen in dieser Gruppe deaktiviert."],"Runners|Instance: Median job queued time":["Instanz: Median Job Warteschlange"],"Runners|Isolated location within a region. The zone determines what computing resources are available and where your data is stored and used.":["Isolierter Standort innerhalb einer Region. Die Zone bestimmt, welche Rechenressourcen verf\xfcgbar sind und wo deine Daten gespeichert und verwendet werden."],"Runners|Jobs":["Jobs"],"Runners|Jobs in projects you have access to.":["Jobs in Projekten, auf die du Zugriff haben."],"Runners|Last contact":["Letzter Kontakt"],"Runners|Last contact was %{timeAgo}":["Letzter Kontakt: %{timeAgo}"],"Runners|Last contact: %{timeAgo}":["Letzter Kontakt: %{timeAgo}"],"Runners|Learn more in the %{linkStart}Google Cloud documentation%{linkEnd}.":["Weitere Informationen findest du in der %{linkStart}Google Cloud-Dokumentation%{linkEnd}."],"Runners|Limits how many API requests a runner can make to jobs endpoints within a 1-minute window, per job token.":["Schr\xe4nkt ein, wie viele API-Anfragen ein Runner pro Job-Token innerhalb eines einmin\xfctigen Zeitfensters an Job-Endpunkte stellen kann."],"Runners|Limits how many API requests a runner can make to patch the job trace within a 1-minute window, per job token.":["Schr\xe4nkt ein, wie viele API-Anfragen ein Runner pro Job-Token innerhalb eines einmin\xfctigen Zeitfensters stellen kann, um die Job-Nachverfolgung zu patchen."],"Runners|Limits how many API requests a runner can make to request jobs within a 1-minute window.":["Schr\xe4nkt ein, wie viele API-Anfragen ein Runner innerhalb eines einmin\xfctigen Zeitfensters zum Anfordern von Jobs stellen kann."],"Runners|Loading":["Wird geladen"],"Runners|Machine type":["Maschinentyp"],"Runners|Machine type help":["Maschinentyp-Hilfe"],"Runners|Machine type is required.":["Maschinentyp ist erforderlich."],"Runners|Machine type must have the right format.":["Computertyp muss das richtige Format haben."],"Runners|Machine type with preset amounts of virtual machines processors (vCPUs) and memory":["Maschinentyp mit voreingestellten Mengen an Prozessoren f\xfcr virtuelle Maschinen (vCPUs) und Speicher"],"Runners|Maintenance note":["Wartungshinweis"],"Runners|Make sure the runner is online and available to run jobs (not paused). Jobs display here when the runner picks them up.":["Stelle sicher, dass der Runner online und verf\xfcgbar (nicht angehalten) ist, um Jobs auszuf\xfchren. Jobs werden hier angezeigt, wenn der Runner sie abholt."],"Runners|Manually verify that the runner is available to pick up jobs.":["Vergewissere dich manuell, dass der Runner zur Abholung von Jobs zur Verf\xfcgung steht."],"Runners|Maximum amount of time the runner can run before it terminates. If a project has a shorter job timeout period, the job timeout period of the instance runner is used instead.":["Maximale Zeitspanne, die der Runner laufen kann, bevor er beendet wird. Wenn ein Projekt eine k\xfcrzere Zeitspanne hat, wird stattdessen die Zeitspanne des Instanz-Runner genutzt."],"Runners|Maximum job timeout":["Maximale Zeit\xfcberschreitung f\xfcr Job"],"Runners|Maximum requests per minute to other Runner Jobs API endpoints":["Maximale Anzahl von Anfragen pro Minute an API-Endpunkte anderer Runner-Jobs"],"Runners|Maximum requests per minute to the PATCH /jobs/:id/trace endpoint":["Maximale Anzahl von Anfragen pro Minute an den Endpunkt PATCH /jobs/:id/trace"],"Runners|Maximum requests per minute to the POST /jobs/request endpoint":["Maximale Anzahl von Anfragen pro Minute an den Endpunkt POST /jobs/request"],"Runners|Median":["Median"],"Runners|Members of the %{type} can create runners":["Mitglieder des %{type} k\xf6nnen Runner erstellen"],"Runners|Minor version upgrades are available.":["Minor-Versions-Upgrades sind verf\xfcgbar."],"Runners|Most recent failures":["Letzte Fehler"],"Runners|Most used group runners":["Am h\xe4ufigsten verwendete Gruppen-Runner"],"Runners|Most used instance runners":["Am h\xe4ufigsten verwendete Instanz-Runner"],"Runners|Must have the format %{format}. Example: %{example}.":["Muss das Format %{format} haben. Beispiel: %{example}."],"Runners|Never contacted":["Nie kontaktiert"],"Runners|Never expires":["L\xe4uft nie ab"],"Runners|New group runners can be registered":["Neue Gruppen-Runner k\xf6nnen registriert werden"],"Runners|New project runners can be registered":["Neue Projekt-Runner k\xf6nnen registriert werden"],"Runners|New registration token generated!":["Neuer Registrierungs-Token generiert!"],"Runners|No description":["Keine Beschreibung"],"Runners|No group runners found":["Keine Gruppen-Runner gefunden"],"Runners|No instance runners found":["Keine Instanz-Runner gefunden"],"Runners|No jobs have been run by group runners assigned to this group in the past 3 hours.":["In den letzten 3\xa0Stunden wurden von Gruppen-Runnern, die dieser Gruppe zugewiesen sind, keine Jobs ausgef\xfchrt."],"Runners|No jobs have been run by instance runners in the past 3 hours.":["In den letzten 3\xa0Stunden wurden von Instanz-Runnern keine Jobs ausgef\xfchrt."],"Runners|No project runners are available to be assigned to this project.":["Es sind keine Projekt-Runner verf\xfcgbar, die diesem Projekt zugewiesen werden k\xf6nnen."],"Runners|No project runners found":["Keine Projekt-Runner gefunden"],"Runners|No runners managers found":["Keine Runner-Manager gefunden"],"Runners|No spot. Default choice for Windows Shell executor.":["Kein Spot. Standardauswahl f\xfcr Windows Shell-Ausf\xfchrungsmodul."],"Runners|No spot. This is the default choice for Linux Docker executor.":["Kein Spot. Dies ist die Standardeinstellung des Linux Docker-Ausf\xfchrungsmoduls."],"Runners|No, keep instance runners enabled":["Nein, Instanz-Runner aktiviert lassen"],"Runners|Node count":["Knotenanzahl"],"Runners|Node count help":["Hilfe zur Knotenanzahl"],"Runners|Node count is required.":["Knotenanzahl ist erforderlich."],"Runners|Node count must have the right format.":["Knotenanzahl muss das richtige Format haben."],"Runners|Node pool label key":["Schl\xfcssel des Knoten-Pool-Labels"],"Runners|Node pool label value":["Wert des Knoten-Pool-Labels"],"Runners|Node pool labels":["Knoten-Pool-Labels"],"Runners|Node pool name":["Knoten-Pool-Name"],"Runners|Node pool name help":["Hilfe zum Knoten-Pool-Namen"],"Runners|Node pool name is required.":["Knoten-Pool-Name ist erforderlich."],"Runners|Node pool name must have the right format.":["Knoten-Pool-Name muss das richtige Format haben."],"Runners|Not accepting jobs":["Jobs werden nicht angenommen"],"Runners|Official runner version data is periodically fetched from GitLab.com to determine whether the runners need upgrades.":["Offizielle Runner-Versionsdaten werden regelm\xe4\xdfig von GitLab.com abgerufen, um festzustellen, ob die Runner Upgrades ben\xf6tigen."],"Runners|Offline":["Offline"],"Runners|Online":["Online"],"Runners|Only the users with the update permission for this runner can view the note.":["Nur Benutzer(innen) mit der Berechtigung zum Aktualisieren f\xfcr diesen Runner k\xf6nnen die Notiz anzeigen."],"Runners|Operating System":["Betriebssystem"],"Runners|Operating systems":["Betriebssysteme"],"Runners|Optional configuration details":["Optionale Konfigurationsdetails"],"Runners|Other available project runners":["Andere verf\xfcgbare Projekt-Runner"],"Runners|Other projects":["Andere Projekte"],"Runners|Other runners":["Andere Runner"],"Runners|Owner":["Eigent\xfcmer(in)"],"Runners|Pause from accepting jobs":["Annehmen von Jobs pausieren"],"Runners|Pause selected":["Ausgew\xe4hlte anhalten"],"Runners|Paused":["Pausiert"],"Runners|Permanently delete %d runner":["%d Runner dauerhaft l\xf6schen","%d Runner dauerhaft l\xf6schen"],"Runners|Permanently delete runner":["Runner dauerhaft l\xf6schen","%d Runner dauerhaft l\xf6schen"],"Runners|Plan the node count size to ensure you can accomodate your workload":["Plane die Gr\xf6\xdfe der Knotenanzahl, um sicherzustellen, dass du deine Workload bew\xe4ltigen kannst"],"Runners|Platform":["Plattform"],"Runners|Project":["Projekt"],"Runners|Project ID is required.":["Projekt-ID ist erforderlich."],"Runners|Project ID must have the right format.":["Projekt-ID muss das richtige Format haben."],"Runners|Project \u203a CI/CD Settings \u203a Runners":["Projekt \u203a CI/CD-Einstellungen \u203a Runner"],"Runners|Projects you have access to":["Projekte, auf die du Zugriff hast"],"Runners|Protected":["Gesch\xfctzt"],"Runners|Recommended":["Empfohlen"],"Runners|Region":["Region"],"Runners|Region help":["Regionshilfe"],"Runners|Region is required.":["Region ist erforderlich."],"Runners|Region must have the right format.":["Region muss das richtige Format haben."],"Runners|Register":["Registrieren"],'Runners|Register "%{runnerDescription}" runner':["Runner \u201e%{runnerDescription}\u201c registrieren"],"Runners|Register a group runner":["Registriere einen Gruppen-Runner"],"Runners|Register a project runner":["Registriere einen Projekt-Runner"],"Runners|Register a runner":["Registriere einen Runner"],"Runners|Register an instance runner":["Registriere einen Instanz-Runner"],"Runners|Register runner":["Runner registrieren"],"Runners|Register your new runner":["Registriere deinen neuen Runner"],"Runners|Registration token":["Registrierungs-Token"],"Runners|Registration token copied to clipboard.":["Registrierungs-Token in Zwischenablage kopiert."],"Runners|Remove Node Pool":["Knoten-Pool entfernen"],"Runners|Remove Node pool":["Knoten-Pool entfernen"],"Runners|Remove Node pool label":["Knoten-Pool-Label"],"Runners|Reset token":["Token zur\xfccksetzen"],"Runners|Resume accepting jobs":["Wieder Jobs akzeptieren"],"Runners|Run the following command to enable the required services and create a service account with the required permissions. Only do this once for each Google Cloud project. You might be prompted to sign in to Google.":["F\xfchre den folgenden Befehl aus, um die erforderlichen Dienste zu aktivieren und ein Dienstkonto mit den erforderlichen Berechtigungen zu erstellen. F\xfchre dies nur einmal f\xfcr jedes Google Cloud-Projekt aus. Du wirst m\xf6glicherweise aufgefordert, dich bei Google anzumelden."],"Runners|Runner":["Runner"],"Runners|Runner %{name}":["Runner %{name}"],"Runners|Runner %{name} was assigned to this project.":["Der Runner %{name} wurde diesem Projekt zugeordnet."],"Runners|Runner %{name} was deleted":["Runner %{name} wurde gel\xf6scht"],"Runners|Runner %{name} was unassigned from this project.":["Die Zuordnung des Runners %{name} zu diesem Projekt wurde aufgehoben."],"Runners|Runner %{runnerName} failed to delete":["Runner %{runnerName} konnte nicht gel\xf6scht werden"],"Runners|Runner Registration":["Runner-Registrierung"],"Runners|Runner Registration token":["Runner Registrierungsschl\xfcssel"],"Runners|Runner Usage":["Runner-Nutzung"],"Runners|Runner assigned to project.":["Runner wurde dem Projekt zugewiesen."],"Runners|Runner authentication token":["Runner-Authentifizierungstoken"],"Runners|Runner authentication token expiration":["Ablauf des Runner-Authentifizierungs-Token"],"Runners|Runner authentication tokens will expire based on a set interval. They will automatically rotate once expired.":["Runner-Authentifizierungs-Tokens laufen in einem festgelegten Intervall ab. Sie werden automatisch rotiert, sobald sie abgelaufen sind."],"Runners|Runner configuration":["Runner-Konfiguration"],"Runners|Runner created.":["Runner erstellt."],"Runners|Runner description":["Runner Beschreibung"],"Runners|Runner has never contacted this instance":["Runner hat diese Instanz noch nie kontaktiert"],"Runners|Runner hasn't contacted GitLab in more than %{elapsedTime} and last contact was %{timeAgo}":["Runner hat GitLab seit mehr als %{elapsedTime} nicht kontaktiert und der letzte Kontakt war %{timeAgo}"],"Runners|Runner is locked and available for currently assigned projects only. Only administrators can change the assigned projects.":["Der Runner ist gesperrt und nur f\xfcr derzeit zugewiesene Projekte verf\xfcgbar. Nur Administratoren k\xf6nnen die zugewiesenen Projekte \xe4ndern."],"Runners|Runner is offline; it has never contacted this instance":["Runner ist offline; er hat diese Instanz noch nie kontaktiert"],"Runners|Runner is offline; last contact was %{runner_contact} ago":["Runner ist offline; letzter Kontakt war vor %{runner_contact}"],"Runners|Runner is older than %{elapsedTime} and has never contacted GitLab":["Runner ist \xe4lter als %{elapsedTime} und hat GitLab noch nie kontaktiert"],"Runners|Runner is online; last contact was %{runner_contact} ago":["Runner ist online; letzter Kontakt war vor %{runner_contact}"],"Runners|Runner is stale; it has never contacted this instance":["Runner ist inaktiv; er hat diese Instanz noch nie kontaktiert"],"Runners|Runner is stale; last contact was %{runner_contact} ago":["Runner ist inaktiv; letzter Kontakt war vor %{runner_contact}"],"Runners|Runner managers registered under this configuration are listed here. Register and start at least one runner manager.":["Runner-Manager, die unter dieser Konfiguration registriert sind, werden hier aufgelistet. Registriere und starte mindestens einen Runner-Manager."],"Runners|Runner performance insights":["Einblicke in die Leistung des Runners"],"Runners|Runner registration":["Runner-Registrierung"],"Runners|Runner unassigned from project.":["Runner wurde aus dem Projekt entfernt."],"Runners|Runner version management":["Runner Versionsverwaltung"],"Runners|Runners":["Runner"],"Runners|Runners are grouped when they have the same authentication token. This happens when you re-use a runner configuration in more than one runner manager. %{linkStart}How does this work?%{linkEnd}":["Runner werden gruppiert, wenn sie dasselbe Authentifizierungstoken haben. Dies geschieht, wenn du eine Runner-Konfiguration in mehr als einem Runner-Manager wiederverwendest. %{linkStart}Wie funktioniert das?%{linkEnd}"],"Runners|Runners are the agents that run your CI/CD jobs.":["Runner sind die Agenten, die deine CI/CD Jobs ausf\xfchren."],"Runners|Runners performance":["Runner Leistung"],"Runners|Running Jobs":["Laufende Jobs"],"Runners|Runs untagged jobs":["F\xfchrt Jobs ohne Tags aus"],"Runners|Save the Terraform script to a file":["Terraform-Skript in einer Datei speichern"],"Runners|Search description\u2026":["Beschreibung suchen\xa0\u2026"],"Runners|Security or compatibility upgrades are recommended.":["Es wird empfohlen, Sicherheits- oder Kompatibilit\xe4tsaktualisierungen durchzuf\xfchren."],"Runners|See more %{linkStart}installation methods and architectures%{linkEnd}.":["Siehe weitere %{linkStart}Installationsmethoden und Architekturen%{linkEnd}."],"Runners|Select all":["Alle ausw\xe4hlen"],"Runners|Select platform specifications to install GitLab Runner.":["W\xe4hle Plattformspezifikationen aus, um GitLab Runner zu installieren."],"Runners|Select projects to assign to this runner":["Projekte ausw\xe4hlen, die diesem Runner zugewiesen werden sollen"],"Runners|Select your preferred runner, then choose the capacity for the runner in the AWS CloudFormation console.":["W\xe4hle deinen bevorzugten Runner und dann die Kapazit\xe4t f\xfcr den Runner in der AWS CloudFormation Konsole aus."],"Runners|Separate multiple tags with a comma. For example, %{example}.":["Trenne mehrere Tags durch Kommata. Beispiel: %{example}."],"Runners|Setup instructions":["Einrichtungsanweisungen"],"Runners|Show %{count} more tags":["%{count} weitere Tags anzeigen"],"Runners|Show only inherited":["Nur geerbte anzeigen"],"Runners|Show runner installation and registration instructions":["Installations- und Registrierungsanleitung f\xfcr Runner anzeigen"],"Runners|Something went wrong while deleting. Please refresh the page to try again.":["Beim L\xf6schen ist etwas schief gelaufen. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Runners|Something went wrong while fetching runner data.":["Beim Abrufen der Runner-Daten ist etwas schiefgegangen."],"Runners|Something went wrong while fetching the tags suggestions":["Beim Abrufen der Tag-Vorschl\xe4ge ist etwas schiefgelaufen"],"Runners|Something went wrong while pausing. Please refresh the page to try again.":["Beim Anhalten ist etwas schief gelaufen. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Runners|Something went wrong while unpausing. Please refresh the page to try again.":["Beim Aufheben des Anhaltens ist etwas schief gelaufen. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Runners|Specific Image for the Nodes in the Node Pool to use":["Spezifisches Image f\xfcr die zu verwendenden Knoten im Knoten-Pool"],"Runners|Specific geographical location where you can run your resources.":["Bestimmter geografischer Standort, an dem du deine Ressourcen ausf\xfchren kannst."],"Runners|Stale":["inaktiv"],"Runners|Status":["Status"],"Runners|Step 1":["Schritt 1"],"Runners|Step 2":["Schritt 2"],"Runners|Step 3 (optional)":["Schritt 3 (optional)"],"Runners|Still using registration tokens?":["Benutzt Du immer noch Registrierungstoken?"],"Runners|Stop the runner from accepting new jobs.":["Halte den Runner davon ab, neue Jobs anzunehmen."],"Runners|Support for registration tokens is deprecated":["Unterst\xfctzung f\xfcr Registrierungs-Token ist veraltet"],"Runners|System ID":["System-ID"],"Runners|Tags":["Tags"],
"Runners|The %{boldStart}runner authentication token%{boldEnd} %{token} displays here %{boldStart}for a short time only%{boldEnd}. After you register the runner, this token is stored in the %{codeStart}config.toml%{codeEnd} and cannot be accessed again from the UI.":["Das %{boldStart}Runner-Authentifizierungstoken%{boldEnd} %{token} wird hier %{boldStart}nur f\xfcr kurze Zeit%{boldEnd} angezeigt. Nachdem du den Runner registriert hast, wird dieses Token in %{codeStart}config.toml%{codeEnd} gespeichert und kann nicht mehr \xfcber die Benutzeroberfl\xe4che aufgerufen werden."],"Runners|The %{boldStart}runner authentication token%{boldEnd} is no longer visible, it is stored in the %{codeStart}config.toml%{codeEnd} if you have registered the runner.":["Das %{boldStart}Runner-Authentifizierungstoken%{boldEnd} ist nicht mehr sichtbar. Es wird in %{codeStart}config.toml%{codeEnd} gespeichert, wenn du den Runner registriert hast."],"Runners|The ID of the machine hosting the runner.":["Die ID der Maschine, die den Runner hostet."],"Runners|The deployment name is invalid":["Der Bereitstellungsname ist ung\xfcltig"],"Runners|The name of node pool":["Der Name des Knoten-Pools"],"Runners|The project, group or instance where the runner was registered. Instance runners are always owned by Administrator.":["Das Projekt, die Gruppe oder die Instanz, in der der Runner registriert wurde. Runner der Instanz sind immer im Besitz des/der Administrator(in)."],"Runners|The runner authentication token displays here %{boldStart}for a short time only%{boldEnd}. After you register the runner, this token is stored in the %{codeStart}config.toml%{codeEnd} and cannot be accessed again from the UI.":["Der Runner-Authentifizierungstoken wird hier %{boldStart}nur f\xfcr kurze Zeit%{boldEnd} angezeigt. Nachdem du den Runner registriert hast, wird dieses Token in %{codeStart}config.toml%{codeEnd} gespeichert und kann nicht mehr \xfcber die Benutzeroberfl\xe4che aufgerufen werden."],"Runners|The runner authentication token is invalid":["Das Runner-Authentifizierungstoken ist ung\xfcltig"],"Runners|The runner will be permanently deleted and no longer available for projects or groups in the instance. Are you sure you want to continue?":["Der Runner wird dauerhaft gel\xf6scht und wird f\xfcr Projekte oder Gruppen in der Instanz nicht mehr verf\xfcgbar sein. M\xf6chtest du wirklich fortfahren?","%d Runner werden dauerhaft gel\xf6scht und werden f\xfcr Projekte oder Gruppen in der Instanz nicht mehr verf\xfcgbar sein. M\xf6chtest du wirklich fortfahren?"],"Runners|The time it takes for a group runner assigned to this group to pick up a job. Jobs waiting for runners are in the pending state.":["Die Zeit, die ein Gruppen-Runner, der dieser Gruppe zugewiesen ist, ben\xf6tigt, um einen Job aufzunehmen. Jobs, die auf Runner warten, befinden sich im Status \u201eAusstehend\u201c."],"Runners|The time it takes for an instance runner to pick up a job. Jobs waiting for runners are in the pending state.":["Die Zeit, die ein Instanz-Runner ben\xf6tigt, um einen Job aufzunehmen. Jobs, die auf Runner warten, befinden sich im Status \u201eAusstehend\u201c."],"Runners|The user is not allowed to create a runner":["Der/Die Benutzer(in) ist nicht berechtigt, einen Runner zu erstellen"],"Runners|The user is not allowed to provision a GKE runner":["Der/Die Benutzer(in) ist nicht berechtigt, einen GKE-Runner bereitzustellen"],"Runners|The user is not allowed to provision a cloud runner":["Der/Die Benutzer(in) ist nicht berechtigt, einen Cloud-Runner bereitzustellen"],"Runners|There are no recent runner failures for your instance runners. Error messages will populate here if runners fail.":["Es gibt keine aktuellen Runner-Fehler f\xfcr deine Instanz-Runner. Wenn Runner fehlschlagen, werden hier Fehlermeldungen angezeigt."],"Runners|There are no runners running jobs right now. Active runners will populate here as they pick up jobs.":["Es gibt derzeit keine Runner, die Jobs ausf\xfchren. Aktive Runner werden hier angezeigt, wenn sie Jobs \xfcbernehmen."],"Runners|These setup instructions use your specifications and follow the best practices for performance and security.":["Diese Einrichtungsanleitung verwendet deine Spezifikationen und befolgt die bew\xe4hrten Methoden f\xfcr Performance und Sicherheit."],"Runners|This group currently has 1 stale runner.":["Diese Gruppe hat derzeit 1 inaktiven Runner.","Diese Gruppe hat derzeit %d inaktive Runner."],"Runners|This group currently has no stale runners.":["Diese Gruppe hat derzeit keine inaktiven Runner."],"Runners|This instance does not have any instance runners yet.":["Die Instanz besitzt noch keine Instanz-Runner"],"Runners|This may not be needed if you manage your runner as a %{linkStart}system or user service%{linkEnd}.":["Dies ist unter Umst\xe4nden nicht erforderlich, wenn du deinen Runner als %{linkStart}System- oder Benutzerdienst%{linkEnd} verwaltest."],"Runners|This runner has not run any jobs":["Dieser Runner hat noch keine Jobs ausgef\xfchrt"],"Runners|This runner is outdated, an upgrade is recommended":["Dieser Runner ist veraltet, ein Upgrade wird empfohlen"],"Runners|To add them, select %{strongStart}Create project runner%{strongEnd}.":["Um sie hinzuzuf\xfcgen, w\xe4hle %{strongStart}Projekt-Runner erstellen%{strongEnd} aus."],"Runners|To install Runner in Kubernetes follow the instructions described in the GitLab documentation.":["Um Runner in Kubernetes zu installieren, befolge die Anweisungen in der GitLab-Dokumentation."],"Runners|To install Runner in a container follow the instructions described in the GitLab documentation":["Um Runner in einem Container zu installieren, befolge die Anweisungen in der GitLab-Dokumentation"],"Runners|To move to the next step, add at least one tag and/or enable the runner to pick up untagged jobs.":["Um mit dem n\xe4chsten Schritt fortzufahren, f\xfcgen mindestens ein Tag hinzu und/oder erm\xf6gliche dem Runner, nicht getaggte Jobs aufzunehmen."],"Runners|To register new runners, contact your administrator.":["Kontaktiere Deinen Administrator, um neue Runner zu registrieren."],"Runners|To register them, go to the %{linkStart}group's Runners page%{linkEnd}.":["Um sie zu registrieren, gehe auf die %{linkStart}Seite der Runner dieser Gruppe%{linkEnd}."],"Runners|To set up an autoscaling fleet of runners on Google Cloud, you can use the following recommended setup or %{linkStart}customize the Terraform configuration%{linkEnd}.":["Um eine Runner-Flotte mit Autoscaling in Google Cloud einzurichten, kannst du das folgende empfohlene Setup verwenden oder die %{linkStart}Terraform-Konfiguration anpassen%{linkEnd}."],"Runners|To view the runner, go to %{runnerListName}.":["Um den Runner anzuzeigen, gehe zu %{runnerListName}."],"Runners|To view the setup instructions, complete the previous form.":["Um die Einrichtungsanweisungen anzuzeigen, f\xfclle das vorherige Formular aus."],"Runners|To view the setup instructions, complete the previous form. The instructions help you set up an autoscaling fleet of runners to execute your CI/CD jobs in Google Cloud.":["Um die Einrichtungsanweisungen anzuzeigen, f\xfclle das vorherige Formular aus. Die Anweisungen helfen dir, eine Autoscaling-Flotte von Runnern einzurichten, um deine CI/CD-Jobs in Google Cloud auszuf\xfchren."],"Runners|To view the setup instructions, make sure all form fields are completed and correct.":["Um die Einrichtungsanweisungen anzuzeigen, stelle sicher, dass alle Formularfelder korrekt ausgef\xfcllt sind."],"Runners|Token expiry":["Token-Ablauf"],"Runners|Token rotation deadline has passed":[""],"Runners|Top projects consuming group runners":["Top-Projekte, die Gruppen-Runner verbrauchen"],"Runners|Top projects consuming runners":["Top-Projekte, die Runner verbrauchen"],"Runners|Turn on group runners for this project":["Gruppen-Runner f\xfcr dieses Projekt aktivieren"],"Runners|Turn on instance runners for this project":["Instanz-Runner f\xfcr dieses Projekt aktivieren"],"Runners|UTC Time":["UTC-Zeit"],"Runners|Unassign":["Zuweisung aufheben"],"Runners|Unassign runner %{name}?":["Runner %{name} die Zuweisung entziehen?"],"Runners|Understand how long it takes for runners to pick up a job. %{linkStart}How is this calculated?%{linkEnd}":["Finde heraus, wie lange es dauert, bis Runner einen Job annehmen. %{linkStart}Wie wird dieser Wert berechnet?%{linkEnd}"],"Runners|Unpause selected":["Anhalten der ausgew\xe4hlten aufheben"],"Runners|Unselect all":["Alle abw\xe4hlen"],"Runners|Up to date":["Aktuell"],"Runners|Upgrade Status":["Upgrade-Status"],"Runners|Upgrade available":["Upgrade verf\xfcgbar"],"Runners|Upgrade recommended":["Upgrade empfohlen"],"Runners|Usage (min)":["Verwendung (Minuten)"],"Runners|Use Terraform to create the required infrastructure in Google Cloud, install GitLab Runner, and register it to this GitLab project.":["Verwende Terraform, um die erforderliche Infrastruktur in Google Cloud zu erstellen, GitLab Runner zu installieren und in diesem GitLab-Projekt zu registrieren."],"Runners|Use the dashboard to view performance statistics of your runner fleet.":["Verwende das Dashboard, um Performance-Statistiken deiner Runner-Flotte anzuzeigen."],"Runners|Use the runner for jobs without tags in addition to tagged jobs.":["Den Runner zus\xe4tzlich zu getaggten Jobs auch f\xfcr Jobs ohne Tags benutzen."],"Runners|Use the runner for the currently assigned projects only. Only administrators can change the assigned projects.":["Diesen Runner nur f\xfcr derzeit zugewiesene Projekte verwenden. Nur Administratoren k\xf6nnen die zugewiesenen Projekte \xe4ndern."],"Runners|Use the runner on pipelines for protected branches only.":["Diesen Runner nur f\xfcr Pipelines gesch\xfctzter Branches verwenden."],"Runners|Version":["Version"],"Runners|Version %{version}":["Version %{version}"],"Runners|Version starts with":["Version beginnt mit"],"Runners|View installation instructions":["Installationsanleitungen anzeigen"],"Runners|View instructions in %{helpLink}.":["Anweisungen in %{helpLink} anzeigen."],"Runners|View metrics":["Metriken anzeigen"],"Runners|View runners":["Runner anzeigen"],"Runners|View runners list":["Liste der Runner anzeigen"],"Runners|Wait time (secs)":["Wartezeit (Sek.)"],"Runners|Wait time to pick a job":["Wartezeit, bis ein Job aufgenommen wird"],"Runners|Windows 2019 Shell with manual scaling and optional scheduling. %{percentage} spot.":["Windows 2019 Shell mit manueller Skalierung und optionalem Scheduling. %{percentage} Spot."],"Runners|Windows 2019 Shell with manual scaling and optional scheduling. Non-spot.":["Windows 2019 Shell mit manueller Skalierung und optionaler Zeitplanung. Non-spot."],"Runners|Yes, disable instance runners":["Ja, Instanz-Runner deaktivieren"],"Runners|Yes, start deleting stale runners":["Ja, das L\xf6schen von inaktiven Runnern starten"],"Runners|You may lose access to the runner token if you leave this page.":["Du kannst den Zugriff auf das Runner-Token verlieren, wenn du diese Seite verl\xe4sst."],"Runners|You've registered a new runner!":["Du hast einen neuen Runner registriert."],"Runners|You've registered a new runner! Your runner is online and ready to run jobs.":["Du hast einen neuen Runner registriert! Dein Runner ist online und kann jetzt Auftr\xe4ge ausf\xfchren."],"Runners|Your runner is online and ready to run jobs.":["Dein Runner ist online und bereit, Jobs auszuf\xfchren."],"Runners|Zone":["Zone"],"Runners|Zone help":["Zonenhilfe"],"Runners|Zone is required.":["Zone ist erforderlich."],"Runners|Zone must have the right format.":["Zone muss das richtige Format haben."],"Runners|documentation":["Dokumentation"],"Runners|token_expires_at is required when token_rotation_deadline is specified":[""],"Runners|token_expires_at is too far in the future (maximum is %{maximum})":[""],"Runners|token_expires_at must be a valid time":[""],"Runners|token_expires_at must be at least %{minimum} in the future":[""],"Runners|token_rotation_deadline cannot be in the past":[""],"Runners|token_rotation_deadline must be a valid time":[""],"Runners|token_rotation_deadline must be less than or equal to token_expires_at":[""],"Runner|1 day selected":["1 Tag ausgew\xe4hlt","%d Tage ausgew\xe4hlt"],"Runner|Assign to project":["Zu Projekt zuweisen"],"Runner|Assigned Projects":["Zugewiesene Projekte"],"Runner|Export runner usage":["Runner-Nutzung exportieren"],"Runner|Export runner usage for selected dates":["Runner-Nutzung f\xfcr ausgew\xe4hlte Daten exportieren"],"Runner|Failed to assign runner to project.":["Die Zuweisung des Runners zum Projekt ist fehlgeschlagen."],"Runner|Failed to unassign runner from project.":["Das Aufheben der Zuweisung des Runners zum Projekt ist fehlgeschlagen."],"Runner|Runner actions":["Runner-Aktionen"],"Runner|Something went wrong while generating the CSV export. Please try again.":["Beim Generieren des CSV-Exports ist etwas schiefgelaufen. Bitte versuche es erneut."],"Runner|The CSV export contains a list of projects, the number of minutes used by instance runners, and the number of jobs that ran. When the export is completed, it is sent as an attachment to your email.":["Der CSV-Export enth\xe4lt eine Liste der Projekte, die Anzahl der Minuten, die von Instanz-Runnern verwendet werden, und die Anzahl der Jobs, die ausgef\xfchrt wurden. Wenn der Export abgeschlossen ist, wird er als Anhang an deine E-Mail-Adresse gesendet."],"Runner|The runner will be unassigned from this project. Depending on your permissions for this runner, you might not be able to assign it again. Are you sure you want to continue?":["Dem Runner wird die Zuweisung zu diesem Projekt entzogen. Abh\xe4ngig von deinen Berechtigungen f\xfcr diesen Runner kannst du ihn m\xf6glicherweise nicht erneut zuweisen. Bist du sicher, dass du fortfahren m\xf6chtest?"],"Runner|Unassign from project":["Zuweisung zum Projekt aufheben"],"Runner|Unassign runner from project":["Runner-Zuweisung zum Projekt aufheben"],"Runner|Your CSV export has started. It will be sent to your email inbox when its ready.":["Dein CSV-Export hat begonnen. Er wird an deinen E-Mail-Posteingang gesendet, wenn er abgeschlossen wurde."],Running:["Laufend"],"Runs a number of housekeeping tasks within the current repository, such as compressing file revisions and removing unreachable objects.":["F\xfchrt eine Reihe von Bereinigungsaufgaben im aktuellen Projekt-Repository aus, z.\xa0B. das Komprimieren von Dateirevisionen und das Entfernen nicht erreichbarer Objekte."],SAML:["SAML"],"SAML SSO":["SAML-SSO"],"SAML discovery tokens":["SAML-Discovery-Token"],"SAML group membership settings":["Einstellungen der SAML-Gruppenmitgliedschaft"],"SAML single sign-on":["SAML Single Sign-On"],"SAML single sign-on for %{group_name}":["SAML Single Sign-on f\xfcr %{group_name}"],"SAML|Please, reload the page and sign in again, if necessary. To avoid data loss, if you have unsaved edits, dismiss the modal and copy the unsaved text before refreshing the page.":["Bitte lade die Seite neu und melde dich gegebenenfalls erneut an. Um Datenverlust zu vermeiden, schlie\xdfe das Modal und kopiere den nicht gespeicherten Text, bevor du die Seite aktualisierst, falls du ungespeicherte \xc4nderungen hast."],"SAML|Sign in to %{groupName}":["Bei %{groupName} anmelden"],"SAML|The %{strongOpen}%{group_path}%{strongClose} group allows you to sign in using single sign-on.":["Die %{strongOpen}%{group_path}%{strongClose} Gruppe erlaubt es Dir, sich mit Single Sign-on anzumelden."],"SAML|The SAML response did not contain an email address. Either the SAML identity provider is not configured to send the attribute, or the identity provider directory does not have an email address value for your user.":["Die SAML-Antwort enthielt keine E-Mail-Adresse. Entweder ist der SAML-Identit\xe4tsanbieter nicht zum Senden des Attributs konfiguriert, oder das Identit\xe4tsanbieterverzeichnis enth\xe4lt keinen E-Mail-Adresswert f\xfcr deine(n) Benutzer(in)."],"SAML|There is already a GitLab account associated with this email address. Sign in with your existing credentials to connect your organization's account":["Es ist bereits ein GitLab-Konto mit dieser E-Mail-Adresse verbunden. Melde dich mit deinen vorhandenen Zugangsdaten an, um das Konto deiner Organisation zu verbinden"],"SAML|To access %{groupName}, you must sign in using single sign-on through an external sign-in page.":["Um auf %{groupName} zuzugreifen, musst Du dich mit Single Sign-on \xfcber eine externe Anmeldeseite einloggen."],"SAML|To allow %{strongOpen}%{group_name}%{strongClose} to manage your GitLab account %{strongOpen}%{username}%{strongClose} (%{email}) after you sign in successfully using single sign-on, select %{strongOpen}Authorize%{strongClose}.":["Melde dich mit Single Sign-On an und w\xe4hle dann %{strongOpen}Autorisieren%{strongClose}, um %{strongOpen}%{group_name}%{strongClose} die Verwaltung deines GitLab-Kontos %{strongOpen}%{username}%{strongClose} (%{email}) zu erlauben."],"SAML|Your SAML session has expired":["Deine SAML-Sitzung ist abgelaufen"],"SAML|Your organization's SSO has been connected to your GitLab account":["Das SSO deiner Organisation wurde mit deinem GitLab-Konto verbunden"],SAST:["SAST"],"SAST configuration":["SAST-Konfiguration"],"SBOMs last updated":["Zuletzt aktualisierte SBOMs"],"SCIM|SCIM Token":["SCIM-Token"],"SCIM|System for Cross-Domain Identity Management.":["System f\xfcr domain\xfcbergreifende Identit\xe4tsverwaltung"],SHA256:["SHA256"],"SOC 2":["SOC\xa02"],SOC2:["SOC2"],SSH:["SSH"],"SSH Key":["SSH-Schl\xfcssel"],"SSH Keys":["SSH-Schl\xfcssel"],"SSH Keys Help":["Hilfe zu SSH-Schl\xfcsseln"],"SSH fingerprints verify that the client is connecting to the correct host. Check the %{config_link_start}current instance configuration%{config_link_end}.":["SSH-Fingerabdr\xfccke stellen sicher, dass sich der Client mit dem korrekten Host verbindet. \xdcberpr\xfcfe die %{config_link_start}aktuelle Konfiguration der Instanz%{config_link_end}."],"SSH host key fingerprints":["SSH-Hostschl\xfcssel-Fingerabdr\xfccke"],"SSH host keys":["SSH-Hostschl\xfcssel"],"SSH host keys are not available on this system. Please use %{ssh_keyscan} command or contact your GitLab administrator for more information.":["SSH-Hostschl\xfcssel sind auf diesem System nicht verf\xfcgbar. Verwende den Befehl %{ssh_keyscan} oder wende dich an deine(n) GitLab-Administrator(in), um weitere Informationen zu erhalten."],"SSH key":["SSH-Schl\xfcssel"],"SSH key fingerprint:":["SSH-Schl\xfcssel Fingerabdruck:"],"SSH key was added to your account":["SSH-Schl\xfcssel wurde deinem Konto hinzugef\xfcgt"],"SSH keys":["SSH-Schl\xfcssel"],"SSH keys allow you to establish a secure connection between your computer and GitLab.":["Mit SSH-Schl\xfcsseln kannst du eine sichere Verbindung zwischen deinem Computer und GitLab herstellen."],"SSH keys with the following fingerprints are scheduled to expire soon. Expired SSH keys can not be used:":["SSH-Schl\xfcssel mit den folgenden Fingerprints laufen in K\xfcrze ab. Abgelaufene SSH-Schl\xfcssel k\xf6nnen nicht verwendet werden:"],"SSH keys with the following fingerprints have expired and can no longer be used:":["SSH-Schl\xfcssel mit den folgenden Fingerprints sind abgelaufen und k\xf6nnen nicht mehr verwendet werden:"],"SSH public key":["\xd6ffentlicher SSH-Schl\xfcssel"],"SSHKey|Authentication":["Authentifikation"],"SSHKey|Authentication & Signing":["Authentifikation & Signierung"],"SSHKey|Signing":["Siginierung"],"SSL Verification:":["SSL Verifizierung:"],"SSL verification":["SSL-Verifizierung"],"SSO for GitLab.com groups":["SSO f\xfcr GitLab.com-Gruppen"],Sat:["Sa"],Satisfied:["Zufrieden"],Saturday:["Samstag"],Save:["Speichern"],"Save %{name} size limits":["Gr\xf6\xdfenlimits f\xfcr %{name} speichern"],"Save Changes":["\xc4nderungen speichern"],"Save application":["Anwendung speichern"],"Save changes":["\xc4nderungen speichern"],"Save changes before testing":["\xc4nderungen vor dem Testen speichern"],"Save changes for GitLab Duo":[""],"Save changes for Service Desk":[""],"Save changes for default description template for issues":[""],"Save changes for naming, description, topics":[""],"Save changes for visibility, project features, permissions":[""],"Save comment":["Kommentar speichern"],"Save deploy freeze":["Bereitstellungssperre speichern"],"Save internal note":["Interne Notiz speichern"],"Save password":["Passwort speichern"],"Save views with your preferred filters and display options to plan and track work easier. Add views shared by your team or create your own.":["Du kannst deine bevorzugten Filter und Anzeigeoptionen als Ansichten speichern, damit du deine Arbeit einfacher planen und verfolgen kannst. F\xfcgen Ansichten hinzu, die Teammitglieder geteilt haben, oder erstelle deine eigenen."],"Saved views are not enabled for this namespace.":["Gespeicherte Ansichten sind f\xfcr diesen Namensraum nicht aktiviert."],Saving:["Speichern"],"Saving project.":["Projekt wird gespeichert."],"SbomErrors|Error parsing SBOM reports":["Fehler beim Parsen von SBOM-Berichten"],"SbomErrors|Learn more":[""],"SbomErrors|Please investigate the provided reports and ensure they conform to %{helpPageLinkStart}the requirements for SBOM documents%{helpPageLinkEnd}.":["Bitte untersuche die bereitgestellten Berichte und stelle sicher, dass sie %{helpPageLinkStart}den Anforderungen f\xfcr SBOM-Dokumente%{helpPageLinkEnd} entsprechen."],"SbomErrors|The following SBOM reports could not be parsed. Therefore the list of components may be incomplete.":["Die folgenden SBOM-Berichte konnten nicht geparst werden. Daher ist die Liste der Komponenten m\xf6glicherweise unvollst\xe4ndig."],"SbomErrors|report-%{index} (%{length})":["report-%{index} (%{length})"],"Scan pushed document contents for policy breaks. %{docs_link}":["\xdcberpr\xfcfe gepushte Dokumentinhalte auf Richtlinienverst\xf6\xdfe. %{docs_link}"],"ScanExecutionPolicy|%{boldStart}inject_ci%{boldEnd} strategy was deprecated. It was replaced by %{boldStart}inject_policy%{boldEnd} which enforces custom stages. %{linkStart}Learn more%{linkEnd}.":["Die Strategie %{boldStart}inject_ci%{boldEnd} wurde eingestellt. Sie wurde durch %{boldStart}inject_policy%{boldEnd} ersetzt, die benutzerdefinierte Phasen erzwingt. %{linkStart}Mehr erfahren%{linkEnd}."],"ScanExecutionPolicy|%{hostname}'s timezone":["Zeitzone von %{hostname}"],"ScanExecutionPolicy|%{labelStart}File path:%{labelEnd} %{filePath}":["%{labelStart}Dateipfad:%{labelEnd} %{filePath}"],"ScanExecutionPolicy|%{rules} actions for %{scopes} %{branches} %{agents} %{branchExceptions} %{namespaces} %{period}":["%{rules} Aktionen f\xfcr %{scopes} %{branches} %{agents} %{branchExceptions} %{namespaces} %{period}"],"ScanExecutionPolicy|%{rules} every time a pipeline runs that %{scopes} %{branches} using %{sources} %{branchExceptions} %{agents} %{namespaces}":["%{rules} jedes Mal, wenn eine Pipeline f\xfcr %{scopes} %{branches} mit %{sources} %{branchExceptions} %{agents} %{namespaces} ausgef\xfchrt wird"],"ScanExecutionPolicy|%{strategySelector} pipeline file to run from %{projectSelector}":["Pipeline-Datei %{strategySelector}, zur Ausf\xfchrung in %{projectSelector}"],"ScanExecutionPolicy|%{strategySelector}into the %{boldStart}.gitlab-ci.yml%{boldEnd} with the following %{boldStart}pipeline execution file%{boldEnd} from %{projectSelector}":["%{strategySelector}in die %{boldStart}.gitlab-ci.yml%{boldEnd} mit der folgenden %{boldStart}Pipeline-Ausf\xfchrungsdatei%{boldEnd} aus %{projectSelector}"],"ScanExecutionPolicy|%{strategySelector}the %{boldStart}.gitlab-ci.yml%{boldEnd} with the following %{boldStart}pipeline execution file%{boldEnd} from %{projectSelector}":["%{strategySelector}die %{boldStart}.gitlab-ci.yml%{boldEnd} mit der folgenden %{boldStart}Pipeline-Ausf\xfchrungsdatei %{boldEnd} aus %{projectSelector}"],"ScanExecutionPolicy|A runner will be selected automatically from those available.":["Aus den verf\xfcgbaren Runnern wird automatisch einer ausgew\xe4hlt."],"ScanExecutionPolicy|A time window is not set. Setting a time window helps distribute scheduled scans and reduces the load on runner infrastructure. We recommend a time window of at least 6 hours.":["Es wurde kein Zeitfenster festgelegt. Lege ein Zeitfenster fest, um die Verteilung geplanter Scans zu erleichtern und die Last der Runner-Infrastruktur zu reduzieren. Wir empfehlen ein Zeitfenster von mindestens 6\xa0Stunden."],"ScanExecutionPolicy|Add new CI variable":["Neue CI-Variable hinzuf\xfcgen"],"ScanExecutionPolicy|Add new CI variables":["Neue CI-Variablen hinzuf\xfcgen"],"ScanExecutionPolicy|Add new condition":["Neue Bedingung hinzuf\xfcgen"],"ScanExecutionPolicy|Are you sure you want to create merge request for this policy?":["M\xf6chtest du wirklich eine Merge-Anfrage f\xfcr diese Richtlinie erstellen?"],"ScanExecutionPolicy|Back to edit policy":["Zur\xfcck zum Bearbeiten der Richtlinie"],"ScanExecutionPolicy|Conditions":["Bedingungen"],"ScanExecutionPolicy|Create merge request":["Merge Request erstellen"],"ScanExecutionPolicy|Create new scan profile":["Neues Scanprofil erstellen"],"ScanExecutionPolicy|Create new site profile":["Neues Siteprofil erstellen"],"ScanExecutionPolicy|Customized CI variables:":["Benutzerdefinierte CI-Variablen:"],"ScanExecutionPolicy|Customized variables will overwrite ones defined in the project CI/CD file and settings":["Benutzerdefinierte Variablen \xfcberschreiben diejenigen, die in der CI/CD-Datei und den Einstellungen des Projekts definiert sind."],"ScanExecutionPolicy|DAST scan profiles":["DAST-Scanprofile"],"ScanExecutionPolicy|DAST site profiles":["DAST-Siteprofile"],"ScanExecutionPolicy|File reference (Optional) %{refSelector}":["Dateireferenz (optional) %{refSelector}"],"ScanExecutionPolicy|Ignore default CI configuration for before/after script":["Standard-CI-Konfiguration vor/nach Skript ignorieren"],"ScanExecutionPolicy|Inject":["Injizieren"],"ScanExecutionPolicy|Inject without custom stages":["Injektion ohne benutzerdefinierte Phasen"],"ScanExecutionPolicy|Key":["Schl\xfcssel"],"ScanExecutionPolicy|Kubernetes agent's timezone":["Zeitzone des Kubernetes-Agenten"],"ScanExecutionPolicy|Link existing CI file":["Verlinke eine vorhandene CI-Datei"],"ScanExecutionPolicy|Maximum number of CI-criteria is one":["Die maximale Anzahl von CI-Kriterien ist eins."],"ScanExecutionPolicy|Only one variable can be added at a time.":["Es kann immer nur eine Variable auf einmal hinzugef\xfcgt werden."],"ScanExecutionPolicy|Override":["\xdcberschreiben"],"ScanExecutionPolicy|Potential overload for infrastructure":["Potenzielle \xdcberlastung der Infrastruktur"],"ScanExecutionPolicy|Prevents project before script and after script from interfering with scan execution.":["Verhindert, dass Projekte vor dem Skript und nach dem Skript die Scanausf\xfchrung beeintr\xe4chtigen."],"ScanExecutionPolicy|Run %{scan} with the following options:":["F\xfchre %{scan} mit den folgenden Optionen aus:"],"ScanExecutionPolicy|Run a %{scan} scan with the following options:":["F\xfchre einen %{scan}-Scan mit den folgenden Optionen aus:"],"ScanExecutionPolicy|Runner tags:":["Runner-Tags:"],"ScanExecutionPolicy|Schedule rule component":["Regelkomponente planen"],"ScanExecutionPolicy|Schedules:":["Zeitpl\xe4ne:"],"ScanExecutionPolicy|Select a scanner":["W\xe4hle einen Scanner"],"ScanExecutionPolicy|Select agent":["Agent ausw\xe4hlen"],"ScanExecutionPolicy|Select branches":["Branches ausw\xe4hlen"],"ScanExecutionPolicy|Select namespaces":["Namensr\xe4ume ausw\xe4hlen"],"ScanExecutionPolicy|Select or Create a Key":["Einen Schl\xfcssel ausw\xe4hlen oder erstellen"],"ScanExecutionPolicy|Select project first, and then insert a file path":["W\xe4hle zuerst das Projekt aus und f\xfcge dann einen Dateipfad ein"],"ScanExecutionPolicy|Select ref":["Ref ausw\xe4hlen"],"ScanExecutionPolicy|Select scanner profile":["Scanner-Profil ausw\xe4hlen"],"ScanExecutionPolicy|Select site profile":["Site-Profil ausw\xe4hlen"],"ScanExecutionPolicy|Select timezone":["W\xe4hle die Zeitzone"],"ScanExecutionPolicy|The content of this pipeline execution YAML file is injected into the .gitlab-ci.yml file of the target project. All GitLab CI/CD features are supported.":["Der Inhalt dieser Pipeline-Ausf\xfchrungs-YAML-Datei ist in der Datei .gitlab-ci.yml des Zielprojekts enthalten. Alle GitLab CI/CD-Funktionen werden unterst\xfctzt."],"ScanExecutionPolicy|The content of this pipeline execution YAML file is injected into the .gitlab-ci.yml file of the target project. Custom stages used in the pipeline execution YAML are ignored, unless they are defined in the `.gitlab-ci.yml` file of the target project. All GitLab CI/CD features are supported.":["Der Inhalt dieser YAML-Datei der Pipelineausf\xfchrung wird in die Datei .gitlab-ci.yml des Zielprojekts eingef\xfcgt. Benutzerdefinierte Phasen, die in der YAML-Datei der Pipelineausf\xfchrung verwendet werden, werden ignoriert, es sei denn, sie sind in der Datei `.gitlab-ci.yml` des Zielprojekts definiert. Alle Funktionen von GitLab CI/CD werden unterst\xfctzt."],"ScanExecutionPolicy|The content of this pipeline execution YAML file of the target project is run at the scheduled time. All GitLab CI/CD features are supported.":["Der Inhalt dieser YAML-Datei f\xfcr die Pipeline-Ausf\xfchrung des Zielprojekts wird zum geplanten Zeitpunkt ausgef\xfchrt. Alle GitLab CI/CD-Funktionen werden unterst\xfctzt."],"ScanExecutionPolicy|The content of this pipeline execution YAML file overrides the .gitlab-ci.yml file of the target project. All GitLab CI/CD features are supported.":["Der Inhalt dieser YAML-Datei f\xfcr die Pipeline-Ausf\xfchrung \xfcberschreibt die Datei .gitlab-ci.yml des Zielprojekts. Alle GitLab CI/CD-Funktionen werden unterst\xfctzt."],"ScanExecutionPolicy|The file at that project, ref, and path doesn't exist":["Die Datei in diesem Projekt, Ref und Pfad existiert nicht"],"ScanExecutionPolicy|The file path can't be empty":["Der Dateipfad darf nicht leer sein"],"ScanExecutionPolicy|This is a required variable for this scanner and cannot be removed.":["Dies ist eine f\xfcr diesen Scanner erforderliche Variable, die nicht entfernt werden kann."],"ScanExecutionPolicy|This scan execution policy will generate a large number of pipelines, which can have a significant performance impact. To reduce potential performance issues, consider creating separate policies for smaller subsets of projects.":["Diese Scanausf\xfchrungsrichtlinie generiert eine gro\xdfe Anzahl von Pipelines, was erhebliche Auswirkungen auf die Performance haben kann. Um potenzielle Performance-Probleme zu reduzieren, solltest du die Erstellung separater Richtlinien f\xfcr kleinere Teilmengen von Projekten in Erw\xe4gung ziehen."],"ScanExecutionPolicy|Triggers:":["Trigger:"],"ScanExecutionPolicy|Use a custom key":["Einen benutzerdefinierten Schl\xfcssel verwenden"],"ScanExecutionPolicy|Value":["Wert"],"ScanExecutionPolicy|agent":["Agent"],"ScanExecutionPolicy|at the following times: %{period} %{days} around %{time} %{timezone}, run for: %{duration}, %{timezoneLabel}":["zu folgenden Zeiten: %{period} %{days} um %{time} %{timezone}, ausf\xfchren f\xfcr: %{duration}, %{timezoneLabel}"],"ScanExecutionPolicy|branch":["Branch"],"ScanExecutionPolicy|file path group":["Dateipfadgruppe"],"ScanExecutionPolicy|has specific tag":["hat ein bestimmtes Tag"],"ScanExecutionPolicy|in namespaces":["in Namensr\xe4umen"],"ScanExecutionPolicy|on %{hostname}":["auf %{hostname}"],"ScanExecutionPolicy|on the Kubernetes agent pod":["auf dem Kubernetes Agent-Pod"],"ScanExecutionPolicy|selected automatically":["Automatisch ausgew\xe4hlt"],"ScanProfiles|A scan is automatically run each time new commits are pushed to a branch associated with an open merge request. The full repository is scanned, but only vulnerabilities introduced by the merge request are highlighted. This helps identify security issues early, before code is merged.":[""],"ScanProfiles|A scan is automatically run when changes are merged or pushed to the default branch. All vulnerabilities found are reported, providing a complete picture of your default branch's security posture.":[""],"ScanProfiles|All":[""],"ScanProfiles|All vulnerabilities":[""],"ScanProfiles|Apply profile":["Profil anwenden"],
"ScanProfiles|Block secrets such as keys and API tokens from being pushed to your repositories. Secret detection is triggered when commits are pushed to a repository. If any secrets are detected, the push is blocked.":["Verhindere, dass Geheimnisse wie Schl\xfcssel und API-Token in deine Repositorys gepusht werden. Die Geheimniserkennung wird ausgel\xf6st, wenn Commits in ein Repository gepusht werden. Falls irgendwelche Geheimnisse entdeckt werden, wird der Push blockiert."],"ScanProfiles|Branch Pipelines (default only)":[""],"ScanProfiles|Configuration profiles are reusable settings templates for security tools. Create and manage profiles once, then apply them to multiple projects to ensure consistent security coverage.":["Konfigurationsprofile sind wiederverwendbare Einstellungsvorlagen f\xfcr Sicherheitstools. Du kannst Profile einmal erstellen und verwalten und anschlie\xdfend auf mehrere Projekte anwenden, um eine einheitliche Sicherheitsabdeckung sicherzustellen."],"ScanProfiles|Currently active":["Derzeit aktiv"],"ScanProfiles|Default":[""],"ScanProfiles|Full repository":[""],"ScanProfiles|General Details":["Allgemeine Details"],"ScanProfiles|Information about this configuration profile.":["Informationen \xfcber dieses Konfigurationsprofil."],"ScanProfiles|Merge Request Pipelines":[""],"ScanProfiles|New vulnerabilities only":[""],"ScanProfiles|Results:":[""],"ScanProfiles|Scan all Git push events and block pushes with detected secrets.":["Scanne alle Git-Push-Ereignisse und blockiere Pushes, in denen Geheimnisse erkannt wurden."],"ScanProfiles|Scan triggers":["Scan-Trigger"],"ScanProfiles|Scans commits to the default branch":[""],"ScanProfiles|Scans new commits to merge requests \xb7 All branches":[""],"ScanProfiles|Scope:":[""],"ScanProfiles|Secret detection profile":["Geheimnis-Erkennungs-Profil"],"ScanProfiles|Secret push protection":["Geheimnis-Push-Schutz"],"ScanProfiles|Target branch:":[""],"ScanProfiles|View documentation":["Dokumentation ansehen"],"ScanProfiles|View profile settings and associated projects.":["Sieh dir Profileinstellungen und zugeh\xf6rige Projekte an."],"ScanProfiles|What are configuration profiles?":["Was sind Konfigurationsprofile?"],"ScanProfiles|When and how scans are run.":["Wann und wie werden Scans ausgef\xfchrt?"],"ScanResultPolicy|%{boldStart}Warning:%{boldEnd} Using this status in strictly enforced policies can block merge requests even if there are no new vulnerabilities found in the latest scan. It's recommended that you use warn mode only with this status.":["%{boldStart}Warnung:%{boldEnd} Die Verwendung dieses Status f\xfcr Richtlinien, f\xfcr die \u201eStrenge Durchsetzung\u201c festgelegt ist, kann Merge Requests blockieren, auch wenn beim letzten Scan keine neuen Sicherheitsl\xfccken gefunden wurden. Es wird empfohlen, den Warnmodus nur mit diesem Status zu verwenden."],"ScanResultPolicy|%{count} licenses":["%{count} Lizenzen"],"ScanResultPolicy|%{listType} according to the %{buttonType}":["%{listType} gem\xe4\xdf %{buttonType}"],"ScanResultPolicy|%{operator} %{value} chance of exploration":["%{operator} %{value} Erkundungschance"],"ScanResultPolicy|Access Token":["Zugriffstoken"],"ScanResultPolicy|Access tokens":["Zugriffstoken"],"ScanResultPolicy|Add another account":["Weiteres Konto hinzuf\xfcgen"],"ScanResultPolicy|Add exception":["Ausnahme hinzuf\xfcgen"],"ScanResultPolicy|Add new criteria":["Neue Kriterien hinzuf\xfcgen"],"ScanResultPolicy|Add new license":["Neue Lizenz hinzuf\xfcgen"],"ScanResultPolicy|Add policy exception":["Richtlinienausnahme hinzuf\xfcgen"],"ScanResultPolicy|Age criteria can only be added for pre-existing vulnerabilities":["Alterskriterien k\xf6nnen nur f\xfcr bereits vorhandene Sicherheitsl\xfccken hinzugef\xfcgt werden"],"ScanResultPolicy|Age is:":["Alter ist:"],"ScanResultPolicy|All licenses have been selected":["Alle Lizenzen wurden ausgew\xe4hlt"],"ScanResultPolicy|Allow entire teams or departments to bypass policies for their specialized workflows.":["Erlaube, dass ganze Teams oder Abteilungen Richtlinien f\xfcr ihre speziellen Workflows umgehen k\xf6nnen."],"ScanResultPolicy|Allow specific automation tokens to bypass policies when service accounts aren't available.":["Erlaube, dass bestimmte Automatisierungstoken Richtlinien umgehen k\xf6nnen, wenn keine Dienstkonten verf\xfcgbar sind."],"ScanResultPolicy|Allow specific types of branches to bypass policies based on naming conventions.":["Erlaube, dass bestimmte Arten von Branches Richtlinien basierend auf Benennungskonventionen umgehen k\xf6nnen."],"ScanResultPolicy|Allow specific users to bypass policies for their specialized workflows.":["Erlaube bestimmten Benutzer(inne)n, Richtlinien f\xfcr ihre spezialisierten Workflows zu umgehen."],"ScanResultPolicy|Allow the merge request to proceed, even if not all criteria are met":["Zulassen, dass die Merge Request fortgesetzt wird, auch wenn nicht alle Kriterien erf\xfcllt sind"],"ScanResultPolicy|Allowed":["Zul\xe4ssig"],"ScanResultPolicy|Allowed license":["Zugelassene Lizenz"],"ScanResultPolicy|Allowlist or Denylist":["Zulassungsliste oder Sperrliste"],"ScanResultPolicy|Apply this approval rule to any branch or a specific protected branch.":["Wende diese Zustimmungsregel auf alle Branches oder einen bestimmten gesch\xfctzten Branch an."],"ScanResultPolicy|Attribute is:":["Das Attribut lautet:"],"ScanResultPolicy|Attribute:":["Attribut:"],"ScanResultPolicy|Attributes are automatically applied by the scanners":["Attribute werden automatisch von den Scannern angewendet"],"ScanResultPolicy|Block the merge request until all criteria are met":["Merge Request blockieren, bis alle Kriterien erf\xfcllt sind"],"ScanResultPolicy|Choose a license":["Lizenz w\xe4hlen"],"ScanResultPolicy|Choose criteria type":["W\xe4hle den Kriterientyp aus"],"ScanResultPolicy|Choose which groups can bypass this policy":["W\xe4hle aus, welche Gruppen diese Richtlinie umgehen k\xf6nnen"],"ScanResultPolicy|Choose which roles can bypass this policy":["W\xe4hle aus, welche Rollen diese Richtlinie umgehen k\xf6nnen"],"ScanResultPolicy|Choose which service accounts can bypass this policy.":["W\xe4hle aus, welche Dienstkonten diese Richtlinie umgehen k\xf6nnen."],"ScanResultPolicy|Choose which users can bypass this policy":["W\xe4hle aus, welche Benutzer(innen) diese Richtlinie umgehen k\xf6nnen"],"ScanResultPolicy|Clear all":["Alle leeren"],"ScanResultPolicy|Critical Risk (100%%)":["Kritisches Risiko (100%%)"],"ScanResultPolicy|Custom Value":["Benutzerdefinierter Wert"],"ScanResultPolicy|Customized CI Variables":["Benutzerdefinierte CI-Variablen"],"ScanResultPolicy|Define branch patterns that can bypass policy requirements. Use an asterisk (*) as a wildcard to match any combination of characters.":["Definiere Branch-Muster, die die Richtlinienanforderungen umgehen k\xf6nnen. Verwende ein Sternchen (*) als Platzhalter f\xfcr eine beliebige Zeichenkombination."],"ScanResultPolicy|Define branch patterns that can bypass policy requirements. Use an asterisk (*) as a wildcard to match any combination of characters. %{linkStart}Learn more%{linkEnd}.":["Definiere Branch-Muster, die die Richtlinienanforderungen umgehen k\xf6nnen. Verwende ein Sternchen (*) als Platzhalter f\xfcr eine beliebige Zeichenkombination. %{linkStart}Mehr erfahren%{linkEnd}"],"ScanResultPolicy|Denied":["Abgelehnt"],"ScanResultPolicy|Denied license":["Gesperrte Lizenz"],"ScanResultPolicy|Don't show me this again":["Nicht erneut anzeigen"],"ScanResultPolicy|Duplicates will be removed":["Duplikate werden entfernt"],"ScanResultPolicy|EPSS has a":["EPSS hat eine/einen"],"ScanResultPolicy|Edge case settings":["Edge-Case-Einstellungen"],"ScanResultPolicy|Edit allowlist":["Zulassungsliste bearbeiten"],"ScanResultPolicy|Edit denylist":["Sperrliste bearbeiten"],"ScanResultPolicy|Enable automated systems and bots to bypass policies for approved workflows.":["Aktiviere f\xfcr automatisierte Systeme und Bots das Umgehen von Richtlinien f\xfcr genehmigte Workflows."],"ScanResultPolicy|Epss score":["EPSS-Punktzahl"],"ScanResultPolicy|Error while fetching":["Fehler beim Abrufen"],"ScanResultPolicy|Except":["Au\xdfer"],"ScanResultPolicy|Exceptions that do not require approval":["Ausnahmen, die keine Genehmigung erfordern"],"ScanResultPolicy|Exceptions that require approval":["Ausnahmen, die eine Genehmigung erfordern"],"ScanResultPolicy|Fail closed":["Fehler beim Schlie\xdfen"],"ScanResultPolicy|Fail closed: Block the merge request until all criteria are met":["Fehler beim Schlie\xdfen: Merge Request blockieren, bis alle Kriterien erf\xfcllt sind"],"ScanResultPolicy|Fail open":["Fehler beim \xd6ffnen"],"ScanResultPolicy|Fail open: Allow the merge request to proceed, even if not all criteria are met":["Zulassen, dass die Merge Request fortgesetzt wird, auch wenn nicht alle Kriterien erf\xfcllt sind"],"ScanResultPolicy|Failure cases:":["Fehlerf\xe4lle:"],"ScanResultPolicy|Fallback behavior":["Fallback-Verhalten"],"ScanResultPolicy|Fallback behavior and edge case settings":["Fallback- und Edge-Case-Einstellungen"],"ScanResultPolicy|False positive":["Falsch positiv"],"ScanResultPolicy|Fix available":["Fix verf\xfcgbar"],"ScanResultPolicy|Fix available is only applicable to container and dependency scanning":["Der verf\xfcgbare Fix gilt nur f\xfcr das Scannen von Containern und Abh\xe4ngigkeiten"],"ScanResultPolicy|For scanners that require builds, when a project does not have a build pipeline.":["F\xfcr Scanner, die Builds erfordern, wenn ein Projekt keine Build-Pipeline hat."],"ScanResultPolicy|Grant bypass permissions to users based on their organizational role or custom role assignments.":["Gew\xe4hre Benutzern bzw. Benutzerinnen die Berechtigung zum Umgehen basieren auf ihrer Organisationsrolle oder benutzerdefinierten Rollenzuweisungen."],"ScanResultPolicy|Groups":["Gruppen"],"ScanResultPolicy|High Risk (80%%)":["Hohes Risiko (80%%)"],"ScanResultPolicy|If Team frequently needs to push infrastructure configuration changes that trigger policy violations but are pre-approved through your change management process, add specific users to bypass infrastructure policies.":["Wenn das Team h\xe4ufig \xc4nderungen der Infrastrukturkonfiguration pushen muss, die Richtlinienverst\xf6\xdfe ausl\xf6sen, aber \xfcber den Change Management-Prozess vorab genehmigt sind, f\xfcge bestimmte Benutzer(innen) zum Umgehen von Infrastruktur-Richtlinien hinzu."],"ScanResultPolicy|If selected, the following choices will overwrite %{linkStart}project settings%{linkEnd} but only affect the branches selected in the policy.":["Falls ausgew\xe4hlt, \xfcberschreiben die folgenden Optionen die %{linkStart}Projekteinstellungen%{linkEnd}, sie wirken sich jedoch ausschlie\xdflich auf die in der Richtlinie ausgew\xe4hlten Branches aus."],"ScanResultPolicy|If selected, the following choices will overwrite %{linkStart}project settings%{linkEnd} for approval rules created by this policy.":["Falls ausgew\xe4hlt, \xfcberschreiben die folgenden Optionen die %{linkStart}Projekteinstellungen%{linkEnd} f\xfcr die von dieser Richtlinie erstellten Genehmigungsregeln."],"ScanResultPolicy|If you want to allow all hotfix branches to bypass approval requirements during production incidents, use \u201chotfix/*\u201d to match branches like hotfix/payment-bug and hotfix/security-patch.":["Wenn allen Hotifx-Branches erlaubt werden soll, w\xe4hrend Produktionsvorf\xe4llen Genehmigungsanforderungen zu umgehen, verwende \u201ehotifx/*\u201c, um Branches wie \u201ehotfix/payment-bug\u201c und \u201ehotfix/security-patch\u201c abzugleichen."],"ScanResultPolicy|If your CI/CD Pipeline Token needs to push automated version updates directly to main branch during release deployments, bypassing the normal merge request approval process.":["Wenn dein CI/CD-Pipeline-Token w\xe4hrend Versionsbereitstellungen automatisierte Versionsaktualisierungen an Haupt-Branches pushen muss und dabei den normalen Genehmigungsprozess f\xfcr Merge Requests umgeht."],"ScanResultPolicy|If your DevOps Team frequently needs to push infrastructure configuration changes that trigger policy violations but are pre-approved through your change management process, add the DevOps Team group to bypass infrastructure policies.":["Wenn das DevOps-Team h\xe4ufig \xc4nderungen der Infrastrukturkonfiguration pushen muss, die Richtlinienverst\xf6\xdfe ausl\xf6sen, aber \xfcber den Change Management-Prozess vorab genehmigt sind, f\xfcge die DevOps-Teamgruppe zum Umgehen von Infrastruktur-Richtlinien hinzu."],"ScanResultPolicy|If your Security Engineer role needs to dismiss false positive findings from security scanners without requiring additional approvals, add the Security Engineer role to bypass security scan policies.":["Wenn deine Sicherheitstechniker-Rolle falsch positive Ergebnisse der Sicherheitsscans ohne weitere Genehmigung verwerfen soll, f\xfcge die Sicherheitstechniker-Rolle zur Umgehung von Sicherheitsscan-Richtlinien hinzu."],"ScanResultPolicy|If your dependabot@company.com service account automatically creates pull requests for dependency updates that may contain license compliance violations requiring manual review.":["Wenn dein dependabot@company.com-Dienstkonto automatisch Pull Requests f\xfcr Abh\xe4ngigkeits-Updates erstellt, die m\xf6glicherweise Konformit\xe4tsverst\xf6\xdfe enthalten, die einen manuellen Review erfordern."],"ScanResultPolicy|In busy projects where the target branch always has a pipeline running, the latest pipeline might be pending. Instead, the policy can use security reports from successful pipelines completed during the specified time window.":["Bei arbeitsreichen Projekten, bei denen im Ziel-Branch immer eine Pipeline ausgef\xfchrt wird, kann es vorkommen, dass die letzte Pipeline noch aussteht. Die Richtlinie kann stattdessen auf Sicherheitsberichte von erfolgreichen Pipelines zur\xfcckgreifen, die im angegebenen Zeitfenster abgeschlossen wurden."],"ScanResultPolicy|Invalid fallback value detected. Please update your selection.":["Ung\xfcltiger Fallback-Wert erkannt. Bitte aktualisiere deine Auswahl."],"ScanResultPolicy|Is":["Ist"],"ScanResultPolicy|Is not":["Ist nicht"],"ScanResultPolicy|KEV status":["KEV-Status"],"ScanResultPolicy|Known exploited":["Bekannter Exploit"],"ScanResultPolicy|License is:":["Die Lizenz lautet:"],"ScanResultPolicy|License status":["Lizenzstatus"],"ScanResultPolicy|License type":["Lizenztyp"],"ScanResultPolicy|Low Risk (10%%)":["Geringes Risiko (10%%)"],"ScanResultPolicy|Make approval rules optional using execution policies":["Genehmigungsregeln mithilfe von Richtlinien zur Ausf\xfchrung optional machen"],"ScanResultPolicy|Matching":["\xdcbereinstimmung"],"ScanResultPolicy|Maximum of one license status criteria allowed":["Es ist maximal ein Lizenzstatuskriterium zul\xe4ssig"],"ScanResultPolicy|Maximum of two attribute criteria allowed":["Es sind maximal zwei Attributkriterien zul\xe4ssig"],"ScanResultPolicy|Maximum of two status criteria allowed":["Es sind maximal zwei Statuskriterien zul\xe4ssig"],"ScanResultPolicy|Merge request approval settings":["Genehmigungseinstellungen f\xfcr Merge Requests"],"ScanResultPolicy|Moderate Risk (50%%)":["Moderates Risiko (50%%)"],"ScanResultPolicy|New age":["Neues Alter"],"ScanResultPolicy|New attribute":["Neues Attribut"],"ScanResultPolicy|New status":["Neuer Status"],"ScanResultPolicy|Newly Detected":["Neu erkannt"],"ScanResultPolicy|No settings available for this policy":["F\xfcr diese Richtlinie sind keine Einstellungen verf\xfcgbar"],"ScanResultPolicy|No tokens available":["Keine Token verf\xfcgbar"],"ScanResultPolicy|On %{scanType} when %{commitType} that targets %{branches} %{branchExceptions}":["Bei %{scanType}, wenn %{commitType} abzielt auf %{branches} %{branchExceptions}"],"ScanResultPolicy|Only 1 age criteria is allowed":["Es ist nur 1\xa0Alterskriterium zul\xe4ssig"],"ScanResultPolicy|Only show/block vulnerabilities that %{boldStart}are%{boldEnd} being exploited.":["Nur Sicherheitsl\xfccken anzeigen/blockieren, die %{boldStart}ausgenutzt%{boldEnd} werden."],"ScanResultPolicy|Override project approval settings":["Projektgenehmigungseinstellungen \xfcberschreiben"],"ScanResultPolicy|Personal access token":["Pers\xf6nliches Zugriffstoken"],"ScanResultPolicy|Policy Exception settings":["Einstellungen f\xfcr Richtlinienausnahmen"],"ScanResultPolicy|Pre-existing":["Bereits vorhanden"],"ScanResultPolicy|Prevent %{linkStart}group branch%{linkEnd} modification %{exceptSelection}":["\xc4nderung von %{linkStart}Gruppen-Branches%{linkEnd} verhindern, %{exceptSelection}"],"ScanResultPolicy|Prevent %{linkStart}group branch%{linkEnd} modification %{exceptSelection} %{groupSelection}":["\xc4nderung von %{linkStart}Gruppen-Branches%{linkEnd} verhindern, %{exceptSelection} %{groupSelection}"],"ScanResultPolicy|Prevent approval by commit author":["Genehmigung durch den bzw. die Commit-Autor(in) verhindern"],"ScanResultPolicy|Prevent approval by merge request's author":["Genehmigung durch den/die Autor(in) des Merge Requests verhindern"],"ScanResultPolicy|Prevent branch modification":["Branch-\xc4nderung verhindern"],"ScanResultPolicy|Prevent group branch modification":["\xc4nderung von Gruppen-Branches verhindern"],"ScanResultPolicy|Prevent pushing and force pushing":["Pushen verhinderen und Pushen erzwingen"],"ScanResultPolicy|Protected branch settings":["Gesch\xfctzte Branch-Einstellungen"],"ScanResultPolicy|Recently created":["Zuletzt erstellt"],"ScanResultPolicy|Recommended settings":["Empfohlene Einstellungen"],"ScanResultPolicy|Remove all approvals with new commit":["Alle Genehmigungen mit neuem Commit entfernen"],"ScanResultPolicy|Require user re-authentication (password or SAML) to approve":["Zur Genehmigung ist eine erneute Benutzerauthentifizierung (Passwort oder SAML) erforderlich"],"ScanResultPolicy|Required number of approvals became higher than available, valid approvers.":["Die erforderliche Anzahl von Genehmigungen wurde h\xf6her als die verf\xfcgbaren, g\xfcltigen Genehmiger(innen)."],"ScanResultPolicy|Required scanners defined in the condition did not run or produce any artifacts.":["Die in der Bedingung definierten erforderlichen Scanner haben keine Artefakte ausgef\xfchrt oder produziert."],"ScanResultPolicy|Roles":["Regeln"],"ScanResultPolicy|Save allowlist":["Zulassungsliste speichern"],"ScanResultPolicy|Save denylist":["Sperrliste speichern"],"ScanResultPolicy|Select a scan type before adding criteria":["W\xe4hle einen Scan-Typ aus, bevor du Kriterien hinzuf\xfcgst"],"ScanResultPolicy|Select access tokens":["Zugriffstoken ausw\xe4hlen"],"ScanResultPolicy|Select all":["Alle ausw\xe4hlen"],"ScanResultPolicy|Select group exceptions":["Gruppenausnahmen ausw\xe4hlen"],"ScanResultPolicy|Select group exceptions. Choose which groups can bypass this policy.":["W\xe4hle Gruppenausnahmen aus. W\xe4hle aus, welche Gruppen diese Richtlinie umgehen k\xf6nnen."],"ScanResultPolicy|Select instance group or project level access tokens that can bypass this policy.":["W\xe4hle Instanzgruppen oder Zugriffstoken auf Projektebene aus, die diese Richtlinie umgehen k\xf6nnen."],"ScanResultPolicy|Select license types":["Lizenztypen ausw\xe4hlen"],"ScanResultPolicy|Select licenses":["Lizenzen ausw\xe4hlen"],"ScanResultPolicy|Select list type":["Listentyp ausw\xe4hlen"],"ScanResultPolicy|Select operator":["Operator ausw\xe4hlen"],"ScanResultPolicy|Select probability":["Wahrscheinlichkeit ausw\xe4hlen"],"ScanResultPolicy|Select role exceptions":["Rollenausnahmen ausw\xe4hlen"],"ScanResultPolicy|Select role exceptions. Choose which roles can bypass this policy.":["W\xe4hle Rollenausnahmen aus. W\xe4hle aus, welche Rollen diese Richtlinie umgehen k\xf6nnen."],"ScanResultPolicy|Select service account":["Dienstkonto ausw\xe4hlen"],"ScanResultPolicy|Select service account or create a token":["Dienstkonto ausw\xe4hlen oder ein Token erstellen"],"ScanResultPolicy|Select service accounts":["Dienstkonten ausw\xe4hlen"],"ScanResultPolicy|Select this option if you want the policy to block the merge request (or warn the user if the policy is in warn mode) only if it includes vulnerabilities that are actively exploited according to their KEV status. %{linkStart}Learn more%{linkEnd}.":["W\xe4hle diese Option, wenn die Merge Request mit dieser Richtlinie blockiert werden soll (oder Benutzer(innen) gewarnt werden sollen, wenn sich die Richtlinie im Warnmodus befindet), allerdings nur, wenn sie Sicherheitsl\xfccken umfasst, die ihrem KEV-Status zufolge aktiv ausgenutzt werden. %{linkStart}Mehr erfahren%{linkEnd}."],"ScanResultPolicy|Select token exceptions":["Token-Ausnahmen ausw\xe4hlen"],"ScanResultPolicy|Select user exceptions":["Benutzerausnahmen ausw\xe4hlen"],"ScanResultPolicy|Select users exceptions. Choose which users can bypass this policy.":["W\xe4hle Benutzerausnahmen aus. W\xe4hle aus, welche Benutzer(innen) diese Richtlinie umgehen k\xf6nnen."],"ScanResultPolicy|Service accounts":["Dienstkonten"],"ScanResultPolicy|Severity is:":["Der Schweregrad lautet:"],"ScanResultPolicy|Specify the packages where this license does not require approval before use":["Die Pakete festlegen, f\xfcr die diese Lizenz keine Genehmigung vor der Nutzung erfordert"],"ScanResultPolicy|Specify the packages where this license requires approval before use":["Lege die Pakete fest, f\xfcr die diese Lizenz eine Genehmigung vor der Nutzung erfordert"],"ScanResultPolicy|Status is:":["Der Status lautet:"],"ScanResultPolicy|The product %{verb} use the selected licenses":["Das Produkt %{verb} die ausgew\xe4hlten Lizenzen verwenden"],"ScanResultPolicy|There are no access tokens created":["Es wurden keine Zugriffstoken erstellt"],"ScanResultPolicy|Unknown":["Unbekannt"],"ScanResultPolicy|Use security reports from pipelines completed within the last":["Sicherheitsberichte von Pipelines verwenden, die abgeschlossen wurden innerhalb der letzten"],"ScanResultPolicy|Use time window for target pipeline comparison":["Zeitfenster f\xfcr Vergleich von Ziel-Pipelines verwenden"],"ScanResultPolicy|Users":["Benutzer(innen)"],"ScanResultPolicy|When %{scanType} runs in an open merge request that targets %{branches} %{branchExceptions} and finds licenses match all of the following criteria:":["Wenn %{scanType} in einem offenen Merge Request ausgef\xfchrt wird, der auf %{branches} %{branchExceptions} abzielt, und festgestellt wird, dass die Lizenzen alle der folgenden Kriterien erf\xfcllen:"],"ScanResultPolicy|When %{scanners} finds scanner-specific conditions in an open merge request that targets %{branches} %{branchExceptions} and matches %{boldDescription} the following criteria":["Wenn %{scanners} Scanner-spezifische Bedingungen in einem offenen Merge Request findet, der auf %{branches} %{branchExceptions} abzielt und mit %{boldDescription} der folgenden Kriterien \xfcbereinstimmt"],"ScanResultPolicy|When a %{scanType} with %{scanners} runs against %{branches} %{branchExceptions} and finds %{vulnerabilitiesNumber} %{boldDescription} all the following criteria:":["Wenn ein %{scanType} mit %{scanners} f\xfcr %{branches} %{branchExceptions} ausgef\xfchrt wird und feststellt, dass %{vulnerabilitiesNumber} %{boldDescription} alle der folgenden Kriterien erf\xfcllen:"],"ScanResultPolicy|When a security policy fails for an unspecified reason.":["Wenn eine Sicherheitsrichtlinie aus einem nicht angegebenen Grund fehlschl\xe4gt."],"ScanResultPolicy|When enabled, approval rules do not block merge requests when a scan is required by a scan execution policy or a pipeline execution policy but a required scan artifact is missing from the target branch. This option only works when the project or group has an existing scan execution policy or pipeline execution policy with matching scanners.":["Wenn diese Option aktiviert ist, blockieren Zustimmungsregeln keine Merge Requests, wenn ein Scan durch eine Scan-Ausf\xfchrungsrichtlinie oder eine Pipeline-Ausf\xfchrungsrichtlinie erforderlich ist, aber ein erforderliches Scan-Artefakt im Zielbranch fehlt. Diese Option funktioniert nur, wenn das Projekt oder die Gruppe \xfcber eine vorhandene Scan- oder Pipeline-Ausf\xfchrungsrichtlinie mit entsprechenden Scannern verf\xfcgt."],"ScanResultPolicy|When enabled, if an MR receives all necessary approvals to merge, but then a new commit is added, new approvals are required.":["Wenn die Option aktiviert ist und ein MR alle erforderlichen Genehmigungen zum Zusammenf\xfchren erh\xe4lt, aber dann ein neuer Commit hinzugef\xfcgt wird, sind neue Genehmigungen erforderlich."],"ScanResultPolicy|When enabled, merge request authors cannot approve their own MRs.":["Wenn die Option aktiviert ist, k\xf6nnen Merge Request-Autor(inn)en ihre eigenen MRs nicht genehmigen."],"ScanResultPolicy|When enabled, prevents a user from removing a branch from the group protected branches list, deleting a protected branch, or changing the default branch if that branch is included in the security policy.":["Wenn die Option aktiviert ist, verhindert sie, dass ein Benutzer einen Branch aus der Liste gesch\xfctzter Gruppen-Branches entfernen kann, einen gesch\xfctzten Branch l\xf6schen kann oder den Standard-Branch \xe4ndern kann, wenn dieser Branch in der Sicherheitsrichtlinie enthalten ist."],"ScanResultPolicy|When enabled, prevents a user from removing a branch from the project protected branches list, deleting a protected branch, or changing the default branch if that branch is included in the security policy.":["Wenn die Option aktiviert ist, verhindert sie, dass ein Benutzer einen Branch aus der Liste gesch\xfctzter Projekt-Branches entfernen kann, einen gesch\xfctzten Branch l\xf6schen kann oder den Standard-Branch \xe4ndern kann, wenn dieser Branch in der Sicherheitsrichtlinie enthalten ist."],"ScanResultPolicy|When enabled, prevents pushing and force pushing to a protected branch if that branch is included in the security policy.":["Wenn die Option aktiviert ist, verhindert sie Pushing und Force Pushing von gesch\xfctzten Branches, wenn dieser Branch in der Sicherheitsrichtlinie enthalten ist."],"ScanResultPolicy|When enabled, there will be password confirmation on approvals.":["Wenn die Option aktiviert ist, wird bei Genehmigungen eine Passwortbest\xe4tigung angezeigt."],"ScanResultPolicy|When enabled, users who have contributed code to the MR are ineligible for approval.":["Wenn die Option aktiviert ist, k\xf6nnen Benutzer(innen), die Code zum MR beigetragen haben, den MR nicht genehmigen."],"ScanResultPolicy|When this policy's criteria %{strongStart}cannot be met:%{strongEnd}":["Wenn die Kriterien dieser Richtlinie %{strongStart}nicht erf\xfcllt werden k\xf6nnen:%{strongEnd}"],"ScanResultPolicy|You can specify either a deny/allowlist or license types, not both.":["Du kannst entweder eine Sperr-/Zulassungsliste oder Lizenztypen angeben, aber nicht beides."],"ScanResultPolicy|You can specify either a license state (allowlist or denylist) or a license type, not both.":["Du kannst entweder einen Lizenzstatus (Zulassungsliste oder Sperrliste) oder einen Lizenztyp angeben, nicht beides."],"ScanResultPolicy|You have selected all protected branches in this policy's rules. To better protect your project, you should leave this setting enabled. %{linkStart}What are the risks of allowing pushing and force pushing?%{linkEnd}":["Du hast alle gesch\xfctzten Branches in den Regeln dieser Richtlinie ausgew\xe4hlt. Um dein Projekt besser zu sch\xfctzen, solltest du diese Einstellung aktiviert lassen. %{linkStart}Was sind die Risiken, wenn man Push und Force Push zul\xe4sst?%{linkEnd}"],"ScanResultPolicy|access token":["Zugriffstoken"],"ScanResultPolicy|allowlist (%{licenseCount} %{licenses})":["Zulassungsliste (%{licenseCount} %{licenses})"],"ScanResultPolicy|any commits":["alle Commits"],"ScanResultPolicy|any unsigned commits":["alle nicht signierten Commits"],"ScanResultPolicy|denylist (%{licenseCount} %{licenses})":["Sperrliste (%{licenseCount} %{licenses})"],"ScanResultPolicy|greater than":[""],"ScanResultPolicy|input source branch":["Eingabe-Quellbranch"],"ScanResultPolicy|input target branch":["Eingabe-Zielbranch"],"ScanResultPolicy|less than":[""],"ScanResultPolicy|license status":["Lizenzstatus"],"ScanResultPolicy|matching type":["Typ stimmt \xfcberein"],"ScanResultPolicy|minutes":["Minuten"],"ScanResultPolicy|scanners":["Scanner"],"ScanResultPolicy|service account":["Dienstkonto"],"ScanResultPolicy|severity levels":["Schweregrade"],"ScanResultPolicy|token":["Token"],"ScanResultPolicy|vulnerabilities allowed":["Zul\xe4ssige Sicherheitsl\xfccken"],"ScanResultPolicy|vulnerability states":["Sicherheitsl\xfcckenstatus"],"ScanResultPolicy|vulnerability type that matches":["Sicherheitsl\xfcckentyp, der Folgenden entspricht:"],Scanner:["Scanner"],"Scanner profile failed to delete":["L\xf6schen des Scannerprofils fehlgeschlagen"],"Scanner profile not found for given parameters":["Scannerprofil f\xfcr angegebene Parameter nicht gefunden"],"Schedule a new pipeline":["Plane eine neue Pipeline"],"Schedule-based escalation rules must have a schedule in the same project as the policy":["Zeitplanbasierte Eskalationsregeln m\xfcssen einen Zeitplan im gleichen Projekt wie die Richtlinie haben"],Scheduled:["Geplant"],"Scheduled Deletion At - %{permanent_deletion_time}":["Plane L\xf6schung um \u2013 %{permanent_deletion_time}"],"Scheduled a rebase of branch %{branch}.":["Rebase von Branch %{branch} geplant."],"Scheduled pipelines":["Geplante Pipelines"],"Scheduled pipelines cannot run more frequently than once per %{limit} minutes. A pipeline configured to run more frequently only starts after %{limit} minutes have elapsed since the last time it ran.":["Geplante Pipelines k\xf6nnen nicht h\xe4ufiger als einmal pro %{limit} Minute ausgef\xfchrt werden. Eine Pipeline, die f\xfcr eine h\xe4ufigere Ausf\xfchrung konfiguriert ist, wird erst gestartet, wenn seit der letzten Ausf\xfchrung %{limit} Minuten verstrichen sind."],"ScheduledJob|delayed manual action (%{remainingTime})":["versp\xe4tete manuelle Aktion (%{remainingTime})"],Schedules:["Zeitpl\xe4ne"],Schema:[""],Scope:["G\xfcltigkeitsbereich"],"Scope board to current iteration":["\xdcbersichtsbereich zur aktuellen Iteration"],Scopes:["Geltungsbereiche"],"Scopes (select at least one)":["Geltungsbereiche (w\xe4hle mindestens einen aus)"],"Scopes can't be blank":["Geltungsbereiche d\xfcrfen nicht leer sein"],"Scopes: %{scope_list}":["Geltungsbereiche: %{scope_list}"],"Screenshot must be less than 1 MB.":["Der Screenshot muss kleiner als 1 MB sein."],"Scroll down":["Nach unten scrollen"],"Scroll left":["Nach links scrollen"],"Scroll right":["Nach rechts scrollen"],"Scroll to bottom":["Zum Seitenende scrollen"],"Scroll to the bottom to load more items":["Nach unten scrollen, um weitere Elemente zu laden"],"Scroll to top":["Zum Seitenanfang scrollen"],"Scroll up":["Nach oben scrollen"],"Seamlessly create change requests when your team initiates deployments.":["Erstelle nahtlos \xc4nderungsanfragen, wenn dein Team Bereitstellungen initiiert."],Search:["Suchen"],"Search (3 character minimum)":["Suche (mindestens 3\xa0Zeichen)"],"Search an environment spec":["Suche eine Umgebungsspezifikation"],"Search artifacts":["Artefakte durchsuchen"],"Search assignees":["Beauftragte suchen"],"Search branch":["Branch suchen"],"Search branches":["Branches durchsuchen"],"Search branches and tags":["Suche nach Branches und Tags"],"Search branches, tags, and commits":["Suche Branches, Tags und Commits"],"Search by Git revision":["Filtern nach Git-Revision"],"Search by ID":["Nach ID suchen"],"Search by author":["Suche nach Autor(in)"],"Search by full path":["Suche mit vollst\xe4ndigem Pfad"],"Search by message":["Nach Nachricht suchen"],"Search by name":["Suche nach Name"],"Search comment templates":["Kommentarvorlagen suchen"],"Search deploy keys":["Bereitstellungsschl\xfcssel durchsuchen"],"Search files":["Dateien durchsuchen"],"Search filters":["Suchfilter"],"Search for Namespace":["Nach Namens
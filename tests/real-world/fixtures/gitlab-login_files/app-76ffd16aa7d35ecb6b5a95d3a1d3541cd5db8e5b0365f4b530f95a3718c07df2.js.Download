ich."],Milestone:["Meilenstein","Meilensteine"],"Milestone due date":["F\xe4lligkeitsdatum des Meilensteins"],"Milestone id(s) not found: %{milestones}":["Meilenstein-ID(s) nicht gefunden: %{milestones}"],"Milestone lists not available with your current license":["Meilensteinlisten sind mit deiner momentanen Lizenz nicht verf\xfcgbar"],"Milestone(s) not found: %{milestones}":["Meilenstein(e) nicht gefunden: %{milestones}"],"Milestone: %{milestoneTitle}":["Meilenstein: %{milestoneTitle}"],"MilestoneCombobox|Group milestones":["Gruppenmeilensteine"],"MilestoneCombobox|No milestone":["Kein Meilenstein"],"MilestoneCombobox|Project milestones":["Projektmeilensteine"],"MilestoneCombobox|Select milestone":["Meilenstein ausw\xe4hlen"],"MilestoneSidebar|Closed:":["Geschlossen:"],"MilestoneSidebar|Copy reference":["Referenz kopieren"],"MilestoneSidebar|Due date":["F\xe4lligkeitsdatum"],"MilestoneSidebar|Edit":["Bearbeiten"],"MilestoneSidebar|From":["Von"],"MilestoneSidebar|Merge requests":["Merge Requests"],"MilestoneSidebar|Merged:":["Zusammengef\xfchrt:"],"MilestoneSidebar|New Issue":["Neues Ticket"],"MilestoneSidebar|New issue":["Neues Ticket"],"MilestoneSidebar|No due date":["Kein F\xe4lligkeitsdatum"],"MilestoneSidebar|No start date":["Kein Startdatum"],"MilestoneSidebar|None":["Keine"],"MilestoneSidebar|Open:":["Offen:"],"MilestoneSidebar|Reference:":["Referenz:"],"MilestoneSidebar|Start date":["Startdatum"],"MilestoneSidebar|Toggle sidebar":["Men\xfcleiste umschalten"],"MilestoneSidebar|Until":["Bis"],"MilestoneSidebar|Work items":["Arbeitsaufgaben"],"MilestoneSidebar|complete":["vollst\xe4ndig"],Milestones:["Meilensteine"],"Milestones| You\u2019re about to permanently delete the milestone %{milestoneTitle} and remove it from %{issuesWithCount} and %{mergeRequestsWithCount}. Once deleted, it cannot be undone or recovered.":["Du bist im Begriff, den Meilenstein %{milestoneTitle} endg\xfcltig zu l\xf6schen und ihn von %{issuesWithCount} und %{mergeRequestsWithCount} zu e
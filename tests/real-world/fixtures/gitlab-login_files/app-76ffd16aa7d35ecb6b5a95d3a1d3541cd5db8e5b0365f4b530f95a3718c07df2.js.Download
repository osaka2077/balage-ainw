hrt"],"NotificationEvent|Merge request is reassigned":["Merge Request wird neu zugewiesen"],"NotificationEvent|Merge request is reopened":["Merge Request wird erneut ge\xf6ffnet"],"NotificationEvent|Merge request is set to auto-merge":["Merge Request wird f\xfcr automatische Zusammenf\xfchrung konfiguriert"],"NotificationEvent|Merge request receives a push":["Merge Request erh\xe4lt einen Push"],"NotificationEvent|Merge request reviewers are changed":["Merge Request-Pr\xfcfer(innen) werden ge\xe4ndert"],"NotificationEvent|Merge request you're eligible to approve is created":["Es wurde ein neuer Merge Request erstellt, f\xfcr dessen Genehmigung du berechtigt bist"],"NotificationEvent|Merge when pipeline succeeds":["Zusammenf\xfchren, wenn die Pipeline erfolgreich ist"],"NotificationEvent|Moved project":["Projekt verschoben"],"NotificationEvent|New epic":["Neuer Epic"],"NotificationEvent|New issue":["Neues Ticket"],"NotificationEvent|New merge request":["Neuer Merge Request"],"NotificationEvent|New note":["Neue Notiz"],"NotificationEvent|New release":["Neues Release"],"NotificationEvent|Pipeline by Service Account fails":["Pipeline nach Dienstkonto schl\xe4gt fehl"],"NotificationEvent|Pipeline by Service Account is fixed":["Pipeline nach Dienstkonto ist behoben"],"NotificationEvent|Pipeline by Service Account is successful":["Pipeline nach Dienstkonto ist erfolgreich"],"NotificationEvent|Pipeline fails":["Pipeline schl\xe4gt fehl"],"NotificationEvent|Pipeline is fixed":["Pipeline ist repariert"],"NotificationEvent|Pipeline is successful":["Pipeline ist erfolgreich"],"NotificationEvent|Project is moved":["Projekt wird verschoben"],"NotificationEvent|Push to merge request":["Push, um die Anfrage zusammenzuf\xfchren"],"NotificationEvent|Reassign issue":["Ticket neu zuweisen"],"NotificationEvent|Reassign merge request":["Merge Request neu zuweisen"],"NotificationEvent|Release is created":["Release wird erstellt"],"NotificationEvent|Reopen issue":["Ticket wieder \xf6ffnen"],"NotificationEvent|Reopen merge request":["Merge Request erneut \xf6ffnen"],"NotificationLevel|Custom":["Benutzerdefiniert"],"NotificationLevel|Disabled":["Deaktiviert"],"NotificationLevel|Global":["Global"],"NotificationLevel|On mention":["Bei Nennung"],"NotificationLevel|Participate":["Beteiligt"],"NotificationLevel|Watch":["Beobachten"],Notifications:["Benachrichtigungen"],"Notifications Off":["Benachrichtigungen aus"],"Notifications On":["Benachrichtigungen an"],"Notifications for %{project_or_group} are rate-limited due to the high volume of notifications sent.":["Benachrichtigungen f\xfcr %{project_or_group} sind aufgrund des hohen Volumens der gesendeten Benachrichtigungen ratenbegrenzt."],"Notifications have been disabled by the project or group owner":["Benachrichtungen wurden vom/von der Projekt- oder Gruppeneigent\xfcmer(in) deaktiviert"],"Notifications off":["Benachrichtigungen aus"],"Notifications on":["Benachrichtigungen ein"],"Notifications temporarily disabled":["Benachrichtigungen vor\xfcbergehend deaktiviert"],"Notifications turned off":["Benachrichtigungen deaktiviert"],"Notifications turned off.":["Benachrichtigungen deaktiviert"],"Notifications turned on":["Benachrichtigungen aktiviert"],"Notifications turned on.":["Benachrichtigungen aktiviert"],"Notify only broken pipelines":["Nur defekte Pipelines benachrichtigen"],"Notify users by email when sign-in location is not recognized.":["Benutzer(innen) per E-Mail benachrichtigen, wenn der Anmeldeort nicht erkannt wird"],"Notify|%{added} was added as an assignee.":["%{added} wurde als Beauftragte(r) hinzugef\xfcgt."],"Notify|%{added} were added as assignees.":["%{added} wurden als Beauftragte hinzugef\xfcgt."],"Notify|%{author_link}'s issue %{issue_reference_link} is due soon.":["Das Ticket %{issue_reference_link} von %{author_link} ist bald f\xe4llig."],"Notify|%{author_name} %{action_name} %{ref_type} %{ref_name} at %{project_link}":["%{author_name} %{action_name} %{ref_type} %{ref_name} in %{project_link}"],"Notify|%{changed_files}:":["%{changed_files}:"],"Notify|%{commit_link} in %{mr_link}":["%{commit_link} in %{mr_link}"],"Notify|%{commits_text} from branch `%{target_branch}`":["%{commits_text} von Branch `%{target_branch}`"],"Notify|%{committed_by_start} by %{author_name} %{committed_by_end} %{committed_at_start} at %{committed_date} %{committed_at_end}":["%{committed_by_start} von %{author_name} %{committed_by_end} %{committed_at_start} am %{committed_date} %{committed_at_end}"],"Notify|%{invite_email}, now known as %{user_name}, has accepted your invitation to join the %{target_name} %{target_model_name}.":["%{invite_email}, jetzt bekannt als %{user_name}, hat deine Einladung angenommen, dem %{target_name} %{target_model_name} beizutreten."],"Notify|%{invited_user} has %{highlight_start}declined%{highlight_end} your invitation to join the %{target_link} %{target_name}.":["%{invited_user} hat deine Einladung zur Teilnahme an den %{target_link} %{target_name} %{highlight_start}abgelehnt%{highlight_end}."],"Notify|%{issues} imported.":["%{issues} importiert."],"Notify|%{member_link} requested %{member_role} access to the %{target_source_link} %{target_type}.":["%{member_link} hat %{member_role}-Zugriff auf %{target_source_link} %{target_type} angefordert."],"Notify|%{mr_highlight}Merge request%{highlight_end} %{mr_link} %{reviewer_highlight}was approved by%{highlight_end} %{reviewer_avatar} %{reviewer_link}":["%{mr_highlight}Merge Request%{highlight_end} %{mr_link} %{reviewer_highlight}wurde von%{highlight_end} %{reviewer_avatar} %{reviewer_link} genehmigt"],"Notify|%{mr_highlight}Merge request%{highlight_end} %{mr_link} %{reviewer_highlight}was unapproved by%{highlight_end} %{reviewer_avatar} %{reviewer_link}":["%{mr_highlight}Merge Request%{highlight_end} %{mr_link} %{reviewer_highlight}wurde von%{highlight_end} %{reviewer_avatar} %{reviewer_link} nicht genehmigt"],"Notify|%{p_start}To update the remote url in your local repository run (for ssh):%{p_end} %{ssh_url_to_repo} %{p_start}or for http(s):%{p_end} %{http_url_to_repo}":["%{p_start}Um die Remote-URL in deinem lokalen Repository zu aktualisieren, f\xfchre (f\xfcr ssh):%{p_end} %{ssh_url_to_repo} %{p_start}oder f\xfcr http(s):%{p_end} %{http_url_to_repo} aus"],"Notify|%{paragraph_start}Hi %{name}!%{paragraph_end} %{paragraph_start}A new public key was added to your account:%{paragraph_end} %{paragraph_start}title: %{key_title}%{paragraph_end} %{paragraph_start}If this key was added in error, you can remove it under %{removal_link}%{paragraph_end}":["%{paragraph_start}Hallo %{name}!%{paragraph_end} %{paragraph_start}Ein neuer \xf6ffentlicher Schl\xfcssel wurde zu deinem Konto hinzugef\xfcgt:%{paragraph_end} %{paragraph_start}Bezeichnung: %{key_title}%{paragraph_end} %{paragraph_start}Wenn dieser Schl\xfcssel irrt\xfcmlich hinzugef\xfcgt wurde, kannst du ihn unter %{removal_link} entfernen.%{paragraph_end}"],"Notify|%{project_link_start}Download%{project_link_end} the project export.":["%{project_link_start}Lade%{project_link_end} den Projektexport herunter."],"Notify|%{removed} was removed as an assignee.":["%{removed} wurde als Beauftragte(r) entfernt."],"Notify|%{removed} were removed as assignees.":["%{removed} wurden als Beauftragte entfernt."],"Notify|%{singular_or_plural_line} %{error_lines}: Work item type cannot be found or is not supported.":["%{singular_or_plural_line} %{error_lines}: Der Typ des Arbeitsgegenstandes kann nicht gefunden werden oder wird nicht unterst\xfctzt."],"Notify|%{singular_or_plural_line} %{error_lines}: Work item type is empty.":["%{singular_or_plural_line} %{error_lines}: Der Typ der Arbeitsgegenst\xe4nde ist leer."],"Notify|%{singular_or_plural_line} %{error_lines}: Work item type is not available. Please check your license and permissions.":["%{singular_or_plural_line} %{error_lines}: Der Typ der Arbeitsaufgabe ist nicht verf\xfcgbar. Bitte \xfcberpr\xfcfe deine Lizenz und Berechtigungen."],"Notify|%{skipped_count} have used pipeline variables in the past. These projects' CI/CD settings were not updated as there is a risk the setting change would impact pipelines.":["%{skipped_count} haben zuvor Pipeline-Variablen verwendet. Die CI/CD-Einstellungen dieser Projekte wurden nicht aktualisiert, da das Risiko besteht, dass die Einstellungs\xe4nderung Pipelines beeintr\xe4chtigen w\xfcrde."],"Notify|%{strong_open}%{user_name}%{strong_close} updated the custom email address credentials for the Service Desk of %{project_link_start}%{project_name}%{project_link_end} and triggered the verification process.":["%{strong_open}%{user_name}%{strong_close} hat die Anmeldeinformationen der benutzerdefinierten E-Mail-Adresse f\xfcr den Service-Desk von %{project_link_start}%{project_name}%{project_link_end} aktualisiert und den Verifizierungsprozess ausgel\xf6st."],"Notify|%{type} was %{issue_status} by %{updated_by}":["%{type} war %{issue_status} von %{updated_by}"],"Notify|%{update_at_start} Last update at %{update_at_mid} %{last_update_at} %{update_at_end}":["%{update_at_start} Letzte Aktualisierung um %{update_at_mid} %{last_update_at} %{update_at_end}"],"Notify|%{updated_by_user_name} pushed new commits to merge request %{mr_link}":["%{updated_by_user_name} hat neue Commits zum Merge Request %{mr_link} gepusht"],"Notify|%{updated_count} projects were not using pipeline variables. CI/CD settings were updated to prevent future pipeline variable usage.":["%{updated_count} Projekte haben keine Pipeline-Variablen verwendet. Die CI/CD-Einstellungen wurden aktualisiert, um die zuk\xfcnftige Verwendung von Pipeline-Variablen zu verhindern."],"Notify|%{work_items} successfully imported.":["%{work_items} erfolgreich importiert."],"Notify|1 project has used pipeline variables in the past. This project's CI/CD settings were not updated as there is a risk the setting change would impact pipelines.":["1 Projekt hat in der Vergangenheit Pipeline-Variablen verwendet. Die CI/CD-Einstellungen dieses Projekts wurden nicht aktualisiert, da das Risiko besteht, dass die Einstellungs\xe4nderung Pipelines beeintr\xe4chtigen w\xfcrde."],"Notify|1 project was not using pipeline variables. CI/CD settings were updated to prevent future pipeline variable usage.":["1 Projekt hat keine Pipeline-Variablen verwendet. Die CI/CD-Einstellungen wurden aktualisiert, um die zuk\xfcnftige Verwendung von Pipeline-Variablen zu verhindern."],"Notify|A new GPG key was added to your account:":["Ein neuer GPG-Schl\xfcssel wurde deinem Konto hinzugef\xfcgt:"],"Notify|A remote mirror update has failed.":["Ein Remote-Mirror-Update ist fehlgeschlagen."],"Notify|After it expires, you can %{a_start} request a new one %{a_end}.":["Nach Ablauf kannst Du %{a_start} ein neues %{a_end} anfordern."],"Notify|All assignees were removed.":["Alle Beauftragten wurden entfernt."],"Notify|All discussions on merge request %{mr_link} were resolved by %{name}":["Alle Diskussionen zum Merge Request %{mr_link} wurden von %{name} gel\xf6st"],"Notify|All projects in the %{group_name} group were checked for pipeline variables usage.":["Alle Projekte in der Gruppe %{group_name} wurden auf die Verwendung von Pipeline-Variablen \xfcberpr\xfcft."],"Notify|All projects in this group have CI/CD setting set to prevent pipeline variable usage. \ud83c\udf89":["Bei allen Projekten in dieser Gruppe verhindern die CI/CD-Einstellungen die Verwendung von Pipeline-Variablen. \ud83c\udf89"],"Notify|And %{total_stripped_new_commits_count} more":["Und %{total_stripped_new_commits_count} mehr"],"Notify|Author: %{author_name}":["Autor(in): %{author_name}"],"Notify|Auto DevOps pipeline was disabled for %{project}":["Die automatische DevOps-Pipeline wurde f\xfcr %{project} deaktiviert"],"Notify|CI/CD project settings":["CI/CD-Projekteinstellungen"],"Notify|Check your forwarding settings and make sure the original email sender remains in the %{code_open}From%{code_end} header.":["Pr\xfcfe deine Weiterleitungseinstellungen und stelle sicher, dass der urspr\xfcngliche E-Mail-Absender im %{code_open}From%{code_end}-Header verbleibt."],"Notify|Click here to set your password":["Hier klicken, um das Passwort zu setzen"],"Notify|Commit Author":["Autor des Commits"],"Notify|Committed by":["Commited von"],"Notify|Could not find the following %{column} values in %{project}%{parent_groups_clause}: %{error_lines}":["Die folgenden Werte der Spalte %{column} im Projekt %{project}%{parent_groups_clause} konnten nicht gefunden werden: %{error_lines}"],"Notify|Don't want to receive updates from GitLab administrators?":["M\xf6chtest du keine Updates von GitLab-Administratoren erhalten?"],"Notify|Email could not be verified":["E-Mail-Adresse konnte nicht verifiziert werden"],"Notify|Email successfully verified":["E-Mail-Adresse erfolgreich verifiziert"],"Notify|Error parsing CSV file. Please make sure it has the correct format: a delimited text file that uses a comma to separate values.":["Fehler beim Parsen der CSV-Datei. Bitte versichere dich, dass die Datei das richtige Format hat: eine Textdatei mit Trennzeichen, in der die Werte durch ein Komma getrennt sind."],"Notify|Errors found on %{singular_or_plural_line}: %{error_lines}. Please check if these lines have an issue title.":["Fehler gefunden in %{singular_or_plural_line}: %{error_lines}. Bitte \xfcberpr\xfcfe, ob diese Zeilen einen Ticket-Titel haben."],"Notify|Errors found on %{singular_or_plural_line}: %{error_lines}. Please check that these lines have the following fields: %{required_headers}.":["Fehler gefunden in %{singular_or_plural_line}: %{error_lines}. \xdcberpr\xfcfe, ob diese Zeilen die folgenden Felder enthalten: %{required_headers}."],"Notify|Fingerprint: %{fingerprint}":["Fingerabdruck: %{fingerprint}"],"Notify|Forward all emails to the custom email address to %{code_open}%{service_desk_incoming_address}%{code_end}.":["Leite alle E-Mails an die benutzerdefinierte E-Mail-Adresse an %{code_open}%{service_desk_incoming_address}%{code_end} weiter."],"Notify|Here are the results for your CSV import for %{project_link}.":["Hier sind die Ergebnisse f\xfcr deinen CSV-Import f\xfcr %{project_link}."],"Notify|Here are the results for your CSV import for %{project_name} (%{project_link}).":["Hier sind die Ergebnisse f\xfcr deinen CSV-Import f\xfcr %{project_name} (%{project_link})."],"Notify|Hi %{username}!":["Hallo %{username}!"],"Notify|Hi %{user}!":["Hallo %{user}!"],"Notify|If this key was added in error, you can remove it under %{removal_link}":["Wenn dieser Schl\xfcssel irrt\xfcmlich hinzugef\xfcgt wurde, kannst Du ihn unter %{removal_link} entfernen."],"Notify|If this was a mistake you can change these settings or deactivate the custom email address in the project settings.":["Wenn dies ein Fehler war, kannst du diese Einstellungen \xe4ndern oder die benutzerdefinierte E-Mail-Adresse in den Projekteinstellungen deaktivieren."],"Notify|If you no longer wish to use this domain with GitLab Pages, please remove it from your GitLab project and delete any related DNS records.":["Wenn du diese Domain nicht mehr mit GitLab Pages verwenden m\xf6chtest, entferne sie aus deinem GitLab-Projekt und l\xf6sche alle zugeh\xf6rigen DNS-Eintr\xe4ge."],"Notify|Incorrect %{code_open}From%{code_end} header:":["Falscher %{code_open}From%{code_end}-Header:"],"Notify|Incorrect forwarding target:":["Falsches Weiterleitungsziel:"],"Notify|Incorrect verification token:":["Falsches Verifizierungstoken:"],"Notify|Invalid credentials:":["Ung\xfcltige Zugangsdaten:"],"Notify|Issue was moved to another project.":["Das Ticket wurde in ein anderes Projekt verschoben."],"Notify|Learn more about Auto DevOps":["Mehr \xfcber Auto-DevOps erfahren"],"Notify|Logs may contain sensitive data. Please consider before forwarding this email.":["Logs k\xf6nnen sensible Daten enthalten. Bitte pr\xfcfe dies, bevor Du diese E-Mail weiterleitest."],"Notify|Merge request %{merge_request} can no longer be merged due to conflict.":["Merge Request %{merge_request} kann aufgrund von Konflikten nicht mehr zusammengef\xfchrt werden."],"Notify|Merge request %{merge_request} was %{mr_status} by %{updated_by}":["Merge Request %{merge_request} wurde %{mr_status} von %{updated_by}"],"Notify|Merge request %{merge_request} was merged":["Merge Request %{merge_request} wurde zusammengef\xfchrt"],"Notify|Merge request %{mr_link} was closed by %{closed_by}":["Merge Request %{mr_link} wurde von %{closed_by} geschlossen"],"Notify|Merge request URL: %{merge_request_url}":["Merge-Request-URL: %{merge_request_url}"],"Notify|Merge request was approved":["Merge Request wurde genehmigt"],"Notify|Merge request was approved (%{approvals}/%{required_approvals})":["Merge Request wurde genehmigt (%{approvals}/%{required_approvals})"],"Notify|Merge request was unapproved":["Merge Request wurde nicht genehmigt"],"Notify|Merge request was unapproved (%{approvals_count}/%{approvals_required})":["Merge Request wurde nicht genehmigt (%{approvals_count}/%{approvals_required})"],"Notify|Milestone changed to %{milestone}":["Meilenstein zu %{milestone} ge\xe4ndert"],"Notify|Milestone removed":["Meilenstein entfernt"],"Notify|New issue: %{project_issue_url}":["Neues Ticket: %{project_issue_url}"],"Notify|No preview for this file type":["Keine Vorschau f\xfcr diesen Dateityp"],"Notify|No work items have been imported.":["Es wurden keine Arbeitsaufgaben importiert."],"Notify|Pipeline %{pipeline_link} triggered by":["Pipeline %{pipeline_link} ausgel\xf6st durch"],"Notify|Pipeline %{pipeline_name_or_id} has failed!":["Pipeline %{pipeline_name_or_id} ist fehlgeschlagen!"],"Notify|Pipeline %{pipeline_name_or_id} has passed!":["Pipeline %{pipeline_name_or_id} war erfolgreich!"],"Notify|Pipeline has been fixed and %{pipeline_name_or_id} has passed!":["Pipeline wurde repariert und %{pipeline_name_or_id} war erfolgreich!"],"Notify|Please check that your service provider supports email subaddressing and that you have set up email forwarding correctly.":["Bitte \xfcberpr\xfcfen, ob dein Dienstanbieter E-Mail-Unteradressen unterst\xfctzt und ob du die E-Mail-Weiterleitung korrekt eingerichtet hast."],"Notify|Please fix the errors above and try the CSV import again.":["Bitte behebe die oben genannten Fehler und versuche die CSV-Datei erneut zu importieren."],"Notify|Please fix the lines with errors and try the CSV import again.":["Bitte korrigiere die Zeilen mit Fehlern und versuche den CSV-Import erneut."],"Notify|Project %{old_path_with_namespace} was moved to another location.":["Projekt %{old_path_with_namespace} wurde an einen anderen Ort verschoben."],"Notify|Project %{project_name} couldn't be exported.":["Projekt %{project_name} konnte nicht exportiert werden."],"Notify|Project %{project_name} was exported successfully.":["Projekt %{project_name} wurde erfolgreich exportiert."],"Notify|Projects that could not be updated need manual review. You can check the documentation for more information about the pipeline variable setting migration tool.":["Projekte, die nicht aktualisiert werden konnten, m\xfcssen manuell \xfcberpr\xfcft werden. Weitere Informationen zum Migrationstool f\xfcr Einstellungen von Pipeline-Variablen findest du in der Dokumentation."],"Notify|Read timeout:":["Zeit\xfcberschreitung beim Lesen:"],"Notify|Remote mirror":["Remote-Mirror"],"Notify|Repository history rewrite failed on %{project_url}.":["Das Neuschreiben des Repository-Verlaufs f\xfcr %{project_url} ist fehlgeschlagen."],"Notify|Repository history rewrite succeeded on %{project_url}.":["Das Neuschreiben des Repository-Verlaufs f\xfcr %{project_url} war erfolgreich."],"Notify|Repository size is now %{repository_size} MiB.":["Die Repository-Gr\xf6\xdfe betr\xe4gt jetzt %{repository_size}\xa0MiB."],"Notify|Review changes":["\xc4nderungen pr\xfcfen"],"Notify|Review requested":["Pr\xfcfung angefordert"],"Notify|SMTP host issue:":["SMTP-Host-Problem:"],'Notify|Some values in the "type" column could not be matched with supported work item types:':["Einige Werte in der Spalte \u201eTyp\u201c konnten nicht mit unterst\xfctzten Arbeitsaufgabentypen abgeglichen werden:"],"Notify|The Administrator created an account for you. Now you are a member of the company GitLab application.":["Der/die Administrator(in) hat ein Konto f\xfcr Dich erstellt. Du bist nun Mitglied der GitLab-Anwendung des Unternehmens."],"Notify|The Auto DevOps pipeline failed for pipeline %{pipeline_link} and has been disabled for %{project_link}. In order to use the Auto DevOps pipeline with your project, please review the %{supported_langs_link}, adjust your project accordingly, and turn on the Auto DevOps pipeline within your %{settings_link}.":["Die Auto-DevOps-Pipeline ist f\xfcr die Pipeline %{pipeline_link} fehlgeschlagen und wurde f\xfcr %{project_link} deaktiviert. Um die Auto-DevOps-Pipeline mit deinem Projekt zu verwenden, \xfcberpr\xfcfe bitte %{supported_langs_link}, passe dein Projekt entsprechend an und aktiviere die Auto-DevOps-Pipeline in deinen %{settings_link}."],"Notify|The SMTP server did not respond in time.":["Der SMTP-Server hat nicht rechtzeitig geantwortet."],"Notify|The diff for this file was not included because it is too large.":["Der Diff f\xfcr diese Datei war nicht enthalten, weil er zu gro\xdf ist."],"Notify|The diff was not included because it is too large.":["Der Diff war nicht enthalten, weil er zu gro\xdf ist."],"Notify|The download link will expire in 24 hours.":["Der Download-Link l\xe4uft in 24 Stunden ab."],"Notify|The errors we encountered were:":["Die aufgetretenen Fehler waren:"],"Notify|The given credentials (username and password) were rejected by the SMTP server, or you need to explicitly set an authentication method.":["Die angegebenen Zugangsdaten (Benutzername und Passwort) wurden vom SMTP-Server abgelehnt oder du musst explizit eine Authentifizierungsmethode festlegen."],"Notify|The project is now located under %{project_full_name_link_start}%{project_full_name}%{link_end}.":["Das Projekt befindet sich jetzt unter %{project_full_name_link_start}%{project_full_name}%{link_end}."],"Notify|The provided custom email address is %{strong_open}%{email_address}%{strong_close} and uses the SMTP host %{strong_open}%{smtp_host}%{strong_close}.":["Die angegebene benutzerdefinierte E-Mail-Adresse lautet %{strong_open}%{email_address}%{strong_close} und sie verwendet den SMTP-Host %{strong_open}%{smtp_host}%{strong_close}."],"Notify|The push did not contain any new commits, but force pushed to delete the commits and changes below.":["Der Push enthielt keine neuen Commits, erzwang aber das L\xf6schen der unten stehenden Commits und \xc4nderungen."],"Notify|This issue is due on: %{issue_due_date}":["Dieses Ticket ist f\xe4llig am: %{issue_due_date}"],"Notify|This link is valid for %{password_reset_token_valid_time}.":["Dieser Link ist g\xfcltig f\xfcr %{password_reset_token_valid_time}."],"Notify|To enable the custom email address, go to your %{settings_link_start}project's Service Desk settings page%{settings_link_end}.":["Um die benutzerdefinierte E-Mail-Adresse zu aktivieren, gehe zur Seite mit den %{settings_link_start}Service-Desk-Einstellungen deines Projekts%{settings_link_end}."],"Notify|To restart the verification process, go to your %{settings_link_start}project's Service Desk settings page%{settings_link_end}.":["Um den Verifizierungsprozess neu zu starten, gehe zur Seite mit den %{settings_link_start}Service-Desk-Einstellungen deines Projekts%{settings_link_end}."],"Notify|Unless you verify your domain by %{time_start}%{time}%{time_end} it will be removed from your GitLab project.":["Verifiziere deine Domain bis %{time_start}%{time}%{time_end}, ansonsten wird sie aus deinem GitLab-Projekt entfernt."],"Notify|Verification email not received within timeframe:":["Verifizierungs-E-Mail nicht innerhalb des Zeitrahmens erhalten:"],"Notify|Verification for custom email %{email} for %{project_name} triggered":["Verifizierung f\xfcr benutzerdefinierte E-Mail-Adresse %{email} f\xfcr %{project_name} ausgel\xf6st"],"Notify|Verification result for custom email %{email} for %{project_name}":["Verifizierungsergebnis f\xfcr benutzerdefinierte E-Mail-Adresse %{email} f\xfcr %{project_name}"],"Notify|Verify custom email address %{email} for %{project_name}":["Benutzerdefinierte E-Mail-Adresse %{email} f\xfcr %{project_name} verifizieren"],"Notify|We could not verify that we received the email we sent to your email inbox.":["Wir konnten nicht verifizieren, dass wir die E-Mail, die wir an deinen E-Mail-Posteingang gesendet haben, erhalten haben."],"Notify|We could not verify your email address %{strong_open}%{email_address}%{strong_close} for the Service Desk of %{project_link_start}%{project_name}%{project_link_end}.":["Wir konnten deine E-Mail-Adresse %{strong_open}%{email_address}%{strong_close} f\xfcr den Service-Desk von %{project_link_start}%{project_name}%{project_link_end} nicht verifizieren."],"Notify|We did not receive the verification email we sent out to %{strong_open}%{email_address}%{strong_close} in time.":["Wir haben die Verifizierungs-E-Mail, die wir an %{strong_open}%{email_address}%{strong_close} gesendet haben, nicht rechtzeitig erhalten."],"Notify|We wait for 30 minutes for messages to appear in your instance's Service Desk inbox.":["Wir warten 30 Minuten, bis Nachrichten im Posteingang des Service-Desks deiner Instanz erscheinen."],"Notify|We were not able to make a connection to the specified host or there was an SSL issue.":["Wir konnten keine Verbindung zum angegebenen Host herstellen oder es ist ein SSL-Problem aufgetreten."],"Notify|You don't have access to the project.":["Du hast keinen Zugriff auf das Projekt."],"Notify|You have been mentioned in an issue.":["Du wurdest in einem Ticket erw\xe4hnt."],"Notify|You have been mentioned in merge request %{mr_link}":["Du wurdest im Merge Request %{mr_link} erw\xe4hnt"],"Notify|You have been unsubscribed from receiving GitLab administrator notifications.":["Du wurdest vom Empfang von GitLab-Administrator-Benachrichtigungen abgemeldet."],"Notify|You were added as a reviewer on %{long_mr} by %{name}.":["Du wurdest am %{long_mr} von %{name} als Pr\xfcfer(in) hinzugef\xfcgt."],"Notify|Your CSV import for project %{project_link} has been completed.":["Dein CSV-Import f\xfcr Projekt %{project_link} wurde abgeschlossen."],"Notify|Your account has been created successfully.":["Dein Account wurde erfolgreich erstellt."],
"Notify|Your email address %{strong_open}%{email_address}%{strong_close} for the Service Desk of %{project_link_start}%{project_name}%{project_link_end} was verified successfully.":["Deine E-Mail-Adresse %{strong_open}%{email_address}%{strong_close} f\xfcr den Service-Desk von %{project_link_start}%{project_name}%{project_link_end} wurde erfolgreich verifiziert."],"Notify|Your request to join the %{target_to_join} %{target_type} has been %{denied_tag}.":["Deine Anfrage zum Beitritt zu %{target_to_join} %{target_type} wurde %{denied_tag}."],"Notify|currently supported languages":["Aktuell unterst\xfctzte Sprachen"],"Notify|deleted":["el\xf6scht"],"Notify|login..........................................":["Anmelden........................................................................"],"Notify|pushed new":["neu gepusht"],"Notify|pushed to":["gepusht nach"],"Notify|successfully completed %{jobs} in %{stages}.":["%{jobs} erfolgreich in %{stages} abgeschlossen."],Nov:["Nov"],November:["November"],"Now, personalize your GitLab experience":["Personalisiere jetzt dein GitLab-Erlebnis"],"Number of Git pushes after which Gitaly is asked to optimize a repository.":["Anzahl der Git-Pushs, nach denen Gitaly zur Repository-Optimierung aufgefordert wird."],"Number of LOCs per commit":["Anzahl der LOCs pro Commit"],"Number of Reports":["Anzahl der Berichte"],"Number of commits":["Anzahl der Commits"],"Number of commits per MR":["Anzahl der Commits pro MR"],"Number of days to retain security scan data before purging. This controls when scan findings are considered stale and eligible for cleanup. Must be between 7 and 90 days.":[""],"Number of files touched":["Anzahl der verwendeten Dateien"],"Number of namespaces per indexing rollout":["Anzahl der Namensr\xe4ume je Indexierungs-Rollout"],"Number of parallel processes per indexing task":["Anzahl paralleler Prozesse pro Indexierungsauftrag"],"Number of projects":[""],"Number of references exceeds the limit. Please provide no more than %{refs_limit} references at the same time.":["Die Anzahl der Referenzen \xfcberschreitet das Limit. Bitte gib nicht mehr als %{refs_limit}\xa0Referenzen gleichzeitig an."],"Number of replicas":["Anzahl der Replikas"],"Number of replicas per namespace":["Anzahl der Repliken pro Namensraum"],"Number of shards":["Anzahl der Fragmente"],"Number of shards and replicas per index":["Anzahl der Fragmente und Repliken pro Index"],"Number of shards for non-code indexing":["Anzahl der Shards f\xfcr die Nicht-Code-Indizierung"],"Number of users for user cap":["Anzahl der Benutzer f\xfcr die Benutzerkapazit\xe4t"],"OAuth authorizations":["OAuth-Autorisierungen"],"OAuth error occurred. Please try again.":[""],"OAuth state mismatch. Please try again.":[""],OK:["OK"],"OKRs|%{author_link}'s OKR %{work_item_link} requires an update.":["Das folgende OKR des %{author_link}s erfordert eine Aktualisierung: %{work_item_link}"],"OKRs|An update is due on: %{update_due_date}":["Eine Aktualisierung ist f\xe4llig am: %{update_due_date}"],OWASP:[""],"Object does not exist on the server or you don't have permissions to access it":["Das Objekt existiert nicht auf dem Server oder du hast keine Berechtigung, auf dieses zuzugreifen"],Observability:["Beobachtbarkeit"],"ObservabilityLogs|Attribute":["Attribut"],"ObservabilityLogs|Attributes":["Attribute"],"ObservabilityLogs|Count":["Anzahl"],"ObservabilityLogs|Date":["Datum"],"ObservabilityLogs|Failed to load logs.":["Fehler beim Laden der Protokolle."],"ObservabilityLogs|Failed to load metadata.":["Fehler beim Laden der Metadaten."],"ObservabilityLogs|Fingerprint":["Fingerabdruck"],"ObservabilityLogs|Learn more.":["Mehr erfahren."],"ObservabilityLogs|Level":["Stufe"],"ObservabilityLogs|Logs":["Protokolle"],"ObservabilityLogs|Message":["Nachricht"],"ObservabilityLogs|Metadata":["Metadaten"],"ObservabilityLogs|Monitor log events captured from your systems. Send log data to this project using OpenTelemetry. %{docsLink}":["\xdcberwache Protokollereignisse, die von deinen Systemen erfasst wurden. Sende Protokolldaten mit OpenTelemetry an dieses Projekt. %{docsLink}"],"ObservabilityLogs|Resource Attribute":["Ressourcenattribut"],"ObservabilityLogs|Resource attributes":["Ressourcenattribute"],"ObservabilityLogs|Search logs\u2026":["Protokolle werden durchsucht\xa0\u2026"],"ObservabilityLogs|Service":["Dienst"],"ObservabilityLogs|Severity":["Schweregrad"],"ObservabilityLogs|Severity Number":["Schweregradnummer"],"ObservabilityLogs|Showing %{count} logs":["%{count} Protokolle werden angezeigt"],"ObservabilityLogs|Span ID":["Bereichs-ID"],"ObservabilityLogs|Trace Flags":["Spur-Flags"],"ObservabilityLogs|Trace ID":["Spur-ID"],"ObservabilityLogs|name":["Name"],"ObservabilityLogs|value":["Wert"],"ObservabilityMetrics|(Value: %{value})":["(Wert: %{value})"],"ObservabilityMetrics|+%{count} more":["+%{count} weitere"],"ObservabilityMetrics|Cancel":["Abbrechen"],"ObservabilityMetrics|Date":["Datum"],"ObservabilityMetrics|Description":["Beschreibung"],"ObservabilityMetrics|Dimension":["Dimension"],"ObservabilityMetrics|Dimensions":["Dimensionen"],"ObservabilityMetrics|Error: Failed to load metrics details. Try reloading the page.":["Fehler: Die Metrikdetails konnten nicht geladen werden. Versuch die Seite neu zu laden."],"ObservabilityMetrics|Error: Unable to create metric snapshot image.":["Fehler: Es konnte kein Snapshot-Image der Metriken erstellt werden."],"ObservabilityMetrics|Failed to load metrics.":["Metriken konnten nicht geladen werden."],"ObservabilityMetrics|Filter dimensions\u2026":["Dimensionen filtern\xa0\u2026"],"ObservabilityMetrics|Last ingested":["Zuletzt erfasst"],"ObservabilityMetrics|Learn more.":["Mehr erfahren."],"ObservabilityMetrics|Metric Details":["Metrik Details"],"ObservabilityMetrics|Metrics":["Metriken"],"ObservabilityMetrics|Metrics search has been cancelled.":["Metriken-Suche wurde abgebrochen."],"ObservabilityMetrics|Name":["Name"],"ObservabilityMetrics|No data found for the selected time range %{time}":["Keine Daten f\xfcr den ausgew\xe4hlten Zeitbereich %{time} gefunden"],"ObservabilityMetrics|No related traces":["Keine zugeh\xf6rigen Spuren"],"ObservabilityMetrics|No related traces for the selected time. Select another data point and try again.":["Keine zugeh\xf6rigen Spuren f\xfcr die ausgew\xe4hlte Zeit. W\xe4hle einen anderen Datenpunkt aus und versuche es erneut."],"ObservabilityMetrics|Related traces at %{time}":["Zugeh\xf6rige Spuren um %{time}"],"ObservabilityMetrics|Search":["Suche"],"ObservabilityMetrics|Search metrics\u2026":["Metriken werden gesucht\xa0\u2026"],"ObservabilityMetrics|Select dimensions":["Dimensionen ausw\xe4hlen"],"ObservabilityMetrics|Select function":["Funktion ausw\xe4hlen"],"ObservabilityMetrics|Selected dimensions":["Ausgew\xe4hlte Dimensionen"],"ObservabilityMetrics|Trace ID":["Spur-ID"],"ObservabilityMetrics|Track health data from your systems. Send metric data to this project using OpenTelemetry. %{docsLink}":["Verfolge Gesundheitsdaten von deinen Systemen nach. Sende Metrikdaten mit OpenTelemetry an dieses Projekt. %{docsLink}"],"ObservabilityMetrics|Type":["Typ"],"ObservabilityMetrics|Value":["Wert"],"ObservabilityMetrics|View traces":["Spuren anzeigen"],"ObservabilityMetrics|is like":["ist wie"],"ObservabilityMetrics|is not like":["ist nicht wie"],"Observability|%{events} events":["%{events} Ereignisse"],"Observability|32+ character encryption key for secure communication.":["32+-Zeichen-Verschl\xfcsselungsschl\xfcssel f\xfcr sichere Kommunikation."],"Observability|APM & performance":["APM und Performance"],"Observability|Advanced analytics":["Erweiterte Analysen"],"Observability|Alerts":["Warnmeldungen"],"Observability|Allocating compute resources":[""],"Observability|Application performance monitoring with p99 latency tracking and real-time metrics visualization":["\xdcberwachung der Anwendungs-Performance mit p99-Latenzverfolgung und Echtzeit-Metrikvisualisierung"],"Observability|Apply":["Anwenden"],"Observability|Are you sure you want to delete the observability service settings? This action cannot be undone.":["M\xf6chtest du wirklich die Einstellungen des Observability-Dienstes l\xf6schen? Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],"Observability|Are you sure you want to delete this O11y service setting?":["M\xf6chtest du wirklich diese Einstellung des O11y-Dienstes l\xf6schen?"],"Observability|As this is an experimental feature, your insights are important to us. Please don't hesitate to reach out with:":["Dies ist eine experimentelle Funktion. Daher sind deine Erkenntnisse f\xfcr uns sehr wichtig. Du kannst dich gern an uns wenden:"],"Observability|Authentication failed":["Authentifizierung fehlgeschlagen"],"Observability|Authentication failed. Please refresh the page.":["Authentifizierung fehlgeschlagen. Bitte aktualisiere die Seite."],"Observability|Beta release":["Beta-Release"],"Observability|Both endpoints support the full range of OpenTelemetry signal types: traces, metrics, and logs":["Beide Endpunkte unterst\xfctzen s\xe4mtliche OpenTelemetry-Signaltypen: Traces, Metriken und Protokolle"],"Observability|Bug reports":["Fehlerberichte"],"Observability|Built on ClickHouse for superior performance, GitLab Observability makes observability accessible within GitLab.":["Mit der \xfcberlegenen Performance von ClickHouse macht GitLab Observability Observability innerhalb von GitLab zug\xe4nglich."],"Observability|Built on industry-standard OpenTelemetry for seamless integration":["Basierend auf dem Industriestandard OpenTelemetry f\xfcr nahtlose Integration"],"Observability|CI/CD Observability settings":["CI/CD-Observability-Einstellungen"],"Observability|Centralized log management with powerful querying capabilities and advanced search":["Zentralisiertes Protokollmanagement mit leistungsstarken Abfragefunktionen und erweiterter Suche"],"Observability|Centralized logs":["Zentralisierte Protokolle"],"Observability|ClickHouse performance":["ClickHouse-Performance"],"Observability|Configuration notes":["Konfigurationsnotizen"],"Observability|Configure your OpenTelemetry SDK or collector with the appropriate endpoint based on your chosen transport protocol. For detailed integration instructions specific to your language or framework, please refer to the %{otel_docs_link_start}OpenTelemetry documentation for your SDK%{otel_docs_link_end}.":["Konfiguriere dein OpenTelemetry-SDK oder deinen Collector mit dem entsprechenden Endpunkt f\xfcr das ausgew\xe4hlte \xdcbertragungsprotokoll. Detaillierte Anweisungen zur Integration f\xfcr deine Sprache oder dein Framework findest du in der %{otel_docs_link_start}OpenTelemetry-Dokumentation f\xfcr dein SDK%{otel_docs_link_end}."],"Observability|Configure your o11y service connection settings.":["Konfiguriere die Verbindungseinstellungen deines O11y-Dienstes."],"Observability|Configure your observability service connection settings.":["Konfiguriere die Verbindungseinstellungen deines Observability-Dienstes."],"Observability|Configuring OpenTelemetry collectors":[""],"Observability|Configuring authentication":[""],"Observability|Copy HTTP endpoint":["HTTP-Endpunkt kopieren"],"Observability|Copy curl command":["curl-Befehl kopieren"],"Observability|Copy gRPC endpoint":["gRPC-Endpunkt kopieren"],"Observability|Create issues from this page to view them as related items here.":["Erstelle Tickets auf dieser Seite, um sie hier als zugeh\xf6rige Elemente anzuzeigen."],"Observability|Created at":["Erstellt um"],"Observability|Creates alerts automatically for Observability-related errors.":["Erstellt automatisch Alarme f\xfcr Fehler im Zusammenhang mit Observability."],"Observability|Crypto API not available":["Crypto-API nicht verf\xfcgbar"],"Observability|Custom dashboards with anomaly-based alerting and intelligent notification systems":["Benutzerdefinierte Dashboards mit Anomalie-basierten Warnmeldungen und intelligenten Benachrichtigungssystemen"],"Observability|Danger Zone":["Gefahrenzone"],"Observability|Dashboard templates and use cases":["Dashboard-Vorlagen und -Anwendungsf\xe4lle"],"Observability|Dashboards":[""],"Observability|Delete":["L\xf6schen"],"Observability|Delete settings":["Einstellungen l\xf6schen"],"Observability|Distributed tracing":["Verteilte Nachverfolgung"],"Observability|Dive deep into your data with comprehensive analytics, custom visualizations, and intelligent insights for better decision-making.":["Tauche tief in deine Daten ein und triff dank umfassender Analytik, benutzerdefinierten Visualisierungen und intelligenten Erkenntnissen bessere Entscheidungen."],"Observability|Drive the roadmap":["Die Roadmap vorantreiben"],"Observability|Edit":["Bearbeiten"],"Observability|Edit O11y service settings":["O11y-Diensteinstellungen bearbeiten"],"Observability|Email address for authentication with the o11y service.":["E-Mail Adresse f\xfcr die Authentifizierung mit dem O11y-Dienst."],"Observability|Enable Observability":["Observability aktivieren"],"Observability|Enable Observability alerts":["Observability-Alarme aktivieren"],"Observability|Enable tracing, metrics, or logs on your project.":["Aktiviere die Nachverfolgung, Metriken oder Protokolle in deinem Projekt."],"Observability|Encryption key":["Verschl\xfcsselungsschl\xfcssel"],"Observability|Endpoint details":["Endpunkt-Details"],"Observability|Example curl command":["curl-Beispielbefehl"],"Observability|Exception tracking":["Ausnahmenachverfolgung"],"Observability|Exception tracking and error monitoring with detailed stack traces and context":["Ausnahmenachverfolgung und Fehler\xfcberwachung mit detaillierten Stacktraces und Kontext"],"Observability|Exceptions":["Ausnahmen"],"Observability|Experience the power of GitLab Observability with real-time dashboards and comprehensive monitoring capabilities.":["Erlebe die Leistungsf\xe4higkeit von GitLab Observability mit Echtzeit-Dashboards und umfassenden \xdcberwachungsfunktionen."],"Observability|Experimental functionality":["Experimentelle Funktionalit\xe4t"],"Observability|External APIs":[""],"Observability|Failed to create O11y service settings":["Fehler beim Erstellen der Einstellungen des O11y-Dienstes"],"Observability|Failed to delete O11y service settings":["Fehler beim L\xf6schen der Einstellungen des O11y-Dienstes"],"Observability|Failed to delete observability service settings.":["Fehler beim L\xf6schen der Einstellungen des Observability-Dienstes."],"Observability|Failed to load observability usage data.":["Die Observability-Nutzungsdaten konnten nicht geladen werden."],"Observability|Failed to load related issues. Try reloading the page.":["Zugeh\xf6rige Tickets konnten nicht geladen werden. Versuchen, die Seite neu zu laden."],"Observability|Failed to update O11y service settings":["Fehler beim Aktualisieren der Einstellungen des O11y-Dienstes"],"Observability|Feature overview and capabilities":["Funktions\xfcbersicht und -beschreibungen"],"Observability|Feature requests":["Funktionsanfragen"],"Observability|Filter by group ID":["Nach Gruppen-ID filtern"],"Observability|Filter data by month:":["Daten nach Monat filtern:"],"Observability|Firewall configuration: Open outbound access to %{endpoint} on ports 4317-4318":["Firewall-Konfiguration: ausgehenden Zugriff auf %{endpoint} auf den Ports 4317\u20134318 \xf6ffnen"],"Observability|Free during beta period":["W\xe4hrend der Beta-Phase kostenlos"],"Observability|General":["Allgemein"],"Observability|General Observability information":["Allgemeine Observability-Informationen"],"Observability|General feedback and suggestions":["Allgemeines Feedback und Vorschl\xe4ge"],"Observability|GitLab Observability":["GitLab Observability"],"Observability|GitLab Observability dashboard - advanced analytics":["GitLab Observability-Dashboard \u2013 erweiterte Analysen"],"Observability|GitLab Observability dashboard - performance metrics":["GitLab Observability-Dashboard \u2013 Performance-Metriken"],"Observability|GitLab Observability is an open source, OpenTelemetry-native observability platform that unifies logs, metrics, and traces in a single application. Monitor application performance with APM dashboards, visualize distributed traces across microservices, manage centralized logs with powerful querying, and set up intelligent alerts.":["GitLab Observability ist eine Open-Source-Observability-Plattform, die nativ mit OpenTelemetry arbeitet und Protokolle, Metriken und Nachverfolgung in einer Anwendung vereint. \xdcberwache die Anwendungsleistung mit APM-Dashboards, visualisiere verteilte Nachverfolgungen \xfcber Microservices hinweg, verwalte zentralisierte Protokolle mit leistungsstarken Abfragen und richte intelligente Warnmeldungen ein."],"Observability|Group ID":["Gruppen-ID"],"Observability|Group is required":["Gruppe ist erforderlich"],"Observability|Group name":["Gruppenname"],"Observability|Group not found":["Gruppe nicht gefunden"],"Observability|HTTP Endpoint":["HTTP-Endpunkt"],"Observability|If you encounter any connectivity issues or require additional configuration assistance, please contact your system administrator with the endpoint details provided above.":["Wenn du Verbindungsprobleme hast oder Hilfe bei der Konfiguration ben\xf6tigst, wende dich mit den oben angegebenen Details zum Endpunkt an deine(n) Systemadministrator(in)."],"Observability|Iframe not ready for communication":["Iframe nicht bereit zur Kommunikation"],"Observability|Important information":["Wichtige Informationen"],"Observability|Includes Logs, Traces and Metrics. %{learnMoreLink}":["Umfasst Protokolle, Spuren und Metriken. %{learnMoreLink}"],"Observability|Infrastructure":[""],"Observability|Initializing your Observability service":[""],"Observability|Invalid iframe provided":["Ung\xfcltiger iframe angegeben"],"Observability|Kubernetes monitoring":["Kubernetes-\xdcberwachung"],"Observability|Last 1 hour":["Letzte Stunde"],"Observability|Last 12 hours":["Letzte 12\xa0Stunden"],"Observability|Last 14 days":["Letzte 14\xa0Tage"],"Observability|Last 15 minutes":["Letzte 15\xa0Minuten"],"Observability|Last 24 hours":["Letzte 24\xa0Stunden"],"Observability|Last 30 days":["Letzte 30\xa0Tage"],"Observability|Last 30 minutes":["Letzte 30\xa0Minuten"],"Observability|Last 4 hours":["Letzte 4\xa0Stunden"],"Observability|Last 5 minutes":["Letzte 5\xa0Minuten"],"Observability|Last 7 days":["Letzte 7\xa0Tage"],"Observability|Length must be a positive integer":["L\xe4nge muss ein positiver Integer-Wert sein"],"Observability|Loading...":["Laden\u2026"],"Observability|Logs":[""],"Observability|Manage your o11y service connection settings.":["Verwalte die Verbindungseinstellungen deines O11y-Dienstes."],"Observability|Message validation failed":["Nachrichtenvalidierung fehlgeschlagen"],"Observability|Messaging queues":["Nachrichtenwarteschlangen"],"Observability|Metrics":[""],"Observability|Monitor application performance with detailed metrics, response times, and system health indicators in real-time dashboards.":["\xdcberwache die Anwendungsleistung mit detaillierten Metriken, Antwortzeiten und Systemzustandsindikatoren in Echtzeit-Dashboards."],"Observability|Native Kubernetes monitoring with pod-level metrics and cluster health insights":["Native Kubernetes-\xdcberwachung mit Pod-Metriken und Einblicken in die Cluster-Zust\xe4nde"],"Observability|Network requirements: Allow outbound TCP connections to the endpoints listed above":["Netzwerkanforderungen: ausgehende TCP-Verbindungen zu den oben aufgef\xfchrten Endpunkten zulassen"],"Observability|New O11y service setting":["Neue O11y-Diensteinstellung"],"Observability|Next steps":["N\xe4chste Schritte"],"Observability|No cost":["Kostenlos"],"Observability|Notification channels":["Benachrichtigungskan\xe4le"],"Observability|O11y Service Settings":["O11y-Diensteinstellungen"],"Observability|O11y service configuration":["O11y-Dienstkonfiguration"],"Observability|O11y service configurations":["O11y-Dienstkonfigurationen"],"Observability|O11y service settings":["O11y-Diensteinstellungen"],"Observability|O11y service settings already exist":["O11y-Diensteinstellungen bereits vorhanden"],"Observability|Observability":["Observability"],"Observability|Observability Service Configuration":["Observability-Dienstkonfiguration"],"Observability|Observability configuration":["Observability-Konfiguration"],"Observability|Observability for CI/CD is enabled! Your CI/CD pipelines are automatically configured to export telemetry data, giving you comprehensive insights into your build and deployment processes.":["Observability f\xfcr CI/CD ist aktiviert! Deine CI/CD-Pipelines werden automatisch f\xfcr den Export von Telemetriedaten konfiguriert, um umfassende Einblicke in deine Build- und Bereitstellungsprozesse zu liefern."],"Observability|Observability is already enabled for this group":["Observability ist f\xfcr diese Gruppe bereits aktiviert"],"Observability|Observability service settings deleted successfully.":["Einstellungen des Observability-Dienstes erfolgreich gel\xf6scht."],"Observability|Observability service settings updated successfully.":["Einstellungen des Observability-Dienstes erfolgreich aktualisiert."],"Observability|Observability settings for group %{group_name} created successfully.":["Observability-Einstellungen f\xfcr Gruppe %{group_name} wurden erstellt."],"Observability|Observability settings for group %{group_name} deleted successfully.":["Observability-Einstellungen f\xfcr Gruppe %{group_name} wurden gel\xf6scht."],"Observability|Observability settings for group %{group_name} updated successfully.":["Observability-Einstellungen f\xfcr Gruppe %{group_name} wurden aktualisiert."],"Observability|Once provisioned, you can test your HTTP endpoint by sending a sample OpenTelemetry payload using curl. This helps verify that your endpoint is accessible and configured correctly.":["Nach der Bereitstellung kannst du deinen HTTP-Endpunkt testen, indem du OpenTelemetry-Beispielnutzdaten mit curl sendest. Auf diese Weise kannst du \xfcberpr\xfcfen, ob dein Endpunkt erreichbar und korrekt konfiguriert ist."],"Observability|OpenTelemetry native":["OpenTelemetry-Nativ"],"Observability|Password for authentication with the o11y service.":["Passwort f\xfcr die Authentifizierung mit dem O11y-Dienst."],"Observability|Performance overview":["Performance-\xdcbersicht"],"Observability|Permanently delete the observability service configuration.":["L\xf6sche die Einstellungen des Observability-Dienstes dauerhaft."],"Observability|Project not found":["Projekt nicht gefunden"],"Observability|Provisioning databases":[""],"Observability|Provisioning time":["Bereitstellungszeit"],"Observability|Related issues":["Zugeh\xf6rige Tickets"],"Observability|See it in action":["In Aktion ansehen"],"Observability|Service map":["Dienstkarte"],"Observability|Service name":["Dienstname"],"Observability|Services":["Dienste"],"Observability|Setup":["Einrichtung"],"Observability|Shape the roadmap with direct feedback channels to our development team":["Gestalte die Roadmap mit direkten Feedback-Kan\xe4len zu unserem Entwicklungsteam"],"Observability|Single pane of glass for logs, metrics, and traces within GitLab":["Ein zentrales Dashboard f\xfcr Protokolle, Metriken und Nachverfolgungen innerhalb von GitLab"],"Observability|Smart alerts":["Intelligente Warnmeldungen"],"Observability|Sorry, there is no usage data for the selected period":["Leider liegen f\xfcr den gew\xe4hlten Zeitraum keine Nutzungsdaten vor"],"Observability|Sorry, your filter produced no results":["F\xfcr deinen Filter gibt es leider keine Ergebnisse"],"Observability|Spinning up service containers":[""],"Observability|Superior query performance and data compression with ClickHouse backend":["\xdcberlegene Abfrageperformance und Datenkompression mit ClickHouse-Backend"],"Observability|Testing your endpoints":["Deine Endpunkte testen"],"Observability|The HTTP endpoint (port 4318) accepts OTLP/HTTP protocol and is suitable for applications using HTTP-based transport":["Der HTTP-Endpunkt (Port 4318) unterst\xfctzt das OTLP-/HTTP-Protokoll und eignet sich f\xfcr Anwendungen mit HTTP-basierter \xdcbertragung"],"Observability|The ID of the group for this o11y service configuration.":["Die ID der Gruppe f\xfcr diese O11y-Dienstkonfiguration."],"Observability|The gRPC endpoint (port 4317) accepts OTLP/gRPC protocol and is recommended for applications requiring persistent connections or streaming capabilities":["Der gRPC-Endpunkt (Port 4317) unterst\xfctzt das OTLP-/gRPC-Protokoll und wird f\xfcr Anwendungen empfohlen, bei denen persistente Verbindungen oder Streamingfunktionen erforderlich sind."],"Observability|The name of the group for this o11y service configuration.":["Der Name der Gruppe f\xfcr diese O11y-Dienstkonfiguration."],"Observability|The name of your o11y service instance.":["Der Name deiner O11y-Dienstinstanz."],"Observability|The observability service is still initializing. Please try again in a few minutes.":[""],"Observability|To enable GitLab Observability, please ask your %{strong_start}GitLab administrator%{strong_end} to enable it for this group.":[""],"Observability|To enable Observability for CI/CD, set the %{variable_name} CI/CD variable in your group's %{settings_link_start}CI/CD settings%{settings_link_end} to a comma-separated list of data types to export: metrics, logs, and/or traces (e.g., %{metrics_logs} or %{all_data_types}).":["Lege die CI/CD-Variable %{variable_name} in den %{settings_link_start}CI/CD-Einstellungen%{settings_link_end} deiner Gruppe auf eine kommagetrennte Liste aller zu exportierenden Datentypen fest, um die Observability f\xfcr CI/CD zu aktivieren: Metriken, Protokolle und/oder Nachverfolgungen (z.\xa0B., %{metrics_logs} oder %{all_data_types})."],"Observability|To widen your search, change or remove filters above":["\xc4ndere oder entferne die obigen Filter, um deine Suche auszuweiten"],"Observability|Traces":[""],"Observability|Tracing, Metrics & Logs":["Nachverfolgung, Metriken und Protokolle"],"Observability|Troubleshooting tips":["Tipps zur Fehlerbehebung"],"Observability|Try selecting a different period.":["Versuche, einen anderen Zeitraum auszuw\xe4hlen."],"Observability|Unified platform":["Vereinheitlichte Plattform"],"Observability|Unknown group":["Unbekannte Gruppe"],"Observability|Up to %{minutes} minutes":["Bis zu %{minutes} Minuten"],"Observability|Update your o11y service connection settings.":["Aktualisiere die Verbindungseinstellungen deines O11y-Dienstes."],"Observability|Usage by day":["Nutzung nach Tag"],"Observability|User email":["Benutzer-E-Mail"],"Observability|User is required":["Benutzer(in) ist erforderlich"],"Observability|VPN and proxy: If operating within a VPN or behind a proxy, ensure routing rules permit traffic to these external endpoints. Configure proxy settings in your OpenTelemetry SDK if required":["VPN und Proxy: Wenn du dich hinter einem VPN oder einem Proxy befindest, solltest du Routing-Regeln einrichten, die den Datenverkehr zu diesen externen Endpunkten erlauben. Konfiguriere die Proxy-Einstellungen ggf. in deinem OpenTelemetry SDK."],"Observability|View our %{documentation} for further instructions on how to use these features.":["In unserer %{documentation} findest du weitere Anleitungen zur Nutzung dieser Funktionen."],"Observability|View the %{help_page_link_start}Observability documentation%{help_page_link_end} for:":["%{help_page_link_start}Observability-Dokumentation%{help_page_link_end} anzeigen f\xfcr:"],"Observability|Visualize distributed traces with flamegraphs across microservices and understand request flows":["Verteilte Nachverfolgungen mit Flamegraphs \xfcber Microservices hinweg visualisieren und Anfrage-Flows verstehen"],"Observability|We value your feedback":["Dein Feedback ist uns wichtig"],"Observability|Welcome to GitLab Observability!":["Willkommen bei GitLab\xa0Observability!"],"Observability|What you get":["Leistungsumfang"],"Observability|What's coming next":["Ank\xfcndigungen"],"Observability|You are not authorized to request observability access":["Du bist nicht autorisiert, Oberservability-Zugriff anzufordern"],"Observability|You can contact us through our %{issue_link_start}feedback issue in GitLab%{issue_link_end}. You can also join our %{discord_link_start}Discord channel%{discord_link_end} for community discussions and support.":["Du kannst uns \xfcber unser %{issue_link_start}Feedback-Ticket in GitLab%{issue_link_end} kontaktieren. Dar\xfcber hinaus kannst du unserem %{discord_link_start}Discord-Kanal%{discord_link_end} beitreten, in dem du an Community-Diskussionen teilnehmen und Support anfordern kannst."],"Observability|You can test your HTTP endpoint by sending a sample OpenTelemetry payload using curl. This helps verify that your endpoint is accessible and configured correctly.":["Du kannst deinen HTTP-Endpunkt testen, indem du OpenTelemetry-Beispielnutzdaten mit curl sendest. Auf diese Weise kannst du \xfcberpr\xfcfen, ob dein Endpunkt erreichbar und korrekt konfiguriert ist."],"Observability|Your OpenTelemetry (OTel) telemetry data collection endpoints are being provisioned. Once complete, they will be ready to receive data. Please configure your instrumentation with the following endpoints:":["Deine OpenTelemetry (OTel)-Endpunkte zur Datenerfassung werden bereitgestellt und k\xf6nnen anschlie\xdfend Daten empfangen. Konfiguriere deine Instrumentierung mit den folgenden Endpunkten:"],"Observability|Your OpenTelemetry (OTel) telemetry data collection endpoints have been provisioned and are ready to receive data. Please configure your instrumentation with the following endpoints:":["Deine OpenTelemetry (OTel)-Endpunkte zur Datenerfassung wurden bereitgestellt und k\xf6nnen ab sofort Daten empfangen. Konfiguriere deine Instrumente mit den folgenden Endpunkten:"],"Observability|Your OpenTelemetry endpoint configuration":["Konfiguration deiner OpenTelemetry-Endpunkte"],"Observability|allowedMessageType must be a non-empty string":["allowedMessageType muss eine nicht leere Zeichenfolge sein"],"Observability|allowedOrigin must be a non-empty string":["allowedOrigin muss eine nicht leere Zeichenfolge sein"],"Observability|authTokens must be an object":["authTokens muss ein Objekt sein"],"Observability|gRPC Endpoint":["gRPC-Endpunkt"],"Observability|targetPath must be a non-empty string":["targetPath muss eine nicht leere Zeichenfolge sein"],Oct:["Okt"],October:["Oktober"],Off:["Aus"],Offline:["Offline"],"Offline license":["Offline-Lizenz"],"Offline nodes automatically deleted after":["Offline-Knoten automatisch l\xf6schen nach"],"OfflineTransfer|Export failed. Entity full paths must be provided.":["Export fehlgeschlagen. Vollst\xe4ndige Entit\xe4tspfade m\xfcssen angegeben werden."],"OfflineTransfer|Export failed. You do not have permission to export the following resources or they do not exist: %{paths}":["Export fehlgeschlagen. Du hast keine Berechtigung, die folgenden Ressourcen zu exportieren, oder sie sind nicht vorhanden: %{paths}"],"OfflineTransfer|Object storage request responded with status %{status}":["Objektspeicheranforderung hat mit Status %{status} geantwortet"],"OfflineTransfer|Unable to access object storage bucket.":["Kein Zugriff auf Objektspeicher-Bucket m\xf6glich."],"Oh no!":["Oh nein!"],Ok:["OK"],Okay:["Okay"],"Oldest first":["\xc4lteste zuerst"],OmniAuth:["OmniAuth"],On:["An"],"On %{end_date}, your trial will end and %{namespace_name} will be limited to %{free_user_limit} member":["Am %{end_date} endet deine Testversion und %{namespace_name} wird auf %{free_user_limit} Mitglied beschr\xe4nkt.","Am %{end_date} endet deine Testversion und %{namespace_name} wird auf %{free_user_limit} Mitglieder beschr\xe4nkt."],"On the confirmation dialog, choose a deletion method.":["W\xe4hle eine L\xf6schmethode im Best\xe4tigungsdialog."],"On the upper right, select the overflow menu, then select %{strongStart}Delete%{strongEnd}.":["W\xe4hle oben rechts das \xdcberlaufmen\xfc aus und w\xe4hle dann %{strongStart}L\xf6schen%{strongEnd} aus."],"On the upper right, select the overflow menu, then select Delete.":["W\xe4hle oben rechts das \xdcberlaufmen\xfc aus und w\xe4hle dann L\xf6schen aus."],"On this page":["Auf dieser Seite"],"On track":["Planm\xe4\xdfig"],"On-call Schedules":["Bereitschaftszeitpl\xe4ne"],"On-call schedules":["Bereitschaftszeitpl\xe4ne"],"OnCallScheduless|Any escalation rules that are using this schedule will also be deleted.":["Alle Eskalationsregeln, die diesen Zeitplan verwenden, werden ebenfalls gel\xf6scht."],"OnCallSchedules|1 day":["1 Tag"],"OnCallSchedules|2 weeks":["2 Wochen"],"OnCallSchedules|Add a rotation":["Rotation hinzuf\xfcgen"],
"OnCallSchedules|Add an additional schedule to your project":["F\xfcge deinem Projekt einen zus\xe4tzlichen Zeitplan hinzu"],"OnCallSchedules|Add rotation":["Rotation hinzuf\xfcgen"],"OnCallSchedules|Add schedule":["Zeitplan hinzuf\xfcgen"],'OnCallSchedules|Are you sure you want to delete the "%{deleteRotation}" rotation? This action cannot be undone.':["Bist du sicher, dass du die Rotation \u201e%{deleteRotation}\u201c l\xf6schen m\xf6chtest? Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],'OnCallSchedules|Are you sure you want to delete the "%{deleteSchedule}" schedule? This action cannot be undone.':["Bist du sicher, dass du den \u201e%{deleteSchedule}\u201c-Zeitplan l\xf6schen m\xf6chtest? Diese Aktion kann nicht r\xfcckg\xe4ngig gemacht werden."],"OnCallSchedules|Collapse schedule":["Zeitplan einklappen"],"OnCallSchedules|Create on-call schedules in GitLab":["Abrufzeitpl\xe4ne in GitLab erstellen"],"OnCallSchedules|Currently no rotation":["Derzeit keine Rotation"],"OnCallSchedules|Delete rotation":["Rotation l\xf6schen"],"OnCallSchedules|Delete schedule":["Zeitplan l\xf6schen"],"OnCallSchedules|Edit rotation":["Rotation bearbeiten"],"OnCallSchedules|Edit schedule":["Zeitplan bearbeiten"],"OnCallSchedules|Enable end date":["Enddatum aktivieren"],"OnCallSchedules|Expand schedule":["Zeitplan erweitern"],"OnCallSchedules|Failed to add rotation":["Rotation konnte nicht hinzugef\xfcgt werden"],"OnCallSchedules|Failed to add schedule":["Zeitplan konnte nicht hinzugef\xfcgt werden"],"OnCallSchedules|Failed to edit schedule":["Zeitplan konnte nicht bearbeitet werden"],"OnCallSchedules|For this rotation, on-call will be:":["F\xfcr diese Rotation ist in Bereitschaft:"],"OnCallSchedules|On-call schedule %{obstacle} in project %{project}":["Abrufzeitplan %{obstacle} im Projekt %{project}"],"OnCallSchedules|On-call schedules":["Bereitschaftszeitpl\xe4ne"],"OnCallSchedules|Please note, rotations with shifts that are less than four hours are currently not supported in the weekly view.":["Bitte beachte, dass Rotationen mit Schichten, die weniger als vier Stunden betragen, derzeit in der Wochenansicht nicht unterst\xfctzt werden."],"OnCallSchedules|Removing this user may put their on-call team at risk of missing a notification.":["Das Entfernen dieses Benutzers/dieser Benutzerin kann sein Bereitschaftsteam dem Risiko aussetzen, eine Benachrichtigung zu verpassen."],"OnCallSchedules|Removing yourself may put your on-call team at risk of missing a notification.":["Das Entfernen selbst kann dein Bereitschaftsteam dem Risiko aussetzen, eine Benachrichtigung zu verpassen."],"OnCallSchedules|Restrict to time intervals":["Auf Zeitintervalle beschr\xe4nken"],"OnCallSchedules|Rotation end date/time must come after start date/time":["Rotationsenddatum/-zeit muss nach Startdatum/-zeit liegen"],"OnCallSchedules|Rotation length":["Rotationsl\xe4nge"],"OnCallSchedules|Rotation length must be a positive number":["Die Rotationsl\xe4nge muss eine positive Zahl sein."],"OnCallSchedules|Rotation name cannot be empty":["Rotationsname darf nicht leer sein"],"OnCallSchedules|Rotation participants cannot be empty":["Rotationsteilnehmer d\xfcrfen nicht leer sein"],"OnCallSchedules|Rotation start date cannot be empty":["Rotationsstartdatum darf nicht leer sein"],"OnCallSchedules|Rotations":["Rotationen"],"OnCallSchedules|Route alerts directly to specific members of your team":["Benachrichtigungen direkt an bestimmte Mitglieder deines Teams weiterleiten"],"OnCallSchedules|Route alerts directly to specific members of your team. To access this feature, ask %{linkStart}a project Owner%{linkEnd} to grant you at least the Maintainer role.":["Leite Alarme direkt an bestimmte Mitglieder deines Teams weiter. Um auf diese Funktion zuzugreifen, bitte %{linkStart}eine(n) Projekteigent\xfcmer(in)%{linkEnd}, dir mindestens die Betreuerrolle zuzuweisen."],"OnCallSchedules|Select participant":["Teilnehmer ausw\xe4hlen"],"OnCallSchedules|Select timezone":["Zeitzone ausw\xe4hlen"],"OnCallSchedules|Sets the default timezone for the schedule, for all participants":["Legt die Standardzeitzone f\xfcr den Zeitplan f\xfcr alle Teilnehmer fest"],"OnCallSchedules|Successfully created a new rotation":["Neue Rotation erfolgreich erstellt"],"OnCallSchedules|Successfully edited your rotation":["Rotation erfolgreich bearbeitet"],"OnCallSchedules|The rotation could not be deleted. Please try again.":["Die Rotation konnte nicht gel\xf6scht werden. Bitte erneut versuchen."],"OnCallSchedules|The rotation could not be updated. Please try again.":["Die Rotation konnte nicht aktualisiert werden. Bitte erneut versuchen."],"OnCallSchedules|The schedule could not be deleted. Please try again.":["Der Zeitplan konnte nicht gel\xf6scht werden. Bitte erneut versuchen."],"OnCallSchedules|The schedule could not be updated. Please try again.":["Der Zeitplan konnte nicht aktualisiert werden. Bitte erneut versuchen."],"OnCallSchedules|Try adding a rotation":["Versuche, eine Rotation hinzuzuf\xfcgen"],"OnCallSchedules|User %{name} is currently part of:":["Benutzer(in) %{name} ist derzeit Teil von:"],"OnCallSchedules|View next timeframe":["N\xe4chstes Zeitfenster anzeigen"],"OnCallSchedules|View previous timeframe":["Vorheriges Zeitfenster anzeigen"],"OnCallSchedules|You are currently a part of:":["Du bist derzeit Teil von:"],"OnCallSchedules|Your schedule has been successfully created. To add individual users to this schedule, use the Add a rotation button. To enable notifications for this schedule, you must also create an %{linkStart}escalation policy%{linkEnd}.":["Dein Zeitplan wurde erfolgreich erstellt. Um einzelne Benutzer(innen) zu diesem Zeitplan hinzuzuf\xfcgen, verwende die Schaltfl\xe4che Rotation hinzuf\xfcgen. Um Benachrichtigungen f\xfcr diesen Zeitplan zu aktivieren, musst du auch eine %{linkStart}Eskalationsrichtlinie%{linkEnd} erstellen."],"OnDemandScans|%{learnMoreLinkStart}Learn more about on-demand scans%{learnMoreLinkEnd}.":["%{learnMoreLinkStart} Erfahre mehr \xfcber Scans auf Anforderung%{learnMoreLinkEnd}."],"OnDemandScans|%{profileType} profile library":["%{profileType} Profilbibliothek"],"OnDemandScans|%{textStart}Tags specify which runners process this scan. Runners must have every tag selected.%{textEnd} %{linkStart}What are runner tags?%{linkEnd}":["%{textStart}Tags geben an, welche Runner diesen Scan verarbeiten. In den Runnern m\xfcssen alle Tags ausgew\xe4hlt werden.%{textEnd} %{linkStart}Was sind Runner-Tags?%{linkEnd}"],"OnDemandScans|Add a schedule to run this scan at a specified date and time or on a recurring basis. Scheduled scans are automatically saved to scan library.":["F\xfcge einen Zeitplan f\xfcr die Ausf\xfchrung dieses Scans zu einem bestimmten Datum und zu einer bestimmten Uhrzeit oder auf wiederkehrender Basis hinzu. Geplante Scans werden automatisch in der Scan-Bibliothek gespeichert."],"OnDemandScans|Analyze a deployed version of your web application for known vulnerabilities by examining it from the outside in. DAST works by simulating external attacks on your application while it is running.":["Analysiere eine bereitgestellte Version deiner Webanwendung auf bekannte Schwachstellen, indem du sie von au\xdfen untersuchst. DAST simuliert externe Angriffe auf deine Anwendung, w\xe4hrend diese ausgef\xfchrt wird."],"OnDemandScans|Are you sure you want to delete this scan?":["M\xf6chtest du diesen Scan wirklich l\xf6schen?"],"OnDemandScans|Cancel":["Abbrechen"],"OnDemandScans|Could not delete saved scan. Please refresh the page, or try again later.":["Der gespeicherte Scan konnte nicht gel\xf6scht werden. Bitte aktualisiere die Seite oder versuche es sp\xe4ter erneut."],"OnDemandScans|Could not fetch on-demand scans. Please refresh the page, or try again later.":["Scans auf Anforderung konnten nicht abgerufen werden. Bitte aktualisiere die Seite oder versuche es sp\xe4ter erneut."],"OnDemandScans|Could not fetch scanner profiles. Please refresh the page, or try again later.":["Das Scannerprofil konnte nicht gel\xf6scht werden. Bitte aktualisiere die Seite oder versuche es sp\xe4ter erneut."],"OnDemandScans|Could not fetch site profiles. Please refresh the page, or try again later.":["Das Seitenprofil konnte nicht abgerufen werden. Bitte aktualisiere die Seite oder versuche es sp\xe4ter erneut."],"OnDemandScans|Could not run the scan. Please try again.":["Der Scan konnte nicht ausgef\xfchrt werden. Bitte erneut versuchen."],"OnDemandScans|DAST configuration":["DAST-Konfiguration"],"OnDemandScans|DAST scans for vulnerabilities in your project's running application, website, or API. For details of all configuration options, see the %{linkStart}GitLab DAST documentation%{linkEnd}.":["DAST scannt auf Sicherheitsl\xfccken in der Anwendung, Website oder API deines Projekts. Einzelheiten zu allen Konfigurationsoptionen findest du in der %{linkStart}GitLab DAST-Dokumentation%{linkEnd}."],"OnDemandScans|Define the fundamental configuration options for your on-demand scan.":["Definiere die grundlegenden Konfigurationsoptionen f\xfcr deinen On-Demand-Scan."],"OnDemandScans|Delete profile":["Profil l\xf6schen"],"OnDemandScans|Description":["Beschreibung"],"OnDemandScans|Discard changes":["\xc4nderungen verwerfen"],"OnDemandScans|Do you want to discard the changes or keep editing this profile? Unsaved changes will be lost.":["M\xf6chtest Du die \xc4nderungen verwerfen oder dieses Profil weiterhin bearbeiten? Nicht gespeicherte \xc4nderungen gehen verloren."],"OnDemandScans|Dynamic Application Security Testing (DAST)":["Dynamische Anwendungssicherheitstests (DAST)"],"OnDemandScans|Edit %{profileType} profile":["%{profileType}-Profil bearbeiten"],"OnDemandScans|Edit on-demand DAST scan":["DAST-Scan auf Anforderung bearbeiten"],"OnDemandScans|Edit on-demand scan":["DAST-Scan auf Anforderung bearbeiten"],"OnDemandScans|Edit profile":["Profil bearbeiten"],"OnDemandScans|Enable scan schedule":["Scan-Zeitplan aktivieren"],"OnDemandScans|For example: Tests the login page for SQL injections":["Zum Beispiel: Testet die Anmeldeseite f\xfcr SQL-Injektionen"],"OnDemandScans|Keep editing":["Bearbeitung fortsetzen"],"OnDemandScans|My daily scan":["Mein t\xe4glicher Scan"],"OnDemandScans|New %{profileType} profile":["Neues %{profileType}-Profil"],"OnDemandScans|New on-demand DAST scan":["Neuer On-Demand-DAST-Scan"],"OnDemandScans|New on-demand scan":["Neuer DAST-Scan auf Anforderung"],"OnDemandScans|New profile":["Neues Profil"],"OnDemandScans|New scan":["Neuer Scan"],"OnDemandScans|No %{profileType} profiles found for DAST":["Keine %{profileType}-Profile f\xfcr DAST gefunden"],"OnDemandScans|On-demand Scans":["On-Demand-Scans"],"OnDemandScans|On-demand scans":["Scans of Anforderung"],"OnDemandScans|On-demand scans run outside of DevOps cycle and find vulnerabilities in your projects. %{learnMoreLinkStart}Learn more%{learnMoreLinkEnd}.":["Scans auf Anforderung werden au\xdferhalb des DevOps-Zyklus ausgef\xfchrt und suchen nach Sicherheitsl\xfccken in deinen Projekten. %{learnMoreLinkStart}Mehr erfahren%{learnMoreLinkEnd}."],"OnDemandScans|On-demand scans run outside the DevOps cycle and find vulnerabilities in your projects. %{learnMoreLinkStart}Learn more%{learnMoreLinkEnd}.":["On-Demand-Scans werden au\xdferhalb des DevOps-Zyklus ausgef\xfchrt und suchen nach Sicherheitsl\xfccken in deinen Projekten. %{learnMoreLinkStart}Weitere Informationen%{learnMoreLinkEnd}."],"OnDemandScans|Only project owners and maintainers can select runner tags.":["Nur Projekteigent\xfcmer(innen) und Betreuer(innen) k\xf6nnen Runner-Tags ausw\xe4hlen."],"OnDemandScans|Pre-scan verification for %{profile_name} completed with":["Vorabpr\xfcfung f\xfcr %{profile_name} abgeschlossen mit"],"OnDemandScans|Repeats":["Wiederholungen"],"OnDemandScans|Run scan":["Scan ausf\xfchren"],"OnDemandScans|Runner tags":["Runner-Tags"],"OnDemandScans|Save and run scan":["Scan speichern und ausf\xfchren"],"OnDemandScans|Save scan":["Scan speichern"],"OnDemandScans|Scan configuration":["Scan-Konfiguration"],"OnDemandScans|Scan library":["Scan-Bibliothek"],"OnDemandScans|Scan name":["Scanname"],"OnDemandScans|Scan results will be associated with the selected branch.":["Scan-Ergebnisse werden dem ausgew\xe4hlten Branch zugeordnet."],"OnDemandScans|Scan schedule":["Scan-Zeitplan"],"OnDemandScans|Scan type":["Scantyp"],"OnDemandScans|Select runner tags":["Runner-Tags ausw\xe4hlen"],"OnDemandScans|Start by creating a new profile. Profiles make it easy to save and reuse configuration details for GitLab\u2019s security tools.":["Erstelle zun\xe4chst ein neues Profil. Profile erleichtern das Speichern und Wiederverwenden von Konfigurationsdetails f\xfcr die Sicherheitstools von GitLab."],"OnDemandScans|Start time":["Startzeit"],"OnDemandScans|Target":["Ziel"],"OnDemandScans|The scan could not be canceled.":["Der Scan konnte nicht abgebrochen werden."],"OnDemandScans|The scan could not be retried.":["Der Scan konnte nicht wiederholt werden."],"OnDemandScans|There are no finished scans.":["Es gibt keine fertigen Scans."],"OnDemandScans|There are no running scans.":["Es gibt keine laufenden Scans."],"OnDemandScans|There are no saved scans.":["Es sind keine gespeicherten Scans vorhanden."],"OnDemandScans|There are no scheduled scans.":["Es gibt keine geplanten Scans."],"OnDemandScans|Timezone":["Zeitzone"],"OnDemandScans|Unable to fetch runner tags. Try reloading the page.":["Fehler beim Abrufen der Runner-Tags. Aktualisiere die Seite."],"OnDemandScans|Verify configuration":["Konfiguration \xfcberpr\xfcfen"],"OnDemandScans|View results":["Ergebnisse anzeigen"],"OnDemandScans|You cannot perform any action on this page because you only have %{linkStart}auditor-level access%{linkEnd} and are not a member of the project.":["Du kannst auf dieser Seite keine Aktion ausf\xfchren, da du nur %{linkStart}Pr\xfcfer(innen)-Zugriff%{linkEnd} hast und kein Mitglied des Projekts bist."],"OnDemandScans|You have unsaved changes":["Du hast ungespeicherte \xc4nderungen"],"OnDemandScans|You must create a repository within your project to run an on-demand scan.":["Du musst ein Repository in deinem Projekt erstellen, um einen Anforderungsscan auszuf\xfchren."],"OnDemandScans|at":["um"],Ona:["Ona"],"Onboarding|If you can't find your organization, request an invite from your company's GitLab administrator.":["Wenn du deine Organisation nicht finden kannst, fordere eine Einladung von der oder dem GitLab-Administrator(in) deines Unternehmens an."],"Onboarding|Looking for your team?":["Bist du auf der Suche nach deinem Team?"],"Once imported, repositories can be mirrored over SSH. Read more %{link_start}here%{link_end}.":["Nach dem Importieren k\xf6nnen Repositorys \xfcber SSH gespiegelt werden. Weitere Informationen findest du %{link_start}hier%{link_end}."],"Once you reach the number of seats in your subscription, you can no longer invite or add users to the namespace.":["Sobald du die Anzahl der Pl\xe4tze in deinem Abonnement erreicht hast, kannst du keine weiteren Benutzer(innen) mehr zum Namensraum einladen oder hinzuf\xfcgen."],"One and only one of %{params} is required":["Nur eines der %{params} ist erforderlich"],"One and only one of [cn, filter] arguments is required":["Ausschlie\xdflich eines der Argumente [cn, filter] ist erforderlich"],"One more item":["Ein weiteres Element","%d weitere Elemente"],"One or more arguments are invalid: %{args}.":["Ein oder mehrere Argumente sind ung\xfcltig: %{args}."],"One or more contacts were successfully added.":["Mindestens ein Kontakt wurde erfolgreich hinzugef\xfcgt."],"One or more contacts were successfully removed.":["Mindestens ein Kontakt wurde erfolgreich entfernt."],"One or more groups that you don't have access to.":["Eine oder mehrere Gruppen, auf die du keinen Zugriff hast."],"One or more of you personal access tokens were revoked":["Einer oder mehrere deiner pers\xf6nlichen Zugriffstoken wurden widerrufen"],"One or more of your %{provider} projects cannot be imported into GitLab directly because they use Subversion or Mercurial for version control, rather than Git.":["Mindestens eines deiner %{provider}-Projekte kann nicht direkt in GitLab importiert werden, da nicht Git sondern Subversion oder Mercurial f\xfcr die Versionskontrolle verwendet wird."],"One or more of your personal access tokens has expired.":["Mindestens eines deiner pers\xf6nlichen Zugriffstoken ist abgelaufen."],"One or more of your personal access tokens have expired.":["Ein oder mehrere deiner pers\xf6nlichen Zugriffstoken sind abgelaufen."],"One or more of your personal access tokens will expire in %{days_to_expire} days or less:":["Eines oder mehrere deiner pers\xf6nlichen Zugriffstoken laufen in %{days_to_expire} Tagen oder weniger ab:"],"One-time password authenticator (OTP)":["Einmal-Passwort-Authentifikator (OTP)"],"One-time password authenticator deleted":["Einmal-Passwort-Authentifikator gel\xf6scht"],"One-time password authenticator has been deleted!":["Der Einmalpasswort-Authentifikator wurde gel\xf6scht!"],"One-time password authenticator registered":["Einmal-Passwort-Authentifikator registriert"],"Online license":["Online-Lizenz"],"Only %{n} embedded views can be automatically displayed on a page. Click the button below to manually display this view.":["Nur %{n}\xa0eingebettete Ansichten k\xf6nnen automatisch auf einer Seite angezeigt werden. Klicke auf die Schaltfl\xe4che unten, um diese Ansicht manuell anzuzeigen."],"Only %{workspaceType} members with %{permissions} can view or be notified about this %{issuableType}.":["Nur %{workspaceType}-Mitglieder mit %{permissions} k\xf6nnen diesen %{issuableType} anzeigen oder entsprechende Benachrichtigungen erhalten."],"Only 'Reporter' roles and above on tiers Premium and above can see Value Stream Analytics.":["Nur die Rollen \u201eReporter(in)\u201c und h\xf6here Rollen in den Leveln Premium und H\xf6her k\xf6nnen die Wertsch\xf6pfungskettenanalyse sehen."],"Only 1 appearances row can exist":["Maximal eine \u201eErscheinungsbild\u201c-Zeile ist zul\xe4ssig."],"Only HTTP(S)":["Nur HTTP(S)"],"Only Merge Requests are allowed as a noteable to resolve discussions of at the moment.":["Derzeit sind zur L\xf6sung von Diskussionen nur Merge-Anfragen als Noteable zul\xe4ssig."],"Only Project Members":["Nur Projekt-Mitglieder"],"Only SSH":["Nur SSH"],"Only accessible by %{membersPageLinkStart}project members%{membersPageLinkEnd}. Membership must be explicitly granted.":["Nur zug\xe4nglich f\xfcr %{membersPageLinkStart}Projektmitglieder%{membersPageLinkEnd}. Die Mitgliedschaft muss explizit gew\xe4hrt werden."],"Only admin custom roles can be assigned":["Nur benutzerdefinierte Admin-Rollen k\xf6nnen zugewiesen werden"],"Only effective when remote storage is enabled. Set to 0 for no size limit.":["Nur wirksam, wenn Remote-Speicher aktiviert ist. Auf 0 setzen f\xfcr keine Gr\xf6\xdfenbeschr\xe4nkung."],"Only include features new to your current subscription tier.":["F\xfcge nur Funktionen hinzu, die neu in deinem aktuellen Abonnement-Level sind."],"Only issues can be linked from this form. You can also link this issue from an epic or task.":["\xdcber dieses Formular k\xf6nnen nur Tickets verkn\xfcpft werden. Du kannst dieses Ticket auch \xfcber einen Epic oder eine Aufgabe verkn\xfcpfen."],"Only log Akismet verdict, do not prevent issue or snippet creation when spam is detected.":["Nur das Akismet-Urteil protokollieren; Erstellung von Tickets oder Code-Schnipseln bei erkanntem Spam nicht verhindern."],"Only members of this group can access the wiki.":["Nur Mitglieder dieser Gruppe k\xf6nnen auf das Wiki zugreifen."],"Only one security policy bot is allowed per project":["Pro Projekt ist nur ein Sicherheitsrichtlinien-Bot zul\xe4ssig"],"Only policy:":["\u201eNur\u201c (Only)-Richtlinie:"],"Only project level work items can be created to resolve noteable discussions":["Es k\xf6nnen nur Arbeitsaufgaben auf Projektebene erstellt werden, um Noteable-Diskussionen zu l\xf6sen"],"Only project members can comment.":["Nur Projektmitglieder k\xf6nnen kommentieren."],"Only projects created under a Ultimate license are available in Security Dashboards.":["Nur Projekte, die unter einer Ultimate-Lizenz erstellt wurden, sind in Sicherheits-Dashboards verf\xfcgbar."],"Only reCAPTCHA v2 is supported:":["Nur reCAPTCHA v2 wird unterst\xfctzt:"],"Only required if not using role instance credentials.":["Nur erforderlich, wenn keine Rolleninstanz-Zugangsdaten verwendet werden."],"Only the author can change visibility settings":["Nur der/die Autor(in) kann die Sichtbarkeitseinstellungen \xe4ndern"],"Only track method calls that take longer to complete than the given duration.":["Verfolge nur Methodenaufrufe, die mehr Zeit f\xfcr die Fertigstellung in Anspruch nehmen als die angegebene Dauer."],"Only use lowercase letters, numbers, and underscores.":["Verwende nur Kleinbuchstaben, Zahlen und Unterstriche."],"Only verified users with an email address in any of these domains can be added to the group. Multiple domains are supported.":["Nur verifizierte Benutzer(innen) mit einer E-Mail-Adresse in einer dieser Dom\xe4nen k\xf6nnen der Gruppe hinzugef\xfcgt werden. Mehrere Dom\xe4nen werden unterst\xfctzt."],"Only visible to you":["Nur f\xfcr dich sichtbar"],"Only \u2018Reporter\u2019 roles and above on tiers Premium and above can see Productivity Analytics.":["Nur \u201eInformant\u201c-Rollen und h\xf6her in mindestens den Stufen Premium/Silber k\xf6nnen die Produktivit\xe4tsanalyse einsehen."],Open:["Offen"],"Open GitLab Duo Chat":["GitLab Duo Chat \xf6ffnen"],"Open Selection":["Auswahl \xf6ffnen"],"Open color picker":["Farbauswahl \xf6ffnen"],"Open errors":["Fehler \xf6ffnen"],"Open evidence JSON in new tab":["Beweis im JSON-Format in neuem Tab \xf6ffnen"],"Open in Ona":["In Ona \xf6ffnen"],"Open in Web IDE":["In Web IDE \xf6ffnen"],"Open in Workspace":["In Arbeitsbereich \xf6ffnen"],"Open in full page":["In vollst\xe4ndiger Seite \xf6ffnen"],"Open in your IDE":["In deiner IDE \xf6ffnen"],"Open issue":["Offenes Ticket","Offene Tickets"],"Open navigation menu":["Navigationsmen\xfc \xf6ffnen"],"Open new window":["Neues Fenster \xf6ffnen"],"Open raw":["Rohversion \xf6ffnen"],"Open sidebar":["Men\xfcleiste \xf6ffnen"],"Open threads must be resolved.":["Offene Threads m\xfcssen gel\xf6st werden."],"Open with":["\xd6ffnen mit"],"Open: %{open}":["Offen: %{open}"],OpenAPI:["OpenAPI"],"OpenAPI Specification file URL":["URL der OpenAPI-Spezifikationsdatei"],"OpenAPI Specification file path or URL":["Pfad oder URL der OpenAPI-Spezifikationsdatei"],"OpenMrBadge|%{count} Open":["%{count} offen"],"OpenMrBadge|Open merge requests":["Offene Merge Requests"],"OpenMrBadge|Open merge requests created in the past 30 days that target this branch and modify this file.":["In den letzten 30 Tagen erstellte, offene Merge Requests, die diesen Branch als Ziel haben und diese Datei \xe4ndern."],"OpenMrBadge|Opened":["Ge\xf6ffnet"],"OpenSSL version 3":["OpenSSL Version\xa03"],"OpenSearch's region.":["Die Region von OpenSearch."],Opened:["Ge\xf6ffnet"],"OpenedNDaysAgo|Created":["Erstellt"],"Opens in a new window":["Wird in einem neuen Fenster ge\xf6ffnet"],"Opens new window":["\xd6ffnet neues Fenster"],"Operation not allowed":["Vorgang nicht erlaubt"],Operations:["Betrieb"],"Operations Dashboard":["Betriebsdashboard"],"OperationsDashboard|Add a project to the dashboard":["Ein Projekt zum Dashboard hinzuf\xfcgen"],"OperationsDashboard|Add projects":["Projekte hinzuf\xfcgen"],"OperationsDashboard|Cancel":["Abbrechen"],"OperationsDashboard|More information":["Weitere Informationen"],"OperationsDashboard|Operations Dashboard":["Betriebsdashboard"],"OperationsDashboard|The Operations and Environments dashboards share the same list of projects. When you add or remove a project from one, GitLab adds or removes the project from the other. %{linkStart}More information%{linkEnd}":["Die Betriebs- und Umgebungsdashboards zeigen die gleiche Liste von Projekten. Wenn du ein Projekt zu einem davon hinzuf\xfcgst oder daraus entfernst, f\xfcgt GitLab das Projekt auch dem anderen hinzu bzw. entfernt es. %{linkStart}Weitere Informationen%{linkEnd}"],"OperationsDashboard|The operations dashboard provides a summary of each project's operational health, including pipeline and alert statuses.":["Das Betriebsdashboard zeigt eine Zusammenfassung des Betriebszustandes jedes Projektes, inklusive Pipeline- und Warnungsstatus."],"Opstrace endpoint for Error Tracking integration":["Endpunkt f\xfcr die Integration der Fehlerverfolgung"],"Optimize repository period":["Repository-Zeitraum optimieren"],Optional:["Optional"],"Optional approvals":["Optionale Genehmigungen"],"Optionally, you can %{link_to_customize} how FogBugz email addresses and usernames are imported into GitLab.":["Optional kannst du %{link_to_customize}, wie FogBugz E-Mail-Adressen und Benutzernamen in GitLab importiert werden."],Options:["Optionen"],Orbit:[""],"Orbit|Configuration":[""],"Orbit|Data Explorer":[""],"Orbit|Enable":[""],"Orbit|Enable Orbit for a top-level group to index its projects and make them queryable":[""],"Orbit|Failed to load groups. Please try again.":[""],"Orbit|Failed to update group setting. Please try again.":[""],"Orbit|Indexed":[""],"Orbit|Indexes":[""],"Orbit|Indexing\u2026":[""],"Orbit|Not indexed":[""],"Orbit|Only top-level groups can be indexed":[""],"Orbit|Orbit":[""],"Orbit|Schema":[""],"Ordered list":["Sortierte Liste"],Organization:["Organisation"],"Organization ID cannot be nil":["Organisations-ID darf nicht Null sein"],"Organization parameter must be specified":["Der Organisationsparameter muss angegeben werden"],Organizations:["Organisationen"],"Organizations API rate limits":["Ratenbegrenzungen der Organizations API"],"Organization|%{linkStart}Organizations%{linkEnd} are a top-level container to hold your groups and projects.":["%{linkStart}Organisationen%{linkEnd} sind Container auf oberster Ebene, die Ihre Gruppen und Projekte enthalten."],"Organization|A group is a collection of several projects. If you organize your projects under a group, it works like a folder.":["Eine Gruppe ist eine Ansammlung mehrerer Projekte und funktioniert wie ein Ordner, wenn du deine Projekte in einer Gruppe organisierst."],"Organization|Accessible by any signed in user except external users.":["Zugriff f\xfcr jeden angemeldeten Benutzer au\xdfer f\xfcr externe Benutzer."],"Organization|Accessible without any authentication.":["Zugriff ohne Authentifizierung."],"Organization|An error occurred changing your organization URL. Please try again.":["Beim \xc4ndern der URL deiner Organisation ist ein Fehler aufgetreten. Bitte versuche es erneut."],"Organization|An error occurred creating a group in this organization. Please try again.":["Beim Erstellen einer Gruppe in dieser Organisation ist ein Fehler aufgetreten. Bitte versuche es erneut."],"Organization|An error occurred creating an organization. Please try again.":["Beim Erstellen einer Organisation ist ein Fehler aufgetreten. Bitte versuche es erneut."],"Organization|An error occurred deleting the project. Please refresh the page to try again.":["Beim L\xf6schen des Projekts ist ein Fehler aufgetreten. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Organization|An error occurred loading organizations. Please refresh the page to try again.":["Beim Laden der Projekte ist ein Fehler aufgetreten. Bitte aktualisiere die Seite und versuche es erneut."],"Organization|An error occurred loading the activity. Please refresh the page to try again.":["Beim Laden der Aktivit\xe4t ist ein Fehler aufgetreten. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Organization|An error occurred loading the groups. Please refresh the page to try again.":["Beim Laden der Gruppen ist ein Fehler aufgetreten. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Organization|An error occurred loading the organization users. Please refresh the page to try again.":["Beim Laden der Organisationsbenutzer(innen) ist ein Fehler aufgetreten. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Organization|An error occurred loading the projects. Please refresh the page to try again.":["Beim Laden der Projekte ist ein Fehler aufgetreten. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Organization|An error occurred loading user organizations. Please refresh the page to try again.":["Beim Laden der Benutzerorganisationen ist ein Fehler aufgetreten. Bitte aktualisiere die Seite, um es erneut zu versuchen."],"Organization|An error occurred updating the organization role. Please try again.":["Beim Aktualisieren der Organisationsrolle ist ein Fehler aufgetreten. Bitte versuche es erneut."],"Organization|An error occurred updating your organization. Please try again.":["Beim Aktualisieren deiner Organisation ist ein Fehler aufgetreten. Bitte versuche es erneut."],"Organization|Change organization URL":["Organisations-URL \xe4ndern"],"Organization|Choose organization visibility level.":["W\xe4hle die Sichtbarkeitsstufe der Organisation aus."],"Organization|Copy organization ID":["Organisations-ID kopieren"],"Organization|Create an organization to contain all of your groups and projects.":["Erstelle eine Organisation, die alle deine Gruppen und Projekte enth\xe4lt."],"Organization|Create organization":["Organisation erstellen"],"Organization|Current organization":["Aktuelle Organisation"],"Organization|Get started with organizations":["Erste Schritte mit Organisationen"],"Organization|Help improve Organizations":["Hilf uns, Organisationen zu verbessern"],"Organization|If you proceed with this change you will lose your owner permissions for this organization, including access to this page.":["Wenn du mit dieser \xc4nderung fortf\xe4hrst, verlierst du deine Eigent\xfcmerberechtigungen f\xfcr diese Organisation, einschlie\xdflich des Zugriffs auf diese Seite."],"Organization|Internal - The organization can be accessed by any signed in user except external users.":["Intern \u2013 Alle angemeldeten Benutzer mit Ausnahme von externen Benutzern k\xf6nnen auf die Organisation zugreifen."],"Organization|Manage":["Verwalten"],"Organization|Must start with a letter, digit, emoji, or underscore. Can also contain periods, dashes, spaces, and parentheses.":["Muss mit einem Buchstaben, einer Ziffer, einem Emoji oder einem Unterstrich beginnen. Kann auch Punkte, Bindestriche, Leerzeichen und Klammern enthalten."],"Organization|My organization":["Meine Organisation"],"Organization|New organization":["Neue Organisation"],"Organization|No organizations available to switch to.":["Keine Organisationen verf\xfcgbar, zu denen gewechselt werden kann."],"Organization|Only accessible by organization members.":["Zugriff nur f\xfcr Mitglieder der Organisation."],"Organization|Org ID":["Organisations-ID"],"Organization|Organization ID":["Organisations-ID"],"Organization|Organization URL":["Organisations-URL"],"Organization|Organization URL is required.":["Organisations-URL ist erforderlich."],"Organization|Organization URL is too short (minimum is 2 characters).":["Die Organisations-URL ist zu kurz (mindestens 2\xa0Zeichen)."],"Organization|Organization URL successfully changed.":["Die Organisations-URL wurde erfolgreich ge\xe4ndert."],"Organization|Organization avatar":["Avatar der Organisation"],"Organization|Organization description (optional)":["Organisationsbeschreibung (optional)"],"Organization|Organization description is too long (maximum is 1024 characters).":["Die Organisationsbeschreibung ist zu lang (maximal 1024\xa0Zeichen)."],"Organization|Organization name":["Name der Organisation"],"Organization|Organization name is required.":["Name der Organisation ist erforderlich."],"Organization|Organization navigation":["Navigation der Organisation"],"Organization|Organization overview":["\xdcberblick \xfcber die Organisation"],"Organization|Organization role":["Organisationsrolle"],"Organization|Organization role was updated successfully.":["Die Organisationsrolle wurde erfolgreich aktualisiert."],"Organization|Organization settings":["Organisationseinstellungen"],"Organization|Organization successfully created.":["Organisation erfolgreich erstellt."],"Organization|Organization user details":["Details des/der Organisationsbenutzers/-benutzerin"],"Organization|Organization visibility level":["Sichtbarkeitsstufe der Organisation"],"Organization|Organization was successfully updated.":["Organisation wurde erfolgreich aktualisiert."],"Organization|Organizations":["Organisationen"],"Organization|Organizations is a new feature. Help us make it better by":["Organisationen sind eine neue Funktion. Hilf uns, sie zu verbessern, indem du"],
"Organization|Organizations must have at least one owner.":["Organisationen m\xfcssen \xfcber mindestens eine(n) Eigent\xfcmer(in) verf\xfcgen."],"Organization|Organizations must have at least one owner. To delete the user, first assign a new owner to %{lastLink}.":["Organisationen m\xfcssen mindestens eine(n) Eigent\xfcmer(in) haben. Weise %{lastLink} zun\xe4chst eine(n) neue(n) Eigent\xfcmer(in) zu, bevor du den/die Benutzer(in) l\xf6schst.","Organisationen m\xfcssen mindestens eine(n) Eigent\xfcmer(in) haben. Weise %{links} %{boldStart}und%{boldEnd} %{lastLink} zun\xe4chst eine(n) neue(n) Eigent\xfcmer(in) zu, bevor du den/die Benutzer(in) l\xf6schst."],"Organization|Organizations must have at least one owner. To delete the user, first assign a new owner to %{links} %{boldStart}and%{boldEnd} %{extrasCount} %{boldStart}other Organization%{boldEnd}.":["Organisationen m\xfcssen mindestens eine(n) Eigent\xfcmer(in) haben. Weise zun\xe4chst %{links} %{boldStart}und%{boldEnd} %{extrasCount} %{boldStart}anderer Organisation%{boldEnd} eine(n) neue(n) Eigent\xfcmer(in) zu, bevor du den/die Benutzer(in) l\xf6schst.","Organisationen m\xfcssen mindestens eine(n) Eigent\xfcmer(in) haben. Weise zun\xe4chst %{links} %{boldStart}und%{boldEnd} %{extrasCount} %{boldStart}anderen Organisationen%{boldEnd} eine(n) neue(n) Eigent\xfcmer(in) zu, bevor du den/die Benutzer(in) l\xf6schst."],"Organization|Perform advanced options such as changing the organization URL.":["F\xfchre erweiterte Optionen aus, wie etwa das \xc4ndern der Organisations-URL."],"Organization|Private - The organization can only be viewed by members.":["Privat \u2013 Die Organisation kann nur von Mitgliedern eingesehen werden."],"Organization|Projects are hosted/created in groups. Before creating a project, you must create a group.":["Projekte werden in Gruppen gehostet/erstellt. Bevor du ein Projekt erstellst, musst du eine Gruppe erstellen."],"Organization|Public - The organization can be accessed without any authentication.":["Public\xa0\u2013 Auf die Organisation kann ohne Authentifizierung zugegriffen werden."],"Organization|Recently created groups":["K\xfcrzlich erstellte Gruppen"],"Organization|Recently created projects":["K\xfcrzlich erstellte Projekte"],"Organization|Recently updated groups":["K\xfcrzlich aktualisierte Gruppen"],"Organization|Recently updated projects":["K\xfcrzlich aktualisierte Projekte"],"Organization|Search for an organization":["Nach einer Organisation suchen"],"Organization|Select an organization":["W\xe4hle eine Organisation aus"],"Organization|Switch organizations":["Organisationen wechseln"],"Organization|Switching between organizations is not currently supported.":["Der Wechsel zwischen Organisationen wird derzeit nicht unterst\xfctzt."],"Organization|Unable to fetch organizations. Reload the page to try again.":["Organisationen k\xf6nnen nicht abgerufen werden. Lade die Seite neu, um es erneut zu versuchen."],"Organization|Update your organization name, description, and avatar. %{linkStart}Learn more about organizations%{linkEnd}.":["Aktualisiere den Namen deiner Organisation, die Beschreibung und den Avatar. %{linkStart}Erfahre mehr \xfcber Organisationen%{linkEnd}."],"Organization|View all":["Alle anzeigen"],"Organization|You can now start using your new organization.":["Du kannst deine neue Organisation jetzt verwenden."],"Organization|You don't have any groups yet.":["Du hast noch keine Gruppen."],"Organization|You don't have any projects yet.":["Du hast noch keine Projekte."],"Organization|my-organization":["my-organization"],"Organization|sharing your experience":["deine Erfahrungen teilst."],"Organize work with projects":["Arbeit mit Projekten organisieren"],"Orphaned member":["Verwaistes Mitglied"],"Orphaned request":["Verwaiste Anfrage"],Other:["Sonstige"],"Other information":["Andere Informationen"],"Other labels":["Andere Labels"],"Other merge requests block this MR":["Eine anderer Merge Request blockiert diesen Merge Request"],"Other updates":["Sonstige Updates"],"Other versions":["Andere Versionen"],"Other visibility settings have been disabled by the administrator.":["Andere Sichtbarkeitseinstellungen wurden vom/von der Administrator(in) deaktiviert."],"Otherwise, click the link below to complete the process.":["Andernfalls klicke auf den unten stehenden Link, um den Vorgang abzuschlie\xdfen."],"Otherwise, click the link below to complete the process:":["Andernfalls klicke auf den unten stehenden Link, um den Vorgang abzuschlie\xdfen:"],"Our team has been notified. Please try again.":["Unser Team wurde benachrichtigt. Bitte versuche es erneut."],"Out-of-compliance with this project's policies and should be removed":["Verst\xf6\xdft gegen die Richtlinien dieses Projekts und sollte entfernt werden"],"OutboundRequests|Allow requests to the local network from hooks and integrations.":["Anfragen an das lokale Netzwerk von Hooks und Integrationen zulassen"],"OutboundRequests|Allow requests to the local network from system hooks":["Anfragen an das lokale Netzwerk von System-Hooks erlauben"],"OutboundRequests|Allow requests to the local network from webhooks and integrations":["Anfragen an das lokale Netzwerk von Webhooks und Integrationen zulassen"],"OutboundRequests|Block all requests, except for IP addresses, IP ranges, and domain names defined in the allowlist":["Alle Anfragen blockieren, mit Ausnahme der in der Zulassungsliste definierten IP-Adressen, IP-Bereiche und Domainnamen"],"OutboundRequests|Enforce DNS-rebinding attack protection":["DNS-Rebinding-Angriffsschutz erzwingen"],"OutboundRequests|Local IP addresses and domain names that hooks and integrations can access":["Lokale IP-Adressen und Domainnnamen, auf die Hooks und Integrationen zugreifen k\xf6nnen"],"OutboundRequests|Outbound requests":["Ausgehende Anfragen"],"OutboundRequests|Requests can be made to these IP addresses and domains even when local requests are not allowed. IP ranges such as %{code_start}1:0:0:0:0:0:0:0/124%{code_end} and %{code_start}127.0.0.0/28%{code_end} are supported. Domain wildcards are not supported. To separate entries, use commas, semicolons, or newlines. The allowlist can have a maximum of 1000 entries. Domains must be IDNA-encoded.":["An diese IP-Adressen und Domains k\xf6nnen Anfragen gestellt werden, selbst wenn lokale Anfragen nicht erlaubt sind. IP-Bereiche wie %{code_start}1:0:0:0:0:0:0:0/124%{code_end} und %{code_start}127.0.0.0/28%{code_end} werden unterst\xfctzt. Domain-Wildcards werden nicht unterst\xfctzt. Trenne Eintr\xe4ge mit Kommas, Semikolons oder Zeilenumbr\xfcchen. Die Zulassungsliste kann bis zu 1.000 Eintr\xe4ge enthalten. Domains m\xfcssen IDNA-kodiert sein."],"OutboundRequests|Resolve IP addresses for outbound requests to prevent DNS-rebinding attacks.":["IP-Adressen f\xfcr ausgehende Anfragen aufl\xf6sen, um DNS-Rebinding-Angriffe zu verhindern"],"OutboundRequests|Webhooks and integrations might not work properly. GitLab Duo will not work unless `cloud.gitlab.com` is in the following allowlist.":["Webhooks und Integrationen funktionieren m\xf6glicherweise nicht richtig. GitLab Duo funktioniert nur, wenn `cloud.gitlab.com` in der folgenden Zulassungsliste aufgef\xfchrt ist."],"OutdatedBrowser|GitLab may not work properly, because you are using an outdated web browser.":["GitLab funktioniert m\xf6glicherweise nicht ordnungsgem\xe4\xdf, da du einen veralteten Webbrowser verwendest."],"OutdatedBrowser|Please install a %{browser_link_start}supported web browser%{browser_link_end} for a better experience.":["Installiere einen %{browser_link_start}unterst\xfctzten Webbrowser%{browser_link_end} f\xfcr ein optimales Erlebnis."],"Outdent line":["Zeile ausr\xfccken"],Overridden:["\xdcberschrieben"],Overview:["\xdcbersicht"],"Overwrite diverged branches":["\xdcberschreibe abweichende Branches"],"Owasp|A01:2021 Broken Access Control":["A01:2021 Fehlerhafte Zugriffskontrolle"],"Owasp|A02:2021 Cryptographic Failures":["A02:2021 Kryptografische Fehler"],"Owasp|A03:2021 Injection":["A03:2021 Injektion"],"Owasp|A04:2021 Insecure Design":["A04:2021 Unsicheres Design"],"Owasp|A05:2021 Security Misconfiguration":["A05:2021 Sicherheitsfehlkonfiguration"],"Owasp|A06:2021 Vulnerable and Outdated Components":["A06:2021 Gef\xe4hrdete und veraltete Komponenten"],"Owasp|A07:2021 Identification and Authentication Failures":["A07:2021 Identifizierungs- und Authentifizierungsfehler"],"Owasp|A08:2021 Software and Data Integrity Failures":["A08:2021 Software- und Datenintegrit\xe4tsfehler"],"Owasp|A09:2021 Security Logging and Monitoring Failures":["A09:2021 Fehler bei der Sicherheitsprotokollierung und -\xfcberwachung"],"Owasp|A10:2017 Insufficient Logging & Monitoring":["A10:2017 Unzureichende Protokollierung und \xdcberwachung"],"Owasp|A10:2021 Server-Side Request Forgery":["A10:2021 Serverseitige Anfragef\xe4lschung"],"Owasp|A1:2017 Injection":["A1:2017 Injektion"],"Owasp|A2:2017 Broken Authentication":["A2:2017 Fehlerhafte Authentifizierung"],"Owasp|A3:2017 Sensitive Data Exposure":["A3:2017 Vertrauliche Daten gef\xe4hrdet"],"Owasp|A4:2017 XML External Entities (XXE)":["A4:2017 Externe XML-Entit\xe4ten (XXE)"],"Owasp|A5:2017 Broken Access Control":["A5:2017 Fehlerhafte Zugriffskontrolle"],"Owasp|A6:2017 Security Misconfiguration":["A6:2017 Sicherheitsfehlkonfiguration"],"Owasp|A7:2017 Cross-Site Scripting (XSS)":["A7:2017 Cross-Site-Scripting (XSS)"],"Owasp|A8:2017 Insecure Deserialization":["A8:2017 Unsichere Deserialisierung"],"Owasp|A9:2017 Using Components with Known Vulnerabilities":["A9:2017 Verwendung von Komponenten mit bekannten Sicherheitsl\xfccken"],"Owasp|Non-OWASP Top 10 2017":["Nicht-OWASP Top\xa010 2017"],"Owasp|Non-OWASP Top 10 2021":["Nicht-OWASP Top\xa010 2021"],"Owned by %{image_tag}":["Besitzer(in): %{image_tag}"],"Owned by anyone":["Im Besitz einer beliebigen Person"],"Owned by me":["Im Besitz von mir"],"Owned by:":["Eigent\xfcmer(in):"],Owner:["Eigent\xfcmer(in)"],"Owners and administrators":["Eigent\xfcmer(innen) und Administrator(inn)en"],"PIPL|Important Change to Your GitLab.com Account":["Wichtige \xc4nderung an deinem GitLab.com-Konto"],"PIPL|Please be advised that GitLab can no longer service GitLab.com accounts for individuals and organizations located in Mainland China, Macao, and Hong Kong. Our system indicates that you are visiting GitLab from one of these locations. We advise you to sign up with JiHu %{jihu_link}. JiHu is an independent company with a localized GitLab offering that has an exclusive right to provide GitLab to individuals and organizations located in this region. You must complete the transition by %{deadline}, after which GitLab will delete your account from our systems. If you believe you are receiving this notification in error, please log in to GitLab.com from a supported service location. For further information or support, please feel free to contact %{email}.":["Bitte beachte, dass GitLab keine GitLab.com-Konten f\xfcr Einzelpersonen und Organisationen mit Sitz in Festlandchina, Macao und Hongkong mehr bedienen kann. Unser System zeigt an, dass du GitLab von einem dieser Standorte aus besuchst. Wir empfehlen dir, dich bei JiHu %{jihu_link} anzumelden. JiHu ist ein unabh\xe4ngiges Unternehmen mit einem lokalisierten GitLab-Angebot und dem exklusiven Recht, GitLab Einzelpersonen und Organisationen in dieser Region zur Verf\xfcgung zu stellen. Du musst die Umstellung bis zum %{deadline} abschlie\xdfen, danach wird das Konto von uns aus dem GitLab-System gel\xf6scht. Wenn du glaubst, dass du diese Benachrichtigung irrt\xfcmlich erhalten hast, melde dich bitte von einem unterst\xfctzten Dienststandort aus bei GitLab.com an. F\xfcr weitere Informationen oder Unterst\xfctzung wende dich bitte an %{email}."],"PIPL|Please be advised that GitLab can no longer service GitLab.com accounts for individuals and organizations located in Mainland China, Macao, and Hong Kong. Our system indicates that you are visiting GitLab from one of these locations. We advise you to transition your GitLab.com account from GitLab to %{jihu_link}. JiHu is an independent company with a localized GitLab offering that has exclusive rights to provide GitLab to individuals and organizations located in this region. You have %{deadline} days to complete the transition, after which GitLab will delete your account from our systems. If you believe you are receiving this notification in error, please log in to GitLab.com from a supported service location. For further information or support, please feel free to contact %{email}.":["Bitte beachte, dass GitLab keine GitLab.com-Konten f\xfcr Einzelpersonen und Organisationen mit Sitz in Festlandchina, Macao und Hongkong mehr bedienen kann. Unser System zeigt an, dass du GitLab von einem dieser Standorte aus besuchst. Wir empfehlen dir, dein GitLab.com-Konto von GitLab auf %{jihu_link} umzustellen. JiHu ist ein unabh\xe4ngiges Unternehmen mit einem lokalisierten GitLab-Angebot und den exklusiven Rechten, GitLab Einzelpersonen und Organisationen in dieser Region zur Verf\xfcgung zu stellen. Du hast %{deadline} Tage, um die Umstellung abzuschlie\xdfen. Danach wird das Konto von uns aus dem GitLab-System gel\xf6scht. Wenn du glaubst, dass du diese Benachrichtigung irrt\xfcmlich erhalten hast, melde dich bitte von einem unterst\xfctzten Dienststandort aus bei GitLab.com an. F\xfcr weitere Informationen oder Unterst\xfctzung wende dich bitte an %{email}."],"PQL|An error occurred while sending hand raise lead.":["Ein Fehler ist beim Senden des Hand-Raise-Leads aufgetreten."],"PQL|By providing my contact information, I agree GitLab may contact me via email about its product, services and events. You may opt-out at any time by unsubscribing in emails or visiting our communication preference center.":["Durch die Angabe meiner Kontaktinformationen stimme ich zu, dass GitLab mich per E-Mail \xfcber seine Produkte, Dienstleistungen und Veranstaltungen kontaktieren kann. Du kannst dich jederzeit abmelden, indem du dich per E-Mail abmeldest oder unser Kommunikations-Pr\xe4ferenzzentrum besuchst."],"PQL|Cancel":["Abbrechen"],"PQL|Contact our Sales team":["Kontaktiere unser Vertriebsteam"],"PQL|Contact sales":["Vertrieb kontaktieren"],"PQL|Hello %{userName}. Before putting you in touch with our sales team, we would like you to verify and complete the information below.":["Hallo%{userName}. Bevor du mit unserem Vertriebsteam in Kontakt treten kannst, m\xf6chten wir, dass du die folgenden Informationen \xfcberpr\xfcfst und vervollst\xe4ndigst."],"PQL|Message for the Sales team":["Nachricht f\xfcr das Vertriebsteam"],"PQL|Submit information":["Informationen absenden"],"PQL|Thank you for reaching out! Our sales team will get back to you soon.":["Vielen Dank f\xfcr deine Nachricht! Unser Vertriebsteam wird sich in K\xfcrze bei dir melden."],"Package already exists":["Paket existiert bereits"],"Package deleted successfully":["Paket erfolgreich gel\xf6scht"],"Package file size limits":["Gr\xf6\xdfenlimit f\xfcr Paketdateien"],"Package forwarding":["Paketweiterleitung"],"Package hunter":["Package Hunter"],"Package limits":["Paketbeschr\xe4nkungen"],"Package name of the app in Google Play.":["Paketname der App in Google Play."],"Package recipe already exists":["Paketrezept existiert bereits"],"Package registry":["Paket-Registry"],"Package registry rate limits":["Ratenlimit f\xfcr die Paket-Registry"],"Package registry types for which metadata is stored, required for License Compliance for CycloneDX files.":["Paket-Registry-Typen, f\xfcr die Metadaten gespeichert werden, die f\xfcr die Lizenzkonformit\xe4t von CycloneDX-Dateien erforderlich sind."],"Package registry: authenticated API requests":["Paket-Registry: authentifizierte API-Anfragen"],"Package registry: unauthenticated API requests":["Paket-Registry: nicht authentifizierte API-Anfragen"],"Package type":["Pakettyp"],"Package type must be Conan":["Pakettyp muss Conan sein"],"Package type must be Debian":["Pakettyp muss Debian sein"],"Package type must be Helm":["Pakettyp muss Helm sein"],"Package type must be NuGet":["Pakettyp muss NuGet sein"],"Package type must be PyPI":["Paket muss vom Typ \u201ePyPI\u201c sein"],"PackageRegistry|%d package":["%d Paket","%d Pakete"],"PackageRegistry|%{count} selected":["%{count} ausgew\xe4hlt","%{count} ausgew\xe4hlt"],"PackageRegistry|%{linkStart}Wildcards%{linkEnd} such as `my-package-*` are supported.":["%{linkStart}Wildcards%{linkEnd} wie `my-package-*` werden unterst\xfctzt."],"PackageRegistry|%{message}. Delete this package and try again.":["%{message}. L\xf6sche dieses Paket und versuche es erneut."],"PackageRegistry|%{name} version %{version} was first created %{datetime}":["%{name} Version %{version} wurde zum ersten Mal erstellt am %{datetime}"],"PackageRegistry|A protection rule exists for this package.":["F\xfcr dieses Paket existiert eine Schutzregel."],"PackageRegistry|Add Conan Remote":["Conan Remote hinzuf\xfcgen"],"PackageRegistry|Add Gradle Groovy DSL repository command":["Gradle Groovy DSL-Repository-Befehl hinzuf\xfcgen"],"PackageRegistry|Add Gradle Kotlin DSL repository command":["Gradle Kotlin DSL-Repository-Befehl hinzuf\xfcgen"],"PackageRegistry|Add NuGet Source":["NuGet Quelle hinzuf\xfcgen"],"PackageRegistry|Add composer registry":["Ersteller-Registry hinzuf\xfcgen"],"PackageRegistry|Add protection rule":["Schutzregel hinzuf\xfcgen"],"PackageRegistry|Add rule":["Regel hinzuf\xfcgen"],"PackageRegistry|Allow duplicates":["Duplikate erlauben"],"PackageRegistry|Allow packages with the same name and version to be uploaded to the registry. The newest version of a package is always used when installing.":["Erm\xf6glicht Packages mit dem selben Namen und der selben Version in das Register hochgeladen zu werden. Die neuste Version des Packages wird stets zur Installation verwendet."],"PackageRegistry|App group: %{group}":["App-Gruppe: %{group}"],"PackageRegistry|App name: %{name}":["App-Name: %{name}"],"PackageRegistry|Author email: %{authorEmail}":["E-Mail-Adresse des Autors bzw. der Autorin: %{authorEmail}"],"PackageRegistry|Built by pipeline %{link} triggered %{datetime} by %{author}":["Gebaut nach Pipeline %{link} ausgel\xf6st am %{datetime} durch %{author}"],"PackageRegistry|By default, the NuGet package validates the %{code_open}projectUrl%{code_close}, %{code_open}iconUrl%{code_close}, and %{code_open}licenseUrl%{code_close} metadata. In an offline environment, you cannot upload the NuGet package with this validation because these URLs cannot be resolved. You might want to select the checkbox to skip validation.":["Standardm\xe4\xdfig validiert das NuGet-Paket die Metadaten %{code_open}projectUrl%{code_close}, %{code_open}iconUrl%{code_close} und %{code_open}licenseUrl%{code_close}. In einer Offline-Umgebung kannst du das NuGet-Paket mit dieser Validierung nicht hochladen, da diese URLs nicht aufgel\xf6st werden k\xf6nnen. Du kannst das Kontrollk\xe4stchen aktivieren, um die Validierung zu \xfcberspringen."],"PackageRegistry|Changes saved.":["\xc4nderungen gespeichert."],"PackageRegistry|Composer":["Ersteller"],"PackageRegistry|Composer packages are installed at the group level, but there is no group associated with this project.":["Composer-Pakete werden auf Gruppenebene installiert, aber mit diesem Projekt ist keine Gruppe verkn\xfcpft."],"PackageRegistry|Composer.json with license: %{license} and version: %{version}":["Composer.json mit Lizenz: %{license} und Version: %{version}"],"PackageRegistry|Conan":["Conan"],"PackageRegistry|Conan Command":["Conan-Befehl"],"PackageRegistry|Configure external Maven registry":["Externe Maven-Registry konfigurieren"],"PackageRegistry|Configure in settings":["In Einstellungen konfigurieren"],"PackageRegistry|Configure package forwarding, package limits, and package file size limits.":["Paketweiterleitung, Paketbeschr\xe4nkungen und Gr\xf6\xdfenbeschr\xe4nkungen f\xfcr Paketdateien konfigurieren."],"PackageRegistry|Copy .pypirc content":[".pypirc-Inhalt kopieren"],"PackageRegistry|Copy Conan Command":["Conan-Befehl kopieren"],"PackageRegistry|Copy Conan Setup Command":["Conan-Einrichtungsbefehl kopieren"],"PackageRegistry|Copy Gradle Groovy DSL install command":["Gradle Groovy DSL-Installationsbefehl kopieren"],"PackageRegistry|Copy Gradle Kotlin DSL install command":["Gradle Kotlin DSL-Installationsbefehl kopieren"],"PackageRegistry|Copy Maven XML":["Maven XML kopieren"],"PackageRegistry|Copy Maven command":["Maven-Befehl kopieren"],"PackageRegistry|Copy Maven registry XML":["Maven-Registry-XML kopieren"],"PackageRegistry|Copy NuGet Command":["NuGet Befehl kopieren"],"PackageRegistry|Copy NuGet Setup Command":["NuGet-Einrichtungsbefehl kopieren"],"PackageRegistry|Copy Pip command":["Pip-Befehl kopieren"],"PackageRegistry|Copy SHA":["SHA kopieren"],"PackageRegistry|Copy add Gradle Groovy DSL repository command":["Gradle Groovy DSL-Repository-Befehl hinzuf\xfcgen"],"PackageRegistry|Copy add Gradle Kotlin DSL repository command":["Gradle Kotlin DSL-Repository-Befehl hinzuf\xfcgen"],"PackageRegistry|Copy and paste this inside your %{codeStart}pom.xml%{codeEnd} %{codeStart}dependencies%{codeEnd} block.":["Kopiere diesen Text und f\xfcge ihn im %{codeStart}dependencies%{codeEnd}-Block in der Datei %{codeStart}pom.xml%{codeEnd} ein."],"PackageRegistry|Copy npm command":["npm Befehl kopieren"],"PackageRegistry|Copy npm setup command":["npm-Einrichtungsbefehl kopieren"],"PackageRegistry|Copy registry include":["Registry include kopieren"],"PackageRegistry|Copy require package include":["Require package include kopieren"],"PackageRegistry|Copy target SHA":["Ziel-SHA kopieren"],"PackageRegistry|Copy yarn command":["Yarn-Befehl kopieren"],"PackageRegistry|Copy yarn setup command":["Yarn-Einrichtungsbefehl kopieren"],"PackageRegistry|Created by commit %{link} on branch %{branch}":["Erstellt von Commit %{link} auf Branch%{branch}"],"PackageRegistry|Debian":["Debian"],"PackageRegistry|Default":["Standard"],"PackageRegistry|Delete %{count} assets":["%{count} Assets l\xf6schen"],"PackageRegistry|Delete Package Version":["Paketversion l\xf6schen"],"PackageRegistry|Delete asset":["Asset l\xf6schen"],"PackageRegistry|Delete package":["Paket l\xf6schen"],"PackageRegistry|Delete package asset":["Paket-Asset l\xf6schen"],"PackageRegistry|Delete package protection rule":["Paketschutzregel l\xf6schen"],"PackageRegistry|Delete package protection rule?":["Paketschutzregel l\xf6schen?"],"PackageRegistry|Delete package version":["Paketversion l\xf6schen"],"PackageRegistry|Delete packages":["Pakete l\xf6schen"],"PackageRegistry|Delete selected":["Ausgew\xe4hlte l\xf6schen"],"PackageRegistry|Delete this package":["Dieses Paket l\xf6schen"],"PackageRegistry|Deleting all package assets will remove version %{version} of %{name}. Are you sure?":["Das L\xf6schen aller Paket-Assets wird Version %{version} von %{name} entfernen. Bist Du sicher?"],"PackageRegistry|Deleting the last package asset will remove version %{version} of %{name}. Are you sure?":["Das L\xf6schen des letzten Paket-Assets wird Version %{version} von %{name} entfernen. Bist Du sicher?"],"PackageRegistry|Deleting this package while request forwarding is enabled for the project can pose a security risk. Do you want to delete %{name} version %{version} anyway? %{docLinkStart}What are the risks?%{docLinkEnd}":["Das L\xf6schen dieses Pakets, w\xe4hrend die Weiterleitung von Anfragen f\xfcr das Projekt aktiviert ist, kann ein Sicherheitsrisiko darstellen. M\xf6chtest du %{name} Version %{version} dennoch l\xf6schen? %{docLinkStart}Was sind die Risiken?%{docLinkEnd}"],"PackageRegistry|Developer (default)":["Entwickler(in) (Standard)"],"PackageRegistry|Duplicate packages":["Package duplizieren"],"PackageRegistry|Edit protection rule":["Schutzregel bearbeiten"],"PackageRegistry|Enforce %{packageType} setting for all subgroups":["Erzwinge %{packageType} Einstellung f\xfcr alle Untergruppen"],"PackageRegistry|Enforce %{package_type} setting for all subgroups":["Erzwinge %{package_type} Einstellung f\xfcr alle Untergruppen"],"PackageRegistry|Error":["Fehler"],"PackageRegistry|Error publishing":["Fehler beim Ver\xf6ffentlichen"],"PackageRegistry|Examples of assets include .pom & .jar files":["Beispiele f\xfcr Assets sind unter anderem .pom- & .jar-Dateien"],"PackageRegistry|Failed to load the package data":["Fehler beim Laden der Paketdaten"],"PackageRegistry|Failed to load version data":["Fehler beim Laden der Versionsdaten"],"PackageRegistry|Failed to publish %{count} packages. Delete these packages and try again.":["Ver\xf6ffentlichen von %{count}\xa0Paketen fehlgeschlagen. L\xf6sche diese Pakete und versuche es erneut."],"PackageRegistry|For more information on Composer packages in GitLab, %{linkStart}see the documentation.%{linkEnd}":["Weitere Informationen zu Composer-Paketen in GitLab %{linkStart}findest du in der Dokumentation%{linkEnd}."],"PackageRegistry|For more information on the Conan registry, %{linkStart}see the documentation%{linkEnd}.":["Weitere Informationen zur Conan-Registry %{linkStart}findest du in der Dokumentation%{linkEnd}."],"PackageRegistry|For more information on the Maven registry, %{linkStart}see the documentation%{linkEnd}.":["Weitere Informationen zur Maven-Registry %{linkStart}findest du in der Dokumentation%{linkEnd}."],"PackageRegistry|For more information on the NuGet registry, %{linkStart}see the documentation%{linkEnd}.":["Weitere Informationen zur NuGet-Registry %{linkStart}findest du in der Dokumentation%{linkEnd}."],"PackageRegistry|For more information on the PyPi registry, %{linkStart}see the documentation%{linkEnd}.":["Weitere Informationen zur PyPi-Registry %{linkStart}findest du in der Dokumentation%{linkEnd}."],"PackageRegistry|Forward %{packageType} package requests":["%{packageType} Paketanfragen weiterleiten"],"PackageRegistry|Forward %{package_type} package requests":["%{package_type} Paketanfragen weiterleiten"],"PackageRegistry|Forward package requests":["P
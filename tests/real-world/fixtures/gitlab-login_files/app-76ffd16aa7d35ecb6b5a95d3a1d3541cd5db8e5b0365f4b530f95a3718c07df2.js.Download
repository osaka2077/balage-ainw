["Beispiel: mein-modell"],"MlModelRegistry|Experiment":["Experiment"],"MlModelRegistry|Failed to delete model with error: %{message}":["L\xf6schen des Modells mit Fehler fehlgeschlagen: %{message}"],"MlModelRegistry|Failed to load model runs with error: %{message}":["Laden der Modellausf\xfchrungen mit Fehler fehlgeschlagen: %{message}"],"MlModelRegistry|Failed to load model version with error: %{message}":["Laden der Modellversion mit Fehler fehlgeschlagen: %{message}"],"MlModelRegistry|Failed to load model versions with error: %{message}":["Laden der Modellversionen mit Fehler fehlgeschlagen: %{message}"],"MlModelRegistry|Failed to load model with error: %{message}":["Laden des Modells mit Fehler fehlgeschlagen: %{message}"],"MlModelRegistry|Failed to load models with error: %{message}":["Laden der Modelle mit Fehler fehlgeschlagen: %{message}"],'MlModelRegistry|File "%{name}" is %{size}. It is larger than max allowed size of %{maxAllowedFileSize}':["Datei \u201e%{name}\u201c ist %{size}. Das ist gr\xf6\xdfer als die maximal zul\xe4ssige Gr\xf6\xdfe von %{maxAllowedFileSize}"],"MlModelRegistry|For example 1.0.0":["Zum Beispiel 1.0.0"],"MlModelRegistry|Import model using MLflow":["Modell mit MLflow importieren"],"MlModelRegistry|Import your machine learning models":["Importiere deine Machine Learning-Modelle"],"MlModelRegistry|Latest version":["Neueste Version"],"MlModelRegistry|Logging artifacts":["Artefakte werden protokolliert"],"MlModelRegistry|MLflow compatibility documentation":["MLflow-Kompatibilit\xe4tsdokumentation"],"MlModelRegistry|MLflow run ID":["MLflow-Ausf\xfchrungs-ID"],"MlModelRegistry|Manage versions of your machine learning model":["Versionen deines maschinellen Lernmodells verwalten"],"MlModelRegistry|May not contain spaces.":["Darf keine Leerzeichen enthalten."],"MlModelRegistry|Metadata":["Metadaten"],"MlModelRegistry|Model card":["Modellkarte"],"MlModelRegistry|Model created %{timeAgo} by %{author}":["Modell wurde %{timeAgo} von %{author} ers
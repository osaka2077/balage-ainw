node_modules/
dist/
.env
.env.*
!.env.example
*.log
coverage/
.vitest/
.cache/
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/

# Orchestrator state (auto-managed)
.ai/orchestrator_state.json
.ai/orchestrator_state.lock
.ai/round_reports/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
build/
*.whl
.pytest_cache/

# HTML snapshots from diagnostic runs (may contain tokens/PII)
tests/real-world/snapshots/*.html
!tests/real-world/snapshots/.gitkeep

# HTML fixtures for benchmark (too large for git, generated locally)
tests/real-world/fixtures/*.html
!tests/real-world/fixtures/.gitkeep
!tests/real-world/fixtures/README.md

# LLM response cache (local, not versioned)
tests/real-world/.llm-cache/

# SDK build artifacts (generated, not source)
packages/sdk/src/*.js
packages/sdk/src/*.js.map
packages/sdk/src/*.d.ts

# Claude Code local settings
.claude/settings.local.json

# Platform/QA reports (generated)
.platform/
.qa/

# Internal strategy (never public)
MASTERSPEC/
MARKET_ANALYSIS*.md
docs/ACTION-PLAN*.md
docs/PIVOT-PLAN*.md
docs/customer-discovery/execution-plan*.md
NEXT-SESSION-PROMPT.md
.ai/

# Temp
tmp/
*.tmp
.mailmap
